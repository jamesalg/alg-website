---
/**
 * Footer.astro — v2.1.0 Rev4 (v2.7.7: build-provenance badge)
 *
 * Structure:
 *   - Footer CTA strip: "Need a quote, layout, sample, or rebate match? We respond same business day."
 *                       CTAs: Contact Sales (outline) + Request Layout (red filled)
 *   - Footer body: 5 columns
 *       Col 1: Brand (white SVG logo + tagline "Lighting | Reinvented, since 1997." + social)
 *       Col 2: Products
 *       Col 3: Solutions (8 full vertical names)
 *       Col 4: Resources
 *       Col 5: Support
 *   - Sub-footer: single line with both addresses, phone, URL
 */
const year = new Date().getFullYear();
const buildHash = (import.meta.env.PUBLIC_BUILD_HASH || 'dev').slice(0, 7);
const buildTimeRaw = import.meta.env.PUBLIC_BUILD_TIME;
const buildTime = buildTimeRaw
  ? new Date(buildTimeRaw).toISOString().slice(0, 16) + 'Z'
  : 'local';
---

<!-- FOOTER CTA STRIP -->
<div class="footer-cta">
  <div class="footer-cta-inner">
    <div class="footer-cta-msg">
      Need a quote, layout, sample, or rebate match?
      <strong>We respond same business day.</strong>
    </div>
    <div class="footer-cta-actions">
      <a href="/contact" class="fcta-btn fcta-btn--ghost">Contact Sales</a>
      <a href="/support/layout-request" class="fcta-btn fcta-btn--primary">Request Layout</a>
    </div>
  </div>
</div>

<!-- FOOTER BODY -->
<footer class="site-footer" aria-label="Site footer">
  <div class="footer-inner">

    <!-- Col 1: Brand -->
    <div class="footer-brand">
      <a href="/" class="footer-logo-link" aria-label="Archipelago Lighting Group home">
        <img src="/brand/alg-logo-white.svg" alt="Archipelago Lighting Group" width="140" height="40" loading="lazy" />
      </a>
      <p class="footer-tagline">Lighting | Reinvented, since 1997.</p>
      <div class="footer-social">
        <a href="https://www.facebook.com/archipelago.lighting.group" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.instagram.com/archipelago_lighting/" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/archipelago-lighting" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://x.com/ArchipelagoLED" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="X">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://www.youtube.com/@ArchipelagoLightingInc" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>
    </div>

    <!-- Col 2: Products -->
    <div class="footer-col">
      <h3 class="footer-col-heading">Products</h3>
      <ul class="footer-col-links">
        <li><a href="/collections/indoor" class="footer-link">Indoor</a></li>
        <li><a href="/collections/outdoor" class="footer-link">Outdoor</a></li>
        <li><a href="/collections/residential" class="footer-link">Residential</a></li>
        <li><a href="/collections/lamps" class="footer-link">Lamps</a></li>
        <li><a href="/collections/controls-em" class="footer-link">Safety &amp; Controls</a></li>
        <li><a href="/collections/warehouse-deals" class="footer-link">Warehouse Deals</a></li>
        <li><a href="/resources/taa" class="footer-link">TAA Compliant</a></li>
      </ul>
    </div>

    <!-- Col 3: Solutions -->
    <div class="footer-col">
      <h3 class="footer-col-heading">Solutions</h3>
      <ul class="footer-col-links">
        <li><a href="/solutions/warehouse-logistics" class="footer-link">Warehouse &amp; Logistics</a></li>
        <li><a href="/solutions/industrial-manufacturing" class="footer-link">Industrial &amp; Manufacturing</a></li>
        <li><a href="/solutions/cold-storage-grocery" class="footer-link">Cold Storage &amp; Grocery</a></li>
        <li><a href="/solutions/data-center" class="footer-link">Data Center</a></li>
        <li><a href="/solutions/healthcare" class="footer-link">Healthcare</a></li>
        <li><a href="/solutions/education" class="footer-link">Education</a></li>
        <li><a href="/solutions/hospitality" class="footer-link">Hospitality</a></li>
        <li><a href="/solutions/government-military" class="footer-link">Government &amp; Military</a></li>
      </ul>
    </div>

    <!-- Col 4: Resources -->
    <div class="footer-col">
      <h3 class="footer-col-heading">Resources</h3>
      <ul class="footer-col-links">
        <li><a href="/resources/spec-sheets" class="footer-link">Spec Sheets</a></li>
        <li><a href="/find-a-distributor" class="footer-link">Where to Buy</a></li>
        <li><a href="https://aura.archipelagolighting.com" class="footer-link" target="_blank" rel="noopener">Sales Rep Portal</a></li>
        <li><a href="https://algportal.archipelagolighting.com" class="footer-link" target="_blank" rel="noopener">Customer Portal</a></li>
        <li><a href="/consumers" class="footer-link">Consumers</a></li>
        <li><a href="/resources/rebate-center" class="footer-link">Rebate Center</a></li>
        <li><a href="/privacy" class="footer-link">Privacy Policy</a></li>
      </ul>
    </div>

    <!-- Col 5: Support -->
    <div class="footer-col">
      <h3 class="footer-col-heading">Support</h3>
      <ul class="footer-col-links">
        <li><a href="/about" class="footer-link">About Us</a></li>
        <li><a href="/support/returns" class="footer-link">Returns &amp; Exchanges</a></li>
        <li><a href="/support/sample-request" class="footer-link">Sample Request</a></li>
        <li><a href="/support/layout-request" class="footer-link">Layout &amp; Design Request</a></li>
        <li><a href="/terms" class="footer-link">Terms &amp; Conditions</a></li>
        <li><a href="/warranty" class="footer-link">Warranty Statement</a></li>
        <li><a href="/patents" class="footer-link">Patents</a></li>
        <li><a href="/contact" class="footer-link">Contact Us</a></li>
      </ul>
    </div>

    <!-- Col 6: Company -->
    <div class="footer-col">
      <h3 class="footer-col-heading">Company</h3>
      <ul class="footer-col-links">
        <li><a href="/about" class="footer-link">About Us</a></li>
        <li><a href="/blog" class="footer-link">Blogs</a></li>
        <li><a href="/careers" class="footer-link">Career</a></li>
        <li><a href="/contact" class="footer-link">Contact Us</a></li>
      </ul>
    </div>

  </div>

  <!-- SUB-FOOTER -->
  <div class="sub-footer">
    <div class="sub-footer-inner">
      <span class="sub-footer-line">&copy; {year} Archipelago Lighting Group &middot; 4615 State Street, Montclair, CA 91763 &middot; USA Production: 9345 Sycamore Canyon Blvd, Riverside CA 92508 &middot; +1 (866) 912-3220 &middot; <a href="https://www.archipelagolighting.com" class="sub-footer-url">www.archipelagolighting.com</a></span>
    </div>
  </div>
  <!-- BUILD PROVENANCE BADGE (v2.7.7) -->
  <div class="footer-build-stamp">build {buildHash} &middot; {buildTime}</div>
</footer>

<style>
  :root {
    --brand: var(--color-alg-red, #F32740);
    --brand-dk: var(--color-alg-red-dark, #C41E32);
    --dark: #0c0d12;
    --dark2: #14161e;
    --ink3: #6b7280;
    --ink4: #9ca3af;
    --t: 0.18s ease;
  }

  /* FOOTER CTA STRIP */
  .footer-cta { background: var(--brand); padding: 28px; }
  .footer-cta-inner {
    max-width: 1440px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap;
  }
  .footer-cta-msg { font-size: 17px; color: #fff; line-height: 1.4; max-width: 800px; white-space: normal; }
  .footer-cta-msg strong { font-weight: 700; }
  .footer-cta-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .fcta-btn {
    display: inline-flex; align-items: center; padding: 11px 22px;
    font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none;
    border-radius: 4px; transition: all var(--t); white-space: nowrap;
  }
  .fcta-btn--primary { background: #fff; color: var(--brand); border: 1px solid #fff; }
  .fcta-btn--primary:hover { background: rgba(255,255,255,0.9); }
  .fcta-btn--ghost { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.6); }
  .fcta-btn--ghost:hover { background: rgba(255,255,255,0.12); border-color: #fff; }

  /* FOOTER BODY */
  .site-footer { background: var(--dark); color: rgba(255,255,255,0.7); }
  .footer-inner {
    max-width: 1440px; margin: 0 auto; padding: 80px 28px 60px;
    display: grid; grid-template-columns: 260px repeat(5, 1fr); gap: 40px;
  }
  .footer-brand { display: flex; flex-direction: column; gap: 20px; }
  .footer-logo-link { display: inline-block; }
  .footer-tagline { font-size: 14px; line-height: 1.6; color: var(--ink4); max-width: 220px; }
  .footer-social { display: flex; gap: 12px; }
  .social-link {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;
    color: rgba(255,255,255,0.6); transition: all var(--t);
  }
  .social-link:hover { background: var(--brand); border-color: var(--brand); color: #fff; }
  .social-link svg { width: 16px; height: 16px; }
  .footer-col { display: flex; flex-direction: column; }
  .footer-col-heading {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.9); margin-bottom: 20px;
  }
  .footer-col-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .footer-link { font-size: 14px; color: var(--ink4); text-decoration: none; transition: color var(--t); line-height: 1.4; }
  .footer-link:hover { color: #fff; }

  /* SUB-FOOTER */
  .sub-footer { border-top: 1px solid rgba(255,255,255,0.06); }
  .sub-footer-inner {
    max-width: 1440px; margin: 0 auto; padding: 18px 28px;
    display: flex; justify-content: space-between; gap: 24px; flex-wrap: wrap;
  }
  .sub-footer-line {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.04em;
    color: var(--ink3); line-height: 1.6;
  }
  .sub-footer-url { color: var(--ink3); text-decoration: none; transition: color var(--t); }
  .sub-footer-url:hover { color: rgba(255,255,255,0.7); }

  /* RESPONSIVE */
  @media (max-width: 1200px) {
    .footer-inner { grid-template-columns: 1fr 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 768px) {
    .footer-cta-inner { flex-direction: column; align-items: flex-start; }
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 32px; padding: 48px 20px 40px; }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 480px) {
    .footer-inner { grid-template-columns: 1fr; }
    .sub-footer-inner { padding: 16px 20px; }
  }
  /* BUILD PROVENANCE BADGE */
  .footer-build-stamp {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 10px;
    color: #555;
    letter-spacing: 0.05em;
    text-align: center;
    padding-top: 12px;
    margin-top: 12px;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding-bottom: 12px;
  }
</style>
