---
/**
 * BrandMark.astro
 *
 * Renders ALG brand-stem terminology with the ŌÆČ U+24B6 character wrapped in
 * `<span class="aa">` for brand-red styling.
 *
 * Per Playbook v2.0 ┬¦3: ŌÆČ in body text MUST be wrapped. Naked ŌÆČ is a regression.
 *
 * The 10 sanctioned brand stems (Playbook v2.0 ┬¦3.1):
 *   RCH, LS, NT, CS, BLE, RMOR, DAPT, MILY, IM, PTICS
 *
 * Casing rule (┬¦3.2): the letters surrounding ŌÆČ may be lowercase OR uppercase
 * depending on family. Specifically:
 *   - proŌÆČRCH-III, planoŌÆČRCH, luxoŌÆČRCH, lamparŌÆČRCH, cityŌÆČRCH, tubulŌÆČRCH (lowercase prefix, uppercase suffix)
 *   - sensorŌÆČBLE, surgeŌÆČRMOR, quickŌÆČDAPT, contrŌÆČLS, constŌÆČNT (lowercase prefix, uppercase suffix)
 *   - multi-fŌÆČMILY (lowercase m AND lowercase f, only ŌÆČ uppercase ŌĆö capital M is a regression)
 *   - powerŌÆČIM, proŌÆČPTICS (lowercase prefix, uppercase suffix)
 *   - ŌÆČCS (uppercase, used as brand acronym in "ŌÆČCS by ALG")
 *
 * Usage:
 *   <BrandMark prefix="plano" suffix="RCH" />              ŌåÆ planoŌÆČRCH
 *   <BrandMark prefix="multi-f" suffix="MILY" />           ŌåÆ multi-fŌÆČMILY
 *   <BrandMark prefix="" suffix="CS" />                    ŌåÆ ŌÆČCS
 *   <BrandMark prefix="pro" suffix="RCH" trailing="-III" />ŌåÆ proŌÆČRCH-III
 *
 * The ŌÆČ character is hardcoded as U+24B6. NEVER use ŌōÉ U+24D0 (lowercase),
 * never use HTML entity &#9424; (which is the lowercase). If entities needed: &#9398;
 */

interface Props {
  prefix: string;
  suffix: string;
  trailing?: string;
}

const { prefix, suffix, trailing = '' } = Astro.props;
---
<span class="brand-mark">{prefix}<span class="aa">ŌÆČ</span>{suffix}{trailing}</span>

<style>
  .brand-mark {
    white-space: nowrap;
  }
  /* The .aa class is defined globally in styles/brand.css with brand red */
</style>
