---
/**
 * CollectionLegacy.astro
 * §7 Discontinued families guidance.
 */
export interface Props {
  legacy: { headline: string; body: string; notifyLink: string };
}
const { legacy } = Astro.props;
---
<section class="collection-section collection-section--legacy" id="legacy">
  <div class="collection-content">
    <div class="leg-eyebrow">Legacy Products</div>
    <h2 class="leg-headline">{legacy.headline}</h2>
    <p class="leg-body" set:html={legacy.body}></p>
    <a href={legacy.notifyLink} class="leg-cta">Get notified of replacements →</a>
  </div>
</section>

<style>
  .collection-section--legacy {
    /* B3 (v2.5.4): pale grey alternation */
    background: var(--section-bg-alt, #f4f4f6);
    padding: 72px 0;
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .collection-content {
    max-width: var(--collection-content-width, 1280px);
    margin-inline: auto;
    padding-inline: var(--collection-content-padding-x, 32px);
    width: 100%;
  }
  .leg-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-alg-red, #F32740);
    margin-bottom: 20px;
  }
  .leg-eyebrow::before {
    content: '';
    display: inline-block;
    width: 84px;
    height: 1.5px;
    background: var(--color-alg-red, #F32740);
    flex-shrink: 0;
  }
  .leg-headline {
    font-family: 'Sora', sans-serif;
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink, #111418);
    margin: 0 0 16px;
    max-width: 640px;
  }
  .leg-body {
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink2, #444444);
    max-width: 640px;
    margin-bottom: 24px;
  }
  .leg-cta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-alg-red, #F32740);
    text-decoration: none;
    border-bottom: 1px solid var(--color-alg-red, #F32740);
    padding-bottom: 2px;
  }
  .leg-cta:hover { opacity: 0.8; }
</style>
