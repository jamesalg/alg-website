---
/**
 * CollectionHero.astro
 * §1 Breadcrumb + §2 Hero section for collection pages.
 * B1 (v2.5.4): Eyebrow = {VERTICAL} · {SUBVERTICAL} COLLECTION
 * B2 (v2.5.4): Breadcrumb = HOME › PRODUCTS › {VERTICAL} › COMMERCIAL › {NAME}
 * C1 (v2.5.3): Hero pills use red-bordered style (luxo canonical).
 */
export interface Props {
  slug: string;
  parentVertical: string;
  parentSubVertical: string;
  headlineLine: string;
  description: string;
  pillRow: string[];
}
const { slug, parentVertical, parentSubVertical, headlineLine, description, pillRow } = Astro.props;

// B2: Canonical breadcrumb — all uppercase, COMMERCIAL is plain text (no route)
const verticalUpper = parentVertical.toUpperCase();
const verticalSlug  = parentVertical.toLowerCase();
---
<!-- §1 BREADCRUMB — B2 canonical: HOME › PRODUCTS › {VERTICAL} › COMMERCIAL › {NAME} -->
<div class="breadcrumb-band">
  <a href="/">HOME</a>
  <span class="bc-sep">›</span>
  <a href="/collections">PRODUCTS</a>
  <span class="bc-sep">›</span>
  <a href={`/collections/${verticalSlug}`}>{verticalUpper}</a>
  <span class="bc-sep">›</span>
  <span class="bc-plain">{parentSubVertical.toUpperCase()}</span>
  <span class="bc-sep">›</span>
  <span class="bc-current" set:html={headlineLine}></span>
</div>

<!-- §2 HERO -->
<section class="collection-section collection-section--hero" id="hero">
  <div class="collection-content">
    <!-- B1: {VERTICAL} · {SUBVERTICAL} COLLECTION -->
    <div class="hero-eyebrow">{verticalUpper} · {parentSubVertical.toUpperCase()} COLLECTION</div>
    <h1 class="hero-wordmark" set:html={headlineLine}></h1>
    <p class="hero-desc" set:html={description}></p>
    <!-- C1: Red-bordered pills (luxo canonical) -->
    <div class="hero-pills">
      {pillRow.map(pill => <span class="hero-pill">{pill}</span>)}
    </div>
  </div>
</section>

<style>
  /* B2: Canonical breadcrumb typography — 0.75rem / 12px, weight 500, 0.08em spacing */
  .breadcrumb-band {
    padding: 10px var(--collection-content-padding-x, 32px);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    font-weight: 500;
    text-transform: uppercase;
    color: #666;
    background: var(--bg2, #f5f5f3);
    border-bottom: 1px solid rgba(0,0,0,0.06);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .breadcrumb-band a { color: #666; text-decoration: none; }
  .breadcrumb-band a:hover { color: var(--color-alg-red, #F32740); }
  .bc-sep { color: #c8ccd3; }
  .bc-plain { color: #666; }
  /* B2: Final segment — full opacity, Ⓐ in red via .aa */
  .bc-current { color: #000; font-weight: 600; }
  .bc-current :global(.aa) { color: var(--color-alg-red, #F32740); }

  .collection-section--hero {
    background: #1a1f2e;
    color: #fff;
  }
  .collection-content {
    max-width: var(--collection-content-width, 1280px);
    margin-inline: auto;
    padding-inline: var(--collection-content-padding-x, 32px);
    width: 100%;
  }
  .collection-section--hero .collection-content {
    padding-top: 72px;
    padding-bottom: 80px;
  }
  .hero-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--color-alg-red, #F32740);
    margin-bottom: 24px;
  }
  .hero-wordmark {
    font-family: 'Lato', system-ui, sans-serif;
    font-size: clamp(72px, 10vw, 128px);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: #fff;
    margin: 0 0 28px;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0;
    /* B1 v2.5.5: mixed-case — no text-transform */
    text-transform: none;
  }
  .hero-wordmark :global(.aa) {
    color: var(--color-alg-red, #F32740);
    font-size: inherit;
    font-weight: inherit;
  }
  .hero-desc {
    font-size: 1rem;
    line-height: 1.55;
    color: rgba(255,255,255,0.70);
    max-width: 920px;
    margin-bottom: 32px;
  }
  /* B2 v2.5.5: force single-line at desktop ≥ 1024px */
  @media (min-width: 1024px) {
    .hero-desc {
      white-space: nowrap;
      overflow: visible;
    }
  }
  .hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  /* C1: Red-bordered pills (luxo canonical) */
  .hero-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    border: 1px solid var(--color-alg-red, #F32740);
    border-radius: 2px;
    padding: 6px 14px;
    white-space: nowrap;
  }
  @media (max-width: 767px) {
    .hero-wordmark { font-size: clamp(52px, 14vw, 72px); }
  }
</style>
