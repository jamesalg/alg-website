---
/**
 * CollectionGetStarted.astro
 * §8 Get Started — 4 action cards.
 */
export interface Props {
  getStarted: {
    layoutCopy: string;
    sampleCopy: string;
    distributorCopy: string;
    repCopy: string;
  };
}
const { getStarted } = Astro.props;

const cards = [
  {
    icon: '⊞',
    title: 'Request a Layout',
    body: getStarted.layoutCopy,
    cta: 'Start layout →',
    href: '/support/request-layout',
  },
  {
    icon: '◈',
    title: 'Request a Sample',
    body: getStarted.sampleCopy,
    cta: 'Request sample →',
    href: '/support/sample-request',
  },
  {
    icon: '◎',
    title: 'Find a Distributor',
    body: getStarted.distributorCopy,
    cta: 'Find distributor →',
    href: '/find-a-distributor',
  },
  {
    icon: '◉',
    title: 'Find a Rep',
    body: getStarted.repCopy,
    cta: 'Find rep →',
    href: '/find-a-rep',
  },
];
---
<section class="collection-section collection-section--get-started" id="get-started">
  <div class="collection-content">
    <div class="gs-eyebrow">Get Started</div>
    <h2 class="gs-headline">Ready to specify?</h2>
    <div class="gs-grid">
      {cards.map(card => (
        <div class="gs-card">
          <div class="gs-icon">{card.icon}</div>
          <div class="gs-title">{card.title}</div>
          <p class="gs-body">{card.body}</p>
          <a href={card.href} class="gs-cta">{card.cta}</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .collection-section--get-started {
    /* B3 (v2.5.4): white — alternates with grey legacy/related */
    background: var(--section-bg-default, #ffffff);
    padding: 80px 0;
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .collection-content {
    max-width: var(--collection-content-width, 1280px);
    margin-inline: auto;
    padding-inline: var(--collection-content-padding-x, 32px);
    width: 100%;
  }
  .gs-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-alg-red, #F32740);
    margin-bottom: 16px;
  }
  .gs-eyebrow::before {
    content: '';
    display: inline-block;
    width: 84px;
    height: 1.5px;
    background: var(--color-alg-red, #F32740);
    flex-shrink: 0;
  }
  .gs-headline {
    font-family: 'Sora', sans-serif;
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink, #111418);
    margin: 0 0 40px;
  }
  .gs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .gs-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 8px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .gs-icon {
    font-size: 24px;
    color: var(--color-alg-red, #F32740);
    line-height: 1;
  }
  .gs-title {
    font-family: 'Sora', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--ink, #111418);
    letter-spacing: -0.01em;
  }
  .gs-body {
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink2, #444444);
    flex: 1;
    margin: 0;
  }
  .gs-cta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-alg-red, #F32740);
    text-decoration: none;
    margin-top: 4px;
    display: inline-block;
  }
  .gs-cta:hover { text-decoration: underline; }
  @media (max-width: 1023px) { .gs-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 599px)  { .gs-grid { grid-template-columns: 1fr; } }
</style>
