---
/**
 * CollectionStatStrip.astro
 * §3 Quick stats — 4 cells on dark bg.
 */
export interface Props {
  statStrip: { value: string; label: string }[];
}
const { statStrip } = Astro.props;
---
<section class="collection-section collection-section--stats" id="stats">
  <div class="stat-strip-inner">
    {statStrip.map((s, i) => (
      <>
        <div class="stat-col">
          <span class={`stat-num${s.value === 'DLC' ? ' stat-red' : ''}`}>{s.value}</span>
          <span class="stat-lbl">{s.label}</span>
        </div>
        {i < statStrip.length - 1 && <div class="stat-divider"></div>}
      </>
    ))}
  </div>
</section>

<style>
  .collection-section--stats {
    background: #0c0d12;
    display: flex;
    align-items: stretch;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .stat-strip-inner {
    max-width: var(--collection-content-width, 1280px);
    margin-inline: auto;
    padding-inline: var(--collection-content-padding-x, 32px);
    display: flex;
    align-items: stretch;
    width: 100%;
  }
  .stat-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 36px 20px;
    gap: 6px;
  }
  .stat-divider {
    width: 1px;
    background: rgba(255,255,255,0.08);
    flex-shrink: 0;
    align-self: stretch;
    margin: 20px 0;
  }
  .stat-num {
    font-family: 'Lato', system-ui, sans-serif;
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 800;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .stat-red { color: var(--color-alg-red, #F32740); }
  .stat-lbl {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    text-align: center;
  }
  @media (max-width: 1023px) {
    .stat-strip-inner { flex-wrap: wrap; }
    .stat-col { min-width: 50%; }
  }
</style>
