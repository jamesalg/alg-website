---
/**
 * Header.astro — v2.1.0 canonical header
 *
 * Two-row structure:
 *   Row 1 — Utility strip (amber/gold bg, sticky top:0)
 *     Left:  Find a Distributor · Find a Rep · Sample Request · Contact
 *     Right: SIGN IN ▼ (two-pane dropdown)
 *              Pane 1: Sales Reps → AURA Portal (https://aura.archipelagolighting.com)
 *              Pane 2: Distributors · ESCOs · Specifiers → ALG Shop (https://algportal.archipelagolighting.com)
 *   Row 2 — Main nav (white bg, sticky top:36px)
 *     Left:  ALG logo (color SVG /brand/alg-logo-color.svg)
 *     Center: SOLUTIONS · PRODUCTS · TOOLS · SUPPORT · ABOUT
 *     Right: REQUEST SAMPLE (ghost) · REQUEST LAYOUT (red filled)
 *
 * MegaMenu is rendered inline below main nav via MegaMenu.astro.
 */
import MegaMenu from './MegaMenu.astro';
---

<header class="site-header" id="siteHeader">

  <!-- UTILITY STRIP -->
  <div class="util-strip">
    <div class="util-inner">
      <nav class="util-left" aria-label="Utility navigation">
        <a href="/find-a-distributor" class="util-link">Find a Distributor</a>
        <a href="/find-a-rep" class="util-link">Find a Rep</a>
        <a href="/support/sample-request" class="util-link">Sample Request</a>
        <a href="/contact" class="util-link">Contact</a>
      </nav>
      <div class="signin-wrap" id="signinWrap">
        <button class="signin-btn" id="signinBtn" aria-haspopup="true" aria-expanded="false" aria-controls="signinDropdown">
          SIGN IN
          <svg class="signin-chevron" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="signin-dropdown" id="signinDropdown" role="menu" aria-label="Sign in options" hidden>
          <div class="signin-pane">
            <p class="signin-pane-label">Sales Reps</p>
            <a href="https://aura.archipelagolighting.com" class="signin-pane-link" target="_blank" rel="noopener" role="menuitem">
              <span class="signin-pane-name">AURA Portal</span>
              <span class="signin-pane-arrow">→</span>
            </a>
          </div>
          <div class="signin-divider" aria-hidden="true"></div>
          <div class="signin-pane">
            <p class="signin-pane-label">Distributors · ESCOs · Specifiers</p>
            <a href="https://algportal.archipelagolighting.com" class="signin-pane-link" target="_blank" rel="noopener" role="menuitem">
              <span class="signin-pane-name">ALG Shop</span>
              <span class="signin-pane-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- MAIN NAV -->
  <div class="main-nav" id="mainNav">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Archipelago Lighting Group — home">
        <img src="/brand/alg-logo-color.svg" alt="Archipelago Lighting Group" width="140" height="40" loading="eager" />
      </a>
      <nav class="primary-nav" aria-label="Primary navigation">
        <button class="nav-item" data-mega="solutions" aria-haspopup="true" aria-expanded="false">
          SOLUTIONS <svg class="nav-chevron" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <button class="nav-item" data-mega="products" aria-haspopup="true" aria-expanded="false">
          PRODUCTS <svg class="nav-chevron" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <button class="nav-item" data-mega="tools" aria-haspopup="true" aria-expanded="false">
          TOOLS <svg class="nav-chevron" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <button class="nav-item" data-mega="support" aria-haspopup="true" aria-expanded="false">
          SUPPORT <svg class="nav-chevron" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <a href="/about" class="nav-item nav-item--link">ABOUT</a>
      </nav>
      <div class="nav-ctas">
        <a href="/support/sample-request" class="btn btn--ghost nav-cta-ghost">REQUEST SAMPLE</a>
        <a href="/support/layout-request" class="btn btn--primary nav-cta-primary">REQUEST LAYOUT</a>
      </div>
      <button class="hamburger" id="hamburger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobileDrawer">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
    <MegaMenu />
  </div>

  <!-- Mobile overlay + drawer -->
  <div class="mobile-overlay" id="mobileOverlay" aria-hidden="true"></div>
  <nav class="mobile-drawer" id="mobileDrawer" aria-label="Mobile navigation" aria-hidden="true">
    <div class="mobile-drawer-header">
      <a href="/" aria-label="Home">
        <img src="/brand/alg-logo-color.svg" alt="Archipelago Lighting Group" width="120" height="34" />
      </a>
      <button class="mobile-close" id="mobileClose" aria-label="Close navigation menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="mobile-drawer-body">
      <a href="/solutions" class="mobile-nav-item">Solutions</a>
      <a href="/collections" class="mobile-nav-item">Products</a>
      <a href="/tools" class="mobile-nav-item">Tools</a>
      <a href="/support" class="mobile-nav-item">Support</a>
      <a href="/about" class="mobile-nav-item">About</a>
      <div class="mobile-divider"></div>
      <a href="/support/sample-request" class="mobile-nav-item">Request Sample</a>
      <a href="/support/layout-request" class="mobile-nav-item mobile-nav-item--cta">Request Layout</a>
      <div class="mobile-divider"></div>
      <a href="https://aura.archipelagolighting.com" class="mobile-nav-item" target="_blank" rel="noopener">AURA Portal (Sales Reps)</a>
      <a href="https://algportal.archipelagolighting.com" class="mobile-nav-item" target="_blank" rel="noopener">ALG Shop (Distributors)</a>
    </div>
  </nav>

</header>

<style>
  .util-strip {
    background: #F5A623;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    position: sticky;
    top: 0;
    z-index: 200;
  }
  .util-inner {
    max-width: var(--container-max, 1280px);
    margin-inline: auto;
    padding: 0 var(--container-pad, 24px);
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .util-left {
    display: flex;
    align-items: center;
  }
  .util-link {
    font-size: 11px;
    font-weight: 600;
    color: rgba(0,0,0,0.75);
    text-decoration: none;
    padding: 0 12px;
    letter-spacing: 0.04em;
    transition: color 150ms ease;
    border-right: 1px solid rgba(0,0,0,0.15);
    height: 36px;
    display: flex;
    align-items: center;
  }
  .util-link:first-child { padding-left: 0; }
  .util-link:last-child { border-right: none; }
  .util-link:hover { color: #000; }

  .signin-wrap { position: relative; }
  .signin-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #fff;
    background: var(--color-alg-red, #F32740);
    border: none;
    border-radius: 3px;
    padding: 5px 12px;
    cursor: pointer;
    transition: background 150ms ease;
    height: 26px;
  }
  .signin-btn:hover { background: var(--color-alg-red-dark, #C41E32); }
  .signin-chevron { transition: transform 200ms ease; flex-shrink: 0; }
  .signin-btn[aria-expanded="true"] .signin-chevron { transform: rotate(180deg); }

  .signin-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: #fff;
    border: 1px solid var(--color-border, #E5E5E5);
    border-radius: 4px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    min-width: 240px;
    z-index: 300;
    padding: 8px 0;
  }
  .signin-dropdown[hidden] { display: none; }
  .signin-pane { padding: 10px 16px; }
  .signin-pane-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-mute, #6B6B6B);
    margin: 0 0 6px;
  }
  .signin-pane-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-ink, #111111);
    text-decoration: none;
    padding: 6px 10px;
    border-radius: 3px;
    transition: background 150ms ease, color 150ms ease;
  }
  .signin-pane-link:hover {
    background: var(--color-bg-soft, #F7F7F7);
    color: var(--color-alg-red, #F32740);
  }
  .signin-pane-arrow { color: var(--color-alg-red, #F32740); font-weight: 700; }
  .signin-divider { height: 1px; background: var(--color-border, #E5E5E5); margin: 4px 0; }

  .main-nav {
    background: #fff;
    border-bottom: 1px solid var(--color-border, #E5E5E5);
    position: sticky;
    top: 36px;
    z-index: 199;
  }
  .nav-inner {
    max-width: var(--container-max, 1280px);
    margin-inline: auto;
    padding: 0 var(--container-pad, 24px);
    height: 64px;
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .nav-logo { flex-shrink: 0; display: flex; align-items: center; }
  .nav-logo img { height: 36px; width: auto; display: block; }

  .primary-nav { display: flex; align-items: center; flex: 1; }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-ink, #111111);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 14px;
    height: 64px;
    text-decoration: none;
    transition: color 150ms ease;
    white-space: nowrap;
    position: relative;
  }
  .nav-item::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 14px;
    right: 14px;
    height: 2px;
    background: var(--color-alg-red, #F32740);
    transform: scaleX(0);
    transition: transform 200ms ease;
  }
  .nav-item:hover, .nav-item.active { color: var(--color-alg-red, #F32740); }
  .nav-item:hover::after, .nav-item.active::after { transform: scaleX(1); }
  .nav-chevron { transition: transform 200ms ease; flex-shrink: 0; }
  .nav-item[aria-expanded="true"] .nav-chevron { transform: rotate(180deg); }

  .nav-ctas { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  .nav-cta-ghost {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 8px 16px;
    border-radius: 3px;
    color: var(--color-ink, #111111);
    border-color: var(--color-border-strong, #C5C5C5);
  }
  .nav-cta-ghost:hover { background: var(--color-ink, #111111); color: #fff; }
  .nav-cta-primary { font-size: 11px; font-weight: 700; letter-spacing: 0.08em; padding: 8px 16px; border-radius: 3px; }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    margin-left: auto;
    flex-shrink: 0;
  }
  .hamburger-line { display: block; width: 100%; height: 2px; background: var(--color-ink, #111111); border-radius: 1px; }

  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 400;
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .mobile-overlay.open { opacity: 1; }
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: min(320px, 90vw);
    height: 100vh;
    background: #fff;
    z-index: 500;
    transform: translateX(100%);
    transition: transform 300ms ease;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }
  .mobile-drawer.open { transform: translateX(0); }
  .mobile-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border, #E5E5E5);
    flex-shrink: 0;
  }
  .mobile-close { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; background: none; border: none; cursor: pointer; color: var(--color-ink, #111111); }
  .mobile-drawer-body { padding: 8px 0; flex: 1; }
  .mobile-nav-item {
    display: block;
    padding: 12px 20px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink, #111111);
    text-decoration: none;
    border-bottom: 1px solid var(--color-bg-soft, #F7F7F7);
    transition: background 150ms ease, color 150ms ease;
  }
  .mobile-nav-item:hover { background: var(--color-bg-soft, #F7F7F7); color: var(--color-alg-red, #F32740); }
  .mobile-nav-item--cta { color: var(--color-alg-red, #F32740); font-weight: 700; }
  .mobile-divider { height: 1px; background: var(--color-border, #E5E5E5); margin: 8px 0; }

  @media (max-width: 900px) {
    .primary-nav { display: none; }
    .nav-ctas { display: none; }
    .hamburger { display: flex; }
  }
  @media (max-width: 600px) {
    .util-left .util-link:nth-child(n+3) { display: none; }
  }
</style>

<script>
  (function () {
    const signinBtn = document.getElementById('signinBtn') as HTMLButtonElement | null;
    const signinDropdown = document.getElementById('signinDropdown') as HTMLElement | null;
    const signinWrap = document.getElementById('signinWrap');

    function openSignin() {
      if (!signinBtn || !signinDropdown) return;
      signinDropdown.hidden = false;
      signinBtn.setAttribute('aria-expanded', 'true');
    }
    function closeSignin() {
      if (!signinBtn || !signinDropdown) return;
      signinDropdown.hidden = true;
      signinBtn.setAttribute('aria-expanded', 'false');
    }
    signinBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      signinBtn.getAttribute('aria-expanded') === 'true' ? closeSignin() : openSignin();
    });
    document.addEventListener('click', (e) => {
      if (signinWrap && !signinWrap.contains(e.target as Node)) closeSignin();
    });

    const navItems = document.querySelectorAll<HTMLButtonElement>('.nav-item[data-mega]');
    const megaPanel = document.getElementById('megaMenuPanel');

    function openMegaMenu(key: string) {
      if (!megaPanel) return;
      megaPanel.querySelectorAll<HTMLElement>('.mega-pane').forEach(p => {
        p.hidden = p.dataset.mega !== key;
      });
      megaPanel.hidden = false;
      navItems.forEach(btn => {
        const isThis = btn.dataset.mega === key;
        btn.setAttribute('aria-expanded', String(isThis));
        btn.classList.toggle('active', isThis);
      });
    }
    function closeMegaMenu() {
      if (!megaPanel) return;
      megaPanel.hidden = true;
      navItems.forEach(btn => {
        btn.setAttribute('aria-expanded', 'false');
        btn.classList.remove('active');
      });
    }
    navItems.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const key = btn.dataset.mega!;
        btn.getAttribute('aria-expanded') === 'true' ? closeMegaMenu() : openMegaMenu(key);
      });
    });
    document.addEventListener('click', (e) => {
      const header = document.getElementById('siteHeader');
      if (header && !header.contains(e.target as Node)) closeMegaMenu();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeSignin(); closeMegaMenu(); }
    });

    const hamburger = document.getElementById('hamburger') as HTMLButtonElement | null;
    const mobileDrawer = document.getElementById('mobileDrawer');
    const mobileOverlay = document.getElementById('mobileOverlay');
    const mobileClose = document.getElementById('mobileClose');

    function openDrawer() {
      if (!mobileDrawer || !mobileOverlay || !hamburger) return;
      mobileDrawer.classList.add('open');
      mobileDrawer.setAttribute('aria-hidden', 'false');
      mobileOverlay.style.display = 'block';
      requestAnimationFrame(() => mobileOverlay!.classList.add('open'));
      hamburger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      if (!mobileDrawer || !mobileOverlay || !hamburger) return;
      mobileDrawer.classList.remove('open');
      mobileDrawer.setAttribute('aria-hidden', 'true');
      mobileOverlay.classList.remove('open');
      setTimeout(() => { mobileOverlay!.style.display = 'none'; }, 200);
      hamburger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    hamburger?.addEventListener('click', openDrawer);
    mobileClose?.addEventListener('click', closeDrawer);
    mobileOverlay?.addEventListener('click', closeDrawer);
  })();
</script>
