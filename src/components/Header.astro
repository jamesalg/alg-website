  .megamenu.wide .mm-col::-webkit-scrollbar{width:6px;}
  .megamenu.wide .mm-col::-webkit-scrollbar-thumb{background:rgba(0,0,0,0.15);border-radius:3px;}
  .megamenu.wide .mm-col.mm-col-main{background:var(--dark);}
  .megamenu.wide .mm-col.mm-col-cat{background:var(--bg2);border-right:1px solid rgba(0,0,0,0.06);}
  .megamenu.wide .mm-col.mm-col-app{background:#fff;border-right:1px solid rgba(0,0,0,0.06);}
  .megamenu.wide .mm-col.mm-col-preview{background:#fff;padding:20px 24px;}
  .megamenu.wide .mm-col-head{
