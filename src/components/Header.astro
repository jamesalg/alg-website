  /* Fix A (v2.2.1): Sticky header — whole unit (utility strip + nav) pins to top of viewport */
  :global(#site-header) {
    position: sticky;
    top: 0;
    z-index: 1000;
  }
</style>

<script>
(function(){
  const HOVER_DELAY_MS = 600;

  /* ---- Helper: cross-fade preview image ---- */
  function crossfade(imgEl, newSrc){
    if (!newSrc || imgEl.getAttribute('src') === newSrc){ return; }
    imgEl.style.opacity = '0';
    setTimeout(() => {
      imgEl.setAttribute('src', newSrc);
      imgEl.style.opacity = '1';
      imgEl.style.objectPosition = (newSrc && newSrc.indexOf('hospitality') !== -1) ? 'center 30%' : 'center center';
    }, 120);
  }

  /* ---- Helper: render Ⓐ as styled span ---- */
  function renderAa(str){
    return (str || '').replace(/Ⓐ|Ⓐ/g, '<span class="aa">Ⓐ</span>');
  }

  /* =============================================================
     PRODUCTS MEGA MENU · 3-tier cascade
     ============================================================= */
  const productsLi = document.querySelector('li[data-mm="products"]');
  if (productsLi){
    const menu       = productsLi.querySelector('.megamenu.wide');
    const mainItems  = menu.querySelectorAll('.mm-col-main .mm-main-item[data-main]');
    const catGroups  = menu.querySelectorAll('.mm-cat-group');
    const catItems   = menu.querySelectorAll('.mm-cat-item[data-cat]');
    const appGroups  = menu.querySelectorAll('.mm-app-group');
    const appItems   = menu.querySelectorAll('.mm-app-item');
    const previewImg   = menu.querySelector('#mmPreviewImg');
    const previewLbl   = menu.querySelector('#mmPreviewLabel');
    const previewName  = menu.querySelector('#mmPreviewName');
    const previewDesc  = menu.querySelector('#mmPreviewDesc');
    const tierStrip    = menu.querySelector('#mmTierStrip');
    let hoverTimer = null;

    function switchMain(mainKey){
      mainItems.forEach(el => el.classList.toggle('active', el.dataset.main === mainKey));
      catGroups.forEach(g => g.classList.toggle('active', g.dataset.catGroup === mainKey));
      const firstCat = menu.querySelector(`.mm-cat-group[data-cat-group="${mainKey}"] .mm-cat-item`);
      if (firstCat){ activateCat(firstCat, true); }
    }

    function activateCat(catEl, auto){
      catItems.forEach(el => el.classList.remove('active'));
      catEl.classList.add('active');
      const catKey = catEl.dataset.cat;
      appGroups.forEach(g => g.classList.toggle('active', g.dataset.appGroup === catKey));
      crossfade(previewImg, catEl.dataset.preview);
      if (catEl.dataset.previewLabel) previewLbl.textContent  = catEl.dataset.previewLabel;
      if (catEl.dataset.previewName)  previewName.innerHTML   = renderAa(catEl.dataset.previewName);
      if (catEl.dataset.previewDesc)  previewDesc.textContent = catEl.dataset.previewDesc;
      tierStrip.classList.add('hidden');
      const _catHrefMap = {
        "indoor-plano":"/collections/planoarch/index.html",
        "indoor-lampar":"/collections/lampararch/index.html",
        "outdoor-luxo":"/collections/luxoarch/index.html",
        "outdoor-city":"/collections/cityarch/index.html",
        "res-consumer":"/collections/consumer/index.html",
        "res-multi":"/collections/multifamily/index.html",
        "lamps-tubul":"/collections/tubularch/index.html",
        "ctrl-constant":"/collections/constant/index.html",
        "ctrl-controls":"/collections/controls/index.html",
        "openbox-all":"/collections/warehouse-deals/index.html"
      };
      const _previewCta = menu.querySelector('#mmPreviewCta');
      if (_previewCta && _catHrefMap[catKey]) _previewCta.href = _catHrefMap[catKey];
    }

    const FAMILY_HERO = {
      'indoor-plano':   '/mm-previews/tier-hero-plano.png',
      'indoor-lampar':  '/mm-previews/tier-hero-lampar.png',
      'outdoor-luxo':   '/mm-previews/tier-hero-luxo.png',
      'outdoor-city':   '/mm-previews/tier-hero-city.png',
      'lamps-tubul':    '/mm-previews/tier-hero-tubul.png',
    };

    window._algSwapApp = function(appEl){ swapAppPreview(appEl); };
    function swapAppPreview(appEl){
      crossfade(previewImg, appEl.dataset.preview);
      if (appEl.dataset.previewLabel) previewLbl.textContent  = appEl.dataset.previewLabel;
      if (appEl.dataset.previewName)  previewName.innerHTML   = renderAa(appEl.dataset.previewName);
      if (appEl.dataset.previewDesc)  previewDesc.textContent = appEl.dataset.previewDesc;
      if (appEl.dataset.previewTiers === '1'){
        tierStrip.classList.remove('hidden');
        const activeCat = menu.querySelector('.mm-cat-item.active');
        const catKey    = activeCat ? activeCat.dataset.cat : null;
        const heroSrc   = catKey && FAMILY_HERO[catKey] ? FAMILY_HERO[catKey] : null;
        if (heroSrc) {
          document.getElementById('tierImgEco').src     = heroSrc;
          document.getElementById('tierImgPro').src     = heroSrc;
          document.getElementById('tierImgProplus').src = heroSrc;
        }
        const eco  = appEl.dataset.tierEco     || '';
        const pro  = appEl.dataset.tierPro     || '';
        const plus = appEl.dataset.tierProplus || '';
        const ecoCard  = document.getElementById('tierSkuEco').closest('.tier-card');
        const proCard  = document.getElementById('tierSkuPro').closest('.tier-card');
        const plusCard = document.getElementById('tierSkuProplus').closest('.tier-card');
        if (eco)  { ecoCard.classList.remove('slot-empty');  document.getElementById('tierSkuEco').innerHTML     = renderAa(eco);  }
        else      { ecoCard.classList.add('slot-empty'); }
        if (pro)  { proCard.classList.remove('slot-empty');  document.getElementById('tierSkuPro').innerHTML     = renderAa(pro);  }
        else      { proCard.classList.add('slot-empty'); }
        if (plus) { plusCard.classList.remove('slot-empty'); document.getElementById('tierSkuProplus').innerHTML = renderAa(plus); }
        else      { plusCard.classList.add('slot-empty'); }
      } else {
        tierStrip.classList.add('hidden');
      }
    }

    mainItems.forEach(el => {
      el.addEventListener('mouseenter', () => {
        clearTimeout(hoverTimer);
        const key = el.dataset.main;
        if (!key) return;
        hoverTimer = setTimeout(() => switchMain(key), HOVER_DELAY_MS);
      });
      el.addEventListener('mouseleave', () => clearTimeout(hoverTimer));
    });
    catItems.forEach(el => {
      el.addEventListener('mouseenter', () => {
        clearTimeout(hoverTimer);
        hoverTimer = setTimeout(() => activateCat(el, false), HOVER_DELAY_MS);
      });
      el.addEventListener('mouseleave', () => clearTimeout(hoverTimer));
    });
    appItems.forEach(el => {
      el.addEventListener('mouseenter', () => {
        clearTimeout(hoverTimer);
        hoverTimer = setTimeout(() => swapAppPreview(el), HOVER_DELAY_MS);
      });
      el.addEventListener('mouseleave', () => clearTimeout(hoverTimer));
    });
    productsLi.addEventListener('mouseleave', () => clearTimeout(hoverTimer));
  }

  /* =============================================================
     SOLUTIONS MEGA MENU
     ============================================================= */
  const solLi = document.querySelector('li[data-mm="solutions"]');
  if (solLi){
    const solMenu    = solLi.querySelector('.megamenu.solutions');
    const vertItems  = solMenu.querySelectorAll('.mm-vert-item');
    const solPrevImg = solMenu.querySelector('#solPreviewImg');
    const solPrevLbl = solMenu.querySelector('#solPreviewLabel');
    const solPrevNm  = solMenu.querySelector('#solPreviewName');
    const solPrevDsc = solMenu.querySelector('#solPreviewDesc');
    let solTimer = null;
    vertItems.forEach(el => {
      el.addEventListener('mouseenter', () => {
        clearTimeout(solTimer);
        solTimer = setTimeout(() => {
          vertItems.forEach(v => v.classList.remove('active'));
          el.classList.add('active');
          crossfade(solPrevImg, el.dataset.preview);
          if (el.dataset.previewLabel) solPrevLbl.textContent = el.dataset.previewLabel;
          if (el.dataset.previewName)  solPrevNm.innerHTML    = renderAa(el.dataset.previewName);
          if (el.dataset.previewDesc)  solPrevDsc.textContent = el.dataset.previewDesc;
        }, HOVER_DELAY_MS);
      });
      el.addEventListener('mouseleave', () => clearTimeout(solTimer));
    });
    solLi.addEventListener('mouseleave', () => clearTimeout(solTimer));
  }

  /* =============================================================
     A1 (v2.5.4): MOBILE SIGN IN — click-toggle disclosure
     Now a <button> for reliable tap events on all devices.
     Desktop: hover CSS still works (hover:hover media query).
     Mobile: click/touchend toggles .signin--open class.
     ============================================================= */
  const signinTrigger = document.getElementById('signinTrigger');
  if (signinTrigger) {
    function closeSignin() {
      signinTrigger.classList.remove('signin--open');
      signinTrigger.setAttribute('aria-expanded', 'false');
    }
    function openSignin() {
      signinTrigger.classList.add('signin--open');
      signinTrigger.setAttribute('aria-expanded', 'true');
    }
    // Click handler — fires on both mouse and touch
    signinTrigger.addEventListener('click', function(e) {
      e.stopPropagation();
      const isOpen = signinTrigger.classList.contains('signin--open');
      if (isOpen) { closeSignin(); } else { openSignin(); }
    });
    // Prevent dropdown link clicks from bubbling to document close handler
    const dropdown = document.getElementById('signinDropdown');
    if (dropdown) {
      dropdown.addEventListener('click', function(e) { e.stopPropagation(); });
    }
    // Close on outside click / touch
    document.addEventListener('click', function(e) {
      if (!signinTrigger.contains(e.target)) { closeSignin(); }
    });
    // Close on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') { closeSignin(); }
    });
  }

  /* =============================================================
     MOBILE DRAWER · accordion
     ============================================================= */
  const toggle = document.querySelector('.nav-toggle');
  const drawer = document.getElementById('mobileDrawer');
  if (toggle && drawer) {
    toggle.addEventListener('click', () => {
      const isOpen = drawer.classList.toggle('open');
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      drawer.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });
    drawer.querySelectorAll('[data-expand]').forEach(trigger => {
      trigger.addEventListener('click', e => {
        e.preventDefault();
        const id    = trigger.dataset.expand;
        const panel = drawer.querySelector(`[data-expand-id="${id}"]`);
        if (!panel) return;
        const isOpen = panel.classList.toggle('open');
        trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    });
  }
})();
</script>
