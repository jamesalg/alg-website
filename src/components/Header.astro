---
/**
 * Header.astro — v3.14 · exact port of alglighting-he6frhek.manus.space
 *
 * Structure:
 *   Row 1 — Utility bar (dark bg, sticky top:0): Find a Distributor · Find a Rep · Sample Request · Contact · Sign In
 *   Row 2 — site-nav (white, sticky top:34px):
 *     Left:  color SVG logo
 *     Center: SOLUTIONS · PRODUCTS · TOOLS · SUPPORT · ABOUT
 *     Right: Request Sample (outline) + Request Layout (red filled)
 *     Far right: hamburger (mobile)
 *
 * Mega menus:
 *   SOLUTIONS  — 3-col: Main nav | 8 industry verticals | Preview pane
 *   PRODUCTS   — 4-col wide: Main | Category | Application | Preview + tier strip
 *   TOOLS      — 2-col narrow: For Buyers | For Specifiers
 *   SUPPORT    — 2-col narrow: Service | Legal & Compliance
 *
 * Behavior: hover on <li.has-dropdown> shows .megamenu via CSS opacity/visibility.
 *           JS IIFE handles 3-tier cascade for Products and Solutions preview swap.
 *           Mobile: hamburger toggles .mobile-drawer.open, accordion via data-expand.
 */
---
<!-- UTILITY BAR -->
<div class="utility-bar">
  <a href="/find-a-distributor">Find a Distributor</a>
  <a href="/find-a-rep">Find a Rep</a>
  <a href="/support/sample-request">Sample Request</a>
  <a href="/contact">Contact</a>
  <button class="signin" id="signinTrigger" type="button" aria-expanded="false" aria-haspopup="true">
    Sign In
    <div class="signin-dropdown" id="signinDropdown">
      <a href="https://aura.archipelagolighting.com" target="_blank" rel="noopener noreferrer">
        <span class="label">Sales Reps</span>
        <span>AURA Portal →</span>
      </a>
      <a href="https://algportal.archipelagolighting.com" target="_blank" rel="noopener noreferrer">
        <span class="label">Distributors · ESCOs · Specifiers</span>
        <span>ALG Shop →</span>
      </a>
    </div>
  </button>
</div>

<!-- PERSISTENT SITE NAV -->
<nav class="site-nav" id="siteNav">
  <div class="logo-wrap">
    <a href="/" aria-label="Archipelago Lighting Group home">
      <img src="/brand/alg-logo-color.svg" alt="Archipelago Lighting Group" width="160" height="44" loading="eager" />
    </a>
  </div>

  <ul class="main-nav">

    <!-- ============================================================
         SOLUTIONS — 3-col: Main | Verticals | Preview
         ============================================================ -->
    <li class="has-dropdown" data-mm="solutions">
      <a href="/solutions">Solutions</a>
      <div class="megamenu solutions">
        <div class="mm-col mm-col-main">
          <div class="mm-col-head">Browse by</div>
          <div class="mm-main-group-label">Start here</div>
          <a href="/solutions" class="mm-main-item active">Solutions<span class="mm-main-sub">By vertical · 8 industries</span></a>
          <div class="mm-main-divider"></div>
          <div class="mm-main-group-label">Purchase tools</div>
          <a href="/find-a-distributor" class="mm-main-item">Where to Buy</a>
          <a href="/taa-compliant-lighting" class="mm-main-item">TAA Compliant</a>
          <a href="/find-a-rep" class="mm-main-item">Find a Rep</a>
          <a href="/find-a-distributor" class="mm-main-item">Find a Distributor</a>
        </div>
        <div class="mm-col mm-col-vert">
          <div class="mm-col-head">Industry Vertical</div>
          <a href="/solutions/warehouse-logistics" class="mm-vert-item active"
             data-preview="/mm-previews/indoor-plano.png"
             data-preview-name="Warehouse &amp; Logistics"
             data-preview-label="Vertical · Warehouse"
             data-preview-desc="High-bay and low-bay systems engineered for distribution centers and 3PL facilities. DLC Premium listed with integrated sensors and emergency egress.">
             Warehouse &amp; Logistics<span class="mm-vert-sub">High bays · EM · sensors</span>
          </a>
          <a href="/solutions/industrial-manufacturing" class="mm-vert-item"
             data-preview="/mm-previews/indoor-plano.png"
             data-preview-name="Industrial &amp; Manufacturing"
             data-preview-label="Vertical · Industrial"
             data-preview-desc="Production-floor and process-facility lighting engineered for uptime. Washdown-rated, vibration-resistant, and hazardous-location configurations.">
             Industrial &amp; Manufacturing<span class="mm-vert-sub">Washdown · hazloc · strip</span>
          </a>
          <a href="/solutions/cold-storage-grocery" class="mm-vert-item"
             data-preview="/mm-previews/indoor-plano.png"
             data-preview-name="Cold Storage &amp; Grocery"
             data-preview-label="Vertical · Cold Chain"
             data-preview-desc="Freezer, cooler, and grocery cold-chain fixtures rated for low-temperature starts down to -40°F. IP-rated with moisture-resistant gaskets.">
             Cold Storage &amp; Grocery<span class="mm-vert-sub">Cooler luminaires · refer</span>
          </a>
          <a href="/solutions/data-center" class="mm-vert-item"
             data-preview="/mm-previews/indoor-plano.png"
             data-preview-name="Data Center"
             data-preview-label="Vertical · Data Center"
             data-preview-desc="Hyperscale and colocation facility lighting with controls integration. Low-profile troffers and linear with BMS-ready DALI and 0–10V dimming.">
             Data Center<span class="mm-vert-sub">Troffers · linear · DALI</span>
          </a>
          <a href="/solutions/healthcare" class="mm-vert-item"
             data-preview="/mm-previews/indoor-plano.png"
             data-preview-name="Healthcare"
             data-preview-label="Vertical · Healthcare"
             data-preview-desc="Patient-care, surgical, and administrative lighting with compliance coverage. UL1598 listed with anti-microbial finish options and tunable-white.">
             Healthcare<span class="mm-vert-sub">Tunable-white · surgical</span>
          </a>
          <a href="/solutions/education" class="mm-vert-item"
             data-preview="/mm-previews/indoor-plano.png"
             data-preview-name="Education"
             data-preview-label="Vertical · Education"
             data-preview-desc="K-12 and higher-ed lighting with CEC JA8 and DLC Premium. Panel, troffer, and classroom controls packages with occupancy + daylight harvesting.">
             Education<span class="mm-vert-sub">Panels · JA8 · controls</span>
          </a>
          <a href="/solutions/hospitality" class="mm-vert-item"
             data-preview="/mm-previews/indoor-plano.png"
             data-preview-name="Hospitality"
             data-preview-label="Vertical · Hospitality"
             data-preview-desc="Hotels, restaurants, and hospitality venues with warm-dimming and controls. Décor-grade finishes with 2700K–3000K warm CCT and phase-cut compatibility.">
             Hospitality<span class="mm-vert-sub">Warm-dim · décor · phase</span>
          </a>
          <a href="/solutions/government-military" class="mm-vert-item"
             data-preview="/mm-previews/outdoor-city.png"
             data-preview-name="Government &amp; Military"
             data-preview-label="Vertical · Gov &amp; Mil"
             data-preview-desc="TAA-compliant fixtures for federal, state, and DoD facilities. Buy American Act eligible with documentation for GSA schedules and set-aside procurements.">
             Government &amp; Military<span class="mm-vert-sub">TAA · BAA · GSA</span>
          </a>
        </div>
        <div class="mm-col mm-col-preview">
          <div class="mm-preview">
            <div class="preview-img-wrap">
              <img src="/mm-previews/indoor-plano.png" alt="Solutions preview" id="solPreviewImg">
            </div>
            <div class="preview-label" id="solPreviewLabel">Vertical · Warehouse</div>
            <div class="preview-name" id="solPreviewName">Warehouse &amp; Logistics</div>
            <div class="preview-desc" id="solPreviewDesc">High-bay and low-bay systems engineered for distribution centers and 3PL facilities. DLC Premium listed with integrated sensors and emergency egress.</div>
            <a href="/solutions" class="preview-cta">View solutions →</a>
          </div>
        </div>
      </div>
    </li>

    <!-- ============================================================
         PRODUCTS — 4-col wide: Main | Category | Application | Preview
         ============================================================ -->
    <li class="has-dropdown" data-mm="products">
      <a href="/collections">Products</a>
      <div class="megamenu wide">
        <!-- COLUMN 1: MAIN MENU (dark panel) -->
        <div class="mm-col mm-col-main">
          <div class="mm-col-head">Browse by</div>
          <div class="mm-main-group-label">Category</div>
          <a href="#" class="mm-main-item active" data-main="indoor">Indoor<span class="mm-main-sub">plano<span class="aa">Ⓐ</span>RCH · lampar<span class="aa">Ⓐ</span>RCH</span></a>
          <a href="#" class="mm-main-item" data-main="outdoor">Outdoor<span class="mm-main-sub">luxo<span class="aa">Ⓐ</span>RCH · city<span class="aa">Ⓐ</span>RCH</span></a>
          <a href="#" class="mm-main-item" data-main="residential">Residential<span class="mm-main-sub">Consumer · multi-f<span class="aa">Ⓐ</span>MILY</span></a>
          <a href="#" class="mm-main-item" data-main="lamps">Lamps<span class="mm-main-sub">tubul<span class="aa">Ⓐ</span>RCH · T5 · T8 · PL · PLL · U6</span></a>
          <div class="mm-main-divider"></div>
          <div class="mm-main-group-label">By tech capability</div>
          <a href="#" class="mm-main-item" data-main="controls">Safety &amp; Controls<span class="mm-main-sub">const<span class="aa">Ⓐ</span>NT · contr<span class="aa">Ⓐ</span>LS</span></a>
          <div class="mm-main-divider"></div>
          <a href="#" class="mm-main-item" data-main="openbox">Warehouse Deals<span class="mm-main-sub">Last-run inventory</span></a>
          <div class="mm-main-divider"></div>
          <div class="mm-main-group-label">Purchase tools</div>
          <a href="/find-a-distributor" class="mm-main-item">Where to Buy</a>
          <a href="/taa-compliant-lighting" class="mm-main-item">TAA Compliant</a>
        </div>

        <!-- COLUMN 2: CATEGORY -->
        <div class="mm-col mm-col-cat">
          <div class="mm-col-head">Category</div>
          <!-- INDOOR · 2 categories -->
          <div class="mm-cat-group active" data-cat-group="indoor">
            <a href="/collections/planoarch/index.html" class="mm-cat-item active" data-cat="indoor-plano"
               data-preview="/mm-previews/indoor-plano.png"
               data-preview-name="Commercial | planoⒶRCH"
               data-preview-label="Indoor · Commercial"
               data-preview-desc="Commercial LED lighting for offices, retail, education, and healthcare. Recessed downlights, back-lit panels, architectural linear, troffers, and surface-mount.">
