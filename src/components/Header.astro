<style>
  /* ================================================================
     CSS VARIABLES
     ================================================================ */
  :root {
    --ink:#111418;--ink2:#3a3f47;--ink3:#8a8f99;--ink4:#c8ccd3;
    --bg:#ffffff;--bg2:#f5f5f3;--bg3:#eceae4;
    --dark:#0c0d12;--dark2:#14161e;
    --brand:#F32740;--brand-dk:#C41F32;
    --kraft:#c9a876;--amber:#f0a932;--grn:#0FAE7C;
  }

  /* ================================================================
     UTILITY BAR
     ================================================================ */
  .utility-bar{
    background:var(--dark);color:#fff;
    height:34px;display:flex;align-items:center;justify-content:flex-end;
    padding:0 28px;font-size:11px;letter-spacing:0.5px;
    position:sticky;top:0;z-index:101;
    border-bottom:1px solid rgba(255,255,255,0.05);
  }
  .utility-bar a{color:#fff;text-decoration:none;opacity:0.8;margin-left:20px;transition:opacity 0.15s;}
  .utility-bar a:hover{opacity:1;}
  .utility-bar .signin{
    position:relative;
    background:var(--brand);padding:5px 14px;border-radius:3px;
    margin-left:24px;font-weight:600;letter-spacing:1px;text-transform:uppercase;
    cursor:pointer;display:inline-flex;align-items:center;gap:6px;
    user-select:none;
    /* button reset */
    border:none;color:#fff;font-family:inherit;font-size:inherit;
    min-height:44px;min-width:44px;
    -webkit-tap-highlight-color:rgba(0,0,0,0.1);
  }
  .utility-bar .signin::after{content:'▾';font-size:9px;}
  .signin-dropdown{
    position:absolute;top:100%;right:0;margin-top:6px;
    background:#fff;color:var(--ink);
    border:1px solid rgba(0,0,0,0.08);
    box-shadow:0 8px 24px rgba(0,0,0,0.15);
    min-width:320px;
    opacity:0;visibility:hidden;transform:translateY(-4px);
    transition:all 0.15s;
    border-radius:4px;
    overflow:hidden;
    z-index:200;
  }
  /* A1 (v2.5.3): Desktop hover behavior preserved */
  @media (hover: hover) and (pointer: fine) {
    .utility-bar .signin:hover .signin-dropdown{opacity:1;visibility:visible;transform:translateY(0);}
  }
  /* A1 (v2.5.3): Mobile click-toggle — JS adds .signin--open class */
  .utility-bar .signin.signin--open .signin-dropdown{opacity:1;visibility:visible;transform:translateY(0);}
  .signin-dropdown a{
    display:block;padding:14px 16px;text-align:left;text-transform:none;
    letter-spacing:0;margin:0;font-size:13px;color:var(--ink);font-weight:400;
    border-bottom:1px solid rgba(0,0,0,0.06);opacity:1;text-decoration:none;
  }
  .signin-dropdown a:hover{background:var(--bg2);color:var(--brand);}
  .signin-dropdown a:last-child{border-bottom:0;}
  .signin-dropdown .label{
    font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--brand);
    letter-spacing:1.5px;text-transform:uppercase;font-weight:600;
    display:block;margin-bottom:3px;white-space:nowrap;
  }

  /* ================================================================
     SITE NAV
     ================================================================ */
  .site-nav{
    position:sticky;top:34px;z-index:100;
    background:rgba(255,255,255,0.97);
    backdrop-filter:blur(10px);
    -webkit-backdrop-filter:blur(10px);
    border-bottom:1px solid rgba(0,0,0,0.06);
    height:56px;
    display:flex;align-items:center;justify-content:space-between;
    padding:0 28px;
  }
  .site-nav .logo-wrap{display:flex;align-items:center;}
  .site-nav .logo-wrap img{height:36px;width:auto;display:block;}
  .site-nav ul.main-nav{display:flex;list-style:none;gap:32px;margin:0;padding:0;}
  .site-nav ul.main-nav > li{position:relative;padding:18px 0;}
  .site-nav ul.main-nav > li > a{
    text-decoration:none;color:var(--ink2);
    font-size:12px;font-weight:600;letter-spacing:0.8px;
    text-transform:uppercase;
    transition:color 0.15s;
    display:inline-flex;align-items:center;gap:5px;
  }
  .site-nav ul.main-nav > li.has-dropdown > a::after{
    content:'▾';font-size:8px;opacity:0.5;
  }
  .site-nav ul.main-nav > li > a:hover{color:var(--brand);}
  .site-nav ul.main-nav > li.has-dropdown:hover .megamenu{opacity:1;visibility:visible;transform:translateY(0);}

  /* ================================================================
     MEGA MENU — base (narrow: Tools / Support)
     ================================================================ */
  .megamenu{
    position:absolute;top:100%;left:-20px;
    background:#fff;
    border:1px solid rgba(0,0,0,0.08);
    box-shadow:0 12px 40px rgba(0,0,0,0.12);
    padding:24px 28px;
    /* A2 (v2.5.3): no outer white wrapper — inner panels handle their own bg */
