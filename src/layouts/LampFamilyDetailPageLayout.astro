---
/**
 * LampFamilyDetailPageLayout.astro
 *
 * v2.7.2 — Rebuilt from pixel-target mockups.
 * Route: /collections/{collection-slug}/{family-slug}
 *
 * Section structure (matches mockup):
 *   1. Breadcrumb (light chrome)
 *   2. lamp-page (dark themed)
 *      a. lamp-subcrumb (dark sub-breadcrumb)
 *      b. collection-mark (top-right italic logomark)
 *      c. lamp-hero (2-col: copy + subject)
 *      d. lamp-hero__footer (CRI badge + certifications)
 *      e. collection-band (full-width brand lockup)
 *      f. spec-section (SKU table)
 *      g. dimmers-section (optional)
 *      h. hot-sellers-section (sister families)
 *      i. get-started (CTA row)
 */
import BaseLayout from './BaseLayout.astro';
import skuIndex from '../data/sku-index.json';

export interface Props {
  family: {
    slug: string;
    name: string;
    collectionSlug: string;
    collectionName: string;
    collectionTitleAscii: string;
    collectionHeadlineLine: string;
    collectionAesthetic: 'vintage' | 'nostalgic' | 'utility';
    tagline: string;
    description: string;
    heroImage?: string;
    echelon?: 'ECO' | 'PRO' | 'PRO+';
    keySpecs: { inputWatts: string; lumens: string; lmPerW: string; cri: string };
    certifications: string[];
    compatibleDimmers?: { brand: string; models: string[] }[];
    datasheetUrl?: string;
    installGuideUrl?: string;
    comingSoon?: boolean;
    isTubularArch?: boolean;
  };
  siblingFamilies: {
    slug: string;
    name: string;
    tagline: string;
    skuCount: number;
  }[];
  relatedCollections: {
    slug: string;
    name: string;
    vertical: string;
    description: string;
    status: 'live' | 'coming-soon';
  }[];
  getStarted: {
    layoutCopy: string;
    sampleCopy: string;
    distributorCopy: string;
    repCopy: string;
  };
}

const { family: f, siblingFamilies, relatedCollections, getStarted } = Astro.props;

// Pull SKUs for this family from sku-index.json
const collectionData = (skuIndex as any).collections?.[f.collectionSlug];
const familySkus = collectionData?.skus?.filter((s: any) =>
  s.family === f.name || s.family === f.slug ||
  s.family?.toLowerCase() === f.slug?.toLowerCase() ||
  s.family?.toLowerCase().replace(/[\s\-]+/g, '-') === f.slug?.toLowerCase()
) ?? [];

// Theme tokens — one object per aesthetic, consumed via CSS custom properties
const themes = {
  vintage: {
    bg: '#0c0d12',
    bgSoft: '#16171d',
    fg: '#f5e9d2',
    fgMuted: '#a8a094',
    fgDim: '#6b6760',
    accent: '#c9a45c',
    accentDark: '#8a7340',
    filament: '#ff8c2a',
    border: 'rgba(245,233,210,0.12)',
    watermarkUrl: "url('/lamps/scrollwork-vintage.svg')",
    bandBg: 'linear-gradient(180deg,#0c0d12 0%,#161721 50%,#0c0d12 100%)',
    bandGlow: 'radial-gradient(ellipse at 25% 50%,rgba(255,140,42,0.18),transparent 30%),radial-gradient(ellipse at 75% 50%,rgba(255,140,42,0.18),transparent 30%),radial-gradient(ellipse at 50% 50%,rgba(255,140,42,0.10),transparent 25%)',
    bandTextShadow: 'none',
    placeholderBg: 'linear-gradient(180deg,rgba(201,164,92,0.06) 0%,rgba(255,140,42,0.08) 50%,rgba(201,164,92,0.04) 100%)',
    placeholderBorder: 'rgba(201,164,92,0.3)',
    watermarkInset: '-10% -15%',
    watermarkPosition: 'center',
    watermarkSize: 'contain',
    hoverShadow: 'none',
    subjectAlign: 'center',
    subjectHaze: 'none',
  },
  nostalgic: {
    bg: '#0a0d18',
    bgSoft: '#11142a',
    fg: '#e8eef8',
    fgMuted: '#8a92ad',
    fgDim: '#525a78',
    accent: '#00d4ff',
    accentDark: '#009ab8',
    filament: '#ffaa44',
    border: 'rgba(232,238,248,0.10)',
    watermarkUrl: "url('/lamps/cybergrid-nostalgic.svg')",
    bandBg: 'linear-gradient(180deg,#0a0d18 0%,#15192e 50%,#0a0d18 100%)',
    bandGlow: 'none',
    bandTextShadow: '0 0 8px rgba(0,212,255,0.4),0 0 24px rgba(0,212,255,0.2)',
    placeholderBg: 'linear-gradient(180deg,rgba(0,212,255,0.06) 0%,rgba(255,170,68,0.10) 50%,rgba(255,45,208,0.08) 100%)',
    placeholderBorder: 'rgba(0,212,255,0.4)',
    watermarkInset: '25% -10% -5% -10%',
    watermarkPosition: 'center bottom',
    watermarkSize: 'cover',
    hoverShadow: '0 0 24px rgba(0,212,255,0.15)',
    subjectAlign: 'flex-end',
    subjectHaze: 'radial-gradient(ellipse at center bottom,rgba(255,45,208,0.4),transparent 60%)',
  },
  utility: {
    bg: '#1a1d24',
    bgSoft: '#21252f',
    fg: '#ffffff',
    fgMuted: '#9aa0b0',
    fgDim: '#5a6070',
    accent: '#F32740',
    accentDark: '#d61f37',
    filament: '#F32740',
    border: 'rgba(255,255,255,0.10)',
    watermarkUrl: 'none',
    bandBg: 'linear-gradient(180deg,#1a1d24 0%,#21252f 50%,#1a1d24 100%)',
    bandGlow: 'none',
    bandTextShadow: 'none',
    placeholderBg: 'linear-gradient(180deg,rgba(243,39,64,0.06) 0%,rgba(243,39,64,0.04) 100%)',
    placeholderBorder: 'rgba(243,39,64,0.3)',
    watermarkInset: '-10% -15%',
    watermarkPosition: 'center',
    watermarkSize: 'contain',
    hoverShadow: 'none',
    subjectAlign: 'center',
    subjectHaze: 'none',
  },
};

const t = themes[f.collectionAesthetic];

// Breadcrumb: HOME › PRODUCTS › INDOOR › {Collection} › {Family}
// collectionLabelHtml is used in the breadcrumb via set:html to render wrapped Ⓐ spans.
const collectionLabelHtml = f.collectionSlug === 'tubulararch' ? 'TUBUL<span class="aa">\u24B6</span>RCH' :
  f.collectionSlug === 'nostalgic-decor' ? 'NOST<span class="aa">\u24B6</span>LGIC D\u00C9COR' :
  f.collectionSlug === 'vintage-decor' ? 'VINT<span class="aa">\u24B6</span>GE D\u00C9COR' :
  f.collectionSlug === 'signature' ? 'SIGN<span class="aa">\u24B6</span>TURE' :
  f.collectionName.toUpperCase();

const collectionHref = `/collections/${f.collectionSlug}/`;

// Collection mark (top-right italic) — uses set:html for wrapped Ⓐ
const collectionMarkHtml = f.collectionHeadlineLine;

// Collection band lockup — uppercase ASCII title
const bandLockupHtml = f.collectionTitleAscii;

// Echelon badge
const badgeLabel = f.comingSoon ? 'COMING SOON' : (f.echelon ?? 'ECO');

// CTA classes
const docClass = f.comingSoon ? 'lamp-cta lamp-cta--coming-soon' : (f.datasheetUrl ? 'lamp-cta lamp-cta--secondary' : 'lamp-cta lamp-cta--coming-soon');
const pricingClass = f.comingSoon ? 'lamp-cta lamp-cta--coming-soon' : 'lamp-cta lamp-cta--primary';

// Strip HTML tags and replace Ⓐ (U+24B6) with A for use in <title> and og:title
const collectionTitlePlain = f.collectionTitleAscii.replace(/<[^>]+>/g, '').replace(/\u24B6/g, 'A');
const pageTitle = `${f.name} | ${collectionTitlePlain} | Archipelago Lighting Group`;
---
<BaseLayout title={pageTitle} description={f.description}>
<style define:vars={{
  lampBg: t.bg,
  lampBgSoft: t.bgSoft,
  lampFg: t.fg,
  lampFgMuted: t.fgMuted,
  lampFgDim: t.fgDim,
  lampAccent: t.accent,
  lampAccentDark: t.accentDark,
  lampBorder: t.border,
  lampWatermarkUrl: t.watermarkUrl,
  lampBandBg: t.bandBg,
  lampBandTextShadow: t.bandTextShadow,
  lampPlaceholderBg: t.placeholderBg,
  lampPlaceholderBorder: t.placeholderBorder,
  lampWatermarkInset: t.watermarkInset,
  lampWatermarkPosition: t.watermarkPosition,
  lampWatermarkSize: t.watermarkSize,
  lampHoverShadow: t.hoverShadow,
  lampSubjectAlign: t.subjectAlign,
}}>
  /* ============================================================
     BREADCRUMB — light chrome
     ============================================================ */
  .breadcrumb-band {
    background: #fff;
    padding: 14px 32px;
    font-size: 12px;
    letter-spacing: 0.08em;
    color: #666;
    text-transform: uppercase;
    border-bottom: 1px solid #e5e5e5;
    font-weight: 500;
  }
  .breadcrumb-band a { color: #666; text-decoration: none; }
  .breadcrumb-band a:hover { color: #F32740; }
  .breadcrumb-band .bc-sep { margin: 0 8px; color: #ccc; }
  .breadcrumb-band .bc-current { color: #000; }

  /* ============================================================
     LAMP PAGE — dark themed body
     ============================================================ */
  .lamp-page {
    background: var(--lampBg);
    color: var(--lampFg);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }
  .lamp-page .aa { color: var(--lampAccent); }

  /* Sub-breadcrumb inside dark area */
  .lamp-subcrumb {
    max-width: 1180px;
    margin: 0 auto;
    padding: 28px 40px 0;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--lampFgMuted);
  }
  .lamp-subcrumb a { color: var(--lampFgMuted); text-decoration: none; }
  .lamp-subcrumb .sep { margin: 0 6px; opacity: 0.5; }
  .lamp-subcrumb .current { color: var(--lampFg); }

  /* Top-right collection logomark */
  .collection-mark {
    position: absolute;
    top: 30px;
    right: 40px;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 22px;
    letter-spacing: 0.05em;
    font-style: italic;
    color: var(--lampAccent);
    z-index: 2;
  }
  .collection-mark .aa { color: var(--lampAccent); }

  /* ============================================================
     HERO — 2-column: copy left, subject right
     ============================================================ */
  .lamp-hero {
    max-width: 1180px;
    margin: 0 auto;
    padding: 60px 40px 100px;
    display: grid;
    grid-template-columns: minmax(0,1fr) minmax(0,1.1fr);
    gap: 80px;
    align-items: center;
    position: relative;
  }
  .lamp-hero__copy { position: relative; z-index: 2; }
  .lamp-hero__series-eyebrow {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--lampAccent);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .lamp-hero__series-eyebrow::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: var(--lampAccent);
    flex-shrink: 0;
  }
  .lamp-family-name {
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: 400;
    font-size: 48px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--lampFg);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .echelon-badge {
    display: inline-block;
    padding: 4px 12px;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    background: rgba(255,255,255,0.08);
    border: 1px solid var(--lampFgDim);
    color: var(--lampFg);
    border-radius: 2px;
    text-transform: uppercase;
    align-self: center;
    transform: translateY(2px);
    flex-shrink: 0;
  }
  .echelon-badge--accent {
    background: rgba(0,0,0,0.15);
    border-color: var(--lampAccent);
    color: var(--lampAccent);
  }
  .echelon-badge--soon {
    background: rgba(150,150,150,0.10);
    border-color: rgba(150,150,150,0.4);
    color: #888;
  }

  .lamp-tagline {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 28px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--lampFg);
    margin: 32px 0 20px;
    letter-spacing: -0.01em;
  }
  .lamp-description {
    font-size: 15px;
    line-height: 1.65;
    color: var(--lampFgMuted);
    max-width: 540px;
    margin: 0 0 32px;
  }

  /* Key spec strip */
  .lamp-keyspec {
    display: flex;
    gap: 18px;
    align-items: center;
    margin: 0 0 36px;
    font-size: 13px;
    color: var(--lampFgMuted);
    flex-wrap: wrap;
  }
  .lamp-keyspec__item { display: flex; align-items: baseline; gap: 6px; }
  .lamp-keyspec__label {
    font-weight: 700;
    color: var(--lampFg);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
  }
  .lamp-keyspec__sep { color: var(--lampFgDim); margin: 0 4px; }

  /* CTA row */
  .lamp-cta-row { display: flex; gap: 16px; margin-top: 8px; flex-wrap: wrap; }
  .lamp-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.15s ease;
    border: 1px solid transparent;
    cursor: pointer;
    min-width: 200px;
  }
  .lamp-cta--primary {
    background: #F32740;
    color: #fff;
    border-color: #F32740;
  }
  .lamp-cta--primary:hover { background: #d61f37; border-color: #d61f37; }
  .lamp-cta--secondary {
    background: transparent;
    color: var(--lampFg);
    border-color: var(--lampFg);
  }
  .lamp-cta--secondary:hover { background: var(--lampFg); color: var(--lampBg); }
  .lamp-cta--coming-soon {
    background: transparent;
    color: var(--lampFgDim);
    border-color: var(--lampFgDim);
    cursor: not-allowed;
    pointer-events: none;
  }
  .lamp-cta--coming-soon::after {
    content: " · COMING SOON";
    font-size: 10px;
    letter-spacing: 0.08em;
    opacity: 0.7;
  }

  /* Hero subject column */
  .lamp-hero__subject {
    position: relative;
    aspect-ratio: 1.1 / 1;
    display: flex;
    align-items: var(--lampSubjectAlign);
    justify-content: center;
    overflow: hidden;
  }
  .lamp-hero__watermark {
    position: absolute;
    inset: var(--lampWatermarkInset);
    pointer-events: none;
    background-image: var(--lampWatermarkUrl);
    background-position: var(--lampWatermarkPosition);
    background-repeat: no-repeat;
    background-size: var(--lampWatermarkSize);
    z-index: 1;
  }
  .lamp-hero__product {
    position: relative;
    z-index: 2;
    max-width: 70%;
    max-height: 100%;
    width: auto;
    height: auto;
  }
  .lamp-hero__product-placeholder {
    position: relative;
    z-index: 2;
    width: 60%;
    aspect-ratio: 1 / 1.4;
    background: var(--lampPlaceholderBg);
    border: 1px dashed var(--lampPlaceholderBorder);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lampAccent);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-align: center;
    padding: 20px;
  }

  /* Hero footer band — CRI badge + certifications */
  .lamp-hero__footer {
    max-width: 1180px;
    margin: 0 auto;
    padding: 32px 40px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--lampBorder);
  }
  .cri-row { display: flex; align-items: center; }
  .cri-badge {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: conic-gradient(from 0deg,#ff5050,#ff8c2a,#ffd84a,#94d05a,#4ad0d0,#5a8cd0,#8c5ad0,#d05a8c,#ff5050);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 0 0 6px var(--lampBg);
  }
  .cri-badge__inner {
    background: var(--lampBg);
    width: 80%;
    height: 80%;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--lampFg);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
  }
  .cri-badge__num { font-size: 20px; font-weight: 700; line-height: 1; }
  .cri-badge__lbl { font-size: 8px; letter-spacing: 0.1em; color: var(--lampFgMuted); margin-top: 2px; }
  .cct-callout {
    margin-left: 16px;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--lampFgMuted);
  }
  .certifications { display: flex; gap: 32px; align-items: center; flex-wrap: wrap; }
  .cert {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    color: var(--lampFgMuted);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    gap: 4px;
  }
  .cert__icon {
    width: 36px;
    height: 36px;
    border: 1.5px solid var(--lampFgMuted);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    color: var(--lampFg);
    font-family: Georgia, serif;
  }
  .cert__icon--square { border-radius: 4px; }

  /* ============================================================
     COLLECTION BRAND HERO BAND
     ============================================================ */
  .collection-band {
    position: relative;
    background: var(--lampBandBg);
    padding: 120px 40px;
    text-align: center;
    overflow: hidden;
    border-top: 1px solid var(--lampBorder);
    border-bottom: 1px solid var(--lampBorder);
  }
  .collection-band__lockup {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 80px;
    letter-spacing: -0.02em;
    color: var(--lampAccent);
    margin: 0 0 12px;
    font-style: italic;
    text-shadow: var(--lampBandTextShadow);
  }
  .collection-band__lockup .aa { color: var(--lampAccent); }
  .collection-band__sub {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 12px;
    letter-spacing: 0.4em;
    color: var(--lampFgMuted);
    text-transform: uppercase;
  }
  .collection-band__bg { position: absolute; inset: 0; pointer-events: none; }
  .collection-band > * { position: relative; z-index: 1; }

  /* ============================================================
     SPECIFICATIONS TABLE
     ============================================================ */
  .spec-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 80px 40px 60px;
  }
  .section-eyebrow {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 11px;
    letter-spacing: 0.4em;
    color: var(--lampFgMuted);
    text-transform: uppercase;
    margin: 0 0 12px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .section-eyebrow::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--lampAccent);
    flex-shrink: 0;
  }
  .section-title {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 32px;
    color: var(--lampFg);
    margin: 0 0 40px;
    font-weight: 600;
  }
  .spec-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 13px;
  }
  .spec-table th {
    text-align: left;
    padding: 14px 16px;
    color: var(--lampFgMuted);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--lampBorder);
    background: rgba(255,255,255,0.02);
  }
  .spec-table td {
    padding: 16px;
    color: var(--lampFg);
    border-bottom: 1px solid var(--lampBorder);
  }
  .spec-table tr:hover td { background: rgba(255,255,255,0.03); }
  .coming-soon-msg {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 13px;
    color: var(--lampFgMuted);
    padding: 32px 0;
    letter-spacing: 0.05em;
  }

  /* ============================================================
     COMPATIBLE DIMMERS
     ============================================================ */
  .dimmers-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 40px 40px 80px;
  }
  .dimmers-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 13px;
  }
  .dimmers-table th, .dimmers-table td {
    padding: 14px 16px;
    text-align: left;
    border-bottom: 1px solid var(--lampBorder);
    vertical-align: top;
  }
  .dimmers-table th {
    background: rgba(255,255,255,0.02);
    color: var(--lampFgMuted);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .dimmers-table td:first-child { font-weight: 700; color: var(--lampAccent); width: 200px; }
  .dimmers-table td .model-list { display: flex; flex-wrap: wrap; gap: 8px 16px; color: var(--lampFg); }

  /* ============================================================
     HOT SELLERS — sister-shape cross-sell strip
     ============================================================ */
  .hot-sellers-section {
    background: var(--lampBgSoft);
    padding: 80px 40px 100px;
    border-top: 1px solid var(--lampBorder);
  }
  .hot-sellers-grid {
    max-width: 1280px;
    margin: 24px auto 0;
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 20px;
  }
  .sister-card {
    background: var(--lampBg);
    border: 1px solid var(--lampBorder);
    padding: 28px 24px;
    text-decoration: none;
    color: var(--lampFg);
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
    aspect-ratio: 1 / 1;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }
  .sister-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--lampWatermarkUrl);
    background-size: 200% auto;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0.15;
    pointer-events: none;
  }
  .sister-card:hover {
    border-color: var(--lampAccent);
    transform: translateY(-2px);
    box-shadow: var(--lampHoverShadow);
  }
  .sister-card__name {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 28px;
    color: var(--lampFg);
    position: relative;
  }
  .sister-card__sku-count {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 11px;
    color: var(--lampFgMuted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    position: relative;
  }
  .sister-card__arrow { font-family: 'JetBrains Mono', monospace; font-size: 14px; color: var(--lampAccent); margin-left: 6px; }

  /* ============================================================
     GET STARTED
     ============================================================ */
  .get-started {
    max-width: 1280px;
    margin: 0 auto;
    padding: 80px 40px;
    text-align: center;
  }
  .get-started__title {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 36px;
    color: var(--lampFg);
    margin: 0 0 16px;
  }
  .get-started__sub { color: var(--lampFgMuted); margin: 0 0 36px; font-size: 15px; }
  .get-started__row { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 900px) {
    .lamp-hero { grid-template-columns: 1fr; gap: 48px; padding: 40px 24px 60px; }
    .lamp-family-name { font-size: 36px; }
    .lamp-tagline { font-size: 22px; }
    .collection-band__lockup { font-size: 48px; }
    .hot-sellers-grid { grid-template-columns: repeat(2,1fr); }
    .lamp-cta-row { flex-direction: column; }
    .lamp-cta { width: 100%; min-width: unset; }
    .collection-mark { font-size: 16px; top: 14px; right: 16px; }
    .lamp-hero__footer { flex-direction: column; gap: 24px; align-items: flex-start; }
    .certifications { gap: 16px; }
    .hot-sellers-grid { grid-template-columns: repeat(2,1fr); }
    .spec-section, .dimmers-section, .get-started { padding-inline: 24px; }
  }
  @media (max-width: 600px) {
    .hot-sellers-grid { grid-template-columns: 1fr 1fr; }
    .breadcrumb-band { padding: 10px 16px; }
  }
</style>

<!-- Breadcrumb (light chrome) -->
<nav class="breadcrumb-band" aria-label="breadcrumb">
  <a href="/">HOME</a>
  <span class="bc-sep">›</span>
  <a href="/products/">PRODUCTS</a>
  <span class="bc-sep">›</span>
  <a href="/products/lamps/">LAMPS</a>
  <span class="bc-sep">›</span>
  <a href={collectionHref} set:html={collectionLabelHtml}></a>
  <span class="bc-sep">›</span>
  <span class="bc-current">{f.name.toUpperCase()}</span>
</nav>

<!-- Lamp page — dark themed -->
<main class="lamp-page" data-aesthetic={f.collectionAesthetic} data-coming-soon={f.comingSoon ? 'true' : undefined}>

  <!-- Sub-breadcrumb in dark area -->
  <div class="lamp-subcrumb">
    <a href={collectionHref} set:html={f.collectionHeadlineLine}></a>
    <span class="sep">/</span>
    <span class="current">{f.name}</span>
  </div>

  <!-- Top-right collection logomark -->
  <div class="collection-mark" set:html={collectionMarkHtml}></div>

  <!-- HERO -->
  <section class="lamp-hero">
    <div class="lamp-hero__copy">
      <div class="lamp-hero__series-eyebrow" set:html={`${f.collectionName} · Series`}></div>
      <h1 class="lamp-family-name">
        {f.name}
        {f.comingSoon
          ? <span class="echelon-badge echelon-badge--soon">COMING SOON</span>
          : f.echelon
            ? <span class="echelon-badge echelon-badge--accent">{f.echelon}</span>
            : null
        }
      </h1>
      <h2 class="lamp-tagline">{f.tagline}</h2>
      <p class="lamp-description">{f.description}</p>

      <div class="lamp-keyspec">
        <span class="lamp-keyspec__item">
          <span class="lamp-keyspec__label">Input Watts:</span>{f.keySpecs.inputWatts}
        </span>
        <span class="lamp-keyspec__sep">|</span>
        <span class="lamp-keyspec__item">
          <span class="lamp-keyspec__label">Lumens:</span>{f.keySpecs.lumens}
        </span>
        <span class="lamp-keyspec__sep">|</span>
        <span class="lamp-keyspec__item">
          <span class="lamp-keyspec__label">lm/W:</span>{f.keySpecs.lmPerW}
        </span>
        <span class="lamp-keyspec__sep">|</span>
        <span class="lamp-keyspec__item">
          <span class="lamp-keyspec__label">CRI:</span>{f.keySpecs.cri}
        </span>
      </div>

      <div class="lamp-cta-row">
        <a href="#pricing" class={pricingClass}>Pricing &amp; Availability</a>
        {f.datasheetUrl
          ? <a href={f.datasheetUrl} class="lamp-cta lamp-cta--secondary" target="_blank" rel="noopener">Documentation Download</a>
          : <span class="lamp-cta lamp-cta--coming-soon">Documentation Download</span>
        }
      </div>
    </div>

    <div class="lamp-hero__subject">
      <div class="lamp-hero__watermark"></div>
      {f.heroImage
        ? <img src={f.heroImage} alt={`${f.name} product`} class="lamp-hero__product" loading="lazy" />
        : <div class="lamp-hero__product-placeholder">Family hero photography<br />placeholder<br /><br />(Rooster Creative deliverable)</div>
      }
    </div>
  </section>

  <!-- Hero footer — CRI badge + certifications -->
  <div class="lamp-hero__footer">
    <div class="cri-row">
      <div class="cri-badge">
        <div class="cri-badge__inner">
          <div class="cri-badge__num">{f.keySpecs.cri.replace(/[^0-9]/g, '').slice(0,2) || '80'}</div>
          <div class="cri-badge__lbl">CRI</div>
        </div>
      </div>
    </div>
    <div class="certifications">
      {f.certifications.map(cert => (
        <div class="cert">
          <div class={`cert__icon${cert.includes('UL') || cert.includes('DLC') || cert.includes('JA8') ? ' cert__icon--square' : ''}`}>
            {cert.includes('UL') ? 'UL' : cert.includes('FCC') ? 'FC' : cert.includes('RoHS') ? '✓' : cert.includes('DLC') ? 'DLC' : cert.includes('JA8') ? 'JA8' : cert.includes('Lead') ? 'PD' : cert.includes('Wet') ? '⛆' : cert.slice(0,2)}
          </div>
          {cert}
        </div>
      ))}
    </div>
  </div>

  <!-- Collection brand hero band -->
  <section class="collection-band">
    {f.collectionAesthetic === 'nostalgic'
      ? <div class="collection-band__bg collection-band__bg-grid" style={`background-image:var(--lampWatermarkUrl);background-size:100% auto;background-position:center bottom;background-repeat:no-repeat;opacity:0.5;`}></div>
      : f.collectionAesthetic === 'vintage'
        ? <div class="collection-band__bg" style={`background-image:${t.bandGlow};`}></div>
        : null
    }
    <div class="collection-band__lockup" set:html={bandLockupHtml}></div>
    <div class="collection-band__sub">DÉCOR LAMPS</div>
  </section>

  <!-- Specifications table -->
  <section class="spec-section" id="pricing">
    <div class="section-eyebrow">SPECIFICATIONS</div>
    <h2 class="section-title">Full SKU specifications.</h2>
    {f.comingSoon
      ? <p class="coming-soon-msg">SKUs coming soon. Subscribe for launch updates.</p>
      : (
        <table class="spec-table">
          <thead>
            <tr>
              <th>SKU Description</th>
              <th>Wattage</th>
              <th>CCT</th>
              <th>Finish / Style</th>
              <th>Voltage</th>
              <th>Dimmable</th>
            </tr>
          </thead>
          <tbody>
            {familySkus.length > 0
              ? familySkus.map((sku: any) => {
                // Parse Décor SKU string: "Décor | Shape | Finish | Wattage/CCT[/Style]"
                const parts = (sku.sku ?? '').split('|').map((p: string) => p.trim());
                const skuDesc = parts.slice(1).join(' · ') || sku.sku || '—';
                const wattage = sku.wattages?.[0] ? `${sku.wattages[0]}W` : (parts[3]?.match(/([\d.]+W)/)?.[1] ?? '—');
                const cct = parts[3]?.match(/(\d{4}K)/)?.[1] ?? (sku.ccts?.[0] ? `${sku.ccts[0]}K` : '—');
                const finish = parts[2] ?? '—';
                const style = parts[3]?.replace(/[\d.]+W\/\d{4}K\/?/, '').replace(/^\//, '') || '—';
                const finishStyle = style && style !== '—' ? `${finish} · ${style}` : finish;
                const voltage = sku.voltage || '120V';
                const dimmable = (sku.sku ?? '').includes('Non-Dimmable') ? 'No' : 'Yes';
                return (
                  <tr>
                    <td style="font-family:'JetBrains Mono','Courier New',monospace;font-size:11px;">{parts[1] ?? sku.sku}</td>
                    <td>{wattage}</td>
                    <td>{cct}</td>
                    <td>{finishStyle}</td>
                    <td>{voltage}</td>
                    <td>{dimmable}</td>
                  </tr>
                );
              })
              : <tr><td colspan="6" style="text-align:center;padding:32px;color:var(--lampFgMuted);font-size:12px;letter-spacing:0.05em;">LOADING SKU DATA</td></tr>
            }
          </tbody>
        </table>
      )
    }
  </section>

  <!-- Compatible Dimmers (omitted for coming-soon pages) -->
  {!f.comingSoon && f.compatibleDimmers && f.compatibleDimmers.length > 0 && (
    <section class="dimmers-section">
      <div class="section-eyebrow">DIMMER COMPATIBILITY</div>
      <h2 class="section-title">Compatible Dimmers</h2>
      <table class="dimmers-table">
        <thead>
          <tr><th>Brand</th><th>Models</th></tr>
        </thead>
        <tbody>
          {f.compatibleDimmers.map(d => (
            <tr>
              <td>{d.brand}</td>
              <td><div class="model-list">{d.models.map(m => <span>{m}</span>)}</div></td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <!-- Hot Sellers — sister families -->
  {siblingFamilies.length > 0 && (
    <section class="hot-sellers-section">
      <div class="section-eyebrow" style="max-width:1280px;margin:0 auto;">DON'T MISS THESE</div>
      <h2 class="section-title" style="max-width:1280px;margin:12px auto 0;">More from this collection.</h2>
      <div class="hot-sellers-grid">
        {siblingFamilies.map(s => (
          <a href={`/collections/${f.collectionSlug}/${s.slug}/`} class="sister-card">
            <div>
              <div class="sister-card__name">{s.name}</div>
            </div>
            <div class="sister-card__sku-count">
              {s.skuCount} SKUs <span class="sister-card__arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Get Started -->
  <section class="get-started">
    <h2 class="get-started__title">Ready to specify?</h2>
    <p class="get-started__sub">Layouts in under 48 hours. Samples shipped from US warehouses.</p>
    <div class="get-started__row">
      <a href="/layout/" class="lamp-cta lamp-cta--primary">Request Layout</a>
      <a href="/sample/" class="lamp-cta lamp-cta--secondary">Request Sample</a>
      <a href="/distributor/" class="lamp-cta lamp-cta--secondary">Find a Distributor</a>
      <a href="/rep/" class="lamp-cta lamp-cta--secondary">Find a Rep</a>
    </div>
  </section>

</main>
</BaseLayout>
