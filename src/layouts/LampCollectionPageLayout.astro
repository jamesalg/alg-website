---
/**
 * LampCollectionPageLayout.astro — v2.7.2
 * Rebuilt from mockup design language: Georgia serif, sister-card grid,
 * define:vars (no is:global), camelCase token names matching LampFamilyDetailPageLayout.
 */
import BaseLayout from './BaseLayout.astro';

export interface Props {
  collection: {
    slug: string;
    name: string;
    titleAscii: string;
    parentVertical: 'Indoor';
    parentSubVertical: string;
    headlineLine: string;
    description: string;
    pillRow: string[];
    aesthetic: 'vintage' | 'nostalgic' | 'utility';
    families: {
      slug: string;
      name: string;
      tagline: string;
      heroImage: string;
      echelon?: 'ECO' | 'PRO' | 'PRO+';
      skuCount: number;
      comingSoon?: boolean;
    }[];
    legacyFamilies?: {
      slug: string;
      name: string;
      tagline: string;
      heroImage: string;
      skuCount: number;
    }[];
    getStarted: {
      layoutCopy: string;
      sampleCopy: string;
      distributorCopy: string;
      repCopy: string;
    };
    relatedCollections: {
      slug: string;
      name: string;
      vertical: string;
      description: string;
      status: 'live' | 'coming-soon';
    }[];
  };
}

const { collection: c } = Astro.props;

const themes: Record<string, Record<string, string>> = {
  vintage: {
    lampBg: '#0c0d12',
    lampBgSoft: '#16171d',
    lampFg: '#f5e9d2',
    lampFgMuted: '#a8a094',
    lampFgDim: '#6b6760',
    lampAccent: '#c9a45c',
    lampBorder: 'rgba(245,233,210,0.12)',
    lampWatermarkUrl: "url('/lamps/scrollwork-vintage.svg')",
    lampBandBg: 'linear-gradient(135deg,#0c0d12 0%,#1a1610 50%,#0c0d12 100%)',
    lampBandTextShadow: '0 0 40px rgba(201,164,92,0.3)',
    lampHoverShadow: '0 8px 32px rgba(201,164,92,0.15)',
    lampCtaPrimary: '#F32740',
    lampCtaPrimaryHover: '#d61f37',
  },
  nostalgic: {
    lampBg: '#0a0d18',
    lampBgSoft: '#11142a',
    lampFg: '#e8eef8',
    lampFgMuted: '#8a92ad',
    lampFgDim: '#525a78',
    lampAccent: '#00d4ff',
    lampBorder: 'rgba(232,238,248,0.10)',
    lampWatermarkUrl: "url('/lamps/cybergrid-nostalgic.svg')",
    lampBandBg: 'linear-gradient(135deg,#0a0d18 0%,#0d1030 50%,#0a0d18 100%)',
    lampBandTextShadow: '0 0 60px rgba(0,212,255,0.4),0 0 120px rgba(255,45,208,0.2)',
    lampHoverShadow: '0 8px 32px rgba(0,212,255,0.15)',
    lampCtaPrimary: '#F32740',
    lampCtaPrimaryHover: '#d61f37',
  },
  utility: {
    lampBg: '#1a1d24',
    lampBgSoft: '#22262e',
    lampFg: '#ffffff',
    lampFgMuted: '#a8b0bc',
    lampFgDim: '#6a7280',
    lampAccent: '#F32740',
    lampBorder: 'rgba(255,255,255,0.08)',
    lampWatermarkUrl: 'none',
    lampBandBg: 'linear-gradient(135deg,#1a1d24 0%,#22262e 50%,#1a1d24 100%)',
    lampBandTextShadow: 'none',
    lampHoverShadow: '0 8px 32px rgba(243,39,64,0.15)',
    lampCtaPrimary: '#F32740',
    lampCtaPrimaryHover: '#d61f37',
  },
};

const t = themes[c.aesthetic] ?? themes.utility;

const collBandSub =
  c.slug === 'nostalgic-decor' ? 'DECOR LAMPS' :
  c.slug === 'vintage-decor' ? 'DECOR LAMPS' :
  c.slug === 'tubulararch' ? 'LINEAR FLUORESCENT' :
  c.slug === 'utility-signature' ? 'UTILITY LAMPS' :
  'LAMPS';
---
<BaseLayout title={`${c.titleAscii} | Archipelago Lighting Group`} description={c.description}>
<style define:vars={t}>
  .breadcrumb-band {
    background: #fff;
    padding: 14px 32px;
    font-size: 12px;
    letter-spacing: 0.08em;
    color: #666;
    text-transform: uppercase;
    border-bottom: 1px solid #e5e5e5;
    font-weight: 500;
  }
  .breadcrumb-band a { color: #666; text-decoration: none; }
  .breadcrumb-band a:hover { color: #F32740; }
  .breadcrumb-band .bc-sep { margin: 0 8px; color: #ccc; }
  .breadcrumb-band .bc-current { color: #000; }
  .lamp-page {
    background: var(--lampBg);
    color: var(--lampFg);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    -webkit-font-smoothing: antialiased;
    position: relative;
  }
  .lamp-page :global(.aa) { color: var(--lampAccent); }
  .lamp-subcrumb {
    padding: 16px 40px;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lampFgMuted);
    border-bottom: 1px solid var(--lampBorder);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    position: relative;
  }
  .lamp-subcrumb a { color: var(--lampFgMuted); text-decoration: none; }
  .lamp-subcrumb a:hover { color: var(--lampAccent); }
  .lamp-subcrumb .sc-sep { margin: 0 4px; color: var(--lampFgDim); }
  .lamp-subcrumb .current { color: var(--lampFg); font-weight: 600; }
  .collection-mark {
    position: absolute;
    top: 16px;
    right: 40px;
    text-align: right;
    z-index: 2;
  }
  .collection-mark__label {
    font-family: 'JetBrains Mono','Courier New',monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--lampFgDim);
    margin-bottom: 4px;
  }
  .collection-mark__name {
    font-family: Georgia,'Times New Roman',serif;
    font-size: 13px;
    font-style: italic;
    color: var(--lampAccent);
  }
  .lamp-hero {
    padding: 80px 40px 72px;
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
  }
  .lamp-hero__eyebrow {
    font-family: 'JetBrains Mono','Courier New',monospace;
    font-size: 11px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--lampAccent);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .lamp-hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 40px;
    height: 1px;
    background: var(--lampAccent);
    flex-shrink: 0;
  }
  .lamp-hero__headline {
    font-family: Georgia,'Times New Roman',serif;
    font-size: clamp(48px,7vw,96px);
    font-weight: normal;
    font-style: italic;
    letter-spacing: -0.02em;
    line-height: 0.95;
    color: var(--lampFg);
    margin: 0 0 28px;
    text-shadow: var(--lampBandTextShadow);
  }
  .lamp-hero__desc {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--lampFgMuted);
    max-width: 680px;
    margin-bottom: 32px;
  }
  .lamp-hero__pills { display: flex; flex-wrap: wrap; gap: 8px; }
  .lamp-hero__pill {
    font-family: 'JetBrains Mono','Courier New',monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lampFg);
    border: 1px solid var(--lampBorder);
    border-radius: 2px;
    padding: 6px 14px;
    white-space: nowrap;
  }
  .collection-band {
    background: var(--lampBandBg);
    border-top: 1px solid var(--lampBorder);
    border-bottom: 1px solid var(--lampBorder);
    padding: 56px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .collection-band__bg {
    position: absolute;
    inset: 0;
    background-image: var(--lampWatermarkUrl);
    background-size: 600px auto;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0.06;
    pointer-events: none;
  }
  .collection-band > * { position: relative; z-index: 1; }
  .collection-band__lockup {
    font-family: Georgia,'Times New Roman',serif;
    font-size: clamp(32px,5vw,64px);
    font-style: italic;
    color: var(--lampFg);
    letter-spacing: -0.01em;
    text-shadow: var(--lampBandTextShadow);
    margin-bottom: 8px;
  }
  .collection-band__sub {
    font-family: 'JetBrains Mono','Courier New',monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--lampFgDim);
  }
  .family-grid-section {
    background: var(--lampBgSoft);
    padding: 80px 40px 100px;
    border-top: 1px solid var(--lampBorder);
  }
  .family-grid-section__eyebrow {
    font-family: 'JetBrains Mono','Courier New',monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--lampAccent);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
  }
  .family-grid-section__eyebrow::before {
    content: '';
    display: inline-block;
    width: 64px;
    height: 1.5px;
    background: var(--lampAccent);
    flex-shrink: 0;
  }
  .family-grid-section__headline {
    font-family: Georgia,'Times New Roman',serif;
    font-size: clamp(22px,2.8vw,32px);
    font-style: italic;
    color: var(--lampFg);
    margin: 0 0 40px;
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
  }
  .family-grid {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 20px;
  }
  .sister-card {
    background: var(--lampBg);
    border: 1px solid var(--lampBorder);
    padding: 28px 24px;
    text-decoration: none;
    color: var(--lampFg);
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
    aspect-ratio: 1/1;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }
  .sister-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--lampWatermarkUrl);
    background-size: 200% auto;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0.12;
    pointer-events: none;
  }
  .sister-card:hover:not(.sister-card--soon) {
    border-color: var(--lampAccent);
    transform: translateY(-2px);
    box-shadow: var(--lampHoverShadow);
  }
  .sister-card--soon { opacity: 0.4; pointer-events: none; cursor: default; }
  .sister-card__name {
    font-family: Georgia,'Times New Roman',serif;
    font-size: 28px;
    color: var(--lampFg);
    position: relative;
    line-height: 1.1;
  }
  .sister-card__tagline {
    font-size: 12px;
    line-height: 1.5;
    color: var(--lampFgMuted);
    position: relative;
    margin-top: 8px;
  }
  .sister-card__sku-count {
    font-family: 'JetBrains Mono','Courier New',monospace;
    font-size: 11px;
    color: var(--lampFgMuted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    position: relative;
  }
  .sister-card__arrow { color: var(--lampAccent); margin-left: 4px; }
  .sister-card__soon-badge {
    font-family: 'JetBrains Mono','Courier New',monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #888;
    border: 1px solid #444;
    border-radius: 2px;
    padding: 3px 8px;
    display: inline-block;
    margin-top: 4px;
  }
  .get-started {
    max-width: 1280px;
    margin: 0 auto;
    padding: 80px 40px;
    text-align: center;
  }
  .get-started__eyebrow {
    font-family: 'JetBrains Mono','Courier New',monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--lampAccent);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }
  .get-started__eyebrow::before,
  .get-started__eyebrow::after {
    content: '';
    display: inline-block;
    width: 40px;
    height: 1px;
    background: var(--lampAccent);
    flex-shrink: 0;
  }
  .get-started__headline {
    font-family: Georgia,'Times New Roman',serif;
    font-size: clamp(20px,2.5vw,28px);
    font-style: italic;
    color: var(--lampFg);
    margin: 0 0 40px;
  }
  .get-started__grid {
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 16px;
    text-align: left;
  }
  .get-started__card {
    background: var(--lampBgSoft);
    border: 1px solid var(--lampBorder);
    padding: 24px;
    border-radius: 4px;
  }
  .get-started__card-label {
    font-family: 'JetBrains Mono','Courier New',monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lampAccent);
    margin-bottom: 10px;
  }
  .get-started__card-copy { font-size: 13px; line-height: 1.55; color: var(--lampFgMuted); }
  .get-started__cta {
    display: inline-block;
    margin-top: 12px;
    font-family: 'JetBrains Mono','Courier New',monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lampCtaPrimary);
    text-decoration: none;
    border-bottom: 1px solid var(--lampCtaPrimary);
    padding-bottom: 2px;
  }
  .get-started__cta:hover { color: var(--lampCtaPrimaryHover); border-color: var(--lampCtaPrimaryHover); }
  .related-collections {
    background: var(--lampBgSoft);
    border-top: 1px solid var(--lampBorder);
    padding: 64px 40px 80px;
  }
  .related-collections__inner { max-width: 1280px; margin: 0 auto; }
  .related-collections__eyebrow {
    font-family: 'JetBrains Mono','Courier New',monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--lampAccent);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .related-collections__eyebrow::before {
    content: '';
    display: inline-block;
    width: 64px;
    height: 1.5px;
    background: var(--lampAccent);
    flex-shrink: 0;
  }
  .related-collections__headline {
    font-family: Georgia,'Times New Roman',serif;
    font-size: clamp(20px,2.5vw,28px);
    font-style: italic;
    color: var(--lampFg);
    margin: 0 0 32px;
  }
  .related-collections__grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
  .related-card {
    background: var(--lampBg);
    border: 1px solid var(--lampBorder);
    padding: 24px;
    text-decoration: none;
    color: var(--lampFg);
    transition: border-color 0.2s ease;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .related-card:hover { border-color: var(--lampAccent); }
  .related-card__vertical {
    font-family: 'JetBrains Mono','Courier New',monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lampFgDim);
  }
  .related-card__name { font-family: Georgia,'Times New Roman',serif; font-size: 18px; font-style: italic; color: var(--lampFg); }
  .related-card__desc { font-size: 12px; line-height: 1.5; color: var(--lampFgMuted); }
  .related-card__arrow { font-size: 12px; color: var(--lampAccent); margin-top: auto; }
  @media (max-width: 1024px) {
    .family-grid { grid-template-columns: repeat(3,1fr); }
    .get-started__grid { grid-template-columns: repeat(2,1fr); }
    .related-collections__grid { grid-template-columns: repeat(2,1fr); }
  }
  @media (max-width: 768px) {
    .lamp-hero { padding: 48px 24px 40px; }
    .family-grid-section { padding: 48px 24px 64px; }
    .family-grid { grid-template-columns: repeat(2,1fr); }
    .get-started { padding: 48px 24px; }
    .get-started__grid { grid-template-columns: 1fr; }
    .related-collections { padding: 40px 24px 56px; }
    .related-collections__grid { grid-template-columns: 1fr; }
    .breadcrumb-band { padding: 12px 20px; }
    .lamp-subcrumb { padding: 12px 24px; }
    .collection-mark { display: none; }
    .collection-band { padding: 40px 24px; }
  }
  @media (max-width: 480px) {
    .family-grid { grid-template-columns: 1fr 1fr; }
    .sister-card { padding: 20px 16px; }
    .sister-card__name { font-size: 22px; }
  }
</style>

<nav class="breadcrumb-band" aria-label="Breadcrumb">
  <a href="/">HOME</a>
  <span class="bc-sep">&#x203A;</span>
  <a href="/collections/">PRODUCTS</a>
  <span class="bc-sep">&#x203A;</span>
  <a href="/collections/">{c.parentSubVertical.toUpperCase()}</a>
  <span class="bc-sep">&#x203A;</span>
  <span class="bc-current" set:html={c.titleAscii}></span>
</nav>

<div class="lamp-page">
  <nav class="lamp-subcrumb" aria-label="Collection navigation">
    <a href="/collections/">Collections</a>
    <span class="sc-sep">&#x203A;</span>
    <span class="current" set:html={c.headlineLine}></span>
  </nav>

  <div class="collection-mark" aria-hidden="true">
    <div class="collection-mark__label">Collection</div>
    <div class="collection-mark__name" set:html={c.headlineLine}></div>
  </div>

  <section class="lamp-hero" aria-labelledby="lamp-hero-headline">
    <div class="lamp-hero__eyebrow">{c.parentSubVertical.toUpperCase()}</div>
    <h1 class="lamp-hero__headline" id="lamp-hero-headline" set:html={c.headlineLine}></h1>
    <p class="lamp-hero__desc">{c.description}</p>
    {c.pillRow && c.pillRow.length > 0 && (
      <div class="lamp-hero__pills">
        {c.pillRow.map((pill: string) => (
          <span class="lamp-hero__pill">{pill}</span>
        ))}
      </div>
    )}
  </section>

  <div class="collection-band" aria-hidden="true">
    <div class="collection-band__bg"></div>
    <div class="collection-band__lockup" set:html={c.headlineLine}></div>
    <div class="collection-band__sub">{collBandSub}</div>
  </div>

  <section class="family-grid-section" aria-labelledby="family-grid-headline">
    <div class="family-grid-section__eyebrow">Shape Families</div>
    <h2 class="family-grid-section__headline" id="family-grid-headline">Select a family to explore SKUs</h2>
    <div class="family-grid">
      {c.families.map((fam: any) => (
        fam.comingSoon
          ? (
            <div class="sister-card sister-card--soon" aria-label={`${fam.name} — coming soon`}>
              <div class="sister-card__name">{fam.name}</div>
              <div>
                <div class="sister-card__sku-count">Coming soon</div>
                <span class="sister-card__soon-badge">Coming Soon</span>
              </div>
            </div>
          )
          : (
            <a href={`/collections/${c.slug}/${fam.slug}/`} class="sister-card">
              <div class="sister-card__name">{fam.name}</div>
              {fam.tagline && <div class="sister-card__tagline">{fam.tagline}</div>}
              <div class="sister-card__sku-count">
                {fam.skuCount} SKUs <span class="sister-card__arrow">&#x2192;</span>
              </div>
            </a>
          )
      ))}
    </div>
  </section>

  <section class="get-started" aria-labelledby="get-started-headline">
    <div class="get-started__eyebrow">Get Started</div>
    <h2 class="get-started__headline" id="get-started-headline">Ready to specify?</h2>
    <div class="get-started__grid">
      <div class="get-started__card">
        <div class="get-started__card-label">Request a Sample</div>
        <p class="get-started__card-copy" set:html={c.getStarted.sampleCopy}></p>
        <a href="/contact/" class="get-started__cta">Request Sample &#x2192;</a>
      </div>
      <div class="get-started__card">
        <div class="get-started__card-label">Find a Distributor</div>
        <p class="get-started__card-copy" set:html={c.getStarted.distributorCopy}></p>
        <a href="/contact/" class="get-started__cta">Find Distributor &#x2192;</a>
      </div>
      <div class="get-started__card">
        <div class="get-started__card-label">Find a Rep</div>
        <p class="get-started__card-copy" set:html={c.getStarted.repCopy}></p>
        <a href="/contact/" class="get-started__cta">Find Rep &#x2192;</a>
      </div>
      <div class="get-started__card">
        <div class="get-started__card-label">Planogram Layout</div>
        <p class="get-started__card-copy" set:html={c.getStarted.layoutCopy}></p>
        <a href="/contact/" class="get-started__cta">Download Layout &#x2192;</a>
      </div>
    </div>
  </section>

  {c.relatedCollections && c.relatedCollections.length > 0 && (
    <section class="related-collections" aria-labelledby="related-headline">
      <div class="related-collections__inner">
        <div class="related-collections__eyebrow">Related Collections</div>
        <h2 class="related-collections__headline" id="related-headline">Explore more from Archipelago</h2>
        <div class="related-collections__grid">
          {c.relatedCollections.map((rc: any) => (
            <a href={`/collections/${rc.slug}/`} class="related-card">
              <div class="related-card__vertical">{rc.vertical}</div>
              <div class="related-card__name" set:html={rc.name}></div>
              <p class="related-card__desc">{rc.description}</p>
              <div class="related-card__arrow">&#x2192;</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</div>
</BaseLayout>
