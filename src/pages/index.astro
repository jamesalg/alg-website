---
/**
 * Homepage — v2.1.0 full implementation.
 *
 * Sections (per Playbook v2.0 §5 and v3.14.x reference):
 *   1. Hero carousel (4 slides, auto-advance 7s, pause on hover)
 *   2. Trust bar (5 trust signals)
 *   3. Category tease (Indoor / Outdoor / Controls & EM)
 *   4. Locator map (Leaflet, 6 warehouse pins)
 *   5. Featured Families (4 product family cards)
 *   6. Layout CTA (48-hour turnaround)
 *   7. Installed At (8 vertical tiles — 3 placeholders for missing assets)
 *   8. Split teasers (Rebate + Specifier)
 *   [Footer CTA strip and Footer are in Footer.astro]
 *
 * Asset notes:
 *   - vertical-coldstorage, vertical-datacenter, vertical-hospitality: MISSING
 *     rendered as placeholder tiles per Playbook §5.3
 *   - mega-tubularch.jpg: MISSING — placeholder in MegaMenu.astro
 *
 * Verify rules: B.1 (no naked Ⓐ), C.1 (no accreditation), C.2 (no CLEARANCE),
 *               D.1 (no [object Object]), D.2 (<title> set), D.3 (meta description set)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandMark from '../components/BrandMark.astro';

const heroSlides = [
  {
    id: 0,
    img: '/images/heroes/hero-illuminator-stadium.jpg',
    imgAlt: 'Illuminator sports lighter installed in a stadium',
    eyebrow: 'Commercial & Industrial · DLC Premium',
    headline: 'Illuminator',
    subhead: 'Premier sports lighter. Up to 115,000 lumens. 160 lm/W. DLC Premium. Ready for broadcast-grade venues.',
    stat1: { value: '115,000', label: 'Max lumens' },
    stat2: { value: '160 lm/W', label: 'Efficacy' },
    stat3: { value: '10 yr', label: 'Warranty' },
    ctaPrimary: { label: 'Request Spec', href: '/resources/spec-sheets' },
    ctaSecondary: { label: 'Learn more', href: '/collections/indoor-industrial' }
  },
  {
    id: 1,
    img: '/images/heroes/hero-warehouse-highbay.jpg',
    imgAlt: 'Titan-II linear high-bay in a warehouse',
    eyebrow: 'Warehouse & Logistics · DLC Premium',
    headline: 'Titan-II',
    subhead: 'Linear high-bay for warehouses and industrial interiors. 3–55W. DLC Premium, built-in 6kVA surge protection.',
    stat1: { value: '20', label: 'Active SKUs' },
    stat2: { value: '155 lm/W', label: 'Efficacy' },
    stat3: { value: '10 yr', label: 'Warranty' },
    ctaPrimary: { label: 'Request Spec', href: '/resources/spec-sheets' },
    ctaSecondary: { label: 'Learn more', href: '/collections/indoor-industrial' }
  },
  {
    id: 2,
    img: '/images/heroes/hero-outdoor-area.jpg',
    imgAlt: 'luxoARCH area luminaire on a parking lot',
    eyebrow: 'Outdoor C&I · DLC Premium',
    headline: 'luxoARCH',
    subhead: 'Full-cutoff area luminaire for parking lots, roadways, and site lighting. Utility rebate qualified.',
    stat1: { value: '18', label: 'Active SKUs' },
    stat2: { value: '145 lm/W', label: 'Efficacy' },
    stat3: { value: '5 yr', label: 'Warranty' },
    ctaPrimary: { label: 'Request Spec', href: '/resources/spec-sheets' },
    ctaSecondary: { label: 'Learn more', href: '/collections/outdoor-ci' }
  },
  {
    id: 3,
    img: '/images/heroes/hero-controls-panel.jpg',
    imgAlt: 'ACS connected systems control panel',
    eyebrow: 'Controls & EM · NLC-Ready',
    headline: 'ACS',
    subhead: 'NLC-ready sensors and controls for every ARCH fixture. Occupancy, daylight harvesting, emergency backup.',
    stat1: { value: '9', label: 'Active SKUs' },
    stat2: { value: 'NLC', label: 'Certified' },
    stat3: { value: '5 yr', label: 'Warranty' },
    ctaPrimary: { label: 'Request Spec', href: '/resources/spec-sheets' },
    ctaSecondary: { label: 'Learn more', href: '/collections/controls-em' }
  }
];

const categories = [
  {
    title: 'Indoor Luminaires',
    href: '/collections/indoor-industrial',
    desc: 'High-bay, low-bay, troffer, and strip fixtures. This catalog delivers high-lm/W for the specifier\'s bid sheet, the distributor\'s floor, and the contractor\'s truck.',
    img: '/images/heroes/hero-warehouse-highbay.jpg',
    imgAlt: 'Indoor luminaires in a warehouse',
    families: ['Titan-II', 'Astra', 'Illuminator']
  },
  {
    title: 'Outdoor Luminaires',
    href: '/collections/outdoor-ci',
    desc: 'Parking lots to area lights, canopy to flood. Designed for specifiers, stocked for distributors, and ready for every US climate.',
    img: '/images/heroes/hero-outdoor-area.jpg',
    imgAlt: 'Outdoor area luminaires in a parking lot',
    families: ['luxoARCH', 'cityARCH', 'Canopy']
  },
  {
    title: 'Controls & EM',
    href: '/collections/controls-em',
    desc: 'NLC-ready sensors, networked controls, and emergency battery backup. One ecosystem — every ARCH fixture.',
    img: '/images/heroes/hero-controls-panel.jpg',
    imgAlt: 'Controls and emergency lighting panel',
    families: ['ACS', 'constANT', 'contrALS']
  }
];

const families = [
  {
    slug: 'illuminator',
    name: 'Illuminator',
    eyebrow: 'luxoARCH · PRO',
    badge: 'DLC PREMIUM',
    badgeVariant: 'premium',
    desc: 'Sports lighter · stadiums + athletic fields',
    skus: 11,
    img: '/images/families/family-illuminator.png',
    imgAlt: 'Illuminator sports lighter',
    bg: 'light',
    href: '/collections/indoor-industrial'
  },
  {
    slug: 'titan',
    name: 'Titan-II',
    eyebrow: 'lamparARCH · PRO',
    badge: 'DLC PREMIUM',
    badgeVariant: 'premium',
    desc: 'Linear high-bay · warehouse + industrial',
    skus: 20,
    img: '/images/families/family-titan.png',
    imgAlt: 'Titan-II linear high-bay',
    bg: 'dark',
    href: '/collections/indoor-industrial'
  },
  {
    slug: 'astra',
    name: 'Astra',
    eyebrow: 'planoARCH · PRO+',
    badge: 'DLC PREMIUM',
    badgeVariant: 'premium',
    desc: 'Commercial downlight · retail + hospitality',
    skus: 18,
    img: '/images/families/family-astra.png',
    imgAlt: 'Astra commercial downlight',
    bg: 'brand',
    href: '/collections/indoor-industrial'
  },
  {
    slug: 'contrals',
    name: 'Connected Systems',
    eyebrow: 'contrALS · BY ACS',
    badge: 'NLC-READY',
    badgeVariant: 'nlc',
    desc: 'NLC-ready sensors + controls · every ARCH fixture',
    skus: 9,
    img: '/images/families/family-contrals.png',
    imgAlt: 'Connected systems sensor',
    bg: 'dark',
    href: '/collections/controls-em'
  }
];

const verticals = [
  { title: 'Warehouse & Logistics',      sub: '3PL facility · OH',      img: '/images/verticals/vertical-warehouse.jpg',     href: '/solutions/warehouse-logistics' },
  { title: 'Industrial & Manufacturing', sub: 'Auto plant · TX',         img: '/images/verticals/vertical-manufacturing.jpg', href: '/solutions/industrial-manufacturing' },
  { title: 'Cold Storage & Grocery',     sub: 'Freezer DC · CA',         img: null,                                           href: '/solutions/cold-storage-grocery' },
  { title: 'Data Center',               sub: 'Hyperscale · VA',          img: null,                                           href: '/solutions/data-center' },
  { title: 'Healthcare',                sub: 'Outpatient · IL',          img: '/images/verticals/vertical-healthcare.jpg',    href: '/solutions/healthcare' },
  { title: 'Education',                 sub: 'K-12 retrofit · NJ',       img: '/images/verticals/vertical-education.jpg',     href: '/solutions/education' },
  { title: 'Hospitality',               sub: 'Hotel reno · MA',          img: null,                                           href: '/solutions/hospitality' },
  { title: 'Government & Military',     sub: 'Federal logistics · GA',   img: '/images/verticals/vertical-government.jpg',    href: '/solutions/government-military' }
];
---

<BaseLayout
  title="Archipelago Lighting Group — Specified. Stocked. Shipped."
  description="Commercial and industrial LED lighting. 2,000+ active SKUs. Five US warehouses. Layouts in under 48 hours."
  bodyClass="page-home"
>

  <!-- ==============================================================
       1. HERO CAROUSEL
       ============================================================== -->
  <section class="hero-section" aria-label="Featured products">
    <div class="hero-carousel" id="heroCarousel">

      {heroSlides.map((slide, i) => (
        <img
          class={`hero-image${i === 0 ? ' active' : ''}`}
          src={slide.img}
          alt={slide.imgAlt}
          data-slide={i}
          width="1280"
          height="720"
          loading={i === 0 ? 'eager' : 'lazy'}
        />
      ))}

      <div class="hero-panel">
        <div class="hero-panel-inner">

          <div class="slot" id="slotEyebrow">
            {heroSlides.map((slide, i) => (
              <p class={`slot-content hero-eyebrow${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                {slide.eyebrow}
              </p>
            ))}
          </div>

          <div class="slot" id="slotHeadline">
            {heroSlides.map((slide, i) => (
              <h2 class={`slot-content hero-headline${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                {slide.headline}
              </h2>
            ))}
          </div>

          <div class="slot" id="slotSubhead">
            {heroSlides.map((slide, i) => (
              <p class={`slot-content hero-subhead${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                {slide.subhead}
              </p>
            ))}
          </div>

          <div class="slot" id="slotStats">
            {heroSlides.map((slide, i) => (
              <div class={`slot-content hero-stats${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                <div class="hero-stat">
                  <span class="hero-stat-value">{slide.stat1.value}</span>
                  <span class="hero-stat-label">{slide.stat1.label}</span>
                </div>
                <div class="hero-stat">
                  <span class="hero-stat-value">{slide.stat2.value}</span>
                  <span class="hero-stat-label">{slide.stat2.label}</span>
                </div>
                <div class="hero-stat">
                  <span class="hero-stat-value">{slide.stat3.value}</span>
                  <span class="hero-stat-label">{slide.stat3.label}</span>
                </div>
              </div>
            ))}
          </div>

          <div class="slot" id="slotCtas">
            {heroSlides.map((slide, i) => (
              <div class={`slot-content hero-ctas${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                <a href={slide.ctaPrimary.href} class="btn btn--primary hero-cta-primary">{slide.ctaPrimary.label}</a>
                <a href={slide.ctaSecondary.href} class="hero-cta-secondary">{slide.ctaSecondary.label} &rsaquo;</a>
              </div>
            ))}
          </div>

          <div class="hero-controls">
            <button class="hero-prev" id="prevBtn" aria-label="Previous slide">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <div class="hero-dots" role="tablist" aria-label="Slide navigation">
              {heroSlides.map((_, i) => (
                <button
                  class={`carousel-dot${i === 0 ? ' active' : ''}`}
                  role="tab"
                  aria-selected={i === 0 ? 'true' : 'false'}
                  aria-label={`Slide ${i + 1}`}
                  data-dot={i}
                ></button>
              ))}
            </div>
            <button class="hero-next" id="nextBtn" aria-label="Next slide">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <span class="hero-counter" id="carouselCounter" aria-live="polite" aria-atomic="true">01 / 04</span>
          </div>

        </div>
      </div>

      <div class="hero-overlay-text">
        <p class="hero-overlay-eyebrow">Commercial &amp; Industrial · DLC Premium</p>
        <h1 class="hero-overlay-headline">
          Specified.<br>
          Stocked.<br>
          <span class="hero-overlay-accent">Shipped.</span>
        </h1>
        <p class="hero-overlay-sub">Five US warehouses. 2,000+ active SKUs. Layouts in under 48 hours.</p>
      </div>

    </div>
  </section>

  <!-- ==============================================================
       2. TRUST BAR
       ============================================================== -->
  <section class="trust-bar" aria-label="Trust signals">
    <div class="trust-bar-inner">
      <div class="trust-item">
        <img src="/brand/alg-brandmark-red.png" alt="ALG" width="24" height="24" loading="lazy" />
        <span class="trust-label">ALG</span>
      </div>
      <div class="trust-divider" aria-hidden="true"></div>
      <div class="trust-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span class="trust-label">USA</span>
      </div>
      <div class="trust-divider" aria-hidden="true"></div>
      <div class="trust-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span class="trust-label">UL Listed</span>
      </div>
      <div class="trust-divider" aria-hidden="true"></div>
      <div class="trust-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="trust-label">3–10 yr Warranty</span>
      </div>
      <div class="trust-divider" aria-hidden="true"></div>
      <div class="trust-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <span class="trust-label">3-Day Ship</span>
      </div>
    </div>
  </section>

  <!-- ==============================================================
       3. CATEGORY TEASE
       ============================================================== -->
  <section class="section section--soft category-section" aria-labelledby="cat-heading">
    <div class="container">
      <h2 id="cat-heading" class="section-headline">
        Lighting that <em>specifies</em>, stocks, and ships.
      </h2>
      <p class="section-subhead">
        From warehouse high-bays to parking-lot area lights. From emergency backup to
        commercial controls — built for the specifier's bid sheet, the distributor's floor,
        and the contractor's truck.
      </p>
      <div class="category-grid">
        {categories.map(cat => (
          <a href={cat.href} class="category-card">
            <div class="category-card-img">
              <img src={cat.img} alt={cat.imgAlt} width="400" height="260" loading="lazy" />
            </div>
            <div class="category-card-body">
              <h3 class="category-card-title">{cat.title}</h3>
              <p class="category-card-desc">{cat.desc}</p>
              <div class="category-card-families">
                {cat.families.map(f => (
                  <span class="family-chip">{f}</span>
                ))}
              </div>
              <span class="category-card-cta">Browse collection &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==============================================================
       4. LOCATOR MAP
       ============================================================== -->
  <section class="section locator-section" aria-labelledby="locator-heading">
    <div class="container">
      <div class="locator-header">
        <div class="locator-header-text">
          <p class="section-eyebrow">FIND ALG NEAR YOU</p>
          <h2 id="locator-heading">
            One map. <span class="text-accent">Three ways to find us.</span>
          </h2>
          <p class="section-subhead">
            Your local team has stocking distributors, and ALG warehouses — all on one
            map. Search by ZIP, city, or state. Coverage in every US region.
          </p>
        </div>
        <div class="locator-legend">
          <div class="legend-item">
            <span class="legend-dot legend-dot--wh"></span>
            <span>ALG Warehouse</span>
          </div>
          <div class="legend-item">
            <span class="legend-dot legend-dot--rep"></span>
            <span>Sales Rep</span>
          </div>
          <div class="legend-item">
            <span class="legend-dot legend-dot--dist"></span>
            <span>Stocking Distributor</span>
          </div>
        </div>
      </div>

      <div class="locator-map-wrap">
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
        <div id="algLocatorMap" class="locator-map" aria-label="ALG warehouse and distributor locator map" role="application"></div>
      </div>

      <div class="locator-actions">
        <a href="/find-a-rep" class="btn btn--ghost locator-btn-ghost">Find a Rep</a>
        <a href="/distributor" class="btn btn--ghost locator-btn-ghost">Become a Distributor</a>
        <a href="/find-a-rep" class="btn btn--primary">Apply as Sales Rep</a>
      </div>
    </div>
  </section>

  <!-- ==============================================================
       5. FEATURED FAMILIES
       ============================================================== -->
  <section class="section section--soft families-section" aria-labelledby="families-heading">
    <div class="container">
      <p class="section-eyebrow">FEATURED FAMILIES</p>
      <h2 id="families-heading">
        The families distributors stock<br>and specifiers spec.
      </h2>
      <p class="section-subhead">
        <BrandMark prefix="plano" suffix="RCH" /> families are the connected-systems platform that ties them together
        — the core of our 2,000+ active SKU catalog.
      </p>
      <div class="families-grid">
        {families.map(fam => (
          <a href={fam.href} class={`family-card family-card--${fam.bg}`} aria-label={`${fam.name} — ${fam.desc}`}>
            <div class="family-card-badge-wrap">
              <span class={`family-badge family-badge--${fam.badgeVariant}`}>{fam.badge}</span>
            </div>
            <div class="family-card-img">
              <img src={fam.img} alt={fam.imgAlt} width="320" height="240" loading="lazy" />
            </div>
            <div class="family-card-body">
              <p class="family-card-eyebrow">{fam.eyebrow}</p>
              <h3 class="family-card-name">{fam.name}</h3>
              <p class="family-card-desc">{fam.desc}</p>
              <div class="family-card-footer">
                <span class="family-card-skus">{fam.skus} SKUs</span>
                <span class="family-card-link">VIEW &rarr;</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==============================================================
       6. LAYOUT CTA
       ============================================================== -->
  <section class="layout-cta-section" aria-labelledby="layout-heading">
    <div class="layout-cta-inner">
      <div class="layout-cta-text">
        <p class="section-eyebrow layout-eyebrow">PHOTOMETRIC LAYOUT</p>
        <h2 id="layout-heading">
          Get a lighting layout in<br>
          <span class="text-accent">under 48hrs.</span>
        </h2>
        <p class="layout-cta-body">
          Every layout comes from a photometric expert with platform-grade precision.
          Provide the space with product selection or let us recommend — fixture count,
          layout, and lux levels included.
        </p>
        <ul class="layout-checklist" role="list">
          <li>Photometric calculations per IES standard</li>
          <li>Product selection with short-list options</li>
          <li>Fixture count + BOM</li>
        </ul>
        <div class="layout-cta-actions">
          <a href="/support/layout-request" class="btn btn--primary">Request a Layout</a>
          <a href="/resources/sell-sheets" class="layout-sample-link">See sample layouts (PDF+) &rsaquo;</a>
        </div>
      </div>
      <div class="layout-cta-visual" aria-hidden="true">
        <div class="layout-grid-mock">
          {Array.from({ length: 16 }, (_, i) => (
            <div class={`layout-grid-cell${i % 2 === 0 ? ' layout-grid-cell--lit' : ''}`}></div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================================================
       7. INSTALLED AT
       ============================================================== -->
  <section class="section installed-section" aria-labelledby="installed-heading">
    <div class="container">
      <p class="section-eyebrow">INSTALLED AT</p>
      <h2 id="installed-heading">
        Where ALG lighting goes to <span class="text-accent">work.</span>
      </h2>
      <p class="section-subhead">
        From cold storage in Cincinnati to a stadium retrofit in Sacramento — real
        installations, real results.
      </p>
      <div class="verticals-grid">
        {verticals.map(v => (
          <a href={v.href} class="vertical-tile" aria-label={`${v.title} — ${v.sub}`}>
            {v.img
              ? <img src={v.img} alt={v.title} width="320" height="240" loading="lazy" />
              : <div class="vertical-placeholder">
                  <span class="placeholder-label">Photography pending</span>
                </div>
            }
            <div class="vertical-overlay">
              <h3 class="vertical-title">{v.title}</h3>
              <p class="vertical-sub">{v.sub}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==============================================================
       8. SPLIT TEASERS
       ============================================================== -->
  <section class="section section--soft split-section" aria-label="Rebate and specifier resources">
    <div class="container">
      <div class="split-grid">

        <div class="split-card">
          <p class="section-eyebrow">UTILITY REBATES</p>
          <h2 class="split-card-headline">
            Most projects qualify for utility rebates.
          </h2>
          <p class="split-card-body">
            Search by ZIP-mapped rebate library. ALG-stocked family SKUs often return
            40–90% of project cost in qualifying utility incentives.
          </p>
          <div class="split-stat-row">
            <div class="split-stat">
              <span class="split-stat-value">2,400+</span>
              <span class="split-stat-label">Qualifying SKUs</span>
            </div>
            <div class="split-stat">
              <span class="split-stat-value">$0.10–0.30</span>
              <span class="split-stat-label">Per kWh saved</span>
            </div>
          </div>
          <a href="/resources/rebate-center" class="btn btn--primary">Find Rebates &rarr;</a>
        </div>

        <div class="split-card">
          <p class="section-eyebrow">SPECIFIER RESOURCES</p>
          <h2 class="split-card-headline">
            Spec sheets, IES files, training.
          </h2>
          <p class="split-card-body">
            Everything you need for the bid sheet — and the lunch-and-learn for your team.
          </p>
          <div class="spec-resource-grid">
            <a href="/resources/ies-files" class="spec-res-item">IES Photometric Library <span class="arr">&rarr;</span></a>
            <a href="/resources/spec-sheets" class="spec-res-item">Resource Library <span class="arr">&rarr;</span></a>
            <a href="/resources/sell-sheets" class="spec-res-item">TAA Documentation <span class="arr">&rarr;</span></a>
            <a href="/resources/catalog" class="spec-res-item">Training Center <span class="arr">&rarr;</span></a>
          </div>
