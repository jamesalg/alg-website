---
/**
 * Homepage — v2.1.0 (revision 2 — fixes per rejection notes 2026-04-25)
 *
 * Sections:
 *   1. Hero carousel (4 slides, slot-cycling right panel, 7s auto-advance)
 *   2. Differentiation strip (6 trust signals — matches reference diff-strip)
 *   3. Persona segmenter (NEW — "I am a…" pill strip)
 *   4. Category tease / "What we make" (3 cards, BrandMark stems)
 *   5. Locator map (Leaflet, 5 warehouse pins)
 *   6. Featured Families (4 cards, BrandMark stems, locked SKU counts from reference)
 *   7. Layout CTA (4-item checklist, stat overlay)
 *   8. Installed At (8 vertical tiles — 3 CSS-only placeholders for missing assets)
 *   9. Split teasers (Rebate + Specifier)
 *
 * SKU counts (locked from reference v3.14.x): Illuminator 11 · Titan-II 20 · Astra 18 · Connected Systems 9
 * Brand-mark rule: every Ⓐ in body content MUST be inside .aa span (via BrandMark or manual span).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandMark from '../components/BrandMark.astro';

const heroSlides = [
  {
    id: 0,
    bgClass: 'img-illuminator',
    eyebrow: 'Featured · Sports Lighting · LSPL',
    name: 'Illuminator',
    gradClass: 'grad-slide0',
    desc: 'Precision sports lighter. Up to 116,000 lumens. 150 lm/W. DLC Premium listed for broadcast-grade venues.',
    stats: [
      { num: '116,000', lbl: 'Max Lumens' },
      { num: '150 lm/W', lbl: 'Efficacy' },
      { num: '10 yr', lbl: 'Warranty' },
    ],
    brandMark: null,
  },
  {
    id: 1,
    bgClass: 'img-titan',
    eyebrow: 'Featured · High-Bay · LLHB',
    name: 'Titan-II',
    gradClass: 'grad-slide1',
    desc: 'Linear high-bay for warehouses and industrial interiors. 3-WATTselect 85/130/155W. DLC Premium, built-in 6kVA surge.',
    stats: [
      { num: '155 W', lbl: 'Max Wattage' },
      { num: '150+ lm/W', lbl: 'Efficacy' },
      { num: '90x90', lbl: 'Distribution' },
    ],
    brandMark: null,
  },
  {
    id: 2,
    bgClass: 'img-outdoor',
    eyebrow: 'Featured · Area Lighting · LSBX',
    name: 'Liberty',
    gradClass: 'grad-slide2',
    desc: null,
    stats: [
      { num: 'Type III/IV/V', lbl: 'Optics' },
      { num: '150 lm/W', lbl: 'Efficacy' },
      { num: '10 kVA', lbl: 'SPD' },
    ],
    brandMark: null,
  },
  {
    id: 3,
    bgClass: 'img-proarch',
    eyebrow: 'Featured · Back-Lit Panel · LBLP',
    name: null,
    gradClass: 'grad-slide3',
    desc: 'Back-lit panel for offices, classrooms, and commercial interiors. 5-WATTselect x 5-CCTselect across 1x4 / 2x2 / 2x4 form factors. TAA Compliant.',
    stats: [
      { num: '20 – 50 W', lbl: 'WATTselect' },
      { num: '2700 – 5000K', lbl: 'CCTselect' },
      { num: 'TAA', lbl: 'Compliant' },
    ],
    brandMark: 'proarch',
  },
];

const diffSignals = [
  { num: '5',      lbl: 'US Warehouses',    svg: '<path d="M3 7l9-4 9 4v10l-9 4-9-4V7z"/><path d="M3 7l9 4 9-4M12 11v10"/>' },
  { num: 'DLC',   lbl: 'Premium Listed',    svg: '<circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/>' },
  { num: 'USA',   lbl: 'TAA Compliant',     svg: '<path d="M3 12h18M12 3v18M3 6h18M3 18h18"/>' },
  { num: 'UL',    lbl: 'Listed & Tested',   svg: '<path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/>' },
  { num: '3–10 yr', lbl: 'Tiered Warranty', svg: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>' },
  { num: '3-Day', lbl: 'US Shipping',       svg: '<path d="M3 9l4-6h10l4 6M3 9v9a2 2 0 002 2h14a2 2 0 002-2V9M3 9h18M9 14h6"/>' },
];

const verticals = [
  { cls: 't1', vert: 'Warehouse & Logistics',      place: '3PL facility · OH',      hasImg: true },
  { cls: 't2', vert: 'Industrial & Manufacturing', place: 'Auto plant · TX',         hasImg: true },
  { cls: 't3', vert: 'Cold Storage & Grocery',     place: 'Freezer DC · CA',         hasImg: false },
  { cls: 't4', vert: 'Data Center',                place: 'Hyperscale · VA',          hasImg: false },
  { cls: 't5', vert: 'Healthcare',                 place: 'Outpatient · IL',          hasImg: true },
  { cls: 't6', vert: 'Education',                  place: 'K-12 retrofit · NJ',       hasImg: true },
  { cls: 't7', vert: 'Hospitality',                place: 'Hotel reno · MA',           hasImg: false },
  { cls: 't8', vert: 'Government & Military',      place: 'Federal logistics · GA',    hasImg: true },
];
---
<BaseLayout
  title="Archipelago Lighting Group — Specified. Stocked. Shipped."
  description="Commercial and industrial LED lighting. 2,000+ active SKUs. Five US warehouses. Layouts in under 48 hours."
  bodyClass="page-home"
>

  <!-- ==============================================================
       1. HERO CAROUSEL
       ============================================================== -->
  <section class="hero-carousel" id="heroCarousel" aria-label="Featured products">
    <div class="hero-carousel-inner">

      <!-- LEFT: Application image layer (cycles) -->
      <div class="hero-image-stage">
        {heroSlides.map((slide, i) => (
          <div class={`hero-image ${slide.bgClass}${i === 0 ? ' active' : ''}`} data-slide={i}></div>
        ))}
        <!-- Persistent overlay — stays fixed across all slides -->
        <div class="hero-persistent">
          <span class="p-eyebrow">Commercial &amp; Industrial · DLC Premium</span>
          <h1>
            Specified.<br />
            Stocked.<span class="stop">.</span><br />
            <span class="accent">Shipped.</span>
          </h1>
          <p class="tag">Five US warehouses. 2,000+ active SKUs. Layouts in under 48 hours.</p>
        </div>
      </div>

      <!-- RIGHT: Content panel (slot-cycling) -->
      <div class="hero-panel">
        <div class="hero-panel-inner">
          <div class="slide-label">
            <span class="slide-num" id="slideNum">01</span> / 04 · Now shipping
          </div>

          <div class="slot-stack">
            <!-- EYEBROW SLOT -->
            <div class="slot slot-eyebrow">
              {heroSlides.map((slide, i) => (
                <div class={`slot-content${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                  <span class="eyebrow">{slide.eyebrow}</span>
                </div>
              ))}
            </div>

            <!-- PRODUCT NAME SLOT -->
            <div class="slot slot-name">
              {heroSlides.map((slide, i) => (
                <div class={`slot-content${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                  {slide.brandMark === 'proarch'
                    ? <h2 class={`display-product ${slide.gradClass}`}>pro<span class="aa">Ⓐ</span>RCH-III</h2>
                    : <h2 class={`display-product ${slide.gradClass}`}>{slide.name}</h2>
                  }
                </div>
              ))}
            </div>

            <!-- DESCRIPTION SLOT -->
            <div class="slot slot-desc">
              {heroSlides.map((slide, i) => (
                <div class={`slot-content${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                  {slide.id === 2
                    ? <p>Commercial area lighting for parking, campuses, and outdoor grounds. Type III/IV/V optics. surge<span class="aa">Ⓐ</span>RMOR built in.</p>
                    : <p>{slide.desc}</p>
                  }
                </div>
              ))}
            </div>

            <!-- STATS SLOT -->
            <div class="slot slot-stats">
              {heroSlides.map((slide, i) => (
                <div class={`slot-content${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                  <div class="stat-row">
                    {slide.stats.map(s => (
                      <div class="stat">
                        <div class="stat-num">{s.num}</div>
                        <div class="stat-lbl">{s.lbl}</div>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>

            <!-- CTA SLOT -->
            <div class="slot slot-cta">
              {heroSlides.map((_, i) => (
                <div class={`slot-content${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                  <div class="cta-pair">
                    <a href="/resources/spec-sheets" class="cta-primary">Download Spec</a>
                    <a href="/collections" class="cta-link">Learn more ›</a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Carousel controls -->
    <div class="carousel-controls">
      <div class="carousel-dots">
        {heroSlides.map((slide, i) => (
          <button
            class={`carousel-dot${i === 0 ? ' active' : ''}`}
            data-slide-to={i}
            aria-label={slide.name ?? 'Slide'}
          ></button>
        ))}
      </div>
      <div class="carousel-arrows">
        <span class="carousel-counter" id="carouselCounter">01 / 04</span>
        <button class="carousel-arrow" id="prevBtn" aria-label="Previous slide">
          <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 1L3 7l6 6"/></svg>
        </button>
        <button class="carousel-arrow" id="nextBtn" aria-label="Next slide">
          <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 1l6 6-6 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ==============================================================
       2. DIFFERENTIATION STRIP (6 trust signals)
       ============================================================== -->
  <div class="diff-strip" aria-label="Trust signals">
    <div class="diff-inner">
      {diffSignals.map(sig => (
        <div class="diff-item">
          <div class="diff-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" set:html={sig.svg} aria-hidden="true"></svg>
          </div>
          <div class="diff-text">
            <div class="diff-num">{sig.num}</div>
            <div class="diff-lbl">{sig.lbl}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- ==============================================================
       3. PERSONA SEGMENTER
       ============================================================== -->
  <div class="persona-strip" aria-label="Persona selector">
    <div class="persona-inner">
      <span class="persona-label">I am a…</span>
      <div class="persona-chips">
        <a href="/distributor" class="persona-chip active" data-persona="distributor">Distributor</a>
        <button class="persona-chip" data-persona="specifier" title="Coming soon">Specifier / Engineer</button>
        <button class="persona-chip" data-persona="contractor" title="Coming soon">Contractor</button>
        <button class="persona-chip" data-persona="esco" title="Coming soon">ESCO</button>
        <button class="persona-chip" data-persona="facility-manager" title="Coming soon">Facility Manager</button>
      </div>
    </div>
  </div>

  <!-- ==============================================================
       4. WHAT WE MAKE — Category tease (3 cards)
       ============================================================== -->
  <section class="content-section" aria-labelledby="wm-heading">
    <div class="section-inner">
      <div class="sec-eyebrow">What we make</div>
      <h2 id="wm-heading" class="sec-title">Lighting that <span class="accent">specifies</span>, stocks, and ships.</h2>
      <p class="sec-sub">From warehouse high-bays to parking-lot area lights, from emergency backup to networked controls — built for the specifier's bid sheet, the distributor's floor, and the contractor's truck.</p>
      <div class="what-we-make">
        <a href="/collections/indoor" class="wm-card indoor">
          <div class="wm-img"></div>
          <div class="wm-body">
            <h3>Indoor Luminaires</h3>
            <p>Troffers, panels, high-bays, downlights. The catalog distributors stock and specifiers spec.</p>
            <div class="wm-meta">
              <span class="wm-sub-brands"><BrandMark prefix="lampar" suffix="RCH" /> · <BrandMark prefix="plano" suffix="RCH" /></span>
              <span class="wm-arrow">Browse →</span>
            </div>
          </div>
        </a>
        <a href="/collections/outdoor" class="wm-card outdoor">
          <div class="wm-img"></div>
          <div class="wm-body">
            <h3>Outdoor Luminaires</h3>
            <p>Wall packs, parking-lot area lights, canopy, floods, and bollards. Built for the elements.</p>
            <div class="wm-meta">
              <span class="wm-sub-brands"><BrandMark prefix="city" suffix="RCH" /> · <BrandMark prefix="luxo" suffix="RCH" /></span>
              <span class="wm-arrow">Browse →</span>
            </div>
          </div>
        </a>
        <a href="/collections/controls-em" class="wm-card controls">
          <div class="wm-img"></div>
          <div class="wm-body">
            <h3>Controls &amp; EM</h3>
            <p><BrandMark prefix="contr" suffix="LS" /> three-tier (ECO · PRO · PRO+) and <BrandMark prefix="const" suffix="NT" /> emergency drivers and egress / exit signs.</p>
            <div class="wm-meta">
              <span class="wm-sub-brands"><BrandMark prefix="contr" suffix="LS" /> · <BrandMark prefix="const" suffix="NT" /></span>
              <span class="wm-arrow">Browse →</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ==============================================================
       5. LOCATOR MAP
       ============================================================== -->
  <section class="locator-section" aria-labelledby="loc-heading">
    <div class="locator-inner">
      <div class="sec-eyebrow">Find your local support</div>
      <h2 id="loc-heading" class="sec-title">One map. <span class="accent">Three ways to find us.</span></h2>
      <p class="sec-sub">Your local sales rep, nearest stocking distributor, and ALG warehouse — all on one map. Search by ZIP, city, or state.</p>
      <div class="locator-toolbar">
        <div class="loc-filter-group">
          <span class="loc-filter-label">Show:</span>
          <span class="loc-pill active" data-filter="all">All</span>
          <span class="loc-pill" data-filter="warehouse">
            <span class="kind-dot wh"></span>Warehouses <span class="loc-count">(5)</span>
          </span>
          <span class="loc-pill" data-filter="rep">
            <span class="kind-dot rep"></span>Sales Reps
          </span>
          <span class="loc-pill" data-filter="dist">
            <span class="kind-dot dist"></span>Distributors
          </span>
        </div>
        <div class="loc-search-group">
          <input type="text" class="loc-search-input" placeholder="ZIP, city, or state" aria-label="Search by ZIP, city, or state" />
          <button class="loc-search-btn">Find Nearest</button>
        </div>
      </div>
      <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
      <div id="algLocatorMap" class="locator-map" aria-label="ALG warehouse and distributor locator map" role="application"></div>
      <div class="locator-actions">
        <a href="/find-a-rep" class="loc-action-link">Find a Rep or Distributor</a>
        <a href="/distributor" class="loc-action-link">Become a Distributor</a>
        <a href="/careers/sales-rep" class="loc-action-link">Apply as Sales Rep</a>
      </div>
    </div>
  </section>

  <!-- ==============================================================
       6. FEATURED FAMILIES (4 cards — locked SKU counts from reference)
       ============================================================== -->
  <section class="content-section" aria-labelledby="fam-heading">
    <div class="section-inner">
      <div class="sec-eyebrow">Featured families</div>
      <h2 id="fam-heading" class="sec-title">The families distributors stock and specifiers spec.</h2>
      <p class="sec-sub">Three fixture families plus the connected systems platform that ties them together — the core of our 2,000+ active SKU catalog.</p>
      <div class="families-rail">
        <a href="/collections/indoor-industrial" class="fam-card">
          <div class="fam-img cream">
            <span class="fam-tag">DLC Premium</span>
            <img class="fam-product" src="/images/families/family-illuminator.png" alt="Illuminator sports lighter" width="320" height="240" loading="lazy" />
          </div>
          <div class="fam-body">
            <div class="fam-eyebrow"><BrandMark prefix="luxo" suffix="RCH" /> · PRO</div>
            <div class="fam-name">Illuminator</div>
            <div class="fam-desc">Sports lighter · stadiums + athletic fields</div>
            <div class="fam-meta"><span class="fam-skucount">11 SKUs</span><span class="fam-arrow">View →</span></div>
          </div>
        </a>
        <a href="/collections/indoor-industrial" class="fam-card">
          <div class="fam-img dk">
            <span class="fam-tag">DLC Premium</span>
            <img class="fam-product" src="/images/families/family-titan.png" alt="Titan-II linear high-bay LED luminaire" width="320" height="240" loading="lazy" />
          </div>
          <div class="fam-body">
            <div class="fam-eyebrow"><BrandMark prefix="lampar" suffix="RCH" /> · PRO</div>
            <div class="fam-name">Titan-II</div>
            <div class="fam-desc">Linear high-bay · warehouse + industrial</div>
            <div class="fam-meta"><span class="fam-skucount">20 SKUs</span><span class="fam-arrow">View →</span></div>
          </div>
        </a>
        <a href="/collections/indoor-industrial" class="fam-card">
          <div class="fam-img brand">
            <span class="fam-tag">DLC Premium</span>
            <img class="fam-product" src="/images/families/family-astra.png" alt="Astra commercial downlight with white trim and chrome reflector" width="320" height="240" loading="lazy" />
          </div>
          <div class="fam-body">
            <div class="fam-eyebrow"><BrandMark prefix="plano" suffix="RCH" /> · PRO+</div>
            <div class="fam-name">Astra</div>
            <div class="fam-desc">Commercial downlight · retail + hospitality</div>
            <div class="fam-meta"><span class="fam-skucount">18 SKUs</span><span class="fam-arrow">View →</span></div>
          </div>
        </a>
        <a href="/collections/controls-em" class="fam-card">
          <div class="fam-img dark2">
            <span class="fam-tag">NLC-Ready</span>
            <img class="fam-product" src="/images/families/family-contrals.png" alt="contrALS outdoor PIR occupancy sensor and controller pair" width="320" height="240" loading="lazy" />
          </div>
          <div class="fam-body">
            <div class="fam-eyebrow"><BrandMark prefix="contr" suffix="LS" /> · by <BrandMark prefix="" suffix="CS" /></div>
            <div class="fam-name">Connected Systems</div>
            <div class="fam-desc">NLC-ready sensors + controls · every <span class="aa">Ⓐ</span>RCH fixture</div>
            <div class="fam-meta"><span class="fam-skucount">9 SKUs</span><span class="fam-arrow">View →</span></div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ==============================================================
       7. LAYOUT CTA
       ============================================================== -->
  <section class="layout-cta" aria-labelledby="lc-heading">
    <div class="layout-cta-inner">
      <div>
        <div class="sec-eyebrow">Free professional service</div>
        <h2 id="lc-heading">Get a lighting layout in <span class="accent">under 48hrs.</span></h2>
        <p>Send us your floor plan. Our layout team returns a photometric layout with product callouts, IES files, fixture counts, and footcandle calculations — at no cost.</p>
        <div class="layout-features">
          <div class="lf-item"><span class="lf-check">&#10003;</span> Photometric calculations per IES standards</div>
          <div class="lf-item"><span class="lf-check">&#10003;</span> Product callouts with exact SKUs</div>
          <div class="lf-item"><span class="lf-check">&#10003;</span> IES files included</div>
          <div class="lf-item"><span class="lf-check">&#10003;</span> Fixture count + BOM</div>
        </div>
        <div class="layout-cta-actions">
          <a href="/support/layout-request" class="cta-primary">Request a Layout</a>
          <a href="/resources/sample-layouts" class="cta-secondary on-dark">See Sample Layouts (100+)</a>
        </div>
      </div>
      <div class="layout-visual" aria-hidden="true">
        <div class="lv-grid">
          <div class="lv-cell bright"></div><div class="lv-cell bright"></div><div class="lv-cell med"></div><div class="lv-cell med"></div><div class="lv-cell dim"></div><div class="lv-cell dim"></div><div class="lv-cell"></div><div class="lv-cell"></div>
          <div class="lv-cell bright"></div><div class="lv-cell fix"></div><div class="lv-cell bright"></div><div class="lv-cell med"></div><div class="lv-cell dim"></div><div class="lv-cell dim"></div><div class="lv-cell"></div><div class="lv-cell"></div>
          <div class="lv-cell med"></div><div class="lv-cell bright"></div><div class="lv-cell bright"></div><div class="lv-cell med"></div><div class="lv-cell dim"></div><div class="lv-cell"></div><div class="lv-cell"></div><div class="lv-cell"></div>
          <div class="lv-cell med"></div><div class="lv-cell med"></div><div class="lv-cell fix"></div><div class="lv-cell bright"></div><div class="lv-cell med"></div><div class="lv-cell dim"></div><div class="lv-cell"></div><div class="lv-cell"></div>
          <div class="lv-cell dim"></div><div class="lv-cell dim"></div><div class="lv-cell bright"></div><div class="lv-cell bright"></div><div class="lv-cell med"></div><div class="lv-cell dim"></div><div class="lv-cell"></div><div class="lv-cell"></div>
          <div class="lv-cell"></div><div class="lv-cell dim"></div><div class="lv-cell med"></div><div class="lv-cell med"></div><div class="lv-cell dim"></div><div class="lv-cell"></div><div class="lv-cell"></div><div class="lv-cell"></div>
        </div>
        <div class="lv-overlay">90 fc avg · 0.65 uniformity</div>
      </div>
    </div>
  </section>

  <!-- ==============================================================
       8. INSTALLED AT — 8 vertical tiles
       ============================================================== -->
  <section class="content-section" aria-labelledby="inst-heading">
    <div class="section-inner">
      <div class="sec-eyebrow">Installed at</div>
      <h2 id="inst-heading" class="sec-title">Where ALG lighting goes to <span class="accent">work.</span></h2>
      <p class="sec-sub">From cold storage in Cincinnati to a stadium retrofit in Sacramento — real installations, real results.</p>
      <div class="installed-grid">
        {verticals.map(v => (
          <div class={`installed-tile ${v.cls}${!v.hasImg ? ' placeholder' : ''}`}>
            <div class="installed-label">
              <div class="il-vert">{v.vert}</div>
              <div class="il-place">{v.place}</div>
              {!v.hasImg && <div class="placeholder-tag">Photography pending</div>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==============================================================
       9. SPLIT TEASERS — Rebate + Specifier
       ============================================================== -->
  <section class="content-section" aria-label="Rebate and specifier resources">
    <div class="section-inner">
      <div class="split-teasers">
        <div class="teaser teaser-rebate">
          <div class="sec-eyebrow">Find your rebate</div>
          <h3>Most projects qualify for utility rebates.</h3>
          <p>Search by ZIP and product family. Rebates can offset 15–40% of project cost in qualifying utilities.</p>
          <div class="rebate-stat">
            <div>
              <div class="rebate-stat-num">2,400+</div>
              <div class="rebate-stat-lbl">Active utility programs</div>
            </div>
            <div>
              <div class="rebate-stat-num">$0.10-0.30</div>
              <div class="rebate-stat-lbl">Per sqft typical</div>
            </div>
          </div>
          <a href="/resources/rebate-center" class="cta-primary">Open Rebate Center</a>
        </div>
        <div class="teaser teaser-spec">
          <div class="sec-eyebrow">For specifiers</div>
          <h3>Spec sheets, IES files, training.</h3>
          <p>Everything you need for the bid sheet — and the lunch-and-learn for your team.</p>
          <div class="spec-resource-grid">
