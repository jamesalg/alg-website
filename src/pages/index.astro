<script>
  /* ============================================================
     HERO CAROUSEL
     ============================================================ */
  (function () {
    const carousel = document.getElementById('heroCarousel');
    if (!carousel) return;

    const images = carousel.querySelectorAll('.hero-image') as NodeListOf<HTMLElement>;
    const dots = carousel.querySelectorAll('.carousel-dot') as NodeListOf<HTMLButtonElement>;
    const slotStacks = carousel.querySelectorAll('.slot') as NodeListOf<HTMLElement>;
    const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement | null;
    const counter = document.getElementById('carouselCounter');

    const TOTAL = 4;
    const AUTO_MS = 7000;
    let current = 0;
    let timer: number | null = null;

    function setActive(n: number) {
      if (n === current) return;
      current = ((n % TOTAL) + TOTAL) % TOTAL;

      images.forEach((img, i) => img.classList.toggle('active', i === current));

      slotStacks.forEach(stack => {
        const contents = stack.querySelectorAll('.slot-content') as NodeListOf<HTMLElement>;
        contents.forEach(c => c.classList.remove('active'));
        const incoming = stack.querySelector(`.slot-content[data-slot-slide="${current}"]`) as HTMLElement | null;
        if (incoming) requestAnimationFrame(() => incoming.classList.add('active'));
      });

      dots.forEach((d, i) => {
        d.classList.toggle('active', i === current);
        d.setAttribute('aria-selected', String(i === current));
      });

      if (counter) {
        const pad = String(current + 1).padStart(2, '0');
        counter.textContent = `${pad} / 04`;
      }
    }

    function next() { setActive(current + 1); }
    function prev() { setActive(current - 1); }
    function start() { stop(); timer = window.setInterval(next, AUTO_MS); }
    function stop() { if (timer !== null) { clearInterval(timer); timer = null; } }

    prevBtn?.addEventListener('click', () => { prev(); start(); });
    nextBtn?.addEventListener('click', () => { next(); start(); });
    dots.forEach((dot, i) => dot.addEventListener('click', () => { setActive(i); start(); }));

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft') { prev(); start(); }
      if (e.key === 'ArrowRight') { next(); start(); }
    });

    carousel.addEventListener('mouseenter', stop);
    carousel.addEventListener('mouseleave', start);

    start();
  })();

  /* ============================================================
     LEAFLET MAP
     ============================================================ */
  (function () {
    const el = document.getElementById('algLocatorMap');
    if (!el) return;

    const script = document.createElement('script');
    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    script.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';
    script.crossOrigin = '';
    script.onload = function () {
      const L = (window as any).L;
      if (!L) return;

      const map = L.map('algLocatorMap', {
        center: [39.5, -96.5],
        zoom: 4,
        scrollWheelZoom: false,
        zoomControl: true,
        attributionControl: true
      });

      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 19
      }).addTo(map);

      const whIcon = L.divIcon({
        className: 'alg-pin-wh',
        html: '<span style="display:block;width:14px;height:14px;border-radius:50%;background:#C8102E;border:2px solid rgba(12,13,18,0.85);box-shadow:0 0 0 4px rgba(200,16,46,0.25),0 0 14px rgba(200,16,46,0.5);"></span>',
        iconSize: [18, 18],
        iconAnchor: [9, 9]
      });

      const warehouses = [
        { name: 'Montclair, CA',   lat: 34.0776, lng: -117.6897, address: '4615 State Street, Montclair CA' },
        { name: 'Riverside, CA',   lat: 33.9213, lng: -117.3517, address: '9345 Sycamore Canyon Blvd, Riverside CA 92508' },
        { name: 'Crestwood, IL',   lat: 41.6647, lng:  -87.7372, address: 'Crestwood, IL' },
        { name: 'Rahway, NJ',      lat: 40.6082, lng:  -74.2776, address: 'Rahway, NJ' },
        { name: 'Brockton, MA',    lat: 42.0834, lng:  -71.0184, address: 'Brockton, MA' },
        { name: 'Cincinnati, OH',  lat: 39.1031, lng:  -84.5120, address: 'Cincinnati, OH' }
      ];

      warehouses.forEach(wh => {
        L.marker([wh.lat, wh.lng], { icon: whIcon, title: wh.name })
          .bindPopup(`<strong>${wh.name}</strong><br>${wh.address}`)
          .addTo(map);
      });
    };
    document.head.appendChild(script);
  })();
</script>
