---
/**
 * Homepage — v2.1.0 (revision 2 — fixes per rejection notes 2026-04-25)
 *
 * Sections:
 *   1. Hero carousel (4 slides, slot-cycling right panel, 7s auto-advance)
 *   2. Differentiation strip (6 trust signals — matches reference diff-strip)
 *   3. Persona segmenter (NEW — "I am a…" pill strip)
 *   4. Category tease / "What we make" (3 cards, BrandMark stems)
 *   5. Locator map (Leaflet, 5 warehouse pins)
 *   6. Featured Families (4 cards, BrandMark stems, locked SKU counts from reference)
 *   7. Layout CTA (4-item checklist, stat overlay)
 *   8. Installed At (8 vertical tiles — 3 CSS-only placeholders for missing assets)
 *   9. Split teasers (Rebate + Specifier)
 *
 * SKU counts (locked from reference v3.14.x): Illuminator 11 · Titan-II 20 · Astra 18 · Connected Systems 9
 * Brand-mark rule: every Ⓐ in body content MUST be inside .aa span (via BrandMark or manual span).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandMark from '../components/BrandMark.astro';

const heroSlides = [
  {
    // SKU basis: LSPL-xxx series (Illuminator sports lighter, peak 116klm config)
    id: 0,
    bgClass: 'img-illuminator',
    eyebrow: 'Featured · Sports Lighting · LSPL',
    name: 'Illuminator',
    gradClass: 'grad-slide0',
    seriesNameColor: '#a8c8e8', // C1: stadium blue-white — matches sports lighting field bg (kept for fallback)
    // D (v2.5.5): multi-color gradient sampled from hero-illuminator-stadium.jpg
    // Hues: cool slate sky → bright stadium-light white → warm amber spill → lit-field green
    seriesNameGradient: 'linear-gradient(95deg, #7b9ec8 0%, #c8dff0 28%, #f5f0e8 55%, #d4e8a0 80%, #a8c870 100%)',
    desc: 'Precision sports lighter. Up to 116,000 lumens. 150 lm/W. DLC Premium listed for broadcast-grade venues.',
    lineDrawing: '/images/heroes/line-drawings/line-illuminator.png',
    stats: [
      { num: '<span class="uptotag">Up to</span><span style="white-space:nowrap">116,000</span>', lbl: 'Peak Lumens', hasBrandMark: true },
      { num: '<span style="white-space:nowrap">150 lm/W</span>', lbl: 'DLC Premium Efficacy', hasBrandMark: true },
      { num: '<span style="white-space:nowrap">10-Year</span>', lbl: 'Tiered Warranty', hasBrandMark: true },
    ],
    brandMark: null,
  },
  {
    // SKU basis: LLHB-xxx series (Titan-II linear high-bay, 155W peak config)
    id: 1,
    bgClass: 'img-titan',
    eyebrow: 'Featured · High-Bay · LLHB',
    name: 'Titan-II',
    gradClass: 'grad-slide1',
    seriesNameColor: '#f0c070', // C1: warm amber — matches warehouse/industrial warm tone (kept for fallback)
    // D (v2.5.5): multi-color gradient sampled from hero-warehouse-highbay.jpg
    // Hues: steel blue-grey ceiling → warm industrial amber → orange forklift accent
    seriesNameGradient: 'linear-gradient(95deg, #98b0c8 0%, #c8b890 35%, #f0c070 65%, #e87830 100%)',
    desc: 'Linear high-bay for warehouses and industrial interiors. Up to 155W. 3-step WATTselect (85/130/155W). DLC Premium, built-in 6kVA surge.',
    lineDrawing: '/images/heroes/line-drawings/line-titan.png',
    stats: [
      { num: '<span style="white-space:nowrap">3-Step</span>', lbl: 'WATTselect', hasBrandMark: true },
      { num: '<span style="white-space:nowrap">150+ lm/W</span>', lbl: 'DLC Premium', hasBrandMark: true },
      { num: '<span style="white-space:nowrap">90×90</span>', lbl: 'Photometric', hasBrandMark: true },
    ],
    brandMark: null,
  },
  {
    // SKU basis: LSBX-xxx series (Liberty area luminaire, full optic + SPD config)
    id: 2,
    bgClass: 'img-outdoor',
    eyebrow: 'Featured · Area Lighting · LSBX',
    name: 'Liberty',
    gradClass: 'grad-slide2',
    seriesNameColor: '#c9a876', // C1: warm amber-gold — matches outdoor area lighting dusk hue (kept for fallback)
    // D (v2.5.5): multi-color gradient sampled from hero-outdoor-area.jpg
    // Hues: warm sunset orange → rose-mauve horizon → deep sky blue → cool steel blue
    seriesNameGradient: 'linear-gradient(95deg, #f0a050 0%, #e87880 28%, #9878c0 55%, #6a8cb2 80%, #4890d0 100%)',
    lineDrawingClass: 'liberty-render', // C2: -20% size
    desc: null,
    lineDrawing: '/images/heroes/line-drawings/line-liberty.png',
    stats: [
      { num: 'proⒶPTICS', lbl: 'Type III · IV · V', hasBrandMark: true },
      { num: '150 lm/W', lbl: 'DLC Premium' },
      { num: 'surgeⒶRMOR', lbl: '10 kVA SPD', hasBrandMark: true },
    ],
    brandMark: null,
  },
  {
    // SKU basis: LBLP-xxx series (proⒶRCH-III back-lit panel, 5×5 matrix config)
    id: 3,
    bgClass: 'img-proarch',
    eyebrow: 'Featured · Back-Lit Panel · LBLP',
    name: null,
    gradClass: 'grad-slide3',
    seriesNameColor: '#e8d8b0', // C1: warm office white — matches back-lit panel warm CCT (kept for fallback)
    // D (v2.5.5): multi-color gradient sampled from hero-commercial-office.jpg
    // Hues: warm walnut amber → cool grey-blue glass → soft tungsten cream
    seriesNameGradient: 'linear-gradient(95deg, #c89060 0%, #d0b890 30%, #a8b8c8 60%, #e8d8b0 100%)',
    desc: 'Back-lit panel for offices, classrooms, and commercial interiors. Up to 5×5 WATTselect/CCTselect matrix. 1×4 · 2×2 · 2×4.',
    lineDrawing: '/images/heroes/line-drawings/line-panel.png',
    stats: [
      { num: '<span style="white-space:nowrap">5-Step</span>', lbl: 'WATTselect', hasBrandMark: true },
      { num: '<span style="white-space:nowrap">5-Step</span>', lbl: 'CCTselect', hasBrandMark: true },
      { num: 'TAA', lbl: 'Compliant' },
    ],
    brandMark: 'proarch',
  },
];

const diffSignals = [
  { num: '5',      lbl: 'US Warehouses',    svg: '<path d="M3 7l9-4 9 4v10l-9 4-9-4V7z"/><path d="M3 7l9 4 9-4M12 11v10"/>' },
  { num: 'DLC',   lbl: 'Premium Listed',    svg: '<circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/>' },
  { num: 'USA',   lbl: 'TAA Compliant',     svg: '<path d="M3 12h18M12 3v18M3 6h18M3 18h18"/>' },
  { num: 'UL',    lbl: 'Listed & Tested',   svg: '<path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/>' },
  { num: '3–10 yr', lbl: 'Tiered Warranty', svg: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>' },
  { num: '3-Day', lbl: 'US Shipping',       svg: '<path d="M3 9l4-6h10l4 6M3 9v9a2 2 0 002 2h14a2 2 0 002-2V9M3 9h18M9 14h6"/>' },
];

const verticals = [
  { cls: 't1', vert: 'Warehouse & Logistics',      place: '3PL facility · OH',      hasImg: true },
  { cls: 't2', vert: 'Industrial & Manufacturing', place: 'Auto plant · TX',         hasImg: true },
  { cls: 't3', vert: 'Cold Storage & Grocery',     place: 'Freezer DC · CA',         hasImg: true },
  { cls: 't4', vert: 'Data Center',                place: 'Hyperscale · VA',          hasImg: true },
  { cls: 't5', vert: 'Healthcare',                 place: 'Outpatient · IL',          hasImg: true },
  { cls: 't6', vert: 'Education',                  place: 'K-12 retrofit · NJ',       hasImg: true },
  { cls: 't7', vert: 'Hospitality',                place: 'Hotel reno · MA',           hasImg: true },
  { cls: 't8', vert: 'Government & Military',      place: 'Federal logistics · GA',    hasImg: true },
];
---
<BaseLayout
  title="Archipelago Lighting Group — Specified. Stocked. Shipped."
  description="Commercial and industrial LED lighting. 2,000+ active SKUs. Five US warehouses. Layouts in under 48 hours."
  bodyClass="page-home"
>

  <!-- ==============================================================
       1. HERO CAROUSEL
       ============================================================== -->
  <section class="hero-carousel" id="heroCarousel" aria-label="Featured products">
    <div class="hero-carousel-inner">

      <!-- LEFT: Application image layer (cycles) -->
      <div class="hero-image-stage">
        {heroSlides.map((slide, i) => (
          <div class={`hero-image ${slide.bgClass}${i === 0 ? ' active' : ''}`} data-slide={i}></div>
        ))}
        <!-- Persistent overlay — stays fixed across all slides -->
        <div class="hero-persistent">
          <span class="p-eyebrow">Commercial &amp; Industrial · DLC Premium</span>
          <h1>
            Specified<span class="period-red">.</span><br />
            Stocked<span class="period-red">.</span><br />
            <span class="accent">Shipped<span class="period-red">.</span></span>
          </h1>
          <p class="tag">Five US warehouses. 2,000+ active SKUs. Layouts in under 48 hours.</p>
        </div>
      </div>

      <!-- RIGHT: Content panel (slot-cycling) -->
      <div class="hero-panel">
        <div class="hero-panel-inner">
          <div class="slide-label">
            <span class="slide-num" id="slideNum">01</span> / 04 · Now shipping
          </div>

          <div class="slot-stack">
            <!-- EYEBROW SLOT -->
            <div class="slot slot-eyebrow">
              {heroSlides.map((slide, i) => (
                <div class={`slot-content${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                  <span class="eyebrow">{slide.eyebrow}</span>
                </div>
              ))}
            </div>

            <!-- PRODUCT NAME SLOT -->
            <div class="slot slot-name">
              {heroSlides.map((slide, i) => (
                <div class={`slot-content${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                  {slide.brandMark === 'proarch'
                    ? <h2 class="display-product display-product--proarch">
                        {/* A1 fix (v2.5.6): gradient on text parts, brand-red on Ⓐ — never transparent on .aa span */}
                        <span class="dp-text" style={slide.seriesNameGradient
                          ? `background: ${slide.seriesNameGradient}; -webkit-background-clip: text; background-clip: text; color: transparent; -webkit-text-fill-color: transparent;`
                          : `color: ${slide.seriesNameColor ?? '#fff'};`}>pro</span><span class="aa" style="color: var(--brand-red, #E3353C); -webkit-text-fill-color: var(--brand-red, #E3353C);">Ⓐ</span><span class="dp-text" style={slide.seriesNameGradient
                          ? `background: ${slide.seriesNameGradient}; -webkit-background-clip: text; background-clip: text; color: transparent; -webkit-text-fill-color: transparent;`
                          : `color: ${slide.seriesNameColor ?? '#fff'};`}>RCH-III</span>
                      </h2>
                    : <h2 class="display-product" style={slide.seriesNameGradient
                        ? `background: ${slide.seriesNameGradient}; -webkit-background-clip: text; background-clip: text; color: transparent; -webkit-text-fill-color: transparent;`
                        : `color: ${slide.seriesNameColor ?? '#fff'};`}>{slide.name}</h2>
                  }
                </div>
              ))}
            </div>

            <!-- DESCRIPTION SLOT -->
            <div class="slot slot-desc">
              {heroSlides.map((slide, i) => (
                <div class={`slot-content${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                  {slide.id === 2
                    ? <p>Commercial area lighting for parking, campuses, and outdoor grounds. Type III/IV/V optics. surge<span class="aa">Ⓐ</span>RMOR built in.</p>
                    : <p>{slide.desc}</p>
                  }
                </div>
              ))}
            </div>

            <!-- STATS SLOT -->
            <div class="slot slot-stats">
              {heroSlides.map((slide, i) => (
                <div class={`slot-content${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                  <div class="stat-grid">
                    {slide.stats.map(s => (
                      <div class="stat">
                        <div class="stat-num">
                          {s.hasBrandMark
                            ? <Fragment set:html={s.num.replace('Ⓐ', '<span class="aa">Ⓐ</span>')} />
                            : s.num
                          }
                        </div>
                        <div class="stat-lbl">{s.lbl}</div>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>

            <!-- LINE DRAWING SLOT (anchored bottom-right, per-slide) -->
            <div class="slot slot-product-img">
              {heroSlides.map((slide, i) => (
                <div class={`slot-content${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                  <img src={slide.lineDrawing} alt={`${slide.name ?? 'Product'} line drawing`} class={`product-render${slide.lineDrawingClass ? ' ' + slide.lineDrawingClass : ''}`} loading="eager" />
                </div>
              ))}
            </div>

            <!-- CTA SLOT -->
            <div class="slot slot-cta">
              {heroSlides.map((_, i) => (
                <div class={`slot-content${i === 0 ? ' active' : ''}`} data-slot-slide={i}>
                  <div class="cta-pair">
                    <a href="/resources/spec-sheets" class="cta-primary">Download Spec</a>
                    <a href="/collections" class="cta-link">Learn more ›</a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Carousel controls -->
    <div class="carousel-controls">
      <div class="carousel-dots">
        {heroSlides.map((slide, i) => (
          <button
            class={`carousel-dot${i === 0 ? ' active' : ''}`}
            data-slide-to={i}
            aria-label={slide.name ?? 'Slide'}
          ></button>
        ))}
      </div>
      <div class="carousel-arrows">
        <span class="carousel-counter" id="carouselCounter">01 / 04</span>
        <button class="carousel-arrow" id="prevBtn" aria-label="Previous slide">
          <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 1L3 7l6 6"/></svg>
        </button>
        <button class="carousel-arrow" id="nextBtn" aria-label="Next slide">
          <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 1l6 6-6 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ==============================================================
       2. DIFFERENTIATION STRIP (6 trust signals)
       ============================================================== -->
  <div class="diff-strip" aria-label="Trust signals">
    <div class="diff-inner">
      {diffSignals.map(sig => (
        <div class="diff-item">
          <div class="diff-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" set:html={sig.svg} aria-hidden="true"></svg>
          </div>
          <div class="diff-text">
            <div class="diff-num">{sig.num}</div>
            <div class="diff-lbl">{sig.lbl}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- ==============================================================
       3. PERSONA SEGMENTER
       ============================================================== -->
  <div class="persona-strip" aria-label="Persona selector">
    <div class="persona-inner">
      <span class="persona-label">I am a…</span>
      <div class="persona-chips">
        <a href="/distributor" class="persona-chip active" data-persona="distributor">Distributor</a>
        <a href="/specifier" class="persona-chip" data-persona="specifier">Specifier / Engineer</a>
        <a href="/contractor" class="persona-chip" data-persona="contractor">Contractor</a>
        <a href="/esco" class="persona-chip" data-persona="esco">ESCO</a>
        <a href="/facility-manager" class="persona-chip" data-persona="facility-manager">Facility Manager</a>
      </div>
    </div>
  </div>

  <!-- ==============================================================
       4. WHAT WE MAKE — Category tease (4 cards)
       ============================================================== -->
  <section class="content-section" aria-labelledby="wm-heading">
    <div class="section-inner">
      <div class="sec-eyebrow">What we make</div>
      <h2 id="wm-heading" class="sec-title">Built for the bid sheet, the floor, and the <span class="accent">truck.</span></h2>
      <p class="sec-sub">From warehouse high-bays to parking-lot area lights, from emergency backup to networked controls — built for the specifier, the distributor, and the contractor.</p>
      <div class="what-we-make">
        <a href="/collections/indoor" class="wm-card indoor">
          <div class="wm-img"></div>
          <div class="wm-body">
            <h3>Indoor Luminaires</h3>
            <p>Troffers, panels, high-bays, downlights. The catalog distributors stock and specifiers spec.</p>
            <div class="wm-meta">
              <span class="wm-sub-brands"><BrandMark prefix="lampar" suffix="RCH" /> · <BrandMark prefix="plano" suffix="RCH" /></span>
              <span class="wm-arrow">Browse →</span>
            </div>
          </div>
        </a>
        <a href="/collections/outdoor" class="wm-card outdoor">
          <div class="wm-img"></div>
          <div class="wm-body">
            <h3>Outdoor Luminaires</h3>
            <p>Wall packs, parking-lot area lights, canopy, floods, and bollards. Built for the elements.</p>
            <div class="wm-meta">
              <span class="wm-sub-brands"><BrandMark prefix="city" suffix="RCH" /> · <BrandMark prefix="luxo" suffix="RCH" /></span>
              <span class="wm-arrow">Browse →</span>
            </div>
          </div>
        </a>
        <a href="/collections/controls-em" class="wm-card controls">
          <div class="wm-img"></div>
          <div class="wm-body">
            <h3>Safety &amp; Controls</h3>
            <p><BrandMark prefix="contr" suffix="LS" /> three-tier (ECO · PRO · PRO+) and <BrandMark prefix="const" suffix="NT" /> emergency drivers and egress / exit signs.</p>
            <div class="wm-meta">
              <span class="wm-sub-brands"><BrandMark prefix="contr" suffix="LS" /> · <BrandMark prefix="const" suffix="NT" /></span>
              <span class="wm-arrow">Browse →</span>
            </div>
          </div>
        </a>
        <a href="/collections/lamps" class="wm-card lamps">
          <div class="wm-img"></div>
          <div class="wm-body">
            <h3>Utility &amp; Décor Lamps</h3>
            <p>T8 linear, vintage filament, and decorative lamps. Retrofit-ready for every socket.</p>
            <div class="wm-meta">
              <span class="wm-sub-brands">Nostalgic · Vintage · <BrandMark prefix="tubul" suffix="RCH" /></span>
              <span class="wm-arrow">Browse →</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ==============================================================
       5. LOCATOR MAP
       ============================================================== -->
  <section class="locator-section" aria-labelledby="loc-heading">
    <div class="locator-inner">
      <div class="sec-eyebrow">Find your local support</div>
      <h2 id="loc-heading" class="sec-title">One map. <span class="accent">Three ways to find us.</span></h2>
      <p class="sec-sub">Your local sales rep, nearest stocking distributor, and ALG warehouse — all on one map. Search by ZIP, city, or state. Coverage in every US region.</p>
      <div class="locator-toolbar">
        <div class="loc-filter-group">
          <span class="loc-filter-label">Show:</span>
          <span class="loc-pill active" data-filter="all">All</span>
            <span class="loc-pill" data-filter="warehouse">
            <span class="kind-dot wh"></span>Warehouses <span class="loc-count">(6)</span>
          </span>
          <span class="loc-pill" data-filter="rep">
            <span class="kind-dot rep"></span>Sales Reps
          </span>
          <span class="loc-pill" data-filter="dist">
            <span class="kind-dot dist"></span>Distributors
          </span>
        </div>
        <div class="loc-search-group">
          <input type="text" class="loc-search-input" placeholder="ZIP, city, or state" aria-label="Search by ZIP, city, or state" />
          <button class="loc-search-btn">Find Nearest</button>
        </div>
      </div>
      <div class="locator-map-wrap">
        <div id="algLocatorMap" class="locator-map" aria-label="ALG warehouse, sales rep, and distributor locations across the United States" role="application"></div>
        <div class="loc-sidebar">
          <div class="loc-legend">
            <h4>Map key</h4>
            <div class="legend-row">
              <span class="legend-dot"><span class="dot-vis" style="background:#F32740;"></span>ALG Warehouse</span>
              <span class="legend-count">6 locations</span>
            </div>
            <div class="legend-row">
              <span class="legend-dot"><span class="dot-vis" style="background:#f0a932;"></span>Sales Rep</span>
              <span class="legend-count">All 50 states</span>
            </div>
            <div class="legend-row">
              <span class="legend-dot"><span class="dot-vis" style="background:#0FAE7C;"></span>Stocking Distributor</span>
              <span class="legend-count">Nationwide</span>
            </div>
          </div>
          <div class="loc-results">
            <h4>Nearest to 91761</h4>
            <div class="result-row">
              <span class="result-kind" style="background:#F32740;"></span>
              <div class="result-info"><span class="result-name">Montclair, CA</span><span class="result-meta">West Coast HQ &middot; Warehouse</span></div>
              <span class="result-dist">On-site</span>
            </div>
            <div class="result-row">
              <span class="result-kind" style="background:#f0a932;"></span>
              <div class="result-info"><span class="result-name">Pacific Lighting Rep</span><span class="result-meta">Southern California territory</span></div>
              <span class="result-dist">8 mi</span>
            </div>
            <div class="result-row">
              <span class="result-kind" style="background:#0FAE7C;"></span>
              <div class="result-info"><span class="result-name">Ontario Electric Supply</span><span class="result-meta">Stocking distributor</span></div>
              <span class="result-dist">3 mi</span>
            </div>
            <div class="result-row">
              <span class="result-kind" style="background:#0FAE7C;"></span>
              <div class="result-info"><span class="result-name">Inland Lighting Dist.</span><span class="result-meta">Stocking distributor</span></div>
              <span class="result-dist">12 mi</span>
            </div>
          </div>
        </div>
      </div>
      <div class="locator-ctas">
        <a href="/find-a-rep" class="cta-primary">Find a Rep or Distributor</a>
        <a href="/distributor" class="cta-secondary on-dark">Become a Distributor</a>
        <a href="/careers/sales-rep" class="cta-secondary on-dark">Apply as Sales Rep</a>
      </div>
    </div>
  </section>

  <!-- ==============================================================
       6. FEATURED FAMILIES (4 cards — locked SKU counts from reference)
       ============================================================== -->
  <section class="content-section" aria-labelledby="fam-heading">
    <div class="section-inner">
      <div class="sec-eyebrow">Featured families</div>
      <h2 id="fam-heading" class="sec-title">The families distributors stock and specifiers spec.</h2>
      <p class="sec-sub" style="max-width:none">Three fixture families plus the connected systems platform that ties them together — the core of our 2,000+ active SKU catalog.</p>
      <div class="families-rail">
        <a href="/collections/luxoarch" class="fam-card">
          <div class="fam-img cream">
            <span class="fam-tag">DLC Premium</span>
            <img class="fam-product" src="/images/families/family-illuminator.png" alt="Illuminator sports lighter" width="320" height="240" loading="lazy" />
          </div>
          <div class="fam-body">
            <div class="fam-eyebrow"><BrandMark prefix="luxo" suffix="RCH" /> · PRO</div>
            <div class="fam-name">Illuminator</div>
            <div class="fam-desc">Sports lighter · stadiums + athletic fields</div>
            <div class="fam-meta"><span class="fam-skucount">11 SKUs</span><span class="fam-arrow">View →</span></div>
          </div>
        </a>
        <a href="/collections/indoor-industrial" class="fam-card">
          <div class="fam-img dk">
            <span class="fam-tag">DLC Premium</span>
            <img class="fam-product" src="/images/families/family-titan.jpg" alt="Titan-II linear high-bay LED luminaire" width="320" height="240" loading="lazy" />
          </div>
          <div class="fam-body">
            <div class="fam-eyebrow"><BrandMark prefix="lampar" suffix="RCH" /> · PRO</div>
