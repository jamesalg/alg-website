<script>
// Carousel autoplay \u2014 count is read from actual DOM so adding/removing slides
// doesn't drift the modulo math.
(function() {
  var track = document.getElementById('carouselTrack');
  var dots  = document.querySelectorAll('#carouselDots > span');
  var slides = track ? track.querySelectorAll('.carousel-slide').length : 0;
  if (!track || !slides) return;
  var idx = 0;
  function go(i) {
    idx = (i + slides) % slides;
    track.style.transform = 'translateX(-' + (idx * 100) + '%)';
    dots.forEach(function(d, n) { d.classList.toggle('active', n === idx); });
  }
  var timer = setInterval(function() { go(idx + 1); }, 5000);
  dots.forEach(function(d) {
    d.addEventListener('click', function() {
      clearInterval(timer);
      go(parseInt(d.dataset.i, 10));
      timer = setInterval(function() { go(idx + 1); }, 5000);
    });
  });
})();

// Spec model toggle \u2014 full WATTSELECT \u00D7 CCTSELECT matrix per model (LWPF Sentinel datasheet)
// LWPF3W40:  20W / 30W / 40W   (default 40W) \u2014 CCT 3500K \u00B7 4000K \u00B7 5000K via DIP
// LWPF3W80:  40W / 60W / 80W   (default 80W) \u2014 same 3 CCTs
// LWPF3W120: 80W / 100W / 120W (default 120W) \u2014 same 3 CCTs
(function() {
  var data = {
    '40': [
      { watt: '20W',   lumens: '2,800 lm',   lpw: '140 lm/W', cct: '3500K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: false },
      { watt: '30W',   lumens: '4,200 lm',   lpw: '140 lm/W', cct: '3500K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: false },
      { watt: '40W \u2605', lumens: '5,500 lm',   lpw: '137 lm/W', cct: '3500K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: true  }
    ],
    '80': [
      { watt: '40W',   lumens: '5,800 lm',   lpw: '145 lm/W', cct: '3500K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: false },
      { watt: '60W',   lumens: '8,700 lm',   lpw: '145 lm/W', cct: '3500K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: false },
      { watt: '80W \u2605', lumens: '11,250 lm',  lpw: '140 lm/W', cct: '3500K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: true  }
    ],
    '120': [
      { watt: '80W',    lumens: '11,500 lm', lpw: '144 lm/W', cct: '3500K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: false },
      { watt: '100W',   lumens: '14,400 lm', lpw: '144 lm/W', cct: '3500K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: false },
      { watt: '120W \u2605', lumens: '16,500 lm', lpw: '139 lm/W', cct: '3500K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: true  }
    ]
  };
  var tbody = document.getElementById('specTableBody');
  var tabs = document.querySelectorAll('.spec-watt-tab');
  function render(model) {
    tbody.innerHTML = data[model].map(function(r) {
      return '<tr class="' + (r.def ? 'is-default' : '') + '">' +
             '<td>' + r.watt   + '</td>' +
             '<td>' + r.lumens + '</td>' +
             '<td>' + r.lpw    + '</td>' +
             '<td>' + r.cct    + '</td>' +
             '<td>' + r.volt   + '</td>' +
             '</tr>';
    }).join('');
  }
  tabs.forEach(function(t) {
    t.addEventListener('click', function() {
      tabs.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-selected', 'false'); });
      t.classList.add('active');
      t.setAttribute('aria-selected', 'true');
      render(t.dataset.w);
    });
  });
  render('80');
})();

// Dimensions zoom modal \u2014 click magnifier to open, click anywhere or ESC to close
(function() {
  function initZoom() {
    var btn      = document.querySelector('.spec-dim-zoom');
    var modal    = document.getElementById('zoomModal');
    var img      = document.getElementById('dimImg');
    var src      = document.getElementById('dimSvg');
    var dst      = document.getElementById('zoomContent');
    var closeBtn = document.getElementById('zoomClose');
    if (!btn || !modal || !dst || !(img || src)) {
      console.warn('zoom-modal: missing DOM nodes', {btn:!!btn, modal:!!modal, img:!!img, src:!!src, dst:!!dst});
      return;
    }
    function openModal(e) {
      if (e) { e.preventDefault(); e.stopPropagation(); }
      // Prefer the production drawing; fall back to inline SVG
      if (img && img.complete && img.naturalWidth > 0) {
        dst.innerHTML = '<img src="' + img.getAttribute('src') + '" alt="' + img.alt + '" />';
      } else if (src) {
        dst.innerHTML = src.outerHTML.replace(/\bdisplay\s*:\s*none[;]?/i, '');
      }
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeModal(e) {
      if (e) { e.preventDefault(); }
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }
    btn.addEventListener('click', openModal);
    modal.addEventListener('click', closeModal);
    if (closeBtn) closeBtn.addEventListener('click', function(e){ e.stopPropagation(); closeModal(e); });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initZoom);
  } else {
    initZoom();
  }
})();

