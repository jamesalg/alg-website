  /* SECTION 5 — Total Adaptive Control · Synapse */
  /* Full-bleed backdrop: sensor on left + radiating red dot mesh that spills across into the text area */
  .tac-section {
    position: relative;
    background: #0a0e14;
    overflow: hidden;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    min-height: 560px;
  }
  /* Red dot mesh — every dot rendered, opacity falloff from sensor outward.
     Strong/bold near the sensor (left side), faded near the text content (right side). */
  .tac-mesh-overlay {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1.2px 1.2px, rgba(243,39,64,0.78) 1.2px, transparent 1.6px);
    background-size: 14px 14px;
    -webkit-mask-image: radial-gradient(circle at 25% 50%,
      black 0%,
      rgba(0,0,0,0.95) 18%,
      rgba(0,0,0,0.72) 35%,
      rgba(0,0,0,0.42) 55%,
      rgba(0,0,0,0.18) 78%,
      rgba(0,0,0,0.05) 100%);
            mask-image: radial-gradient(circle at 25% 50%,
      black 0%,
      rgba(0,0,0,0.95) 18%,
      rgba(0,0,0,0.72) 35%,
      rgba(0,0,0,0.42) 55%,
      rgba(0,0,0,0.18) 78%,
      rgba(0,0,0,0.05) 100%);
    pointer-events: none;
    z-index: 1;
  }
  /* Shockwave — single expanding ring centered on sensor, fires on platform tab click */
  .tac-shockwave {
    position: absolute;
    left: 25%;
    top: 50%;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 2px solid rgba(243, 39, 64, 0.85);
    transform: translate(-50%, -50%);
    pointer-events: none;
    opacity: 0;
    z-index: 1;
  }
  .tac-shockwave.is-rippling { animation: tac-shockwave 1.4s ease-out; }
  @keyframes tac-shockwave {
    0%   { width: 60px;   height: 60px;   opacity: 1; border-width: 3px; }
    60%  {                                opacity: 0.55; }
    100% { width: 1400px; height: 1400px; opacity: 0; border-width: 0.5px; }
  }
  /* Sensor stack — ABOVE the mesh, multiple SVGs, only the active platform's is opaque */
  .tac-sensor-area {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    pointer-events: none;
  }
  .tac-sensor-svg {
    position: absolute;
    width: 60%;
    max-width: 380px;
    height: auto;
    opacity: 0;
    transform: scale(0.94);
    transition: opacity 0.5s ease, transform 0.55s cubic-bezier(0.2, 0.6, 0.2, 1);
    filter: drop-shadow(0 16px 48px rgba(0,0,0,0.6));
  }
  .tac-sensor-svg.is-active {
    opacity: 0.96;
    transform: scale(1);
  }
  /* Soft right-side darkening for text legibility — does NOT hide the mesh, just softens it */
  .tac-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 28%, rgba(10,14,20,0.4) 55%, rgba(10,14,20,0.7) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .tac-grid {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 88px 32px 96px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .tac-spacer { /* left half placeholder so backdrop sensor shows through */ }
  .tac-content { color: var(--text-primary); max-width: 580px; }
  .tac-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .tac-eyebrow::before {
    content: "";
    display: inline-block;
    width: 28px; height: 1px;
    background: var(--brand-red);
  }
  .tac-title {
    font-size: 44px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.005em;
    margin-bottom: 18px;
  }
  .tac-desc {
    font-size: 15.5px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 28px;
  }
  /* Callout block — button-styled, multi-platform-ready */
  .tac-callout {
    border: 1px solid rgba(243,39,64,0.4);
    border-radius: 4px;
    background: rgba(20,23,27,0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    overflow: hidden;
  }
  /* Tabs row — single tab today, multi-tab for products with Bi-Level / ⒶCS / SILVAIR / Synapse */
  .tac-callout-tabs {
    display: flex;
    background: rgba(0,0,0,0.25);
  }
  .tac-callout-tab {
    flex: 1;
    background: transparent;
    border: 0;
    padding: 13px 18px;
    font-family: inherit;
    font-size: 13px;
    font-weight: 700;
    color: var(--text-secondary);
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: background 0.18s, color 0.18s;
    border-right: 1px solid rgba(255,255,255,0.08);
    text-align: center;
  }
  .tac-callout-tab:last-child { border-right: 0; }
  .tac-callout-tab:hover { color: var(--text-primary); background: rgba(255,255,255,0.05); }
  .tac-callout-tab.active {
    background: var(--brand-red);
    color: white;
  }
  .tac-callout-body {
    padding: 22px 24px 22px;
  }
  .tac-callout-body p {
    font-size: 14px;
    color: var(--text-primary);
    line-height: 1.6;
    margin-bottom: 14px;
  }
  .tac-callout-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 13.5px;
    cursor: pointer;
    transition: color 0.18s;
    text-decoration: none;
  }
  .tac-callout-link:hover { color: var(--brand-red); }
  .tac-callout-link svg { width: 16px; height: 16px; color: var(--brand-red); flex-shrink: 0; }

  @media (max-width: 1100px) {
    .tac-grid { grid-template-columns: 1fr; gap: 32px; padding-top: 64px; }
    .tac-sensor-area { position: relative; width: 100%; height: 240px; }
    .tac-title { font-size: 30px; }
  }

  /* SECTION 4 — Highlights & Features */
  .hf-section {
    background: var(--bg-page);
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .hf-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .hf-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--brand-red);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 16px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
  }
  .hf-eyebrow::before, .hf-eyebrow::after {
    content: ""; display: block;
    width: 28px; height: 1px;
    background: var(--brand-red);
  }
  .hf-title {
    text-align: center;
    font-size: 38px;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin-bottom: 12px;
    line-height: 1.05;
  }
  .hf-sub {
    text-align: center;
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: 48px;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
  .hf-grid {
    display: grid;
    gap: 12px;
  }
  .hf-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .hf-tile {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    background: linear-gradient(135deg, #2a2e34 0%, #14171b 100%);
    aspect-ratio: 16/9;
    cursor: default;
    transition: transform 0.3s ease;
  }
  .hf-tile:hover { transform: translateY(-2px); }
  .hf-tile-hero { aspect-ratio: 24/9; }
  .hf-tile-image {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.18);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-align: center;
    padding: 32px;
  }
  /* Real generated images fill the entire tile via object-fit: cover so the
     tile box stays anchored to its aspect-ratio (16/9 or 24/9 for hero) and
     the image crops as needed. The .hf-tile-overlay gradient still sits on top. */
  .hf-tile-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  /* Per-tile crop overrides: pull tile 1's framing UP so the pole fixtures
     are visible; pull tile 3's framing LEFT so the corner luminaire is
     half-cropped against the right edge. */
  .hf-tile-hero .hf-tile-image img      { object-position: center 30%; }
  .hf-tile-grad-3 .hf-tile-image img    { object-position: 25% 80%; transform: scale(1.2); transform-origin: 25% 80%; }
  .hf-tile-grad-4 .hf-tile-image img    { transform: translateY(-15%) scale(1.2); }
  .hf-tile-controls .hf-tile-image img  { transform: translateY(-18%); }
  .hf-tile-overlay {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 32px 36px 28px;
    background: linear-gradient(to top, rgba(0,0,0,0.92) 20%, rgba(0,0,0,0.5) 70%, transparent 100%);
    color: white;
  }
  .hf-tile-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .hf-tile-overlay h3 {
    font-size: 30px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.005em;
    margin-bottom: 6px;
  }
  .hf-tile-hero .hf-tile-overlay h3 { font-size: 42px; }
  .hf-tile-overlay p {
    font-size: 14px;
    color: rgba(255,255,255,0.78);
    line-height: 1.55;
    max-width: 540px;
  }
  .hf-tile-grad-1 { background: linear-gradient(135deg, #1a3656 0%, #0a1a2e 100%); }
  .hf-tile-grad-2 { background: linear-gradient(135deg, #2a3338 0%, #14171b 100%); }
  .hf-tile-grad-3 { background: linear-gradient(135deg, #2c2620 0%, #14110d 100%); }
  .hf-tile-grad-4 { background: linear-gradient(135deg, #1a2e3a 0%, #0d1822 100%); }
  .hf-tile-grad-5 { background: linear-gradient(135deg, #2e1f1a 0%, #1a0f0a 100%); }
  .hf-tile-grad-6 { background: linear-gradient(135deg, #1c2a30 0%, #0e171b 100%); }
  @media (max-width: 900px) {
    .hf-row-2 { grid-template-columns: 1fr; }
    .hf-title { font-size: 28px; }
    .hf-tile-overlay h3 { font-size: 22px; }
    .hf-tile-hero .hf-tile-overlay h3 { font-size: 28px; }
  }

  /* Hero feature-icons row — pinned to bottom of hero-left.
     min-height matches .hero-compliance so the two bottom rows occupy the
     same vertical band, keeping ideal-card / carousel bottoms aligned. */
  .hero-feature-icons {
    margin-top: auto;
    padding-top: 28px;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    gap: 12px;
    min-height: 96px;
    align-items: center;
  }
  .feature-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
    color: var(--text-secondary);
    transition: color 0.2s;
    cursor: default;
    flex: 1;
    min-width: 0;
  }
  .feature-chip:hover { color: var(--text-primary); }
  .feature-chip-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.85);
  }
  .feature-chip:hover .feature-chip-icon { color: var(--text-primary); }
  .feature-chip-icon svg { width: 100%; height: 100%; }
  .feature-chip-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.08em;
    line-height: 1.3;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  /* Hero compliance row — pinned to bottom of hero-right (under carousel).
     min-height matches .hero-feature-icons so the bottom-row band is
     symmetric across both columns. */
  .hero-compliance {
    margin-top: 0;
    padding-top: 28px;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-around;
    align-items: center;
    gap: 12px;
    min-height: 96px;
  }
  .cb {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex: 1;
    min-width: 0;
    opacity: 0.65;
    transition: opacity 0.2s;
  }
  .cb:hover { opacity: 1; }
  .cb img, .cb svg.cb-img {
    height: 42px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }
  .cb-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    white-space: nowrap;
  }

  /* SECTION 7 — Compatible Accessories
     Production accessory pattern (dark grid → click card → modal with specs + 3 CTAs).
     Card grid is filterable by category pill row above it.
     Modal close: ESC key, click overlay, or close-button. */
  .acc-section {
    background: var(--bg-page);
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .acc-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .acc-head { text-align: center; margin-bottom: 36px; }
  .acc-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .acc-eyebrow::before, .acc-eyebrow::after {
    content: ""; display: block; width: 28px; height: 1px; background: var(--brand-red);
  }
  .acc-title {
    font-size: 38px;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin-bottom: 12px;
    line-height: 1.05;
  }
  .acc-sub {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 720px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Filter pill row */
  .acc-pills {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
    margin: 32px auto 40px;
    max-width: 1100px;
  }
  .acc-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 1px solid var(--line-medium);
    color: var(--text-secondary);
    padding: 9px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.18s;
  }
  .acc-pill:hover { color: var(--text-primary); border-color: var(--text-primary); }
  .acc-pill.active {
    background: var(--brand-red);
    border-color: var(--brand-red);
    color: white;
  }
  .acc-pill .acc-pill-count {
    font-size: 10px;
    font-weight: 600;
    opacity: 0.75;
    padding: 1px 6px;
    border-radius: 8px;
    background: rgba(255,255,255,0.10);
    letter-spacing: 0.04em;
  }
  .acc-pill.active .acc-pill-count {
    background: rgba(0,0,0,0.22);
    opacity: 1;
  }

  /* Card grid */
  /* CFG-LAYOUT-2: Section 8b Accessories renders 5-up at desktop matching
     Illuminator-canonical (mockup_illuminator_pdp_v2.html lines 1586-1590).
     Sentinel ships 4 accessories (EM07 + EM20 + SP10 + SP20) — they
     left-justify in row 1 with 1 empty col on the right (intentional negative
     space matching the family rhythm). Do NOT override to 4-up. */
  .acc-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 18px;
  }
  .acc-card {
    background: var(--bg-spec);
    border: 1px solid var(--line);
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    text-align: left;
    width: 100%;
    color: inherit;
    font-family: inherit;
    padding: 0;
  }
  .acc-card:hover {
    border-color: var(--brand-red);
    transform: translateY(-2px);
  }
  .acc-card.is-hidden { display: none; }
  .acc-card-img {
    background: var(--bg-darker);
    height: 168px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }
  .acc-card-img svg {
    width: 64%;
    height: 64%;
    color: rgba(255,255,255,0.55);
  }
  /* Real product photo (used by Synapse contrⒶLS cards). Same image-box rule
     as the SVG silhouettes: image fits within the 168px-tall box, never resizes
     the box. Drop-shadow gives the cutout depth on the dark surface. */
  .acc-card-img .acc-card-photo {
    max-width: 86%;
    max-height: 86%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 8px 14px rgba(0,0,0,0.5));
  }
  .acc-card-img-tag {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 2;          /* stack above the product img/svg */
    background: rgba(0,0,0,0.55);
    color: rgba(255,255,255,0.85);
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 2px;
    border: 1px solid rgba(255,255,255,0.10);
  }
  .acc-card-body {
    padding: 16px 16px 18px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 10px;
  }
  .acc-card-cat {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brand-red);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .acc-card-title {
    font-size: 14.5px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-primary);
    /* clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.6em;
  }
  .acc-card-sku {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-top: -4px;
  }
  .acc-card-cta {
    margin-top: auto;
    padding-top: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-secondary);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.18s, gap 0.18s;
  }
  .acc-card:hover .acc-card-cta { color: var(--brand-red); gap: 10px; }

  /* Modal */
  .acc-modal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.78);
    z-index: 1100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 32px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .acc-modal.open { display: flex; }
  .acc-modal-panel {
    background: var(--bg-spec);
    border: 1px solid var(--line-medium);
    border-radius: 4px;
    width: 100%;
    max-width: 920px;
    max-height: 90vh;
    overflow: auto;
    position: relative;
  }
  .acc-modal-grid {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: 0;
  }
  .acc-modal-img {
    background: var(--bg-darker);
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--line);
    min-height: 360px;
    padding: 28px;
    position: relative;
  }
  .acc-modal-img svg {
    width: 70%;
    height: 70%;
    max-width: 240px;
    color: rgba(255,255,255,0.65);
  }
  .acc-modal-img-cat {
    position: absolute;
    top: 16px;
    left: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-red);
    background: rgba(243,39,64,0.10);
    border: 1px solid rgba(243,39,64,0.35);
    padding: 4px 10px;
    border-radius: 2px;
  }
  .acc-modal-body {
    padding: 32px 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .acc-modal-title {
    font-size: 22px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
    margin: 0;
  }
  .acc-modal-sku {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }
  .acc-modal-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .acc-modal-specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .acc-spec-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
  }
  .acc-spec-row:nth-last-child(-n+2) { border-bottom: none; }
  .acc-spec-row:nth-child(odd) { padding-right: 18px; }
  .acc-spec-row:nth-child(even) { padding-left: 18px; border-left: 1px solid var(--line); }
  .acc-spec-key {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .acc-spec-val {
    font-size: 13.5px;
    color: var(--text-primary);
    font-weight: 600;
    line-height: 1.4;
  }
  .acc-modal-ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .acc-modal-cta {
    flex: 1;
    min-width: 170px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 13px 18px;
    border-radius: 2px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.18s;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .acc-modal-cta.primary {
    background: var(--brand-red);
    color: white;
  }
  .acc-modal-cta.primary:hover { background: var(--brand-red-deep); }
  .acc-modal-cta.outline {
    background: transparent;
    color: var(--text-secondary);
    border-color: var(--line-medium);
  }
  .acc-modal-cta.outline:hover { color: var(--text-primary); border-color: var(--text-primary); }
  .acc-modal-cta svg { width: 14px; height: 14px; }
  .acc-modal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 38px;
    height: 38px;
    background: rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.15);
    color: white;
    border-radius: 2px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: all 0.18s;
  }
  .acc-modal-close:hover { background: var(--brand-red); border-color: var(--brand-red); }
  .acc-modal-close svg { width: 16px; height: 16px; }

  @media (max-width: 1100px) {
    .acc-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 760px) {
    .acc-grid { grid-template-columns: repeat(2, 1fr); }
    .acc-modal-grid { grid-template-columns: 1fr; }
    .acc-modal-img { min-height: 220px; border-right: none; border-bottom: 1px solid var(--line); }
    .acc-modal-specs { grid-template-columns: 1fr; }
    .acc-spec-row:nth-child(odd) { padding-right: 0; }
    .acc-spec-row:nth-child(even) { padding-left: 0; border-left: none; }
    .acc-spec-row { border-bottom: 1px solid var(--line); }
    .acc-spec-row:last-child { border-bottom: none; }
    .acc-title { font-size: 28px; }
  }

  /* SECTION 8 — Configurator (Build Your Model)
     Mirror of production "Build Your Model" pattern with v2 enhancements:
     - Chip-style selectors instead of plain text rows
     - Live SKU resolution that updates on every click (not on submit)
     - Live spec readout (lumens, efficacy, voltage, etc.) in the preview card
     - Dependency rules: 90° optic disabled when LWPF3W120 is the model
     - 3-CTA finisher row matching the production drawer (P&A primary,
       Submittal PDF, Request Layout)
     The chip pattern + SKU template + dependency engine in the JS below is
     copy-portable to the proⒶRCH-III / Nebula-II / Symmetry / Titan-II PDPs;
     each just swaps the FIELDS + ENCODE arrays. */
  .cfg-section {
    background: var(--bg-darker);
    padding: 88px 0 0;
    border-top: 1px solid var(--line);
  }
  .cfg-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .cfg-head { text-align: center; margin-bottom: 28px; }
  .cfg-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .cfg-eyebrow::before, .cfg-eyebrow::after {
    content: ""; display: block; width: 28px; height: 1px; background: var(--brand-red);
  }
  .cfg-title {
    font-size: 38px;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin-bottom: 10px;
    line-height: 1.05;
  }
  .cfg-sub {
    font-size: 14.5px;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .cfg-sub small {
    display: block;
    color: var(--text-muted);
    font-size: 12px;
    margin-top: 6px;
  }
  .cfg-counter-band {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin: 28px 0 36px;
  }
  .cfg-counter {
    background: rgba(243,39,64,0.10);
    border: 1px solid rgba(243,39,64,0.35);
    color: var(--text-primary);
    padding: 9px 18px;
    border-radius: 2px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
  }
  .cfg-counter strong { color: var(--brand-red); font-weight: 700; }
  .cfg-counter.complete { background: rgba(72,180,97,0.10); border-color: rgba(72,180,97,0.4); }
  .cfg-counter.complete strong { color: #5fc77a; }
  .cfg-reset {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    cursor: pointer;
    background: transparent;
    border: none;
    padding: 4px 8px;
    transition: color 0.18s;
  }
  .cfg-reset:hover { color: var(--brand-red); }
  .cfg-reset svg { width: 13px; height: 13px; }

  .cfg-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 36px 0;
  }
  .cfg-col { padding: 0 36px; }
  .cfg-col + .cfg-col { border-left: 1px solid var(--line); }
  .cfg-col-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 22px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--line);
  }
  .cfg-col-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.005em;
  }
  .cfg-col-title-required::after {
    content: '*';
    color: var(--brand-red);
    margin-left: 4px;
    font-weight: 700;
  }
  .cfg-col-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .cfg-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px 24px;
  }
  .cfg-field { display: flex; flex-direction: column; gap: 8px; }
  .cfg-field-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    color: var(--text-muted);
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .cfg-field-label .req { color: var(--brand-red); font-weight: 700; }
  .cfg-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .cfg-chip {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 10px;
    row-gap: 2px;
    align-items: center;
    padding: 8px 12px;
    background: transparent;
    border: 1px solid var(--line-medium);
    color: var(--text-secondary);
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.15s;
    min-width: 84px;
    font-family: inherit;
    text-align: left;
  }
  .cfg-chip > .cfg-chip-val  { grid-column: 1; grid-row: 1; }
  .cfg-chip > .cfg-chip-code { grid-column: 1 / -1; grid-row: 2; }
  .cfg-chip:hover:not(.disabled):not(.locked) {
    border-color: var(--text-primary);
    color: var(--text-primary);
  }
  .cfg-chip.selected {
    background: var(--brand-red);
    border-color: var(--brand-red);
    color: white;
  }
  .cfg-chip.locked {
    background: rgba(255,255,255,0.04);
    border-color: var(--line-medium);
    color: var(--text-secondary);
    cursor: default;
  }
  .cfg-chip.disabled {
    opacity: 0.32;
    cursor: not-allowed;
    border-style: dashed;
  }
  .cfg-chip-val {
    font-size: 12.5px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: 0.01em;
  }
  .cfg-chip-code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.06em;
    opacity: 0.65;
  }
  .cfg-chip.selected .cfg-chip-code { opacity: 0.85; }

  /* QS / MTO inventory tag — sits inline at right of row 1 (grid col 2 row 1).
     Never overlaps the chip's value text; the chip widens horizontally to fit. */
  .cfg-chip-stock {
    grid-column: 2;
    grid-row: 1;
    justify-self: end;
    align-self: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.10em;
    padding: 2px 5px;
    border-radius: 1px;
    text-transform: uppercase;
    pointer-events: none;
    line-height: 1.1;
    white-space: nowrap;
  }
  .cfg-chip-stock.qs  { background: rgba(95,199,122,0.18); color: #6fd789; border: 1px solid rgba(95,199,122,0.35); }
  .cfg-chip-stock.mto { background: rgba(255,159,28,0.16); color: #ffb14d; border: 1px solid rgba(255,159,28,0.40); }
  .cfg-chip-stock.wb  { background: rgba(96,168,255,0.16); color: #7fb6ff; border: 1px solid rgba(96,168,255,0.40); }
  .cfg-chip.selected .cfg-chip-stock.qs  { background: rgba(0,0,0,0.30); color: #c8f5d3; border-color: rgba(255,255,255,0.30); }
  .cfg-chip.selected .cfg-chip-stock.mto { background: rgba(0,0,0,0.30); color: #ffd591; border-color: rgba(255,255,255,0.30); }
  .cfg-chip.selected .cfg-chip-stock.wb  { background: rgba(0,0,0,0.30); color: #c5dcff; border-color: rgba(255,255,255,0.30); }

  /* Special chip variants — finish chips have a 3-column grid:
     swatch | val/code | stock-badge. Swatch spans both rows (centered). */
  .cfg-chip-finish {
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 10px;
    padding: 6px 11px 6px 8px;
  }
  .cfg-chip-finish .cfg-finish-swatch {
    grid-column: 1;
    grid-row: 1 / span 2;
    align-self: center;
    width: 22px;
    height: 22px;
    border-radius: 1px;
    border: 1px solid rgba(255,255,255,0.18);
    flex-shrink: 0;
  }
  .cfg-chip-finish > .cfg-chip-val   { grid-column: 2; grid-row: 1; }
  .cfg-chip-finish > .cfg-chip-code  { grid-column: 2 / -1; grid-row: 2; }
  .cfg-chip-finish > .cfg-chip-stock { grid-column: 3; grid-row: 1; }
  .cfg-chip.selected .cfg-finish-swatch { border-color: rgba(255,255,255,0.6); }
  .cfg-chip-toggle .cfg-chip-val { font-size: 11px; }

  /* RAL input — only shown when Custom RAL finish is the active selection.
     Lives inside the Finish field, below the chip row. Validates on blur AND
     on each keystroke so the SKU updates live. */
  .cfg-ral-input-wrap {
    display: none;
    margin-top: 12px;
    padding: 12px 14px;
    background: rgba(255,255,255,0.025);
    border: 1px solid var(--line);
    border-radius: 2px;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .cfg-ral-input-wrap.show { display: flex; }
  .cfg-ral-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    color: var(--text-muted);
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .cfg-ral-input-group {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--line-medium);
    border-radius: 2px;
    background: var(--bg-page);
    transition: border-color 0.18s, box-shadow 0.18s;
    overflow: hidden;
  }
  .cfg-ral-input-prefix {
    display: inline-flex;
    align-items: center;
    padding: 0 10px;
    background: rgba(255,255,255,0.04);
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    border-right: 1px solid var(--line-medium);
  }
  .cfg-ral-input {
    background: transparent;
    border: none;
    color: var(--text-primary);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    padding: 8px 10px;
    width: 80px;
    outline: none;
    letter-spacing: 0.04em;
  }
  .cfg-ral-input::placeholder { color: var(--text-muted); font-weight: 400; }
  .cfg-ral-input-wrap.valid .cfg-ral-input-group   { border-color: rgba(95,199,122,0.55); box-shadow: 0 0 0 1px rgba(95,199,122,0.25); }
  .cfg-ral-input-wrap.invalid .cfg-ral-input-group { border-color: rgba(243,39,64,0.55);  box-shadow: 0 0 0 1px rgba(243,39,64,0.25); }
  .cfg-ral-status {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    line-height: 1.4;
    flex: 1;
    min-width: 200px;
  }
  .cfg-ral-status .hint    { color: var(--text-muted); }
  .cfg-ral-status .ok      { color: #6fd789; }
  .cfg-ral-status .err     { color: #ff8b9c; }
  .cfg-ral-input-wrap .ok, .cfg-ral-input-wrap .err { display: none; }
  .cfg-ral-input-wrap.valid   .ok   { display: inline; }
  .cfg-ral-input-wrap.valid   .hint { display: none; }
  .cfg-ral-input-wrap.invalid .err  { display: inline; }
  .cfg-ral-input-wrap.invalid .hint { display: none; }

  /* Live preview card */
  .cfg-preview-wrap {
    background: var(--bg-page);
    padding: 56px 32px 88px;
  }
  .cfg-preview {
    max-width: 1400px;
    margin: 0 auto;
    background: var(--bg-spec);
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
  }
  .cfg-preview-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 0;
  }
  .cfg-preview-img {
    background: var(--bg-darker);
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--line);
    padding: 32px;
    position: relative;
    min-height: 360px;
  }
  .cfg-preview-img img {
    width: 100%;
    height: auto;
    max-width: 360px;
    max-height: 320px;
    object-fit: contain;
    filter: drop-shadow(0 18px 30px rgba(0,0,0,0.45));
  }
  .cfg-preview-img-tag {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 2;          /* stack above the live-preview finish image */
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-red);
    background: rgba(243,39,64,0.10);
    border: 1px solid rgba(243,39,64,0.35);
    padding: 4px 10px;
    border-radius: 2px;
  }
  .cfg-preview-body {
    padding: 32px 36px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .cfg-sku-block { display: flex; flex-direction: column; gap: 6px; }
  .cfg-sku-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.18em;
    color: var(--brand-red);
    text-transform: uppercase;
    font-weight: 700;
  }
  .cfg-sku {
    font-family: 'JetBrains Mono', monospace;
    font-size: 22px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.02em;
    word-break: break-all;
    line-height: 1.25;
  }
  .cfg-sku .placeholder { color: var(--text-muted); font-weight: 400; }
  .cfg-sku-copy {
    margin-top: 4px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    background: transparent;
    border: 1px solid var(--line-medium);
    color: var(--text-secondary);
    padding: 5px 10px;
    border-radius: 2px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.18s;
  }
  .cfg-sku-copy:hover { color: var(--text-primary); border-color: var(--text-primary); }
  .cfg-sku-copy.copied { background: var(--brand-red); border-color: var(--brand-red); color: white; }
  .cfg-sku-copy svg { width: 11px; height: 11px; }

  .cfg-spec-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .cfg-spec-cell {
    padding: 14px 14px 14px 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-right: 1px solid var(--line);
  }
  /* Left-padding only on cells that are NOT at the start of a row.
     The start of each row (4n+1) flushes left so OPTIC · BEAM (cell 5)
     vertically aligns with MAX LUMENS (cell 1). */
  .cfg-spec-cell { padding-left: 14px; }
  .cfg-spec-cell:nth-child(4n+1) { padding-left: 0; }
  .cfg-spec-cell:nth-child(4n) { border-right: none; }
  .cfg-spec-cell:nth-child(n+5) { border-top: 1px solid var(--line); }
  .cfg-spec-cell-key {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    letter-spacing: 0.14em;
    color: var(--text-muted);
    text-transform: uppercase;
    font-weight: 700;
  }
  .cfg-spec-cell-val {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
  }
  .cfg-spec-cell-val.placeholder { color: var(--text-muted); font-weight: 400; }

  .cfg-cta-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .cfg-cta {
    flex: 1;
    min-width: 180px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 20px;
    border-radius: 2px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.18s;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .cfg-cta.primary {
    background: var(--brand-red);
    color: white;
  }
  .cfg-cta.primary:hover { background: var(--brand-red-deep); }
  .cfg-cta.outline {
    background: transparent;
    color: var(--text-secondary);
    border-color: var(--line-medium);
  }
  .cfg-cta.outline:hover { color: var(--text-primary); border-color: var(--text-primary); }
  .cfg-cta.disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }
  .cfg-cta svg { width: 14px; height: 14px; }

  .cfg-incomplete-warning {
    display: none;
    padding: 12px 14px;
    background: rgba(255,159,28,0.08);
    border: 1px solid rgba(255,159,28,0.35);
    border-radius: 2px;
    color: #ffb14d;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    line-height: 1.5;
  }
  .cfg-incomplete-warning.show { display: block; }
  .cfg-incomplete-warning strong { color: #ffd591; }

  /* Legend block — sits in lower-right of the Optional column */
  .cfg-legend {
    margin-top: auto;
    align-self: flex-end;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--line);
    border-radius: 2px;
    padding: 12px 14px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 6px 12px;
    align-items: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    color: var(--text-secondary);
    letter-spacing: 0.04em;
    width: max-content;
    max-width: 100%;
  }
  .cfg-legend-row { display: contents; }
  .cfg-legend-key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    padding: 3px 7px;
    border-radius: 1px;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.10em;
  }
  .cfg-legend-key.star { color: var(--text-primary); background: transparent; font-size: 14px; padding: 0 4px; min-width: 24px; }
  .cfg-legend-key.qs   { background: rgba(95,199,122,0.18); color: #6fd789; border: 1px solid rgba(95,199,122,0.35); }
  .cfg-legend-key.wb   { background: rgba(96,168,255,0.16); color: #7fb6ff; border: 1px solid rgba(96,168,255,0.40); }
  .cfg-legend-key.mto  { background: rgba(255,159,28,0.16); color: #ffb14d; border: 1px solid rgba(255,159,28,0.40); }
  .cfg-legend-val {
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.10em;
    font-size: 10px;
  }
  .cfg-col-optional-flex {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .cfg-col-optional-flex .cfg-fields { flex: 1; }

  @media (max-width: 1100px) {
    .cfg-body { grid-template-columns: 1fr; }
    .cfg-col + .cfg-col { border-left: none; border-top: 1px solid var(--line); padding-top: 36px; margin-top: 36px; }
    .cfg-preview-grid { grid-template-columns: 1fr; }
    .cfg-preview-img { border-right: none; border-bottom: 1px solid var(--line); }
    .cfg-spec-grid { grid-template-columns: repeat(2, 1fr); }
    .cfg-spec-cell:nth-child(2n) { border-right: none; }
    .cfg-spec-cell:nth-child(n+3) { border-top: 1px solid var(--line); }
  }
  @media (max-width: 720px) {
    .cfg-fields { grid-template-columns: 1fr; }
    .cfg-spec-grid { grid-template-columns: 1fr; }
    .cfg-spec-cell { border-right: none; }
    .cfg-spec-cell:nth-child(n+2) { border-top: 1px solid var(--line); }
    .cfg-title { font-size: 28px; }
    .cfg-sku { font-size: 16px; }
  }

  /* SECTION 9 — Documentation & Resources
     Spec-mode pattern: 6-card primary grid (PDFs, IES bundle, CAD/Revit,
     compliance bundle) + secondary quick-link row (DLC QPL, TAA cert,
     warranty, spec catalog text). Each card is a download trigger; all
     cards have file-format / file-size pill labels. */
  .docs-section {
    background: var(--bg-page);
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .docs-inner { max-width: 1400px; margin: 0 auto; padding: 0 32px; }
  .docs-head  { text-align: center; margin-bottom: 48px; }
  .docs-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .docs-eyebrow::before, .docs-eyebrow::after {
    content: ""; display: block; width: 28px; height: 1px; background: var(--brand-red);
  }
  .docs-title {
    font-size: 38px;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin-bottom: 12px;
    line-height: 1.05;
  }
  .docs-sub {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 720px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Primary card grid — 4 cards across (Data Sheet, Install, IES, Submittal) */
  .docs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-bottom: 32px;
  }
  .docs-card {
    background: var(--bg-spec);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 28px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s, background 0.2s;
    position: relative;
    overflow: hidden;
  }
  .docs-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    height: 3px; width: 0;
    background: var(--brand-red);
    transition: width 0.25s ease;
  }
  .docs-card:hover {
    border-color: rgba(243,39,64,0.45);
    transform: translateY(-2px);
    background: #2e3239;
  }
  .docs-card:hover::before { width: 100%; }

  .docs-card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
  }
  .docs-card-icon {
    width: 56px;
    height: 56px;
    border-radius: 4px;
    background: rgba(243,39,64,0.10);
    border: 1px solid rgba(243,39,64,0.30);
    color: var(--brand-red);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .docs-card-icon svg { width: 28px; height: 28px; }
  .docs-card-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .docs-card-format {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--line-medium);
    padding: 3px 8px;
    border-radius: 1px;
  }
  .docs-card-size {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }

  .docs-card-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
    letter-spacing: -0.005em;
  }
  .docs-card-desc {
    font-size: 13.5px;
    color: var(--text-secondary);
    line-height: 1.55;
    flex: 1;
  }
  .docs-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 6px;
    padding-top: 14px;
    border-top: 1px solid var(--line);
  }
  .docs-card-cta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--brand-red);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: gap 0.18s;
  }
  .docs-card:hover .docs-card-cta { gap: 12px; }
  .docs-card-cta svg { width: 14px; height: 14px; }
  .docs-card-updated {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }

  /* Secondary quick-links row */
  .docs-secondary {
    background: var(--bg-spec);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 20px 24px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 10px 28px;
    align-items: center;
  }
  .docs-secondary-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brand-red);
    font-weight: 700;
    white-space: nowrap;
  }
  .docs-secondary-links {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 22px;
  }
  .docs-secondary-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--text-secondary);
    font-size: 13px;
    font-weight: 600;
    transition: color 0.18s;
    white-space: nowrap;
    cursor: pointer;
  }
  .docs-secondary-link:hover { color: var(--brand-red); }
  .docs-secondary-link svg {
    width: 14px;
    height: 14px;
    color: var(--text-muted);
    transition: color 0.18s;
  }
  .docs-secondary-link:hover svg { color: var(--brand-red); }
  .docs-secondary-link.copied { color: #5fc77a; }
  .docs-secondary-link.copied svg { color: #5fc77a; }

  @media (max-width: 1280px) {
    .docs-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 1100px) {
    .docs-secondary { grid-template-columns: 1fr; gap: 10px; }
  }
  @media (max-width: 720px) {
    .docs-grid { grid-template-columns: 1fr; }
    .docs-title { font-size: 28px; }
  }

  /* SECTION 10 — Wall Pack Family (direct siblings within the LWPF Wall Pack line).
     Sits between Documentation (Sec 9) and the page closer (Sec 11).
     Reuses .family-card styles from below; adds a "you-are-here" current-product
     tile so the user can place Sentinel within the Wall Pack line. */
  .wp-family-section {
    background: var(--bg-page);
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .wp-family-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .wp-family-head { text-align: center; margin-bottom: 40px; }
  .wp-family-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 40px;
  }
  /* "You are here" current-product card — visually distinct, not clickable */
  .family-card.is-current {
    background: linear-gradient(135deg, rgba(243,39,64,0.08) 0%, var(--bg-spec) 60%);
    border-color: rgba(243,39,64,0.45);
    cursor: default;
    pointer-events: none;
  }
  .family-card.is-current .family-card-img {
