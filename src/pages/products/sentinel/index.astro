  var fallback = { '40': '35', '80': '35', '120': '35' };

  function init() {
    var img = document.getElementById('photoImg');
    var statPeak = document.getElementById('photoStatPeak');
    var statLum = document.getElementById('photoStatLumens');
    var statFile = document.getElementById('photoStatFile');
    if (!img || !statPeak) return;
    var modelTabs = document.querySelectorAll('.photo-tab[data-model]');
    var cctTabs = document.querySelectorAll('.photo-tab[data-cct]');
    var state = { model: '80', cct: '40' };  // 35\u00B0 is the datasheet default optic
    // Mark the 35\u00B0 optic tab active on initial load
    cctTabs.forEach(function(t) { t.classList.toggle('active', t.dataset.cct === state.cct); t.setAttribute('aria-selected', t.dataset.cct === state.cct ? 'true' : 'false'); });

    function refreshOpticTabs() {
      var available = optics[state.model];
      cctTabs.forEach(function(t) {
        var opt = t.dataset.cct;
        var isAvailable = available.indexOf(opt) >= 0;
        t.disabled = !isAvailable;
        t.style.opacity = isAvailable ? '1' : '0.3';
        t.style.cursor = isAvailable ? 'pointer' : 'not-allowed';
        t.title = isAvailable ? '' : 'IES test data not available for this combination';
      });
      // If current optic isn't available for new model, snap to the default
      if (true /* all CCTs available */) state.cct = fallback[state.model];
      cctTabs.forEach(function(t) {
        t.classList.toggle('active', t.dataset.cct === state.cct);
        t.setAttribute('aria-selected', t.dataset.cct === state.cct ? 'true' : 'false');
      });
    }

    function render() {
      var key = state.model + '_' + state.cct;
      var d = data[key];
