    var state     = Object.assign({}, DEFAULT_STATE);

    // ---- Chip click handler ----
    chips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        if (chip.classList.contains('disabled')) return;
        var field    = chip.dataset.field;
        var val      = chip.dataset.val;
        var isOpt    = OPTIONAL.indexOf(field) >= 0;
        var isMulti  = MULTI.indexOf(field) >= 0;

        if (isMulti) {
          // Multi-select: store as array. Click toggles on/off independently.
          var arr = Array.isArray(state[field]) ? state[field].slice() : [];
          var i = arr.indexOf(val);
          if (i >= 0) arr.splice(i, 1); else arr.push(val);
          if (arr.length === 0) delete state[field]; else state[field] = arr;
        } else if (isOpt && state[field] === val) {
          // Single-select optional: clicking the active chip clears it
          delete state[field];
        } else {
          // Single-select required (or first pick on optional)
          state[field] = val;
        }
        applyState();
      });
    });

    // ---- Reset all ----
    resetBtn.addEventListener('click', function() {
      state = Object.assign({}, DEFAULT_STATE);
      var ralInput = document.getElementById('cfgRalInput');
      if (ralInput) ralInput.value = '';
      applyState();
    });

    // ---- RAL number input handler ----
    var ralInput   = document.getElementById('cfgRalInput');
    var ralWrap    = document.getElementById('cfgRalInputWrap');
    var ralName    = document.getElementById('cfgRalName');
    if (ralInput && ralWrap) {
      ralInput.addEventListener('input', function() {
        // Strip non-digit characters as the user types.
        var raw = ralInput.value.replace(/\D/g, '').slice(0, 4);
        if (raw !== ralInput.value) ralInput.value = raw;

        ralWrap.classList.remove('valid', 'invalid');
        if (raw.length === 0) {
          delete state.finishRAL;
        } else if (raw.length < 4) {
          // Not enough digits yet \u2014 neutral state, but no SKU code
          delete state.finishRAL;
        } else {
          var num = parseInt(raw, 10);
          if (RAL_VALID.has(num)) {
            state.finishRAL = raw;
            ralWrap.classList.add('valid');
            if (ralName) ralName.textContent = 'RAL ' + raw + (RAL_NAMES[num] ? ' \u00B7 ' + RAL_NAMES[num] : '');
          } else {
            delete state.finishRAL;
            ralWrap.classList.add('invalid');
          }
        }
        applyState();
      });
    }

    // ---- Apply state to UI ----
    function applyState() {
      // Update chip selected states (multi-select aware)
      chips.forEach(function(chip) {
        var f = chip.dataset.field;
        var v = chip.dataset.val;
        var sel;
        if (MULTI.indexOf(f) >= 0) {
          sel = Array.isArray(state[f]) && state[f].indexOf(v) >= 0;
        } else {
          sel = state[f] === v;
        }
        chip.classList.toggle('selected', sel);
        // Dependency: data-only-model attr restricts which model the chip is valid for.
        var onlyModel = chip.dataset.onlyModel;
        if (onlyModel) {
          var disabled = state.model && state.model !== onlyModel;
          chip.classList.toggle('disabled', !!disabled);
          // If currently selected but now disabled, clear it
          if (disabled && state[f] === v) delete state[f];
        }
      });

      // RAL input wrap visibility \u2014 only when Custom RAL is the active finish
      var ralWrapEl = document.getElementById('cfgRalInputWrap');
      if (ralWrapEl) ralWrapEl.classList.toggle('show', state.finish === 'RAL');

      // Required-counter \u2014 RAL finish counts as set ONLY when a valid RAL number is entered
      var ralPending = (state.finish === 'RAL' && !state.finishRAL);
      var filled = REQUIRED.filter(function(k) {
        if (k === 'finish' && ralPending) return false;
        return state[k] != null;
      }).length;
      counter.textContent = filled;
      counterEl.classList.toggle('complete', filled === REQUIRED.length);

      // SKU
      var complete = (filled === REQUIRED.length);
      renderSKU(complete);
      // Warning + CTAs
      warning.classList.toggle('show', !complete);
      ctaPrice.classList.toggle('disabled', !complete);
      ctaPdf.classList.toggle('disabled', !complete);
      copyBtn.disabled = !complete;
      // Reset copy-button state when SKU changes
      copyBtn.classList.remove('copied');
      copyLabel.textContent = 'Copy SKU';

      // Live specs
      renderSpecs();
    }

    // ---- SKU encoder ----
    // Walks SKU_ORDER and concatenates each segment with its SEP rule.
    // Multi-select fields (controls, glare) emit one /CODE per selected value.
    // Optic uses '' (blank) as its code when 35\u00B0 is selected \u2192 no segment emitted.
    function renderSKU(complete) {
      var html = 'LWPF3W' + (state.model || '<span class="placeholder">[40|80|120]</span>');
      SKU_ORDER.forEach(function(k) {
        // Use hasOwnProperty so an EMPTY-STRING separator (finish: '') is preserved.
        // Earlier 'SEP[k] || '/'' short-circuited the '' case \u2192 finish got a stray '/'.
        var sep = Object.prototype.hasOwnProperty.call(SEP, k) ? SEP[k] : '/';
        var val = state[k];
        var isReq = REQUIRED.indexOf(k) >= 0;
        var isMulti = MULTI.indexOf(k) >= 0;

        // No selection?
        if (val == null || (isMulti && (!Array.isArray(val) || val.length === 0))) {
          if (isReq) html += sep + '<span class="placeholder">' + placeholderFor(k) + '</span>';
          // Optional + unset \u2192 no segment emitted
          return;
        }

        // Finish = Custom RAL \u2192 special-case: emit the 4-digit code (or RAL#
        // placeholder) flush against voltage \u2014 Finish never adds a leading
        // separator, same rule as B / D / S / W.
        if (k === 'finish' && val === 'RAL') {
          if (state.finishRAL) {
            html += state.finishRAL;
          } else {
            html += '<span class="placeholder">RAL#</span>';
          }
          return;
        }

        if (isMulti) {
          // Emit one segment per selected value. SKU_ORDER preserves field order;
          // within a multi-field we emit values in the chip's source order (markup order).
          var orderedVals = [];
          section.querySelectorAll('.cfg-chip[data-field="' + k + '"]').forEach(function(c) {
            if (val.indexOf(c.dataset.val) >= 0) orderedVals.push(c.dataset.code);
          });
          orderedVals.forEach(function(code) {
            if (code) html += sep + code;
          });
          return;
        }

        // Single-select \u2014 look up the code from the matching chip
        var chip = section.querySelector('.cfg-chip[data-field="' + k + '"][data-val="' + val + '"]');
        var code = chip ? chip.dataset.code : '';
        if (code === '') return;          // default optic / standard TAA \u2192 blank
        html += sep + code;
      });
      skuEl.innerHTML = html;
    }
    function placeholderFor(k) {
      return ({
        cct:       '[CCT]',
        voltage:   '[V]',
        finish:    '[FIN]',
        photocell: '[PS]',
        mount:     '[MNT]',
        em:        '[EM]',
        spd:       '[SPD]'
      })[k] || '[' + k.toUpperCase() + ']';
    }

    // ---- Live spec readout ----
    function renderSpecs() {
      setSpec('lumens',  state.model    ? SPEC_TABLE.model[state.model].lumensMax       : null);
      setSpec('lpw',     state.model    ? SPEC_TABLE.model[state.model].lpw             : null);
      setSpec('cct',     state.cct      ? SPEC_TABLE.cct[state.cct]                     : null);
      setSpec('voltage', state.voltage  ? SPEC_TABLE.voltage[state.voltage]             : null);
      setSpec('optic',   state.cct    ? SPEC_TABLE.optic[state.cct]                 : null);
      setSpec('peak',    (state.model && state.cct) ? SPEC_TABLE.peak[state.model + '_' + state.cct] || '\u2014' : null);
      // Finish \u2014 for Custom RAL, show "RAL 9005 \u00B7 Jet Black" (or just "RAL 9005") instead
      var finishVal = null;
      if (state.finish === 'RAL') {
        if (state.finishRAL) {
          var ralNum = parseInt(state.finishRAL, 10);
          finishVal = 'RAL ' + state.finishRAL + (RAL_NAMES[ralNum] ? ' \u00B7 ' + RAL_NAMES[ralNum] : '');
        }
      } else if (state.finish) {
        finishVal = SPEC_TABLE.finish[state.finish];
      }
      setSpec('finish', finishVal);
      // Compliance auto-updates with surge / EM selections
      var compliance = 'DLC \u00B7 UL \u00B7 RoHS \u00B7 IP65 Wet Loc.';
      if (state.spd) compliance += ' \u00B7 Surge-Protected';
      if (state.em)  compliance += ' \u00B7 EM Backup';
      setSpec('compliance', compliance);
      // Swap the live-preview image src per selected finish.
      // Soft cross-fade: opacity 0 \u2192 swap src \u2192 opacity 1 (200ms).
      var previewImg = document.getElementById('cfgPreviewImg');
      var newSrc = state.finish ? SPEC_TABLE.finishImg[state.finish] : SPEC_TABLE.finishImg['B'];
      if (previewImg && newSrc && !previewImg.src.endsWith(newSrc)) {
        previewImg.style.opacity = '0';
        setTimeout(function() {
          previewImg.src = newSrc;
          previewImg.style.opacity = '1';
        }, 180);
      }
    }
    function setSpec(name, val) {
      var el = section.querySelector('[data-spec="' + name + '"]');
      if (!el) return;
      if (val == null || val === '\u2014') {
        el.textContent = '\u2014';
        el.classList.add('placeholder');
      } else {
        el.textContent = val;
        el.classList.remove('placeholder');
      }
    }

    // ---- Copy SKU ----
    copyBtn.addEventListener('click', function() {
      if (copyBtn.disabled) return;
      var txt = skuEl.textContent.trim();
      if (!txt) return;
      // Use Clipboard API where available, fallback to execCommand
      var done = function() {
        copyBtn.classList.add('copied');
        copyLabel.textContent = 'Copied \u2713';
        setTimeout(function() {
          copyBtn.classList.remove('copied');
          copyLabel.textContent = 'Copy SKU';
        }, 1800);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(txt).then(done, done);
      } else {
        var ta = document.createElement('textarea');
        ta.value = txt;
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch(e){}
        document.body.removeChild(ta);
        done();
      }
    });

    // ---- Submittal PDF \u2014 opens submittal_template.html in new tab with full config in query string ----
    // The template auto-fills page-1 catalog number, quick specs, ordering-code matrix, and photometric data.
    // Manus replaces this with a real backend at /submittal-generator/?sku=\u2026 on production.
    function buildSubmittalUrl() {
      var sku = skuEl.textContent.trim();
      var params = new URLSearchParams({
        product:   'sentinel',
        sku:       sku,
        wattage:   state.model     || '120',
        cct:       state.cct       || '50',
        voltage:   state.voltage   || 'U',
        finish:    state.finish    || 'D',
        photocell: state.photocell || 'PS',
        mount:     state.mount     || 'WALL',
        em:        state.em        || '',
        spd:       state.spd       || ''
      });
      return 'submittal_template.html?' + params.toString();
    }
    ctaPdf.addEventListener('click', function(e) {
      if (ctaPdf.classList.contains('disabled')) { e.preventDefault(); return; }
      // Update href to current configurator state immediately before navigation
      ctaPdf.setAttribute('href', buildSubmittalUrl());
    });

    // Initial render
    applyState();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();

// Section 3 \u2014 Motion video carousel
(function() {
  // 6 clips sliced from ALG's master LWPF (Sentinel) promo video (the source mp4 lives
  // in WorkDrive: luxo\u24B6RCH/LWPF/VIDEO/LWPF - PromoVideo.mp4).
  // Each is 8 seconds, 720p, ~0.2-3.5 MB, h.264 + faststart for web playback.
  // Manus uploads these to Shopify's video CDN at production time and updates the URLs.
  var clips = [
    { url: '/products/sentinel/assets/motion/sentinel-motion-1-wattselect.mp4',  tag: 'WATTSELECT',     title: 'Three-position DIP switch \u00B7 40 / 80 / 120W field-selectable per model.' },
    { url: '/products/sentinel/assets/motion/sentinel-motion-2-cctselect.mp4',    tag: 'CCTSELECT',      title: 'Three-position DIP \u00B7 3500K / 4000K / 5000K field-selectable per fixture.' },
    { url: '/products/sentinel/assets/motion/sentinel-motion-3-photocell.mp4',    tag: 'PHOTOCELL',      title: 'Integrated dusk-to-dawn photocell standard on every fixture.' },
    { url: '/products/sentinel/assets/motion/sentinel-motion-4-bilevel.mp4',      tag: 'BI-LEVEL READY', title: 'Optional motion + photocell sensor for security-grade automation.' },
    { url: '/products/sentinel/assets/motion/sentinel-motion-5-emergency.mp4',    tag: 'EM BACKUP',      title: 'Optional 8W emergency backup module for code-required egress.' },
    { url: '/products/sentinel/assets/motion/sentinel-motion-6-mounting.mp4',     tag: 'WALL MOUNT',     title: 'Surface wall mount with integrated junction-box adapter \u2014 IK10 vandal-rated.' }
  ];
  function init() {
    var video    = document.getElementById('motionVideo');
    var caption  = document.getElementById('motionCaption');
    var dotsRow  = document.getElementById('motionDots');
    var progress = document.getElementById('motionProgressBar');
    if (!video || !caption || !dotsRow || !progress) return;
    var idx = 0;
    var ticker;

    function set(i) {
      idx = (i + clips.length) % clips.length;
      var c = clips[idx];
      video.src = c.url;
      video.load();
      var play = video.play();
      if (play && typeof play.catch === 'function') play.catch(function(){});
      caption.innerHTML =
        '<div class="motion-caption-eyebrow">' + (idx + 1).toString().padStart(2, '0') + ' / 06 \u00B7 ' + c.tag + '</div>' +
        '<div class="motion-caption-title">' + c.title + '</div>';
      dotsRow.querySelectorAll('button').forEach(function(b, n) {
        b.classList.toggle('active', n === idx);
        b.setAttribute('aria-selected', n === idx ? 'true' : 'false');
      });
      progress.style.width = '0%';
    }

    // Build dots
    dotsRow.innerHTML = clips.map(function(c, n) {
      var num = (n + 1).toString().padStart(2, '0');
      return '<button type="button" data-i="' + n + '" role="tab"' +
             (n === 0 ? ' class="active" aria-selected="true"' : ' aria-selected="false"') +
             '>' + num + ' \u00B7 ' + c.tag + '</button>';
    }).join('');
    dotsRow.querySelectorAll('button').forEach(function(b) {
      b.addEventListener('click', function() {
        clearInterval(ticker);
        set(parseInt(b.dataset.i, 10));
        startTicker();
      });
    });

    // Progress bar \u2014 animates to 100% over the auto-advance window
    function startTicker() {
      var DURATION = 6000; // 6s per clip auto-advance
      var start = Date.now();
      progress.style.width = '0%';
      ticker = setInterval(function() {
        var pct = Math.min(100, ((Date.now() - start) / DURATION) * 100);
        progress.style.width = pct + '%';
        if (pct >= 100) {
          clearInterval(ticker);
          set(idx + 1);
          startTicker();
        }
      }, 60);
    }

    // If a clip fails to load, skip to next after a brief moment
    video.addEventListener('error', function() {
      clearInterval(ticker);
      setTimeout(function() { set(idx + 1); startTicker(); }, 500);
    });

    set(0);
    startTicker();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>


<script>
/* =============================================================================
   CFG-NAV-1 \u00B7 Sticky-nav scroll-spy
   ----------------------------------------------------------------------------
   IntersectionObserver watches each section the sticky-nav links to. The link
   whose target is "most visible" gets '.is-current' (white bg + red text \u00B7 the
   visual inverse of '.primary'). One observer, one Map, one CSS class toggle.
   The Pricing & Availability primary button is NOT a section anchor (its href
   is /pricing-availability/), so it's excluded from the spy by the
   'a[href^="#"]' selector below.
   ============================================================================= */
(function() {
  var nav = document.querySelector('.sticky-nav');
  if (!nav) return;
  var links = Array.prototype.slice.call(nav.querySelectorAll('a[href^="#"]'));
  if (!links.length) return;
  var entries = [];
  links.forEach(function(a) {
    var id = a.getAttribute('href').slice(1);
    var sec = id ? document.getElementById(id) : null;
    if (sec) entries.push({ sec: sec, link: a, ratio: 0 });
  });
  if (!entries.length) return;
  function update() {
    var best = null, bestRatio = 0;
    entries.forEach(function(e) { if (e.ratio > bestRatio) { bestRatio = e.ratio; best = e; } });
    entries.forEach(function(e) { e.link.classList.toggle('is-current', e === best && bestRatio > 0); });
  }
  var io = new IntersectionObserver(function(items) {
    items.forEach(function(item) {
      entries.forEach(function(e) { if (e.sec === item.target) e.ratio = item.intersectionRatio; });
    });
    update();
  }, {
    rootMargin: '-20% 0px -55% 0px',
    threshold: [0, 0.1, 0.25, 0.5, 0.75, 1.0]
  });
  entries.forEach(function(e) { io.observe(e.sec); });
})();
</script>

<script>
// CFG-STATE-1 \u2014 derive ship-tier (QS / WB / MTO) from selected chip badges, render
// canonical 3-state status panel. Self-contained module \u00B7 no dependency on the
// configurator's state object \u00B7 re-derives by walking selected chips on every click.
// Custom RAL forces MTO (custom paint = factory work).
(function() {
  function deriveShipTier() {
    var section = document.getElementById('configurator');
    if (!section) return 'QS';
    var chips = section.querySelectorAll('.cfg-chip.selected, .cfg-chip[aria-pressed="true"]');
    var worst = 'QS';
    var sawCustomRal = false;
    chips.forEach(function(chip) {
      if (chip.dataset.field === 'finish' && chip.dataset.val === 'RAL') sawCustomRal = true;
      if (chip.querySelector('.cfg-chip-stock.mto')) worst = 'MTO';
      else if (chip.querySelector('.cfg-chip-stock.wb') && worst !== 'MTO') worst = 'WB';
    });
    if (sawCustomRal) {
      var input = document.getElementById('cfgRalInput');
      if (input && input.value && /^[0-9]{4}$/.test(input.value)) return 'MTO';
    }
    return worst;
  }
  function refreshShipTier() {
    var tier = deriveShipTier();
    var rowEl = document.getElementById('cfgShipTier');
    var iconEl = document.getElementById('cfgShipTierIcon');
    var textEl = document.getElementById('cfgShipTierText');
    var stockEl = document.getElementById('cfgShipTierStock');
    if (!rowEl || !iconEl || !textEl || !stockEl) return;
    if (tier === 'QS') {
      rowEl.style.background = 'rgba(95,199,122,0.08)';
      rowEl.style.border = '1px solid rgba(95,199,122,0.40)';
      iconEl.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#7fc998" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      textEl.innerHTML = '<strong style="color:#9bd6b1;">QuickShip \u00B7 \u00E0-la-carte assembly</strong> &middot; <span style="color:var(--text-secondary);">All selected components in stock \u2014 ships 2-3 day.</span>';
      stockEl.textContent = 'QuickShip \u00B7 2-3 day';
      stockEl.style.color = '#9bd6b1';
    } else if (tier === 'WB') {
      rowEl.style.background = 'rgba(96,168,255,0.08)';
      rowEl.style.border = '1px solid rgba(96,168,255,0.40)';
      iconEl.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#7fb6ff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>';
      textEl.innerHTML = '<strong style="color:#a8c9ff;">Workbench Assembly &middot; ~1-3 wk</strong> &middot; <span style="color:var(--text-secondary);">One or more selected components are workbench-assembled to order.</span>';
      stockEl.textContent = 'WB \u00B7 ~1-3 wk';
      stockEl.style.color = '#a8c9ff';
    } else {
      rowEl.style.background = 'rgba(255,159,28,0.08)';
      rowEl.style.border = '1px solid rgba(255,159,28,0.40)';
      iconEl.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#ffb14d" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>';
      textEl.innerHTML = '<strong style="color:#ffb14d;">Custom build &middot; Made-to-Order &middot; ~4-6 wk</strong> &middot; <span style="color:var(--text-secondary);">One or more selected components are MTO (custom finish, MTO option, or non-stocked variant).</span>';
      stockEl.textContent = 'MTO \u00B7 ~4-6 wk';
      stockEl.style.color = '#ffb14d';
    }
  }
  function init() {
    var section = document.getElementById('configurator');
    if (!section) return;
    section.addEventListener('click', function(e) {
      if (e.target.closest('.cfg-chip')) setTimeout(refreshShipTier, 50);
    });
    var ralInput = document.getElementById('cfgRalInput');
    if (ralInput) ralInput.addEventListener('input', function() { setTimeout(refreshShipTier, 50); });
    refreshShipTier();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
</BaseLayout>
