<script>
/* =============================================================================
   SECTION 9 \u2014 Configurator engine (Ramparts)
   Single user choice (finish). Wattage + CCT are DIP-set previews \u2014 they
   update the spec grid and lumen output but do NOT modify the SKU.
   SKU pattern: LWPE20-S3-U{D|B}
   ============================================================================= */
(function() {
  // Lumen output table \u2014 precomputed from datasheet. All values at MAX wattage
  // (20W) per CCT, then linear-scaled to lower wattage settings via watt ratio.
  // Peak intensity (cd) reflects the real IES test point at 20W/3000K (1,212 cd).
  var LUMEN = {
    // [wattage][cct] = lumens. Anchored on the Section 3 published 5000K table
    // (10W=1,340 \u00B7 15W=2,010 \u00B7 20W=2,650) and scaled by CCT efficacy ratio
    // (3000K=124, 4000K=139, 5000K=134 lm/W \u2192 0.925\u00D7 / 1.037\u00D7 of 5000K).
    // 20W\u00B73000K and 20W\u00B74000K hit the datasheet values exactly (2,450 / 2,750).
    '10': { '30': 1240, '40': 1390, '50': 1340 },
    '15': { '30': 1860, '40': 2085, '50': 2010 },
    '20': { '30': 2450, '40': 2750, '50': 2650 }
  };
  // Peak intensity (cd) at each (W, CCT) \u2014 IES test was 20W/3000K = 1,212 cd
  // Linear scaled (cd \u221D lumens within the same beam shape).
  function peakCd(w, cct) {
    var lm = LUMEN[w][cct];
    var ratio = lm / 2450; // anchor at 20W\u00B73000K \u00B7 1212 cd
    return Math.round(1212 * ratio);
  }

  // Default state: locked fields preselected, finish empty, DIPs at default
  var state = {
    model:   'LWPE20',
    series:  'S3R',  // 3-CCTselect series identifier
    voltage: 'U',
    finish:  null,   // user choice \u2014 drives counter
    wattage: '20',   // DIP default \u00B7 max wattage
    cct:     '50'    // DIP default \u00B7 5000K
  };

  // Finish-aware preview images (background already removed)
  var FINISH_IMG = {
    'B': '/products/ramparts/assets/hero/configurator-black.webp',
    'D': '/products/ramparts/assets/hero/configurator-darkbronze.webp'
  };

  function render() {
    // Counter
    var counterEl = document.getElementById('cfgCounter');
    var countEl   = document.getElementById('cfgCounterCount');
    // Model + Series + Voltage are auto-locked \u2192 3 fields always counted.
    // Finish adds the 4th once picked.
    var locked = 3 + (state.finish ? 1 : 0);
    countEl.textContent = locked;
    counterEl.classList.toggle('complete', locked === 4);

    // SKU pattern: LWPE20-S3R-U{D|B}/PS
    //   LWPE20 = family \u00B7 -S3R = Ramparts 3-CCTselect series
    //   -U     = Universal 120-277V
    //   {D|B}  = finish (Dark Bronze | Black)
    //   /PS    = integrated photocell (standard, always appended)
    var skuEl = document.getElementById('cfgSku');
    var fin = state.finish || '<span class="placeholder">_</span>';
    skuEl.innerHTML = 'LWPE20-S3R-U' + fin + '/PS';

    // Preview image swap by finish (defaults to Black photo when unconfigured)
    var imgEl = document.getElementById('cfgPreviewImg');
    if (imgEl) {
      var src = state.finish ? FINISH_IMG[state.finish] : FINISH_IMG['B'];
      if (imgEl.getAttribute('src') !== src) imgEl.setAttribute('src', src);
      imgEl.alt = 'Ramparts LWPE20 \u2014 ' + (state.finish === 'D' ? 'Dark Bronze' : 'Black') + ' finish preview';
    }

    // Tag
    var tag = document.getElementById('cfgPreviewTag');
    if (state.finish) {
      tag.textContent = (state.finish === 'D') ? 'DARK BRONZE' : 'BLACK';
    } else {
      tag.textContent = 'UNCONFIGURED';
    }

    // Spec grid \u00B7 finish
    var sf = document.getElementById('cfgSpecFinish');
    if (state.finish) {
      sf.classList.remove('placeholder');
      sf.textContent = (state.finish === 'D') ? 'Dark Bronze' : 'Black';
    } else {
      sf.classList.add('placeholder');
      sf.textContent = '\u2014 pick one \u2014';
    }

    // Spec grid \u00B7 wattage / CCT / output
    document.getElementById('cfgSpecWattage').textContent = state.wattage + 'W';
    var cctMap = { '30': '3000K', '40': '4000K', '50': '5000K' };
    document.getElementById('cfgSpecCCT').textContent = cctMap[state.cct];
    var lumens = LUMEN[state.wattage][state.cct];
    document.getElementById('cfgSpecLumens').textContent = lumens.toLocaleString() + ' lm \u00B7 ' + peakCd(state.wattage, state.cct).toLocaleString() + ' cd';

    // Incomplete warning + CTA gating
    var warn = document.getElementById('cfgIncomplete');
    var pricingCta = document.getElementById('cfgCtaPricing');
    var submittalCta = document.getElementById('cfgCtaSubmittal');
    if (!state.finish) {
      warn.classList.add('show');
      pricingCta.classList.add('disabled');
      submittalCta.classList.add('disabled');
    } else {
      warn.classList.remove('show');
      pricingCta.classList.remove('disabled');
      submittalCta.classList.remove('disabled');
      // Submittal link: pass the SKU + DIP context as query params
      var sku = 'LWPE20-S3R-U' + state.finish + '/PS';
      submittalCta.href = 'submittal_template.html?product=ramparts&sku=' + encodeURIComponent(sku) + '&wattage=' + state.wattage + '&cct=' + state.cct + '&voltage=U&finish=' + state.finish;
    }

    // SKU copy reset
    var copyLabel = document.getElementById('cfgSkuCopyLabel');
    var copyBtn   = document.getElementById('cfgSkuCopy');
    copyLabel.textContent = 'Copy SKU';
    copyBtn.classList.remove('copied');
  }

  function init() {
    // Wire all chips
    var chips = document.querySelectorAll('.cfg-section .cfg-chip');
    chips.forEach(function(chip) {
      if (chip.classList.contains('locked')) return;
      chip.addEventListener('click', function() {
        var f = chip.dataset.field;
        var v = chip.dataset.val;
        // Toggle within same field group: deselect siblings, select self
        var siblings = document.querySelectorAll('.cfg-chip[data-field="' + f + '"]');
        siblings.forEach(function(s) {
          s.classList.remove('selected');
          s.setAttribute('aria-pressed', 'false');
        });
        chip.classList.add('selected');
        chip.setAttribute('aria-pressed', 'true');
        state[f] = v;
        render();
      });
    });

    // Reset button \u2014 clears finish, restores DIP defaults
    var resetBtn = document.getElementById('cfgReset');
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        state.finish = null;
        state.wattage = '20';
        state.cct = '50';
        // Deselect finish chips
        document.querySelectorAll('.cfg-chip[data-field="finish"]').forEach(function(c) {
          c.classList.remove('selected'); c.setAttribute('aria-pressed', 'false');
        });
        // Restore wattage default
        document.querySelectorAll('.cfg-chip[data-field="wattage"]').forEach(function(c) {
          c.classList.toggle('selected', c.dataset.val === '20');
          c.setAttribute('aria-pressed', c.dataset.val === '20' ? 'true' : 'false');
        });
        // Restore CCT default
        document.querySelectorAll('.cfg-chip[data-field="cct"]').forEach(function(c) {
          c.classList.toggle('selected', c.dataset.val === '50');
          c.setAttribute('aria-pressed', c.dataset.val === '50' ? 'true' : 'false');
        });
        render();
      });
    }

    // Copy SKU
    var copyBtn = document.getElementById('cfgSkuCopy');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        if (!state.finish) return;
        var sku = 'LWPE20-S3R-U' + state.finish + '/PS';
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(sku).then(function() {
            document.getElementById('cfgSkuCopyLabel').textContent = 'Copied!';
            copyBtn.classList.add('copied');
            setTimeout(function() {
              document.getElementById('cfgSkuCopyLabel').textContent = 'Copy SKU';
              copyBtn.classList.remove('copied');
            }, 1800);
          });
        }
      });
    }

    render();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

