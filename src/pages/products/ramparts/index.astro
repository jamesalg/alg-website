  }
  .acc-card-sku {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-top: -4px;
  }
  .acc-card-cta {
    margin-top: auto;
    padding-top: 8px;
    font-family: 'JetBrains Mono', monospace;
