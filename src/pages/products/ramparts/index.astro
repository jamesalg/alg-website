        catEl.innerHTML = d.cat.replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
      }
      // Per-spec \u24B6 rendering (e.g. thermal\u24B6RMOR appears in the gasket specs)
      specsEl.innerHTML = d.specs.map(function(s) {
        var v = (s[1] || '').toString().replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
        return '<div class="acc-spec-row">' +
                 '<div class="acc-spec-key">' + s[0] + '</div>' +
                 '<div class="acc-spec-val">' + v + '</div>' +
               '</div>';
      }).join('');
      if (dsLink) {
        if (d.datasheet) {
          dsLink.href = d.datasheet;
          dsLink.style.display = '';
        } else {
          dsLink.style.display = 'none';
          dsLink.removeAttribute('href');
        }
      }
      // Clone the card visual into the modal hero panel
      var srcMedia = card.querySelector('.acc-card-img svg, .acc-card-img img.acc-card-photo');
      Array.from(imgWrap.querySelectorAll('svg, img.acc-card-photo')).forEach(function(s){ s.remove(); });
      if (srcMedia) {
        var clone = srcMedia.cloneNode(true);
        if (clone.tagName === 'IMG') {
          clone.style.maxWidth = '90%';
          clone.style.maxHeight = '90%';
          clone.style.objectFit = 'contain';
          clone.style.filter = 'drop-shadow(0 12px 24px rgba(0,0,0,0.6))';
        }
        imgWrap.appendChild(clone);
      }
      modal.classList.add('open');
    }
    function closeModal() { modal.classList.remove('open'); }

    cards.forEach(function(c) {
      c.addEventListener('click', function() { openModal(c); });
    });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

<!-- =============================================================================
     SECTION 9 — Configurator (Build Your Ramparts · live SKU builder)
     -------------------------------------------------------------------------
     Ramparts is the simplest configurator in the LWPE/LWPC line:
       • Single model class (LWPE20)
       • Single series (S3)
       • Single voltage (U / Universal 120-277V)
       • Two finishes: D (Dark Bronze) | B (Black) ← only real user choice
       • Photocell PS is standard — no suffix needed
     SKU pattern: LWPE20-S3R-U{D|B}/PS
     Wattage (10/15/20W) and CCT (3000/4000/5000K) are FIELD-SET via DIP
     post-install. They do NOT appear in the SKU. The configurator shows them
     in a second column (informational only) so the spec writer can preview
     output ranges without contaminating the order code.
     The simplicity story: order one SKU per finish — dial in the rest at install.
     ============================================================================= -->
