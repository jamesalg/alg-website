<script>
/* =============================================================================
   SECTION 9 · Liberty Configurator
   Builds: LSBX{wattage}-3CS-{voltage}L{finish}[/TAA][/{mount}][/{optic}]
                                                 [/{photocell}][/{sensor}][/{shield}]
   Per playbook: CFG-1 (submittal CTA), CFG-3 (chip badges), CFG-5/5a (share link),
                 CFG-COPY-3 density, CFG-STATE-1 ship-tier derivation.
   ============================================================================= */
(function() {
  'use strict';

  // RAL Classic legal validator (CFG-3 · subset of common 4-digit RAL codes)
  var RAL_VALID = new Set([
    1000, 1001, 1002, 1003, 1004, 1005, 1006, 1007, 1011, 1012, 1013, 1014, 1015, 1016, 1017, 1018, 1019, 1020, 1021, 1023, 1024, 1027, 1028, 1032, 1033, 1034,
    2000, 2001, 2002, 2003, 2004, 2008, 2009, 2010, 2011, 2012,
    3000, 3001, 3002, 3003, 3004, 3005, 3007, 3009, 3011, 3012, 3013, 3014, 3015, 3016, 3017, 3018, 3020, 3022, 3027, 3031,
    4001, 4002, 4003, 4004, 4005, 4006, 4007, 4008, 4009,
    5000, 5001, 5002, 5003, 5004, 5005, 5007, 5008, 5009, 5010, 5011, 5012, 5013, 5014, 5015, 5017, 5018, 5019, 5020, 5021, 5022, 5023, 5024,
    6000, 6001, 6002, 6003, 6004, 6005, 6006, 6007, 6008, 6009, 6010, 6011, 6012, 6013, 6014, 6015, 6016, 6017, 6018, 6019, 6020, 6021, 6022, 6024, 6025, 6026, 6027, 6028, 6029, 6032, 6033, 6034,
    7000, 7001, 7002, 7003, 7004, 7005, 7006, 7008, 7009, 7010, 7011, 7012, 7013, 7015, 7016, 7021, 7022, 7023, 7024, 7026, 7030, 7031, 7032, 7033, 7034, 7035, 7036, 7037, 7038, 7039, 7040, 7042, 7043, 7044, 7045, 7046, 7047,
    8000, 8001, 8002, 8003, 8004, 8007, 8008, 8011, 8012, 8014, 8015, 8016, 8017, 8019, 8022, 8023, 8024, 8025, 8028,
    9001, 9002, 9003, 9004, 9005, 9006, 9007, 9010, 9011, 9016, 9017, 9018
  ]);

  // State
  var state = {
    wattage: '100', voltage: 'U', finish: 'D', taa: '', mount: '', optic: '',
    photocell: '', sensor: '', shield: '', ral: ''
  };

  // Hydrate from URL on load (CFG-5/5a)
  function hydrateFromUrl() {
    var params = new URLSearchParams(window.location.search);
    ['wattage', 'voltage', 'finish', 'taa', 'mount', 'optic', 'photocell', 'sensor', 'shield', 'ral'].forEach(function(k) {
      if (params.has(k)) state[k] = params.get(k);
    });
  }

  // Build SKU from state
  function buildSku() {
    var sku = 'LSBX' + state.wattage + '-3CS-' + state.voltage + 'L' + state.finish;
    if (state.finish === 'RAL' && state.ral && RAL_VALID.has(parseInt(state.ral.replace(/\D/g, ''), 10))) {
      sku = 'LSBX' + state.wattage + '-3CS-' + state.voltage + 'L-' + state.ral.toUpperCase().replace(/\s+/g, '');
    }
    if (state.taa)       sku += '/' + state.taa;
    if (state.mount)     sku += '/' + state.mount;
    if (state.optic)     sku += '/' + state.optic;
    if (state.photocell) sku += '/' + state.photocell;
    if (state.sensor)    sku += '/' + state.sensor;
    if (state.shield)    sku += '/' + state.shield;
    return sku;
  }

  // CFG-STATE-1 · Derive ship tier from chip selections
  function deriveShipTier() {
    // Custom RAL forces MTO (workbench)
    if (state.finish === 'RAL' && state.ral) {
      return { code: 'WB', label: 'Workbench (Custom RAL)', cls: 'wb' };
    }
    // Walk every selected field, find any non-QS chip
    var fields = ['voltage', 'finish', 'taa', 'mount', 'optic', 'photocell', 'sensor', 'shield'];
    var anyMto = false;
    fields.forEach(function(f) {
      var btn = document.querySelector('.cfg-chip.is-selected[data-field="' + f + '"]');
      if (btn) {
        if (btn.querySelector('.cfg-chip-stock.mto')) anyMto = true;
        if (btn.querySelector('.cfg-chip-stock.wb'))  anyMto = true;
      }
    });
    // wattage chip is always QS · finish RAL handled above
    if (anyMto) {
      return { code: 'MTO', label: 'Made to Order', cls: 'mto' };
    }
    // All-QS · check if it's a "vanilla" SKU (no accessory adders) vs assembled QS combo
    var anyAdder = state.taa || state.mount || state.optic || state.photocell || state.sensor || state.shield;
    if (anyAdder) {
      return { code: 'QS-AC', label: 'QuickShip · à-la-carte assembly', cls: 'qs' };
    }
    return { code: 'QS', label: 'QuickShip · catalog SKU', cls: 'qs' };
  }

  // Render the live SKU + ship-tier + submittal href
  function refresh() {
    var sku = buildSku();
    document.getElementById('cfgSku').textContent = sku;

    var tier = deriveShipTier();
    document.getElementById('cfgShipTier').innerHTML = '<span class="' + tier.cls + '">' + tier.label + '</span>';

    // Build submittal link with URL params
    var params = new URLSearchParams();
    params.set('product', 'liberty');
    params.set('sku', sku);
    Object.keys(state).forEach(function(k) {
      if (state[k]) params.set(k, state[k]);
    });
    document.getElementById('cfgSubmittalCta').href = 'submittal_template.html?' + params.toString();
  }

  // Field selection handler
  function selectChip(field, val, btn) {
    var siblings = document.querySelectorAll('.cfg-chip[data-field="' + field + '"]');
    siblings.forEach(function(s) { s.classList.remove('is-selected'); });
    btn.classList.add('is-selected');
    state[field] = val;
    refresh();
  }

  // Hydrate UI from state (used after Quick Pick load)
  function hydrateUi() {
    Object.keys(state).forEach(function(field) {
      if (field === 'ral') return;
      var val = state[field];
      var match = document.querySelector('.cfg-chip[data-field="' + field + '"][data-val="' + val + '"]');
      if (match) {
        var siblings = document.querySelectorAll('.cfg-chip[data-field="' + field + '"]');
        siblings.forEach(function(s) { s.classList.remove('is-selected'); });
        match.classList.add('is-selected');
      }
    });
    var ralInput = document.getElementById('cfgRalInput');
    if (ralInput) ralInput.value = state.ral || '';
  }

  function init() {
    hydrateFromUrl();
    hydrateUi();

    document.querySelectorAll('.cfg-chip[data-field]').forEach(function(btn) {
      if (btn.getAttribute('data-disabled') === 'true') return;
      btn.addEventListener('click', function() {
        var field = btn.getAttribute('data-field');
        var val = btn.getAttribute('data-val');
        selectChip(field, val, btn);
      });
    });

    var ralInput = document.getElementById('cfgRalInput');
    if (ralInput) {
      ralInput.addEventListener('input', function() {
        state.ral = ralInput.value.trim();
        refresh();
      });
    }

    // Quick Pick handlers
    document.querySelectorAll('.cfg-qp-card').forEach(function(card) {
      card.addEventListener('click', function() {
        try {
          var qp = JSON.parse(card.getAttribute('data-qp'));
          Object.keys(qp).forEach(function(k) { state[k] = qp[k]; });
          state.taa = ''; state.ral = '';
          hydrateUi();
          refresh();
          // Smooth scroll to the configurator top
          document.getElementById('configurator').scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (e) { console.error('Quick Pick parse error', e); }
      });
    });

    // Share Configuration handler
    var shareBtn = document.getElementById('cfgShareBtn');
    var shareLabel = document.getElementById('cfgShareLabel');
    if (shareBtn) {
      shareBtn.addEventListener('click', function() {
        var params = new URLSearchParams();
        Object.keys(state).forEach(function(k) {
          if (state[k]) params.set(k, state[k]);
        });
        var url = window.location.origin + window.location.pathname + '?' + params.toString() + '#configurator';
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url).then(function() {
            shareLabel.textContent = 'Link Copied ✓';
            setTimeout(function() { shareLabel.textContent = 'Share Configuration'; }, 1800);
          });
        } else {
          window.prompt('Copy share link:', url);
        }
      });
    }

    refresh();
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>


<script>
/* =============================================================================
   SECTION 9 — Heritage Configurator engine
   8 user choices (Housing · Voltage · Finish · Optic · Mount · Photocell ·
   Sensor — plus auto-locked -3H1 CCTSELECT capability) · 2 field-set DIP
   (WATTSELECT, CCTSELECT) — informational only.
   SKU pattern (per James 2026-05-02 PM):
       LSBX3W{housing}-3H1-{voltage}{finish}{optic}/RB3{/mount?}{/PS?}{/MSP-?}
   Examples:
       LSBX3W150-3H1-UD3/RB3                      ← default · 150W DIP · 5000K DIP
       LSBX3W150-3H1-UD3/RB3/UA                   ← + universal mount adder
       LSBX3W150-3H1-UD3/RB3/UA/PS                ← + photocell
       LSBX3W150-3H1-UD3/RB3/UA/PS/MSP-ACS        ← fully-loaded
       LSBX3W300-3H1-HD3/RB3/SP/MSP-NLC           ← HV + slip-pole + SILVAIR
       LSBX3W150-3H1-URAL70163/RB3                ← custom RAL 7016 · Type III
   Datasheet rated: 150 lm/W flat (5000K).
   LM-79 measured: dispersion across cells — peak 175 lm/W (70W @ 4000K),
                   floor 127 lm/W (300W @ 3000K · 5000K). See Section 7.
   CONSTRAINT: H voltage is only valid on LSBX3W300. When housing flips to
   LSBX3W150, voltage auto-snaps to U.
   ============================================================================= */
(function() {
  // Datasheet rated lumens at 5000K (CCT-invariant per page 2 spec table)
  var LUMEN = {
    '150': { '70':  '10,500', '100': '15,000', '150': '22,500' },
    '300': { '200': '30,000', '240': '36,000', '300': '45,000' }
  };
  var HID = {
    '150': { '70':  '250W MH', '100': '400W MH', '150': '600W MH' },
    '300': { '200': '750W MH', '240': '1000W MH', '300': '1500W MH' }
  };
  var WATTS = {
    '150': ['70',  '100', '150'],
    '300': ['200', '240', '300']
  };
  var CCT_LABEL  = { '30': '3000K', '40': '4000K', '50': '5000K' };
  var FINISH_LBL = {
    'D':   'Dark Bronze (QS)',
    'B':   'Black (MTO)',
    'S':   'Silver (MTO)',
    'W':   'White (MTO)',
    'RAL': 'Custom RAL (MTO)'
  };
  var VOLTAGE_LBL = {
    'U': 'U · 120-277V universal (QS)',
    'H': 'H · 277-480V high-voltage (MTO · LSBX3W300 only)'
