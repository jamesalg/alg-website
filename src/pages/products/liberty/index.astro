   setting per datasheet page 2 spec table. Per-CCT measured variance (if any)
   lives in Section 7 photometrics where the LM-79 detail surfaces; the spec
   table uses datasheet nominals so the buyer cites the published numbers.
   2 housing classes × 3 WATTSELECT settings each = 6 rows total.
   HID replacement values from Heritage Sell Sheet "Up to 1000W HID equivalent"
   framing — datasheet doesn't print explicit per-W HID conversions, so these
   are conservative trade reference values rather than datasheet-published.
   ============================================================================= */
(function() {
  var DATA = {
    '3W150': {
      'rows': [
        { w: '70W',     lm: '10,500',  lpw: '150 lm/W',  hid: '250W MH',  cct: '3000 / 4000 / 5000K' },
        { w: '100W',    lm: '15,000',  lpw: '150 lm/W',  hid: '400W MH',  cct: '3000 / 4000 / 5000K' },
        { w: '150W ★',  lm: '<strong>22,500</strong>', lpw: '<strong>150 lm/W</strong>', hid: '600W MH', cct: '3000 / 4000 / 5000K' }
      ],
      'foot': '★ <em><strong>LSBX3W150</strong> — the 150W-class housing covering the 250W to 600W metal halide retrofit lane in standard parking lots, school perimeters, retail strip lots, and small-to-mid commercial sites. ' +
              'WATTSELECT field-pick at install: 70 / 100 / 150W via 3-position DIP — ' +
              '<strong>150W is the factory default setting</strong>. ' +
              'CCTSELECT field-pick at install: 3000K / 4000K / 5000K via DIP — <strong>5000K is the datasheet default</strong>. ' +
              '22,500 lm @ 150W / 150 lm/W is the datasheet ceiling at 5000K. ' +
              'SKU pattern: <code>LSBX3W150-3H1-UD3/RB3</code> — universal 120-277V QuickShip + 0-10V dim driver + 6KVA built-in surge + photocell-ready 3-pin receptacle with shorting cap, all standard. ' +
              '9.84 × 16.22 × 2.37 in · 6.72 lb. Optional <strong>4 mount adders</strong> (RS · TN · UA · SP) + <strong><code>/PS</code> photocell</strong> + <strong><code>/BLS</code> PIR Bi-Level sensor</strong> — see configurator. ' +
              'Engineered to run in -40°F to 113°F environments via the respirator pressure-management feature.</em>'
    },
    '3W300': {
      'rows': [
        { w: '200W',    lm: '30,000',  lpw: '150 lm/W',  hid: '750W MH',   cct: '3000 / 4000 / 5000K' },
        { w: '240W',    lm: '36,000',  lpw: '150 lm/W',  hid: '1000W MH',  cct: '3000 / 4000 / 5000K' },
        { w: '300W ★',  lm: '<strong>45,000</strong>', lpw: '<strong>150 lm/W</strong>', hid: '1500W MH', cct: '3000 / 4000 / 5000K' }
      ],
      'foot': '★ <em><strong>LSBX3W300</strong> — the line-topper for big-box parking lots, distribution-center perimeters, sports-court yards, and 1000W-1500W MH 1:1 swap-outs. ' +
              'Different footprint from LSBX3W150 (13.31 × 21.14 × 2.37 in · 10.58 lb) but shares the 2.37-in slim depth. ' +
              'WATTSELECT field-pick at install: 200 / 240 / 300W via 3-position DIP — ' +
              '<strong>300W is the factory default setting</strong>. CCTSELECT: 3000K / 4000K / 5000K via DIP. ' +
              '45,000 lm @ 300W / 150 lm/W replaces 1000W to 1500W metal halide at 5000K. ' +
              'SKU pattern: <code>LSBX3W300-3H1-UD3/RB3</code> · same 0-10V dim driver and universal voltage as LSBX3W150, heavier driver chamber (10.58 vs. 6.72 lb). ' +
              '<strong>HV variant available (-HD)</strong> for 277-480V industrial canopies — pick <code>LSBX3W300-3H1-HD3/RB3</code> when the panel is 480V three-phase. Same 4 mount adders (RS · TN · UA · SP) and same /PS + /BLS optional accessory ladder as LSBX3W150.</em>'
    }
  };

  function init() {
    var tabs   = document.querySelectorAll('.spec-watt-tab[data-model]');
    var tbody  = document.getElementById('specTableBody');
    var tfoot  = document.getElementById('specTableFoot');
    if (!tabs.length || !tbody) return;

    function render(model) {
      var d = DATA[model];
      if (!d) return;
      tbody.innerHTML = d.rows.map(function(r) {
        var defaultClass = r.w.indexOf('★') > -1 ? ' class="is-default"' : '';
        return '<tr' + defaultClass + '>' +
                 '<td>' + r.w   + '</td>' +
                 '<td>' + r.lm  + ' lm</td>' +
                 '<td>' + r.lpw + '</td>' +
                 '<td>' + r.hid + '</td>' +
                 '<td>' + r.cct + '</td>' +
               '</tr>';
      }).join('');
      tfoot.innerHTML = d.foot;
    }

    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        render(t.dataset.model);
      });
    });

    render('3W150');  // Default — LSBX3W150 (volume retrofit lane)
  }

  // Zoom modal for dimensions drawing
  function initZoom() {
    var btn = document.getElementById('dimZoomBtn');
    var modal = document.getElementById('dimZoomModal');
    var close = document.getElementById('dimZoomClose');
    if (!btn || !modal) return;
    btn.addEventListener('click', function() { modal.classList.add('open'); });
    modal.addEventListener('click', function(e) {
      if (e.target === modal) modal.classList.remove('open');
    });
    if (close) close.addEventListener('click', function() { modal.classList.remove('open'); });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') modal.classList.remove('open');
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { init(); initZoom(); });
  } else { init(); initZoom(); }
})();
</script>

