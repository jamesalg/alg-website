    position: relative; text-align: center; z-index: 1;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-secondary);
  }
  .family-card-placeholder-mark {
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--brand-red);
    font-weight: 700; margin-bottom: 8px;
  }
  .family-card-placeholder-title { font-size: 18px; font-weight: 700; letter-spacing: -0.005em; }
  .family-card-placeholder-sub  { font-size: 10.5px; color: var(--text-muted); margin-top: 8px; letter-spacing: 0.06em; }


