  }
  .magswap-inner { max-width: 1280px; margin: 0 auto; position: relative; z-index: 1; }
  .magswap-head { text-align: center; max-width: 760px; margin: 0 auto 56px; }
  .magswap-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--brand-red, var(--brand-red));
    margin-bottom: 16px;
    display: inline-block;
    padding: 4px 12px; border-radius: 1px;
    background: rgba(226,35,26,0.10);
    border: 1px solid rgba(226,35,26,0.32);
  }
  .magswap-title {
    font-family: 'Lato', system-ui, sans-serif !important;
    font-size: 38px; font-weight: 700; line-height: 1.15;
    color: var(--text-primary);
    margin: 0 0 14px 0;
  }
  .magswap-title em {
    font-style: normal;
    color: var(--brand-red, var(--brand-red));
  }
  .magswap-sub {
    font-size: 15px; line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }
  .magswap-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 56px;
  }
  .magswap-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
    display: flex; flex-direction: column;
  }
  .magswap-card-img {
    aspect-ratio: 4 / 3;
    background: var(--text-primary);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .magswap-card-img img { width: 90%; height: 90%; object-fit: contain; }
  .magswap-card-body { padding: 22px 20px 24px; }
  .magswap-card-step {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--brand-red, var(--brand-red));
    margin-bottom: 8px;
  }
  .magswap-card-title {
    font-family: 'Lato', system-ui, sans-serif !important;
    font-size: 17px; font-weight: 700; line-height: 1.25;
    color: var(--text-primary);
    margin: 0 0 8px 0;
  }
  .magswap-card-body p {
    font-size: 13px; line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
  }

  .magswap-bullets {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    border-top: 1px solid var(--line);
