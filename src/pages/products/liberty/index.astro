   ============================================================================= */
(function() {
  'use strict';

  // 5 housing classes · 3 wattages each · 3-CCT each · CCT-invariant lumens (per datasheet).
  // Lumens column shows the ★ default wattage's 5000K spec; off-default rows scale ratio-ally.
  var SPEC_DATA = {
    'L100': {
      title:   'LSBX100 · 50 / 75 / 100W',
      meta:    '3-WATTSELECT × 3-CCTSELECT · lumens stated at 5000K · 154 lm/W (peak)',
      rows: [
