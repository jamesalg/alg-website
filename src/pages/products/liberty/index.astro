      title: 'Dimensions · LSBX300',
      rows: [
        { mount: 'Slip-Fitter (SF)',  l: '28.15', w: '13.86', d: '2.95' },
        { mount: 'Round/Square (RS)', l: '31.38', w: '13.86', d: '6.30' },
        { mount: 'Trunnion (TN)',     l: '29.69', w: '13.86', d: '3.15' },
        { mount: 'Universal (UA)',    l: '30.98', w: '13.86', d: '6.30' }
      ]
    },
    '450W': {
      title: 'Dimensions · LSBX450',
      rows: [
        { mount: 'Slip-Fitter (SF)',  l: '32.40', w: '14.90', d: '3.60' },
        { mount: 'Round/Square (RS)', l: '34.00', w: '14.90', d: '6.30' },
        { mount: 'Trunnion (TN)',     l: '30.50', w: '14.90', d: '3.10' },
        { mount: 'Universal (UA)',    l: '33.60', w: '14.90', d: '6.30' }
      ]
    }
  };

  function renderHousing(housing) {
    var d = SPEC_DATA[housing];
    if (!d) return;
    document.getElementById('specTableTitle').textContent = d.title;
    document.getElementById('specTableMeta').textContent = d.meta;
    document.getElementById('specTableBody').innerHTML = d.rows.map(function(r) {
      var isDef = r.w.indexOf('★') > -1;
      return '<tr' + (isDef ? ' class="is-default"' : '') + '>' +
               '<td>' + r.w + '</td>' +
               '<td>' + r.cct + '</td>' +
               '<td>' + r.lm + '</td>' +
               '<td>' + r.lpw + '</td>' +
               '<td>' + r.volt + '</td>' +
               '<td>' + r.cri + '</td>' +
             '</tr>';
    }).join('');
    document.getElementById('specTableFoot').innerHTML = d.foot;

    // Update dimensions panel based on the housing's dim group
    var dim = DIM_DATA[d.dimGroup];
    if (dim) {
      document.getElementById('specDimTitle').textContent = dim.title;
      document.getElementById('specDimBody').innerHTML = dim.rows.map(function(r) {
        return '<tr>' +
                 '<td>' + r.mount + '</td>' +
                 '<td>' + r.l + '"</td>' +
                 '<td>' + r.w + '"</td>' +
                 '<td>' + r.d + '"</td>' +
               '</tr>';
      }).join('');
    }
  }

  function init() {
    var tabs = document.querySelectorAll('.spec-tab[data-housing]');
    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) { x.classList.remove('is-active'); x.setAttribute('aria-selected', 'false'); });
        t.classList.add('is-active');
        t.setAttribute('aria-selected', 'true');
        renderHousing(t.getAttribute('data-housing'));
      });
    });
    renderHousing('L100'); // default
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>


