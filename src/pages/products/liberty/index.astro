    margin-bottom: 14px;
    display: inline-flex; align-items: center; gap: 12px;
  }
  .wp-family-eyebrow::before, .wp-family-eyebrow::after {
    content: ""; display: block; width: 28px; height: 1px; background: var(--brand-red);
  }
  .wp-family-title {
    font-size: 38px; font-weight: 700;
    letter-spacing: -0.005em; margin-bottom: 12px; line-height: 1.05;
  }
  .wp-family-sub {
    font-size: 15px; color: var(--text-secondary);
    max-width: 720px; margin: 0 auto; line-height: 1.6;
  }

  .family-card {
    background: var(--bg-spec);
    border: 1px solid var(--line);
    border-radius: 4px;
    text-decoration: none; color: inherit;
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: border-color 0.2s, transform 0.2s;
  }
  .family-card:hover {
    border-color: rgba(243,39,64,0.45);
    transform: translateY(-3px);
  }
  .family-card-img {
    background: var(--bg-darker);
    height: 160px;
    display: flex; align-items: center; justify-content: center;
    border-bottom: 1px solid var(--line);
    color: rgba(255,255,255,0.65);
    position: relative;
  }
  .family-card-img .family-card-photo {
    max-width: 88%; max-height: 88%;
    width: auto; height: auto;
    object-fit: contain;
    filter: drop-shadow(0 8px 14px rgba(0,0,0,0.5));
  }
  .family-card-tag {
    position: absolute; top: 12px; left: 12px;
    z-index: 2;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    background: rgba(0,0,0,0.55);
    border: 1px solid rgba(255,255,255,0.10);
    padding: 4px 8px; border-radius: 1px;
  }
  .family-card-body {
    padding: 20px 22px 22px;
    display: flex; flex-direction: column;
    gap: 10px; flex: 1;
  }
  .family-card-cat {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
