<script>
/* =============================================================================
   SECTION 7 · Photometrics tab switcher
   Swap polar SVG + stats based on housing × optic selection. Stats parsed
   from the live IES candela tables (Python pre-rendered the SVGs and embedded
   peak/lumens/efficacy in the SVG title text).
   ============================================================================= */
(function() {
  'use strict';

  // Per-(housing, optic) data block · pre-computed from IES parse 2026-05-05
  // Format: { svg, peak, lumens, efficacy, file }
  var DATA = {
    '100-T5': { svg: 'lsbx100-t5.svg', peak: 5525,  lumens: 16237, efficacy: 164, file: 'LSBX-100W-120V-5K-T5.ies' },
    '150-T2': { svg: 'lsbx150-t2.svg', peak: 8172,  lumens: 23426, efficacy: 156, file: 'LSBX-150W-277V-5K-T2.ies' },
    '150-T3': { svg: 'lsbx150-t3.svg', peak: 6359,  lumens: 21160, efficacy: 142, file: 'LSBX-150W-120V-3K-T3.ies' },
    '150-T4': { svg: 'lsbx150-t4.svg', peak: 6120,  lumens: 23264, efficacy: 155, file: 'LSBX-150W-277V-5K-T4.ies' },
    '150-T5': { svg: 'lsbx150-t5.svg', peak: 6985,  lumens: 24238, efficacy: 162, file: 'LSBX-150W-277V-5K-T5.ies' },
    '200-T2': { svg: 'lsbx200-t2.svg', peak: 10197, lumens: 29170, efficacy: 149, file: 'LSBX-200W-277V-5K-T2.ies' },
    '200-T4': { svg: 'lsbx200-t4.svg', peak: 7755,  lumens: 29531, efficacy: 151, file: 'LSBX-200W-277V-5K-T4.ies' },
    '200-T5': { svg: 'lsbx200-t5.svg', peak: 8588,  lumens: 29954, efficacy: 154, file: 'LSBX-200W-277V-5K-T5.ies' },
    '300-T2': { svg: 'lsbx300-t2.svg', peak: 17018, lumens: 43751, efficacy: 149, file: 'LSBX-300W-277V-5K-T2.ies' },
    '300-T3': { svg: 'lsbx300-t3.svg', peak: 12918, lumens: 43473, efficacy: 147, file: 'LSBX-300W-277V-5K-T3.ies' },
    '300-T4': { svg: 'lsbx300-t4.svg', peak: 12590, lumens: 43007, efficacy: 147, file: 'LSBX-300W-277V-5K-T4.ies' },
    '300-T5': { svg: 'lsbx300-t5.svg', peak: 12033, lumens: 43723, efficacy: 149, file: 'LSBX-300W-277V-5K-T5.ies' },
    '450-T4': { svg: 'lsbx450-t4.svg', peak: 19543, lumens: 64143, efficacy: 143, file: 'LSBX-450W-120V-4K-T4.ies' }
  };

  var DIST_HINTS = {
    'T2': 'Type-II distribution &mdash; narrow side-throw for narrow roadways and walkways.',
    'T3': 'Type-III distribution &mdash; standard for parking lots and roadways with side-throw bias.',
    'T4': 'Type-IV distribution &mdash; forward-throw for perimeter and wall-mount applications.',
    'T5': 'Type-V distribution &mdash; symmetric circular for area lighting and intersections.'
  };

  var modelTabs = document.querySelectorAll('#photoModelTabs .photo-tab');
  var opticTabs = document.querySelectorAll('#photoOpticTabs .photo-tab');
  var imgEl   = document.getElementById('photoImg');
  var peakEl  = document.getElementById('photoStatPeak');
  var lumEl   = document.getElementById('photoStatLumens');
  var typeEl  = document.getElementById('photoStatType');
  var hintEl  = document.getElementById('photoStatHint');
  var fileEl  = document.getElementById('photoStatFile');

  var state = { housing: '150', optic: 'T3' };

  function refresh() {
    var key = state.housing + '-' + state.optic;
    var d = DATA[key];
    // Disable optic tabs that don't have data for this housing
    opticTabs.forEach(function(t) {
      var optic = t.getAttribute('data-optic');
      var has = !!DATA[state.housing + '-' + optic];
      t.setAttribute('data-disabled', has ? 'false' : 'true');
    });
    if (!d) {
      // Auto-pick the first available optic for this housing
      var fallback = ['T3','T4','T5','T2'].find(function(o) { return DATA[state.housing + '-' + o]; });
      if (fallback) {
        state.optic = fallback;
        opticTabs.forEach(function(t) {
          t.classList.toggle('active', t.getAttribute('data-optic') === fallback);
          t.setAttribute('aria-selected', t.getAttribute('data-optic') === fallback ? 'true' : 'false');
        });
        d = DATA[state.housing + '-' + state.optic];
      }
    }
    if (!d) return;
    imgEl.src = 'assets/liberty/photometrics/' + d.svg;
    imgEl.alt = 'Liberty LSBX' + state.housing + ' Type-' + state.optic.charAt(1) + ' photometric distribution polar plot rendered from LM-79 IES test data · peak ' + d.peak + ' cd · ' + d.lumens + ' lm · ' + d.efficacy + ' lm/W';
    peakEl.textContent = d.peak.toLocaleString() + ' cd';
    lumEl.textContent  = d.lumens.toLocaleString() + ' lm';
    typeEl.textContent = 'Type-' + state.optic.charAt(1);
    hintEl.innerHTML   = DIST_HINTS[state.optic];
    fileEl.textContent = d.file;
  }

  modelTabs.forEach(function(t) {
    t.addEventListener('click', function() {
      modelTabs.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-selected','false'); });
      t.classList.add('active');
      t.setAttribute('aria-selected','true');
      state.housing = t.getAttribute('data-housing');
      refresh();
    });
  });
  opticTabs.forEach(function(t) {
    t.addEventListener('click', function() {
      if (t.getAttribute('data-disabled') === 'true') return;
      opticTabs.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-selected','false'); });
      t.classList.add('active');
      t.setAttribute('aria-selected','true');
      state.optic = t.getAttribute('data-optic');
      refresh();
    });
  });

  refresh();
})();
</script>


<script>
/* =============================================================================
