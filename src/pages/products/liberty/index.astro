  .cfg-head { text-align: center; max-width: 760px; margin: 0 auto 40px; }
  .cfg-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--brand-red, var(--brand-red)); margin-bottom: 14px;
  }
  .cfg-title {
    font-family: 'Lato', system-ui, sans-serif !important;
    font-size: 32px; font-weight: 700; color: var(--text-primary);
    margin: 0 0 12px 0;
  }
  .cfg-sub { font-size: 14px; line-height: 1.6; color: var(--text-secondary); margin: 0; }

  /* 2-col layout: chips | live preview + SKU + ship-tier */
  .cfg-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 24px;
    margin-bottom: 40px;
  }
  .cfg-col-fields {
    background: var(--bg-spec);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 24px;
  }
  .cfg-col-preview {
    position: sticky; top: 24px;
    align-self: start;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 22px;
    display: flex; flex-direction: column;
    max-height: calc(100vh - 48px);
  }

  /* Chip ladder · field rows */
  .cfg-field { margin-bottom: 22px; }
  .cfg-field:last-child { margin-bottom: 0; }
  .cfg-field-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px; font-weight: 700;
    letter-spacing: 0.10em; text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 10px;
    display: flex; align-items: baseline; justify-content: space-between;
  }
  .cfg-field-label-help {
    font-family: 'Lato', system-ui, sans-serif !important;
    font-size: 11px; font-weight: 400;
    text-transform: none; letter-spacing: 0;
    color: var(--text-muted);
  }
  .cfg-chips {
    display: flex; flex-wrap: wrap; gap: 6px;
  }
  .cfg-chip {
    background: transparent;
    border: 1px solid var(--line-medium);
    color: var(--text-secondary);
    padding: 8px 12px;
    border-radius: 1px;
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    display: inline-flex; align-items: center; gap: 8px;
    transition: background 120ms, color 120ms, border-color 120ms;
  }
  .cfg-chip:hover {
    background: rgba(255,255,255,0.05);
    color: var(--text-primary);
    border-color: rgba(255,255,255,0.28);
  }
  .cfg-chip.is-selected {
    background: var(--brand-red, var(--brand-red));
    border-color: var(--brand-red, var(--brand-red));
    color: #fff;
  }
  .cfg-chip-stock {
    font-size: 8.5px; font-weight: 700;
    letter-spacing: 0.06em;
    padding: 2px 5px; border-radius: 1px;
    line-height: 1;
  }
  .cfg-chip-stock.qs  { background: rgba(74,222,128,0.18); color: #4ade80; }
  .cfg-chip-stock.mto { background: rgba(255,159,28,0.18); color: #ffb14d; }
  .cfg-chip-stock.wb  { background: rgba(96,168,255,0.18); color: #60a8ff; }
  .cfg-chip.is-selected .cfg-chip-stock { background: var(--line-medium); color: #fff; }
  .cfg-chip-val {
    font-family: 'Lato', system-ui, sans-serif;
    font-size: 12px;
    color: inherit;
  }
  .cfg-chip-code { color: inherit; opacity: 0.65; font-size: 10.5px; }
  .cfg-chip.is-selected .cfg-chip-code { opacity: 0.85; }
  .cfg-chip[data-disabled="true"] { opacity: 0.35; cursor: not-allowed; pointer-events: none; }

  /* Custom RAL input */
  .cfg-ral-input {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--line-medium);
    color: var(--text-primary);
    padding: 8px 12px;
    border-radius: 1px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    width: 110px;
  }

  /* Right col · preview + SKU + ship-tier */
  .cfg-preview-img {
    background: var(--text-primary);
    border-radius: 2px;
    aspect-ratio: 4/3;
