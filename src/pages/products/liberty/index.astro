    object-fit: contain; object-position: center;
  }
  .acc-modal-drill-svg-cta {
    position: absolute; right: 14px; bottom: 14px;
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 10px; border-radius: 1px;
    background: var(--brand-red); color: #fff;
    font-size: 11px; font-weight: 700; letter-spacing: 0.04em;
    box-shadow: 0 2px 6px rgba(0,0,0,0.25);
  }
  .acc-modal-drill-svg-cta svg { width: 13px; height: 13px; }

  /* ---------- Fullscreen drill-pattern viewer (#drillModal) ---------- */
  .drill-modal {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.92);
    display: none; align-items: center; justify-content: center;
    z-index: 9999;
    padding: 24px;
  }
  .drill-modal.open { display: flex; }
  .drill-modal-panel {
    background: var(--text-primary);
    border-radius: 4px;
    width: 100%; max-width: 1400px;
    max-height: 92vh;
    display: flex; flex-direction: column;
    box-shadow: 0 30px 80px rgba(0,0,0,0.6);
    overflow: hidden;
  }
  .drill-modal-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #E5E5E5;
    background: #FAFAFA;
  }
  .drill-modal-head-text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .drill-modal-title {
    font-size: 16px; font-weight: 700; color: #1A1A1A;
    margin: 0; line-height: 1.25;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .drill-modal-source {
    font-size: 11px; color: #666;
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .drill-modal-close {
    flex-shrink: 0; margin-left: 16px;
    width: 36px; height: 36px;
    border-radius: 1px; border: 1px solid #DDD;
    background: var(--text-primary); color: #666;
    cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
  }
  .drill-modal-close:hover { background: var(--brand-red); color: #fff; border-color: var(--brand-red); }
  .drill-modal-close svg { width: 16px; height: 16px; }
  .drill-modal-body {
    flex: 1 1 auto;
    overflow: auto;
    background: #F5F5F5;
    padding: 24px;
    display: flex; align-items: center; justify-content: center;
  }
  .drill-modal-body img {
    display: block; max-width: 100%; max-height: 100%;
    width: auto; height: auto;
    background: var(--text-primary);
    box-shadow: 0 4px 14px rgba(0,0,0,0.08);
  }
  .drill-modal-foot {
    padding: 10px 20px;
    border-top: 1px solid #E5E5E5;
    background: #FAFAFA;
    font-size: 11px; color: #666;
    display: flex; align-items: center; justify-content: space-between;
    gap: 10px;
  }
  .drill-modal-foot-letter {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    background: var(--brand-red); color: #fff;
    padding: 2px 8px; border-radius: 1px;
    letter-spacing: 0.06em;
  }


  /* ---------- Section 9 · Configurator ---------- */
  .cfg-section {
    padding: 96px 24px 96px;
    background: var(--bg-page);
    border-top: 1px solid var(--line);
