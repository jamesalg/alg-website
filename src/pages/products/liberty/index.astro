<script>
/* =============================================================================
   SECTION 8 — Heritage "In the Box" modal wiring.
   3 entries · all standard pre-fitted · click-to-detail pattern from
   Pathfinder/Navigator/Atlanta scaffold. Per PDP_BUILD_PLAYBOOK rule #5:
   2-CTA modal, no per-component datasheet.
   IMPORTANT: this section uses inbox* IDs (inboxModal / inboxGrid / inboxModal*)
   so it doesn't collide with Section 8b accessories which owns accModal / accGrid
   per CFG-ACC-1.
   ============================================================================= */
(function() {
  var INBOX = {
    'lens': {
      cat: 'Optic · Pre-fitted',
      title: 'Type-III darkⒶRCH Optic',
      sku: 'UV-stabilized polycarbonate · Dark Sky compliant · Type IV / V available MTO',
      model: 'Type-III forward-throw distribution · darkⒶRCH semi-cutoff geometry',
      desc: 'Default optic on every Heritage. <strong>Type-III forward-throw</strong> &mdash; the contractor default for parking-lot poles, school perimeters, retail strip lots, roadway overlays. <strong>UV-stabilized polycarbonate</strong> lens, <strong>dark<span class="aa">Ⓐ</span>RCH semi-cutoff</strong> &mdash; Dark Sky compliant for IDA zones, residential overlays, observatory zones. <strong>Type IV and V</strong> available MTO (<code>/OT4</code> / <code>/OT5</code>) &mdash; factory-installed, not field-swappable.',
      specs: [
        ['Material', 'UV-stabilized polycarbonate · refractor lens'],
        ['Distribution (default)', 'Type III · forward-throw'],
        ['Distribution (MTO)', 'Type IV (/OT4 forward + lateral) · Type V (/OT5 omnidirectional)'],
        ['Dark Sky', 'darkⒶRCH semi-cutoff · IDA-zone compliant on all 3 optic types'],
        ['Sealing', 'Sealed at housing interface · part of IP65 wet-location envelope'],
        ['UV resistance', 'UV-stabilized for outdoor exposure'],
        ['Service', 'Lens not field-replaceable; housing assembly is the service unit'],
        ['Effective for', 'Parking lots · school perimeters · retail strip lots · roadway overlay · loading-dock approaches · drive-through entry approaches'],
        ['vs Keystone XFit', 'Keystone ships Type IV + V loose lenses in the box (OpticSwap UX win); Heritage ships factory-installed optic of choice (no loose-parts at install)']
      ]
    },
    'driver': {
      cat: 'contrⒶLS · Standard',
      title: '0-10V Dim Driver · Universal Voltage · 6KVA Surge',
      sku: 'U 120-277V QuickShip · H 277-480V Made-to-Order on LSBX3W300 only · 6KVA built-in surge',
      model: '0-10V analog dim driver · isolated · 100% to ~10% smooth dim',
      desc: '0-10V analog dim driver standard on every Heritage. <strong>Two voltage classes:</strong> <code>U</code> universal 120-277V (QuickShip default for commercial 277V service) and <code>H</code> 277-480V MTO &mdash; <strong>HV only on the LSBX3W300 housing</strong>; LSBX3W150 is 120-277V only. Wire violet/grey 0-10V leads to scheduling, DALI, or a 0-10V dimmer. <strong>6KVA surge built-in</strong> &mdash; clears IEEE C62.41 Cat C3 out of the box. Optional inline SPDs: 10SP-277 &middot; 20SP-277 &middot; 10SP-480 &middot; 20SP-480. Optional photocell <code>/PS</code> and 4 sensor variants (BLS &middot; BLS-5D &middot; ACS &middot; NLC) layer on top.',
      specs: [
        ['Driver type', '0-10V analog dimming · isolated · 100% to ~10% smooth dim'],
        ['Voltage range (U)', '120-277V universal (QuickShip default · both housings)'],
        ['Voltage range (H)', '277-480V high-voltage (Made-to-Order · LSBX3W300 housing only)'],
        ['Power factor', '> 0.90 at full load'],
        ['Total harmonic distortion', '< 20% at full load'],
        ['Surge protection', '6KVA built-in (IEEE C62.41 Cat C3) · 10/20KVA optional inline SPD'],
        ['Operating temperature', '−40°F to 113°F (industrial-grade thermal envelope)'],
        ['Optional add-ons', '/PS integrated photocell · /MSP-BLS bi-level · /MSP-BLS-5D bi-level + dials · /MSP-ACS DLC NLC mesh · /MSP-NLC SILVAIR SIG mesh'],
        ['vs competition', 'RAB ALED, Keystone XFit, Lithonia DSX0 — most ship 6-10KVA surge; Heritage matches at 6KVA built-in and offers stack-up to 20KVA inline at the ECO tier']
      ]
    },
    'receptacle': {
      cat: 'Photocell · Pre-fitted',
      title: 'Photocell-Ready 3-pin Receptacle + Shorting Cap',
      sku: '3-pin · ANSI C136.10 · /RB3 in SKU · accepts /PS adder or 3rd-party twist-lock',
      model: 'ANSI C136.10 3-pin twist-lock receptacle · top-of-housing · pre-fitted with shorting cap',
      desc: '<strong>3-pin twist-lock photocell receptacle</strong> on top of every Heritage &mdash; the <code>/RB3</code> in the SKU. <strong>ANSI C136.10</strong>, accepts any utility-grade photocell, NEMA timer, or controller. Ships pre-fitted with a <strong>shorting cap</strong> &mdash; default ON-when-powered. Three install paths: (1) keep the shorting cap, run dusk-to-dawn from a building-side relay or astronomical timer; (2) order <code>/PS</code> integrated photocell (factory-installs in place of the cap); (3) field-install any third-party twist-lock photocell &mdash; vendor-neutral.',
      specs: [
        ['Type', '3-pin twist-lock receptacle · top-of-housing · molded weatherproof'],
        ['Standard', 'ANSI C136.10 · vendor-neutral · accepts any C136.10-compliant photocell or controller'],
        ['SKU segment', '/RB3 in the standard SKU · pre-fitted on every active Heritage'],
        ['Shorting cap', 'Pre-fitted at factory · removes for photocell install · keep on hand at install'],
        ['Optional /PS', 'Factory-installed integrated photocell · ships in place of the shorting cap'],
        ['Third-party use', 'Accepts any utility-grade twist-lock photocell, astronomical timer, or NEMA controller (Tork, Intermatic, SunRise, etc.)'],
        ['Compatibility note', 'For networked controls (/MSP-ACS or /MSP-NLC), the sensor mounts on a separate sensor-ready port on the bottom of the housing — the photocell receptacle is independent and can stack with networked controls if both are spec\'d'],
        ['Wet-location', 'IP65 sealed at the housing interface · holds across thermal cycles via the respirator pressure-management feature']
      ]
    }
  };

  function init() {
    var grid     = document.getElementById('inboxGrid');
    var modal    = document.getElementById('inboxModal');
    var closeBtn = document.getElementById('inboxModalClose');
    var imgWrap  = document.getElementById('inboxModalImg');
    var catEl    = document.getElementById('inboxModalCat');
    var titleEl  = document.getElementById('inboxModalTitle');
    var skuEl    = document.getElementById('inboxModalSku');
    var descEl   = document.getElementById('inboxModalDesc');
    var specsEl  = document.getElementById('inboxModalSpecs');
    if (!grid || !modal) return;
    var cards = grid.querySelectorAll('.acc-card');

    function openModal(card) {
      var id = card.dataset.id;
      var d  = INBOX[id];
      if (!d) { console.warn('inbox-modal: no data for id', id); return; }
      catEl.textContent   = d.cat.replace(/Ⓐ/g, '');
      titleEl.textContent = d.title;
      skuEl.innerHTML     = d.sku + (d.model && d.model !== d.sku ? '<div style="font-size:11px;color:var(--text-muted);font-weight:400;margin-top:2px;">' + d.model + '</div>' : '');
      descEl.innerHTML    = d.desc;
      if (d.cat.indexOf('Ⓐ') >= 0) {
        catEl.innerHTML = d.cat.replace(/Ⓐ/g, '<span class="aa" aria-hidden="true">Ⓐ</span>');
      }
      specsEl.innerHTML = d.specs.map(function(s) {
        var v = (s[1] || '').toString().replace(/Ⓐ/g, '<span class="aa" aria-hidden="true">Ⓐ</span>');
        return '<div class="acc-spec-row">' +
                 '<div class="acc-spec-key">' + s[0] + '</div>' +
                 '<div class="acc-spec-val">' + v + '</div>' +
               '</div>';
      }).join('');
      var srcMedia = card.querySelector('.acc-card-img svg, .acc-card-img img.acc-card-photo');
      Array.from(imgWrap.querySelectorAll('svg, img.acc-card-photo')).forEach(function(s){ s.remove(); });
      if (srcMedia) {
        var clone = srcMedia.cloneNode(true);
        if (clone.tagName === 'IMG') {
          clone.style.maxWidth = '90%';
          clone.style.maxHeight = '90%';
          clone.style.objectFit = 'contain';
          clone.style.filter = 'drop-shadow(0 12px 24px rgba(0,0,0,0.6))';
        } else {
          clone.style.width = '70%';
          clone.style.height = 'auto';
          clone.style.maxWidth = '320px';
        }
        imgWrap.appendChild(clone);
      }
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }

    cards.forEach(function(c) { c.addEventListener('click', function() { openModal(c); }); });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && modal.classList.contains('open')) closeModal(); });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

