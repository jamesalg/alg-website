      dimGroup: '100W/150W'
    },
    'L150': {
      title:   'LSBX150 · 80 / 100 / 150W',
      meta:    '3-WATTSELECT × 3-CCTSELECT · lumens stated at 5000K · 151 lm/W (peak)',
      rows: [
        { w: '80W',     cct: '3000K · 4000K · 5000K', lm: '12,080 lm', lpw: '151', volt: '120-277V · 277-480V', cri: '>80' },
        { w: '100W',    cct: '3000K · 4000K · 5000K', lm: '15,100 lm', lpw: '151', volt: '120-277V · 277-480V', cri: '>80' },
        { w: '150W ★',  cct: '3000K · 4000K · 5000K', lm: '22,650 lm', lpw: '151', volt: '120-277V · 277-480V', cri: '>80' }
      ],
      foot:    '★ <strong>LSBX150</strong> — the 400W metal halide retrofit lane. Same compact 11.18 in W footprint as LSBX100, slightly longer L. The 150W default is the volume-spec for mid-mast parking lots and small commercial perimeters. <strong>SKU pattern:</strong> <code>LSBX150-3CS-{U|H}L{D|B|W}</code>.',
      dimGroup: '100W/150W'
    },
    'L200': {
      title:   'LSBX200 · 120 / 150 / 200W',
      meta:    '3-WATTSELECT × 3-CCTSELECT · lumens stated at 5000K · 149 lm/W (peak)',
      rows: [
        { w: '120W',    cct: '3000K · 4000K · 5000K', lm: '17,880 lm', lpw: '149', volt: '120-277V · 277-480V', cri: '>80' },
        { w: '150W',    cct: '3000K · 4000K · 5000K', lm: '22,350 lm', lpw: '149', volt: '120-277V · 277-480V', cri: '>80' },
        { w: '200W ★',  cct: '3000K · 4000K · 5000K', lm: '29,800 lm', lpw: '149', volt: '120-277V · 277-480V', cri: '>80' }
      ],
      foot:    '★ <strong>LSBX200</strong> — the 750W metal halide retrofit lane. Still on the 11.18 in W chassis. The 200W default targets standard 25 ft pole parking-lot spec. <strong>SKU pattern:</strong> <code>LSBX200-3CS-{U|H}L{D|B|W}</code>.',
      dimGroup: '200W'
    },
    'L300': {
      title:   'LSBX300 · 220 / 250 / 300W',
      meta:    '3-WATTSELECT × 3-CCTSELECT · lumens stated at 5000K · 146 lm/W (peak)',
      rows: [
        { w: '220W',    cct: '3000K · 4000K · 5000K', lm: '32,120 lm', lpw: '146', volt: '120-277V · 277-480V', cri: '>80' },
        { w: '250W',    cct: '3000K · 4000K · 5000K', lm: '36,500 lm', lpw: '146', volt: '120-277V · 277-480V', cri: '>80' },
        { w: '300W ★',  cct: '3000K · 4000K · 5000K', lm: '43,800 lm', lpw: '146', volt: '120-277V · 277-480V', cri: '>80' }
      ],
      foot:    '★ <strong>LSBX300</strong> — the 1000W metal halide retrofit lane. Steps up to the wider 13.86 in W chassis to handle the higher LED count + thermal load. The 300W default is the spec line for big-box parking lots, distribution centers, sports-court yards. <strong>SKU pattern:</strong> <code>LSBX300-3CS-{U|H}L{D|B|W}</code>. Premium-build SKU available: <code>LSBX300-3CS-HLB/UA/OT4</code> (300W + 277-480V + Black + Universal Mount + Type-IV optic).',
      dimGroup: '300W'
    },
    'L450': {
      title:   'LSBX450 · 330 / 390 / 450W',
      meta:    '3-WATTSELECT × 3-CCTSELECT · lumens stated at 5000K · 148 lm/W (peak)',
      rows: [
        { w: '330W',    cct: '3000K · 4000K · 5000K', lm: '48,840 lm', lpw: '148', volt: '120-277V · 277-480V', cri: '>80' },
        { w: '390W',    cct: '3000K · 4000K · 5000K', lm: '57,720 lm', lpw: '148', volt: '120-277V · 277-480V', cri: '>80' },
        { w: '450W ★',  cct: '3000K · 4000K · 5000K', lm: '66,600 lm', lpw: '148', volt: '120-277V · 277-480V', cri: '>80' }
      ],
      foot:    '★ <strong>LSBX450</strong> — the 2000W metal halide retrofit lane. Largest housing at 14.90 in W. Top-end output for 35-40 ft pole stadium-perimeter and high-mast roadway lighting where MH or 1500W HPS was the prior spec. <strong>SKU pattern:</strong> <code>LSBX450-3CS-{U|H}L{D|B|W}</code>. Premium-build SKU available: <code>LSBX450-3CS-ULW/UA/OT4</code> (450W + 120-277V + White + Universal Mount + Type-IV optic).',
      dimGroup: '450W'
    }
  };

  // Per-housing-group dimensions (datasheet page 6) · 4 mounts × L/W/D
  var DIM_DATA = {
    '100W/150W': {
      title: 'Dimensions · LSBX100 / 150',
      rows: [
        { mount: 'Slip-Fitter (SF)',  l: '26.96', w: '11.18', d: '3.11' },
        { mount: 'Round/Square (RS)', l: '28.62', w: '11.18', d: '6.29' },
        { mount: 'Trunnion (TN)',     l: '25.43', w: '11.18', d: '2.95' },
        { mount: 'Universal (UA)',    l: '28.26', w: '11.18', d: '6.29' }
      ]
    },
    '200W': {
      title: 'Dimensions · LSBX200',
      rows: [
        { mount: 'Slip-Fitter (SF)',  l: '26.97', w: '11.18', d: '3.11' },
