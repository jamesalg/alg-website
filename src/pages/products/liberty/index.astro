        '50': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W150-3H1-UD3-70W-50K.svg',  peak: '5,240 cd',  lumens: '11,698 lm', lpw: '167 lm/W',                 draw: '70.0W (LM-79)',  file: 'LSBX3W150-3H1-UD3-RB3-70W-50K_IESNA2002.IES' }
      },
      '100': {
        '30': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W150-3H1-UD3-100W-30K.svg', peak: '6,548 cd',  lumens: '14,134 lm', lpw: '141 lm/W',                 draw: '100.0W (LM-79)', file: 'LSBX3W150-3H1-UD3-RB3-100W-30K_IESNA2002.IES' },
        '40': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W150-3H1-UD3-100W-40K.svg', peak: '6,978 cd',  lumens: '15,356 lm', lpw: '<strong>154 lm/W</strong>', draw: '100.0W (LM-79)', file: 'LSBX3W150-3H1-UD3-RB3-100W-40K_IESNA2002.IES' },
        '50': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W150-3H1-UD3-100W-50K.svg', peak: '6,476 cd',  lumens: '14,371 lm', lpw: '144 lm/W',                 draw: '100.0W (LM-79)', file: 'LSBX3W150-3H1-UD3-RB3-100W-50K_IESNA2002.IES' }
      },
      '150': {
        '30': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W150-3H1-UD3-150W-30K.svg', peak: '8,887 cd',  lumens: '19,109 lm', lpw: '127 lm/W',                 draw: '150.0W (LM-79)', file: 'LSBX3W150-3H1-UD3-RB3-150W-30K_IESNA2002.IES' },
        '40': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W150-3H1-UD3-150W-40K.svg', peak: '10,084 cd', lumens: '22,107 lm', lpw: '<strong>147 lm/W</strong>', draw: '150.0W (LM-79)', file: 'LSBX3W150-3H1-UD3-RB3-150W-40K_IESNA2002.IES' },
        '50': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W150-3H1-UD3-150W-50K.svg', peak: '9,298 cd',  lumens: '20,628 lm', lpw: '137 lm/W',                 draw: '150.0W (LM-79)', file: 'LSBX3W150-3H1-UD3-RB3-150W-50K_IESNA2002.IES' }
      }
    },
    '300': {
      '200': {
        '30': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W300-3H1-UD3-200W-30K.svg', peak: '12,864 cd', lumens: '30,509 lm', lpw: '152 lm/W',                 draw: '200.0W (LM-79)', file: 'LSBX3W300-3H1-UD3-RB3-200W-30K_IESNA2002.IES' },
        '40': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W300-3H1-UD3-200W-40K.svg', peak: '14,093 cd', lumens: '33,851 lm', lpw: '<strong>169 lm/W</strong>', draw: '200.0W (LM-79)', file: 'LSBX3W300-3H1-UD3-RB3-200W-40K_IESNA2002.IES' },
        '50': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W300-3H1-UD3-200W-50K.svg', peak: '12,957 cd', lumens: '31,422 lm', lpw: '157 lm/W',                 draw: '200.0W (LM-79)', file: 'LSBX3W300-3H1-UD3-RB3-200W-50K_IESNA2002.IES' }
      },
      '240': {
        '30': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W300-3H1-UD3-240W-30K.svg', peak: '14,346 cd', lumens: '33,947 lm', lpw: '141 lm/W',                 draw: '240.0W (LM-79)', file: 'LSBX3W300-3H1-UD3-RB3-240W-30K_IESNA2002.IES' },
        '40': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W300-3H1-UD3-240W-40K.svg', peak: '16,061 cd', lumens: '38,496 lm', lpw: '<strong>160 lm/W</strong>', draw: '240.0W (LM-79)', file: 'LSBX3W300-3H1-UD3-RB3-240W-40K_IESNA2002.IES' },
        '50': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W300-3H1-UD3-240W-50K.svg', peak: '14,442 cd', lumens: '34,945 lm', lpw: '146 lm/W',                 draw: '240.0W (LM-79)', file: 'LSBX3W300-3H1-UD3-RB3-240W-50K_IESNA2002.IES' }
      },
      '300': {
        '30': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W300-3H1-UD3-300W-30K.svg', peak: '16,979 cd', lumens: '38,165 lm', lpw: '127 lm/W',                 draw: '300.0W (LM-79)', file: 'LSBX3W300-3H1-UD3-RB3-300W-30K_IESNA2002.IES' },
        '40': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W300-3H1-UD3-300W-40K.svg', peak: '19,856 cd', lumens: '45,525 lm', lpw: '<strong>152 lm/W</strong>', draw: '300.0W (LM-79)', file: 'LSBX3W300-3H1-UD3-RB3-300W-40K_IESNA2002.IES' },
        '50': { svg: '../../luxoARCH_PolarPlots/Heritage-I/LSBX3W300-3H1-UD3-300W-50K.svg', peak: '16,963 cd', lumens: '39,455 lm', lpw: '131 lm/W',                 draw: '300.0W (LM-79)', file: 'LSBX3W300-3H1-UD3-RB3-300W-50K_IESNA2002.IES' }
      }
    }
  };

  // Wattage sub-tab labels per housing
  var WATT_LABELS = {
    '150': [{ k: '70',  l: '70W'        },
            { k: '100', l: '100W'       },
            { k: '150', l: '150W ★'     }],
    '300': [{ k: '200', l: '200W'       },
            { k: '240', l: '240W'       },
            { k: '300', l: '300W ★'     }]
  };

  function init() {
    var img         = document.getElementById('photoImg');
    var statPeak    = document.getElementById('photoStatPeak');
    var statPeakSub = document.getElementById('photoStatPeakSub');
    var statLum     = document.getElementById('photoStatLumens');
    var statLpw     = document.getElementById('photoStatLpw');
    var statDraw    = document.getElementById('photoStatDraw');
    var statFile    = document.getElementById('photoStatFile');
    if (!img) return;

    var photoSection = document.getElementById('photometrics');
    var housingTabs = photoSection.querySelectorAll('.spec-watt-tab[data-photo-housing]');
    var wattTabContainer = photoSection.querySelector('.spec-watt-tabs[aria-label="WATTSELECT setting"]');
    var cctTabs  = photoSection.querySelectorAll('.photo-tab[data-cct]');
    var state    = { housing: '150', watt: '150', cct: '50' };

    function rebuildWattTabs() {
      var labels = WATT_LABELS[state.housing];
      wattTabContainer.innerHTML = '';
      labels.forEach(function(spec, idx) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'spec-watt-tab' + (spec.k === state.watt ? ' active' : '');
        btn.setAttribute('data-photo-watt', spec.k);
        btn.setAttribute('role', 'tab');
        btn.setAttribute('aria-selected', spec.k === state.watt ? 'true' : 'false');
        btn.textContent = spec.l;
        btn.addEventListener('click', function() {
          var tabs = wattTabContainer.querySelectorAll('.spec-watt-tab');
          tabs.forEach(function(x) {
            x.classList.remove('active');
            x.setAttribute('aria-selected', 'false');
          });
          btn.classList.add('active');
          btn.setAttribute('aria-selected', 'true');
          state.watt = spec.k;
          render();
        });
        wattTabContainer.appendChild(btn);
      });
    }

    function render() {
      var hp = PHOTO[state.housing];
      if (!hp) return;
      var wp = hp[state.watt];
      if (!wp) {
        // If switching housings drops the previous wattage, default to top-W
        var defaults = WATT_LABELS[state.housing];
        state.watt = defaults[defaults.length - 1].k;
        wp = hp[state.watt];
        rebuildWattTabs();
      }
      var d = wp[state.cct];
      if (!d) return;
      img.src = d.svg;
      img.alt = 'Heritage LSBX3W' + state.housing + ' · ' + state.watt + 'W setting · ' + state.cct + '00K · Type-III darkⒶRCH forward-throw distribution · LM-79 measured polar plot';
      statPeak.textContent = d.peak;
      if (statPeakSub) statPeakSub.textContent = 'Type-III forward throw at ' + state.watt + 'W · ' + state.cct + '00K';
      statLum.textContent  = d.lumens;
      statLpw.innerHTML    = d.lpw;
      statDraw.textContent = d.draw;
      statFile.textContent = d.file;
    }

    housingTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        housingTabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        state.housing = t.dataset.photoHousing;
        // On housing switch, default to top-W of the new housing
        var defaults = WATT_LABELS[state.housing];
        state.watt = defaults[defaults.length - 1].k;
        rebuildWattTabs();
        render();
      });
    });

    cctTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        cctTabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
          x.style.background = 'transparent';
          x.style.color = 'var(--text-secondary)';
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        t.style.background = 'var(--brand-red)';
        t.style.color = 'white';
        state.cct = t.dataset.cct;
        render();
      });
    });

    // Wire the initial wattage tab listeners (page-load default)
    var initialWattTabs = wattTabContainer.querySelectorAll('.spec-watt-tab[data-photo-watt]');
    initialWattTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        initialWattTabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        state.watt = t.dataset.photoWatt;
        render();
      });
    });

    render();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
<!-- ============================================================================
     SECTION 8 — Heritage "In the Box"
     -------------------------------------------------------------------------
     Three standard components ship pre-fitted on every Heritage shoebox per
     datasheet page 5 "What is in the Box?":
       1. Type-III darkⒶRCH Optic — UV-stabilized polycarbonate, Dark Sky
          compliant default · Type IV / Type V available as MTO accessory
          codes (/OT4 / /OT5) via Section 9 configurator
       2. 0-10V Dim Driver · Universal Voltage — U 120-277V QuickShip standard
          · /3W300 housing also offers H 277-480V (the only Heritage SKU with
          high-voltage option) · 6KVA built-in surge protection · respirator
          pressure-management for IP65 across thermal cycles
       3. Photocell-Ready 3-pin Receptacle + Shorting Cap — ANSI C136.10
          standard · works with the /PS factory-installed photocell adder
          OR with any third-party twist-lock photocell at install · /RB3 in
          the SKU pattern reflects this is on every active Heritage SKU

     Mount + sensor accessories ship as SEPARATE SKUs — they're NOT in the
     box, they're factory-option-line items (Section 9 configurator):
       /RS · /TN · /UA · /SP — 4 single-pick mount adders (LSBX-H1/* SKUs)
       /MSP-BLS · /MSP-BLS-5D · /MSP-ACS · /MSP-NLC — 4 single-pick sensors
       /PS — optional integrated photocell (sits in the receptacle from card 3)

     OPTIC FRAMING — Heritage's Type-III darkⒶRCH default is the contractor-
     grade play. Type IV / Type V are available as MTO accessory codes at
     order time; they ship as factory-installed optic swaps, not field-
     swappable lenses (unlike Keystone XFit's OpticSwap which puts III + IV +
     V in the box). The trade-off honestly: Keystone wins on UX (no separate
     SKU), Heritage wins on no-loose-parts at install + clean SKU ladder.

     Card pattern + modal scaffolding mirror Navigator/Pathfinder/Atlanta.
     ============================================================================ -->
