    .lsbx-family-grid { grid-template-columns: 1fr; }
  }
  /* Rosetta-III placeholder card — production photography pending.
     Brand-red BeamLogic-themed visual treatment so the card reads as
     intentional rather than missing-asset. */
  .family-card-placeholder {
    width: 100%; aspect-ratio: 4/3;
    background:
      radial-gradient(circle at 50% 60%, rgba(243,39,64,0.18) 0%, rgba(243,39,64,0.08) 35%, transparent 65%),
      linear-gradient(135deg, #1a1a1f 0%, #0e0e12 100%);
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .family-card-placeholder::before {
    /* Concentric rings evoking a precision optic */
    content: ''; position: absolute; inset: 0;
    background-image:
      radial-gradient(circle at center, transparent 35%, rgba(243,39,64,0.10) 36%, transparent 38%),
      radial-gradient(circle at center, transparent 50%, rgba(243,39,64,0.08) 51%, transparent 53%),
      radial-gradient(circle at center, transparent 65%, rgba(243,39,64,0.06) 66%, transparent 68%);
    pointer-events: none;
  }
