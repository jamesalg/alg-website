<script>
/* =============================================================================
   Drill-pattern fullscreen viewer wiring · opens when an .acc-modal-drill-svg
   thumbnail is clicked. Reads data-* attributes for url, letter, title, source.
   ESC key + backdrop click close. Restores body scroll on close.
   ============================================================================= */
(function() {
  'use strict';
  var drillModal = document.getElementById('drillModal');
  if (!drillModal) return;
  var drillImg = document.getElementById('drillModalImg');
  var drillTitle = document.getElementById('drillModalTitle');
  var drillSource = document.getElementById('drillModalSource');
  var drillLetter = document.getElementById('drillModalLetter');
  var drillClose = document.getElementById('drillModalClose');

  function openDrill(url, letter, title, source) {
    drillImg.src = url;
    drillImg.alt = title + ' drill pattern · full view';
    drillTitle.textContent = title + ' · Drill Pattern';
    drillSource.textContent = source || '';
    drillLetter.textContent = letter || '';
    drillModal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeDrill() {
    drillModal.classList.remove('open');
    document.body.style.overflow = '';
    // Defer src clear so the close animation doesn't show a broken image.
    setTimeout(function() { drillImg.src = ''; }, 200);
  }

  // Expose globally so the inline onclick on the X button can call it
  // even if event delegation is somehow intercepted upstream.
  window.__closeDrillModal = closeDrill;
  window.__openDrillModal  = openDrill;

  // Belt-and-suspenders click bindings on the close button — both pointerup
  // and click fire, capture phase used so this runs before any bubble-phase
  // listeners that might stopPropagation.
  if (drillClose) {
    drillClose.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      closeDrill();
    }, true);
    drillClose.addEventListener('pointerup', function(e) {
      e.preventDefault();
      e.stopPropagation();
      closeDrill();
    }, true);
  }

  // Backdrop click closes the drill modal.
  drillModal.addEventListener('click', function(e) {
    if (e.target === drillModal) closeDrill();
  });

  // ESC closes the drill modal.
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && drillModal.classList.contains('open')) closeDrill();
  });

  // Legacy event-delegation fallback for any drill thumbnail that wasn't
  // bound directly via the openModal flow (e.g., if the modal HTML is
  // re-rendered by an external pass).
  document.addEventListener('click', function(e) {
    var trigger = e.target.closest && e.target.closest('.acc-modal-drill-svg');
    if (trigger && !trigger.__directlyBound) {
      e.preventDefault();
      openDrill(
        trigger.getAttribute('data-drill-url'),
        trigger.getAttribute('data-drill-letter'),
        trigger.getAttribute('data-drill-title'),
        trigger.getAttribute('data-drill-source')
      );
    }
  });
})();
</script>

