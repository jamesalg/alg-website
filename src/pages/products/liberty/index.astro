  .cfg-preview-img img { width: 86%; height: 86%; object-fit: contain; }

  .cfg-sku-block {
    background: rgba(0,0,0,0.45);
    border: 1px solid rgba(226,35,26,0.30);
    border-radius: 2px;
    padding: 14px 16px;
    margin-bottom: 12px;
  }
  .cfg-sku-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--brand-red, var(--brand-red));
    margin-bottom: 6px;
  }
  .cfg-sku-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px; font-weight: 700;
    color: var(--text-primary);
    word-break: break-all;
    line-height: 1.4;
  }

  .cfg-status-panel {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--line-medium);
    border-radius: 2px;
    padding: 12px 14px;
    margin-bottom: 14px;
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
  }
  .cfg-status-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--text-muted);
  }
  .cfg-status-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; font-weight: 700;
    color: var(--text-primary);
    text-align: right;
  }
  .cfg-status-value .qs  { color: #4ade80; }
  .cfg-status-value .mto { color: #ffb14d; }
  .cfg-status-value .wb  { color: #60a8ff; }

  .cfg-cta-row { display: grid; grid-template-columns: 1fr; gap: 8px; margin-top: auto; padding-top: 14px; }
  .cfg-cta {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    padding: 12px 16px;
    border-radius: 2px;
    font-family: 'Lato', system-ui, sans-serif;
    font-size: 13px; font-weight: 700;
    text-decoration: none;
    cursor: pointer; border: none;
    transition: background 140ms, color 140ms, border-color 140ms;
  }
  .cfg-cta-primary { background: var(--brand-red, var(--brand-red)); color: #fff; }
  .cfg-cta-primary:hover { background: var(--brand-red-deep, var(--brand-red-deep)); }
  .cfg-cta-outline {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.20);
    color: var(--text-secondary);
  }
  .cfg-cta-outline:hover { border-color: var(--text-muted); color: #fff; }
  .cfg-cta svg { width: 14px; height: 14px; }

  /* Quick Picks row */
  .cfg-qp-head {
    margin-top: 24px;
    margin-bottom: 16px;
    text-align: center;
  }
  .cfg-qp-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--brand-red, var(--brand-red));
    margin-bottom: 8px;
  }
  .cfg-qp-title {
    font-family: 'Lato', system-ui, sans-serif !important;
    font-size: 22px; font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 6px 0;
  }
  .cfg-qp-sub {
    font-size: 13px; color: var(--text-muted);
    margin: 0;
  }
  .cfg-qp-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;
  }
  .cfg-qp-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 2px;
    padding: 16px;
    text-align: left;
    cursor: pointer;
    transition: border-color 140ms, transform 140ms, background 140ms;
    font: inherit;
  }
  .cfg-qp-card:hover {
    border-color: var(--brand-red, var(--brand-red));
    transform: translateY(-2px);
    background: rgba(226,35,26,0.04);
  }
  .cfg-qp-card-tag {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: #4ade80;
    background: rgba(74,222,128,0.14);
    padding: 2px 6px; border-radius: 1px;
    margin-bottom: 10px;
  }
  .cfg-qp-card-title {
    font-family: 'Lato', system-ui, sans-serif !important;
    font-size: 14px; font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 4px 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .cfg-qp-card-sub {
    font-size: 11.5px; color: var(--text-muted);
    line-height: 1.4;
