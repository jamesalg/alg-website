  /* ---------- Section 3 · Specifications + Dimensions ---------- */
  .spec-section {
    padding: 96px 24px 80px;
    background: var(--bg-page);
    border-top: 1px solid var(--line);
  }
  .spec-inner { max-width: 1280px; margin: 0 auto; }
  .spec-head { text-align: center; max-width: 720px; margin: 0 auto 40px; }
  .spec-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--brand-red, var(--brand-red)); margin-bottom: 14px;
  }
  .spec-title {
    font-family: 'Lato', system-ui, sans-serif !important;
    font-size: 32px; font-weight: 700; color: var(--text-primary);
    margin: 0 0 12px 0;
  }
  .spec-sub { font-size: 14px; line-height: 1.6; color: var(--text-secondary); margin: 0; }

  /* Tab switcher · 5 housing classes */
  .spec-tabs {
    display: flex; flex-wrap: wrap; gap: 8px;
    border-bottom: 1px solid var(--line-medium);
    padding-bottom: 16px; margin-bottom: 28px;
  }
  .spec-tab {
    background: transparent;
    border: 1px solid var(--line-medium);
    color: var(--text-secondary);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; font-weight: 600;
    letter-spacing: 0.04em;
    padding: 9px 14px;
    border-radius: 1px;
    cursor: pointer;
    transition: background 140ms, color 140ms, border-color 140ms;
  }
  .spec-tab:hover { background: rgba(255,255,255,0.05); color: var(--text-primary); }
  .spec-tab.is-active {
    background: var(--brand-red, var(--brand-red));
    color: #fff;
    border-color: var(--brand-red, var(--brand-red));
  }
  .spec-tab .spec-tab-mh {
    display: inline-block; margin-left: 8px;
    font-size: 10px; opacity: 0.7;
    padding-left: 8px; border-left: 1px solid currentColor;
  }

  /* 2-col layout: spec table | dim panel */
  .spec-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 28px;
    margin-bottom: 32px;
  }

  /* Spec table */
  .spec-table-wrap {
    background: var(--bg-spec);
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
  }
  .spec-table-head {
    padding: 14px 18px;
    border-bottom: 1px solid var(--line);
    background: var(--bg-card);
  }
  .spec-table-head-title {
    font-family: 'Lato', system-ui, sans-serif !important;
    font-size: 18px; font-weight: 700;
    color: var(--text-primary); margin: 0 0 4px 0;
  }
  .spec-table-head-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--text-muted);
    letter-spacing: 0.04em;
  }
  table.spec-table {
    width: 100%; border-collapse: collapse;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
  }
  .spec-table th {
    padding: 12px 14px;
    text-align: left;
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--line);
    background: rgba(255,255,255,0.02);
  }
  .spec-table td {
    padding: 14px;
    color: var(--text-secondary);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    vertical-align: middle;
  }
  .spec-table tr.is-default td { background: rgba(226,35,26,0.04); color: var(--text-primary); font-weight: 600; }
  .spec-table tr.is-default td:first-child::before {
    content: '★ '; color: var(--brand-red, var(--brand-red));
  }
  .spec-table tr:last-child td { border-bottom: none; }
  .spec-table-foot {
    padding: 12px 18px;
    border-top: 1px solid var(--line);
    background: rgba(255,255,255,0.02);
    font-size: 11px; line-height: 1.5;
    color: var(--text-muted);
  }
  .spec-table-foot strong { color: var(--text-secondary); }

  /* Dimensions panel */
  .spec-dim-wrap {
    background: var(--bg-spec);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 18px;
    display: flex; flex-direction: column;
  }
  .spec-dim-head {
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
  }
  .spec-dim-head-title {
    font-family: 'Lato', system-ui, sans-serif !important;
    font-size: 18px; font-weight: 700;
    color: var(--text-primary); margin: 0 0 4px 0;
  }
  .spec-dim-head-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--text-muted);
  }
  table.spec-dim-table {
    width: 100%; border-collapse: collapse;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
  }
  .spec-dim-table th {
    padding: 8px 6px;
    text-align: center;
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--line);
    font-weight: 600;
    text-transform: uppercase;
  }
  .spec-dim-table th:first-child { text-align: left; }
  .spec-dim-table td {
    padding: 12px 6px;
    text-align: center;
    color: var(--text-secondary);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .spec-dim-table td:first-child { text-align: left; color: var(--text-secondary); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; }
  .spec-dim-table tr:last-child td { border-bottom: none; }
  .spec-dim-foot {
    margin-top: 12px;
    padding-top: 10px;
    font-size: 11px; line-height: 1.5;
    color: var(--text-muted);
  }

  /* EPA + key-spec card row */
  .spec-meta-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }
  .spec-meta-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 16px;
  }
  .spec-meta-card-icon {
    width: 24px; height: 24px;
    color: var(--brand-red, var(--brand-red));
    margin-bottom: 10px;
  }
  .spec-meta-card-icon svg { width: 100%; height: 100%; }
  .spec-meta-card-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px; font-weight: 700;
    letter-spacing: 0.10em; text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  .spec-meta-card-value {
    font-family: 'Lato', system-ui, sans-serif !important;
    font-size: 14px; font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
  }
  .spec-meta-card-foot {
    font-size: 11px; color: var(--text-muted);
    margin-top: 4px; line-height: 1.4;
