/* =============================================================================
   SECTION 5 · Motion caption-chip sync
   Highlights the active caption chip based on the video's currentTime.
   ============================================================================= */
(function() {
  'use strict';
  var v = document.getElementById('libertyMotionVideo');
  if (!v) return;
  var caps = document.querySelectorAll('#motionCaptions .motion-cap');
  if (!caps.length) return;

  function updateActive() {
    var t = v.currentTime;
    caps.forEach(function(c) {
      var s = parseFloat(c.getAttribute('data-start'));
      var e = parseFloat(c.getAttribute('data-end'));
      c.classList.toggle('is-active', t >= s && t < e);
    });
  }
  v.addEventListener('timeupdate', updateActive);
  v.addEventListener('seeked', updateActive);
  v.addEventListener('play', updateActive);

  // Allow click-to-scrub on caption chips
  caps.forEach(function(c) {
    c.addEventListener('click', function() {
      var s = parseFloat(c.getAttribute('data-start'));
      if (!isNaN(s)) v.currentTime = s + 0.1;
      v.play();
    });
    c.style.cursor = 'pointer';
  });

  updateActive();
})();
</script>

