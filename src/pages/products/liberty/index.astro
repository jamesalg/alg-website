    color: var(--brand-red, #E2231A);
    margin-bottom: 14px;
  }
  .stub-title {
    font-family: 'Lato', system-ui, sans-serif !important;
    font-size: 26px; font-weight: 700; color: var(--text-primary, rgba(255,255,255,0.95));
    margin: 0 0 12px 0;
  }
  .stub-body { font-size: 14px; line-height: 1.6; margin: 0 0 8px 0; }
  .stub-status {
    display: inline-block; margin-top: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 700; letter-spacing: 0.10em;
    text-transform: uppercase;
    padding: 4px 10px; border-radius: 1px;
    background: rgba(255,159,28,0.14); color: #ffb14d;
    border: 1px solid rgba(255,159,28,0.32);
  }


  .magswap-section {
    padding: 88px 24px 96px;
    background: linear-gradient(180deg, #0a0a0a 0%, var(--bg-page) 100%);
    border-top: 1px solid var(--line, var(--line));
