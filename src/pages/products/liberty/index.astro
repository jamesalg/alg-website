  /* ============================================================================
     SECTION 12 — Page closer (Round Out the Project · Support · Great Rebates ·
     final red CTA strip). Three layered components in one section, lifted from
     Sentinel Section 11 — visual + interaction parity across PDPs.
     ============================================================================ */
  .closing-section {
    background: var(--bg-page);
    padding: 88px 0 0;
    border-top: 1px solid var(--line);
  }
  .closing-inner { max-width: 1400px; margin: 0 auto; padding: 0 32px; }

  /* 12A — Round Out the Project */
  .closing-family { padding-bottom: 72px; }
  .closing-family-head { text-align: center; margin-bottom: 40px; }
  .closing-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.18em;
    color: var(--brand-red); text-transform: uppercase;
    margin-bottom: 14px;
    display: inline-flex; align-items: center; gap: 12px;
  }
  .closing-eyebrow::before, .closing-eyebrow::after {
    content: ""; display: block; width: 28px; height: 1px; background: var(--brand-red);
  }
  .closing-title {
    font-size: 38px; font-weight: 700;
    letter-spacing: -0.005em; margin-bottom: 12px; line-height: 1.05;
  }
  .closing-sub {
    font-size: 15px; color: var(--text-secondary);
    max-width: 720px; margin: 0 auto; line-height: 1.6;
  }
  .closing-family-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-top: 40px;
  }

  /* 12B — Support + Rebates 2-up pillars */
  .closing-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    padding-bottom: 72px;
    border-top: 1px solid var(--line);
    padding-top: 64px;
  }
  .pillar {
    background: var(--bg-spec); border: 1px solid var(--line);
    border-radius: 4px; padding: 36px 36px 32px;
    display: flex; flex-direction: column; gap: 18px;
    position: relative; overflow: hidden;
  }
  .pillar-rebates {
    background: linear-gradient(135deg, #2c2118 0%, var(--bg-spec) 60%);
    border-color: rgba(243,39,64,0.20);
  }
  .pillar-icon {
    width: 52px; height: 52px;
    border-radius: 4px;
    background: rgba(243,39,64,0.10);
    border: 1px solid rgba(243,39,64,0.30);
    color: var(--brand-red);
    display: flex; align-items: center; justify-content: center;
  }
  .pillar-icon svg { width: 26px; height: 26px; }
  .pillar-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px; letter-spacing: 0.18em;
    color: var(--brand-red); text-transform: uppercase;
    font-weight: 700;
  }
  .pillar-title {
    font-size: 26px; font-weight: 700;
    color: var(--text-primary); line-height: 1.15;
    letter-spacing: -0.005em;
  }
  .pillar-body {
    font-size: 14.5px; color: var(--text-secondary);
    line-height: 1.65;
  }
  .pillar-stats {
    display: flex; flex-wrap: wrap; gap: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 16px 0; margin: 4px 0;
  }
  .pillar-stat {
    flex: 1; min-width: 120px;
    padding: 0 16px; border-right: 1px solid var(--line);
  }
  .pillar-stat:first-child { padding-left: 0; }
  .pillar-stat:last-child { border-right: none; padding-right: 0; }
  .pillar-stat-num {
    font-size: 22px; font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.01em; line-height: 1.1;
    white-space: nowrap;
  }
  .pillar-stat:last-child .pillar-stat-num { font-size: 18px; }
  .pillar-stat-key {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px; letter-spacing: 0.14em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-top: 4px;
  }
  .pillar-ctas {
    display: flex; gap: 10px; flex-wrap: wrap;
    margin-top: 4px;
  }
  .pillar-cta {
    flex: 1; min-width: 150px;
    display: inline-flex; align-items: center; justify-content: center;
    gap: 8px;
    padding: 13px 20px;
    border-radius: 2px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.10em; text-transform: uppercase;
    cursor: pointer;
    transition: all 0.18s;
    border: 1px solid transparent;
    text-decoration: none;
    white-space: nowrap;
  }
  .pillar-cta.primary { background: var(--brand-red); color: white; }
  .pillar-cta.primary:hover { background: var(--brand-red-deep); }
  .pillar-cta.outline {
    background: transparent;
    color: var(--text-secondary);
    border-color: var(--line-medium);
  }
  .pillar-cta.outline:hover { color: var(--text-primary); border-color: var(--text-primary); }
  .pillar-cta svg { width: 14px; height: 14px; }

  /* 12C — Final red CTA strip */
  .closing-cta-strip {
    background: var(--brand-red); color: white;
    padding: 22px 32px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px; flex-wrap: wrap;
  }
  .closing-cta-strip-inner {
    max-width: 1400px; margin: 0 auto; width: 100%;
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px; flex-wrap: wrap;
  }
  .closing-cta-msg { font-size: 16px; line-height: 1.4; }
  .closing-cta-msg strong { font-weight: 700; }
  .closing-cta-buttons { display: flex; gap: 10px; flex-wrap: wrap; }
  .closing-cta-btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 8px; padding: 13px 22px;
    border: 1.5px solid white; color: white;
    background: transparent; border-radius: 2px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    cursor: pointer; transition: all 0.18s;
    text-decoration: none; white-space: nowrap;
  }
  .closing-cta-btn:hover { background: white; color: var(--brand-red); }
  .closing-cta-btn.solid { background: white; color: var(--brand-red); }
  .closing-cta-btn.solid:hover { background: rgba(255,255,255,0.92); }

  @media (max-width: 1100px) {
    .closing-family-grid { grid-template-columns: repeat(2, 1fr); }
    .closing-pillars { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .closing-family-grid { grid-template-columns: 1fr; }
    .closing-title { font-size: 28px; }
    .pillar-title { font-size: 22px; }
    .closing-cta-strip-inner { flex-direction: column; align-items: flex-start; }
  }

  /* === PLAYBOOK LESSON #4 · force Lato on h1/h2 to override theme global serif === */
  .liberty-pdp h1, .liberty-pdp h2,
  body.liberty-pdp h1, body.liberty-pdp h2 {
    font-family: 'Lato', system-ui, -apple-system, BlinkMacSystemFont, sans-serif !important;
    font-weight: 700;
  }

  /* ==========================================================================
     STUB SECTION · for Liberty PDP sections that haven't been built yet (v1.x).
     James 2026-05-05: "wipe those sections off of the HTML. I do not want to
     see what's not relevant to the Liberty." Each pending section gets a
