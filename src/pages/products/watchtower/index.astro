<!-- Inline carousel JS — minimal 4-slide auto-rotator + click-to-jump dots -->
<script>
(function() {
  var track = document.getElementById('carouselTrack');
  var dots  = document.getElementById('carouselDots');
  if (!track || !dots) return;
  var slides = track.querySelectorAll('.carousel-slide');
  var dotEls = dots.querySelectorAll('span');
  var i = 0;
  function show(n) {
    i = (n + slides.length) % slides.length;
    track.style.transform = 'translateX(-' + (i * 100) + '%)';
    dotEls.forEach(function(d, k) { d.classList.toggle('active', k === i); });
  }
  dotEls.forEach(function(d, k) { d.addEventListener('click', function() { show(k); }); });
  // Auto-rotate every 5 seconds
  setInterval(function() { show(i + 1); }, 5000);
})();
</script>

<!-- =============================================================================
     SECTION 6 — contr<span class="aa">Ⓐ</span>LS · click ripple/shockwave handler
     Watchtower only ships ONE controls platform (Bi-Level / Photocell), so unlike
     Sentinel (which has 4 platforms to switch between) there's no platform-swap
     logic — just the visual feedback. Click the red contr<span class="aa">Ⓐ</span>LS tab → restart the
     shockwave animation. Pattern lifted from Sentinel Section 5.
     ============================================================================= -->
<script>
(function() {
  function init() {
    var tabs = document.querySelectorAll('.tac-callout-tab');
    var wave = document.getElementById('tacShockwave');
    if (!tabs.length || !wave) return;
    function ripple() {
      // Remove + force reflow + re-add \u2014 restarts the CSS animation cleanly
      wave.classList.remove('is-rippling');
      void wave.offsetWidth;
      wave.classList.add('is-rippling');
    }
    tabs.forEach(function(t) {
      t.addEventListener('click', ripple);
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

<!-- =============================================================================
     SECTION 3 — Model Specifications: model toggle + spec table renderer
     LWPC3W80 = 40/60/80W class · LWPC3W120 = 80/100/120W class.
     Lumens shown are 4000K column from datasheet page 4 Performance Data table
     (highest CCT-bin output across the 3-CCTselect range).
     ============================================================================= -->
<script>
(function() {
  // SPEC_TABLE: 2 model classes \u00D7 3 wattage rows each.
  // Lumens / lm/W from Watchtower datasheet page 4 (Performance Data, 4000K column).
  // \u2605 marks the factory-default DIP wattage position (max of each model class).
  var SPEC_TABLE = {
    '80': [
      { watt: '40W',   lumens: '5,480 lm',  lpw: '137 lm/W', cct: '3000K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: false },
      { watt: '60W',   lumens: '8,220 lm',  lpw: '137 lm/W', cct: '3000K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: false },
      { watt: '80W \u2605', lumens: '11,200 lm', lpw: '140 lm/W', cct: '3000K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: true  }
    ],
    '120': [
      { watt: '80W',    lumens: '11,200 lm', lpw: '140 lm/W', cct: '3000K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: false },
      { watt: '100W',   lumens: '14,000 lm', lpw: '140 lm/W', cct: '3000K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: false },
      { watt: '120W \u2605', lumens: '16,680 lm', lpw: '139 lm/W', cct: '3000K \u00B7 4000K \u00B7 5000K', volt: '120-277V Universal', def: true  }
    ]
  };

  function init() {
    var tabs = document.querySelectorAll('.spec-watt-tab');
    var body = document.getElementById('specTableBody');
    if (!tabs.length || !body) return;

    function render(model) {
      var rows = SPEC_TABLE[model] || [];
      body.innerHTML = rows.map(function(r) {
        return '<tr' + (r.def ? ' class="is-default"' : '') + '>' +
                 '<td>' + r.watt + '</td>' +
                 '<td>' + r.lumens + '</td>' +
                 '<td>' + r.lpw + '</td>' +
                 '<td>' + r.cct + '</td>' +
                 '<td>' + r.volt + '</td>' +
               '</tr>';
      }).join('');
    }

    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        render(t.dataset.w);
      });
    });

    // Initial render \u2014 LWPC3W120 (default-active tab; matches datasheet "default" column)
    var active = document.querySelector('.spec-watt-tab.active');
    render(active ? active.dataset.w : '120');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

<!-- =============================================================================
     SECTION 3 — Dimensions zoom modal: open on zoom-btn click, close on overlay click or Esc
     ============================================================================= -->
<script>
(function() {
  var modal    = document.getElementById('dimZoomModal');
  var openBtn  = document.getElementById('dimZoomBtn');
  var closeBtn = document.getElementById('dimZoomClose');
  if (!modal || !openBtn) return;
  function open()  { modal.classList.add('open'); }
  function close() { modal.classList.remove('open'); }
  openBtn.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  modal.addEventListener('click', function(e) {
    if (e.target === modal) close();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('open')) close();
  });
})();
</script>

<!-- =============================================================================
     SECTION 7 — Photometrics: model × CCT toggle, swap polar plot SVG + stats
     6 plots = 2 model classes × 3 CCTs. Each plot is generated from the IES
     file at the model's default DIP wattage (LWPC3W80 = 80W, LWPC3W120 = 120W).
     Stats values pulled from the datasheet Performance Data table (page 4).
     ============================================================================= -->
<script>
(function() {
  // Per-(model, CCT) data \u2014 beam shape from real IES files; stats from datasheet.
  // \u2605 marks the factory-default position (max wattage of each model class).
  var DATA = {
    // LWPC3W80 \u00B7 80W (default DIP) \u00D7 3 CCTs
    '80_30':  { svg: '/products/watchtower/assets/photometrics/watchtower_LWPC3W80_80w_30k.svg',  peak: '6,956 cd',  lumens: '11,120 lm', lpw: '139 lm/W efficacy', file: 'LWPC3W080-3W1-UDPS-30K_IESNA2002.IES' },
    '80_40':  { svg: '/products/watchtower/assets/photometrics/watchtower_LWPC3W80_80w_40k.svg',  peak: '7,435 cd',  lumens: '11,200 lm', lpw: '140 lm/W efficacy', file: 'LWPC3W080-3W1-UDPS-40K_IESNA2002.IES' },
    '80_50':  { svg: '/products/watchtower/assets/photometrics/watchtower_LWPC3W80_80w_50k.svg',  peak: '7,266 cd',  lumens: '11,120 lm', lpw: '139 lm/W efficacy', file: 'LWPC3W080-3W1-UDPS-50K_IESNA2002.IES' },
    // LWPC3W120 \u00B7 120W (default DIP) \u00D7 3 CCTs
    '120_30': { svg: '/products/watchtower/assets/photometrics/watchtower_LWPC3W120_120w_30k.svg', peak: '9,867 cd',  lumens: '16,560 lm', lpw: '138 lm/W efficacy', file: 'LWPC3W120-3W1-UDPS-30K_IESNA2002.IES' },
    '120_40': { svg: '/products/watchtower/assets/photometrics/watchtower_LWPC3W120_120w_40k.svg', peak: '10,586 cd', lumens: '16,680 lm', lpw: '139 lm/W efficacy', file: 'LWPC3W120-3W1-UDPS-40K_IESNA2002.IES' },
    '120_50': { svg: '/products/watchtower/assets/photometrics/watchtower_LWPC3W120_120w_50k.svg', peak: '10,145 cd', lumens: '16,560 lm', lpw: '138 lm/W efficacy', file: 'LWPC3W120-3W1-UDPS-50K_IESNA2002.IES' }
  };

  function init() {
    var img      = document.getElementById('photoImg');
    var statPeak = document.getElementById('photoStatPeak');
    var statLum  = document.getElementById('photoStatLumens');
    var statLpw  = document.getElementById('photoStatLpw');
    var statFile = document.getElementById('photoStatFile');
    if (!img) return;

    var modelTabs = document.querySelectorAll('.photo-tab[data-model]');
    var cctTabs   = document.querySelectorAll('.photo-tab[data-cct]');
    var state = { model: '120', cct: '50' };

    function render() {
      var key = state.model + '_' + state.cct;
      var d = DATA[key];
      if (!d) return;
      img.src = d.svg;
      img.alt = 'LWPC3W' + state.model + ' \u00B7 ' + state.cct + '00K \u2014 full-cutoff polar plot';
      statPeak.textContent = d.peak;
      statLum.textContent  = d.lumens;
      statLpw.textContent  = d.lpw;
      statFile.textContent = d.file;
    }

    modelTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        modelTabs.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-selected','false'); });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        state.model = t.dataset.model;
        render();
      });
    });
    cctTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        cctTabs.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-selected','false'); });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        state.cct = t.dataset.cct;
        render();
      });
    });

    render();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

