    function closeModal() { modal.classList.remove('open'); }

    cards.forEach(function(c) {
      c.addEventListener('click', function() { openModal(c); });
    });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

<!-- =============================================================================
     SECTION 9 — Configurator engine: state machine + SKU builder + previews
     5 required fields (model, cct, voltage, finish, photocell) + 2 optional
     (em, spd). SKU pattern: LWPC{model}-3W1-U{D|B}/PS[/EM07|/EM20][/10SP|/20SP]
     ============================================================================= -->
<script>
(function() {
  // 5 required fields. 2 optional groups.
  var REQUIRED = ['model', 'cct', 'voltage', 'finish', 'photocell'];
  var OPTIONAL = ['em', 'spd'];

  // SKU build order (after the prefix LWPC{model}):
  //   cct      -3W1   \u2014 leading dash, fixed (CCTselect indicator + W1 series ID)
  //   voltage  -U     \u2014 leading dash, single value
  //   finish   D|B    \u2014 NO separator, attached directly to voltage (UD or UB)
  //   photocell /PS   \u2014 leading slash, single value
  //   em       /EM07|/EM20  \u2014 optional
  //   spd      /10SP|/20SP  \u2014 optional
  var SKU_ORDER = ['cct', 'voltage', 'finish', 'photocell', 'em', 'spd'];
  var SEP = {
    cct: '-', voltage: '-', finish: '', photocell: '/', em: '/', spd: '/'
  };

  // Per-(model) lumens / efficacy / wattage range \u2014 datasheet page 4 (4000K column max)
  var SPEC_TABLE = {
    model: {
      '3W80':  { name: 'LWPC3W80 \u00B7 40 / 60 / 80W',    lumensMax: '11,200 lm', lpw: '140 lm/W',
                 wattRange: '40 / 60 / 80W (DIP)' },
      '3W120': { name: 'LWPC3W120 \u00B7 80 / 100 / 120W', lumensMax: '16,680 lm', lpw: '139 lm/W',
                 wattRange: '80 / 100 / 120W (DIP)' }
    },
    cct: { '30': '3000K', '40': '4000K', '50': '5000K' },
    voltage: { 'U': '120-277V Universal' },
    finish:  { 'D': 'Dark Bronze', 'B': 'Black (MTO)' },
    finishImg: {
      'D': '/products/watchtower/assets/finishes/dark-bronze.webp',
      'B': '/products/watchtower/assets/finishes/black.webp'
    },
    // Peak intensity by model \u2014 pulled from polar-plot data at 4000K (highest CCT-bin)
    peak: { '3W80': '7,435 cd', '3W120': '10,586 cd' }
  };

  function init() {
    var section = document.getElementById('configurator');
    if (!section) return;

    // State \u2014 model unset (the only required field with no default), all others default-set
    var state = {
      model: null,    cct: '50',     voltage: 'U',
      finish: 'D',    photocell: 'PS',
      em: null,       spd: null
    };

    var skuEl       = document.getElementById('cfgSku');
    var copyBtn     = document.getElementById('cfgSkuCopy');
    var copyLabel   = document.getElementById('cfgSkuCopyLabel');
    var counterEl   = document.getElementById('cfgCounter');
    var counterCnt  = document.getElementById('cfgCounterCount');
    var resetBtn    = document.getElementById('cfgReset');
    var warnEl      = document.getElementById('cfgIncompleteWarning');
    var ctaPrice    = document.getElementById('cfgCtaPricing');
    var ctaPdf      = document.getElementById('cfgCtaPdf');
    var previewImg  = document.getElementById('cfgPreviewImg');

    function setSpec(name, val) {
      var el = section.querySelector('[data-spec="' + name + '"]');
      if (!el) return;
      if (val == null || val === '\u2014') {
        el.textContent = '\u2014';
        el.classList.add('placeholder');
      } else {
        el.textContent = val;
        el.classList.remove('placeholder');
      }
    }

    function buildSku() {
      if (!state.model) return null;
      var parts = ['LWPC' + state.model];
      SKU_ORDER.forEach(function(k) {
        var v = state[k];
        if (!v) return;
        var chip = section.querySelector('.cfg-chip[data-field="' + k + '"][data-val="' + v + '"]');
        var code = chip ? chip.dataset.code : v;
        if (!code) return;
        parts.push(SEP[k] + code);
      });
      return parts.join('');
    }

    function applyState() {
      // Update chip selection visuals
      section.querySelectorAll('.cfg-chip').forEach(function(c) {
        var f = c.dataset.field, v = c.dataset.val;
        if (state[f] === v) c.classList.add('selected');
        else if (!c.classList.contains('locked')) c.classList.remove('selected');
      });

      // Counter (5 required fields)
      var have = REQUIRED.filter(function(k) { return state[k]; }).length;
      counterCnt.textContent = have;
      counterEl.classList.toggle('complete', have === REQUIRED.length);

      // Resolved SKU
      var sku = buildSku();
      if (sku) {
        skuEl.innerHTML = sku;
        skuEl.classList.remove('placeholder');
      } else {
        skuEl.innerHTML = '<span class="placeholder">LWPC[3W80|3W120]-3W1-U[D|B]/PS[/EM07|/EM20][/10SP|/20SP]</span>';
      }
      copyBtn.disabled = !sku;

      // Specs
      if (state.model) {
        var m = SPEC_TABLE.model[state.model];
        setSpec('lumens',  m.lumensMax);
        setSpec('lpw',     m.lpw);
        setSpec('wattRange', m.wattRange);
        setSpec('peak',    SPEC_TABLE.peak[state.model]);
      } else {
        ['lumens','lpw','wattRange','peak'].forEach(function(k) { setSpec(k, null); });
      }
      setSpec('cct',     state.cct      ? SPEC_TABLE.cct[state.cct]                                       : null);
      setSpec('voltage', state.voltage  ? SPEC_TABLE.voltage[state.voltage]                               : null);
      setSpec('finish',  state.finish   ? SPEC_TABLE.finish[state.finish]                                 : null);

      // Compliance \u2014 augments with optional adds
      var compliance = 'DLC \u00B7 UL \u00B7 cUL \u00B7 RoHS \u00B7 IP65 \u00B7 3G ANSI C136.31 \u00B7 BUG U0';
      if (state.em)  compliance += ' \u00B7 EM Backup';
      if (state.spd) compliance += ' \u00B7 Surge-Protected';
      setSpec('compliance', compliance);

      // CTA states + warning
      var complete = (have === REQUIRED.length);
      ctaPrice.classList.toggle('disabled', !complete);
      ctaPdf.classList.toggle('disabled', !complete);
      warnEl.classList.toggle('show', !complete);

      // Preview image swap (cross-fade)
      var newSrc = state.finish ? SPEC_TABLE.finishImg[state.finish] : SPEC_TABLE.finishImg['D'];
      if (previewImg && newSrc && !previewImg.src.endsWith(newSrc)) {
        previewImg.style.opacity = '0';
        setTimeout(function() {
          previewImg.src = newSrc;
          previewImg.style.opacity = '1';
        }, 180);
      }
    }

    // Wire up chip clicks (single-select per field; toggle for optional)
    section.querySelectorAll('.cfg-chip').forEach(function(chip) {
      if (chip.classList.contains('locked')) return;
      chip.addEventListener('click', function() {
        var f = chip.dataset.field, v = chip.dataset.val;
        if (OPTIONAL.indexOf(f) >= 0) {
          // Toggle: click selected to de-select; otherwise pick this one (single-select within group)
          state[f] = (state[f] === v) ? null : v;
        } else {
          state[f] = v;
        }
        applyState();
      });
    });

    // Reset
    resetBtn.addEventListener('click', function() {
      state = {
        model: null,    cct: '50',     voltage: 'U',
        finish: 'D',    photocell: 'PS',
        em: null,       spd: null
      };
      applyState();
    });

    // Copy SKU
    copyBtn.addEventListener('click', function() {
      var sku = buildSku();
      if (!sku) return;
      try {
        navigator.clipboard.writeText(sku);
        copyBtn.classList.add('copied');
        copyLabel.textContent = 'Copied!';
        setTimeout(function() {
          copyBtn.classList.remove('copied');
          copyLabel.textContent = 'Copy SKU';
        }, 1400);
      } catch (e) {}
    });

    // ---- Submittal PDF \u2014 opens submittal_template.html in new tab with full config in query string ----
    // Template auto-fills page-1 catalog number, quick specs, ordering matrix, photometric data.
    // Manus replaces this with a real backend at /submittal-generator/?product=watchtower&sku=\u2026 on production.
    function buildSubmittalUrl() {
      var sku = buildSku() || 'LWPC3W120-3W1-UD/PS';
      var params = new URLSearchParams({
        product:   'watchtower',
        sku:       sku,
        wattage:   state.model     || '3W120',
        cct:       state.cct       || '50',
        voltage:   state.voltage   || 'U',
        finish:    state.finish    || 'D',
        photocell: state.photocell || 'PS',
        em:        state.em        || '',
        spd:       state.spd       || ''
      });
      return 'submittal_template.html?' + params.toString();
    }
    ctaPdf.addEventListener('click', function(e) {
      if (ctaPdf.classList.contains('disabled')) { e.preventDefault(); return; }
      ctaPdf.setAttribute('href', buildSubmittalUrl());
    });

    // Initial render
    applyState();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>


<script>
/* =============================================================================
   CFG-NAV-1 \u00B7 Sticky-nav scroll-spy
   ----------------------------------------------------------------------------
   IntersectionObserver watches each section the sticky-nav links to. The link
   whose target is "most visible" gets '.is-current' (white bg + red text \u00B7 the
   visual inverse of '.primary'). One observer, one Map, one CSS class toggle.
   The Pricing & Availability primary button is NOT a section anchor (its href
   is /pricing-availability/), so it's excluded from the spy by the
   'a[href^="#"]' selector below.
   ============================================================================= */
(function() {
  var nav = document.querySelector('.sticky-nav');
  if (!nav) return;
  var links = Array.prototype.slice.call(nav.querySelectorAll('a[href^="#"]'));
  if (!links.length) return;
  var entries = [];
  links.forEach(function(a) {
    var id = a.getAttribute('href').slice(1);
    var sec = id ? document.getElementById(id) : null;
    if (sec) entries.push({ sec: sec, link: a, ratio: 0 });
  });
  if (!entries.length) return;
  function update() {
    var best = null, bestRatio = 0;
    entries.forEach(function(e) { if (e.ratio > bestRatio) { bestRatio = e.ratio; best = e; } });
    entries.forEach(function(e) { e.link.classList.toggle('is-current', e === best && bestRatio > 0); });
  }
  var io = new IntersectionObserver(function(items) {
    items.forEach(function(item) {
      entries.forEach(function(e) { if (e.sec === item.target) e.ratio = item.intersectionRatio; });
    });
    update();
  }, {
    rootMargin: '-20% 0px -55% 0px',
    threshold: [0, 0.1, 0.25, 0.5, 0.75, 1.0]
  });
  entries.forEach(function(e) { io.observe(e.sec); });
})();
</script>

<script>
// CFG-STATE-1 \u2014 derive ship-tier (QS / WB / MTO) from selected chip badges, render
// canonical 3-state status panel. Self-contained module \u00B7 no dependency on the
// configurator's state object \u00B7 re-derives by walking selected chips on every click.
// Custom RAL forces MTO (custom paint = factory work).
(function() {
  function deriveShipTier() {
    var section = document.getElementById('configurator');
    if (!section) return 'QS';
    var chips = section.querySelectorAll('.cfg-chip.selected, .cfg-chip[aria-pressed="true"]');
    var worst = 'QS';
    var sawCustomRal = false;
    chips.forEach(function(chip) {
      if (chip.dataset.field === 'finish' && chip.dataset.val === 'RAL') sawCustomRal = true;
      if (chip.querySelector('.cfg-chip-stock.mto')) worst = 'MTO';
      else if (chip.querySelector('.cfg-chip-stock.wb') && worst !== 'MTO') worst = 'WB';
    });
    if (sawCustomRal) {
      var input = document.getElementById('cfgRalInput');
      if (input && input.value && /^[0-9]{4}$/.test(input.value)) return 'MTO';
    }
    return worst;
  }
  function refreshShipTier() {
    var tier = deriveShipTier();
    var rowEl = document.getElementById('cfgShipTier');
    var iconEl = document.getElementById('cfgShipTierIcon');
    var textEl = document.getElementById('cfgShipTierText');
    var stockEl = document.getElementById('cfgShipTierStock');
    if (!rowEl || !iconEl || !textEl || !stockEl) return;
    if (tier === 'QS') {
      rowEl.style.background = 'rgba(95,199,122,0.08)';
      rowEl.style.border = '1px solid rgba(95,199,122,0.40)';
      iconEl.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#7fc998" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      textEl.innerHTML = '<strong style="color:#9bd6b1;">QuickShip \u00B7 \u00E0-la-carte assembly</strong> &middot; <span style="color:var(--text-secondary);">All selected components in stock \u2014 ships 2-3 day.</span>';
      stockEl.textContent = 'QuickShip \u00B7 2-3 day';
      stockEl.style.color = '#9bd6b1';
    } else if (tier === 'WB') {
      rowEl.style.background = 'rgba(96,168,255,0.08)';
      rowEl.style.border = '1px solid rgba(96,168,255,0.40)';
      iconEl.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#7fb6ff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>';
      textEl.innerHTML = '<strong style="color:#a8c9ff;">Workbench Assembly &middot; ~1-3 wk</strong> &middot; <span style="color:var(--text-secondary);">One or more selected components are workbench-assembled to order.</span>';
      stockEl.textContent = 'WB \u00B7 ~1-3 wk';
      stockEl.style.color = '#a8c9ff';
    } else {
      rowEl.style.background = 'rgba(255,159,28,0.08)';
      rowEl.style.border = '1px solid rgba(255,159,28,0.40)';
      iconEl.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#ffb14d" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>';
      textEl.innerHTML = '<strong style="color:#ffb14d;">Custom build &middot; Made-to-Order &middot; ~4-6 wk</strong> &middot; <span style="color:var(--text-secondary);">One or more selected components are MTO (custom finish, MTO option, or non-stocked variant).</span>';
      stockEl.textContent = 'MTO \u00B7 ~4-6 wk';
      stockEl.style.color = '#ffb14d';
    }
  }
  function init() {
    var section = document.getElementById('configurator');
    if (!section) return;
    section.addEventListener('click', function(e) {
      if (e.target.closest('.cfg-chip')) setTimeout(refreshShipTier, 50);
    });
    var ralInput = document.getElementById('cfgRalInput');
    if (ralInput) ralInput.addEventListener('input', function() { setTimeout(refreshShipTier, 50); });
    refreshShipTier();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
