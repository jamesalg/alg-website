      var id = card.dataset.id;
      var d  = ACC[id];
      if (!d) { console.warn('acc-modal: no data for id', id); return; }
      catEl.textContent   = d.cat.replace(/\u24B6/g, '');
      titleEl.textContent = d.title;
      skuEl.innerHTML     = d.sku + (d.model && d.model !== d.sku ? '<div style="font-size:11px;color:var(--text-muted);font-weight:400;margin-top:2px;">' + d.model + '</div>' : '');
      descEl.innerHTML    = d.desc;
      if (d.cat.indexOf('\u24B6') >= 0) {
        catEl.innerHTML = d.cat.replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
      }
      specsEl.innerHTML = d.specs.map(function(s) {
        var v = (s[1] || '').toString().replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
        return '<div class="acc-spec-row">' +
                 '<div class="acc-spec-key">' + s[0] + '</div>' +
                 '<div class="acc-spec-val">' + v + '</div>' +
               '</div>';
      }).join('');
      var srcMedia = card.querySelector('.acc-card-img svg, .acc-card-img img.acc-card-photo');
      Array.from(imgWrap.querySelectorAll('svg, img.acc-card-photo')).forEach(function(s){ s.remove(); });
      if (srcMedia) {
        var clone = srcMedia.cloneNode(true);
        if (clone.tagName === 'IMG') {
          clone.style.maxWidth = '90%';
          clone.style.maxHeight = '90%';
          clone.style.objectFit = 'contain';
          clone.style.filter = 'drop-shadow(0 12px 24px rgba(0,0,0,0.6))';
        }
        imgWrap.appendChild(clone);
      }
      modal.classList.add('open');
    }
    function closeModal() { modal.classList.remove('open'); }

    cards.forEach(function(c) {
      c.addEventListener('click', function() { openModal(c); });
    });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>
<!-- ============================================================================
     SECTION 9 — Configurator (Build Your Navigator · live SKU builder)
     -------------------------------------------------------------------------
     SKU PATTERN (per James 2026-05-02 + datasheet page 3 ordering guide):
       LCNP3W{40|100}-3N1-{U|HV}{D|B|S|W|RAL####}{/EM08?|/EM20?}{/MSP-XXX?}
       Required-only standard SKU:  LCNP3W100-3N1-UD
       With EM + sensor:            LCNP3W100-3N1-UD/EM20/MSP-ACS
       LCNP3W40 + RAL + EM + sensor: LCNP3W40-3N1-URAL7016/EM08/MSP-NLC

       Element decode:
         LCNP3W40 / LCNP3W100  housing class (40W or 100W max)
         -3N1                  3-CCTselect Navigator-I series (locked)
         -U  · -HV             voltage: U universal 120-277V (QS) · HV 277-480V (MTO)
         D · B · S · W · RAL####   finish (joins voltage with no separator)
         /EM08 · /EM20         optional EM battery (single-pick — sized to housing)
         /MSP-{BLS|BLS-5D|ACS|NLC}  optional sensor (single-pick — one per fixture)

     User-pickable fields (5):
       1. Housing class    LCNP3W100 ★ (default) or LCNP3W40
       2. Voltage          U ★ (default · QS) or HV (MTO)
       3. Finish           D ★ | B | S | W | RAL####
       4. EM battery       None ★ | /EM08 (recommended for 3W40) | /EM20 (recommended for 3W100)
       5. Sensor           None ★ | /MSP-BLS | /MSP-BLS-5D | /MSP-ACS | /MSP-NLC
     Auto-locked: -3N1 (CCTSELECT capability)
     Field-set at install (informational, NOT in SKU):
       WATTSELECT (3 wattages per housing) + CCTSELECT (3500K/4000K/5000K)
     Default complete SKU: LCNP3W100-3N1-UD (LCNP3W100 · /U · D · No EM · No sensor)

     EM SINGLE-PICK because they're sized to housing (8W for 40W class, 20W
     for 100W class). Spec writer can pick the recommended-for-housing or pick
     the other variant if the project demands it (e.g., /EM20 on a 3W40 for
     extended runtime margin) — not enforced as housing-locked.
     ============================================================================ -->
