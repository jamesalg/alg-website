<script>
/* =============================================================================
   SECTION 9 \u2014 Navigator Configurator engine
   5 user choices (Housing \u00B7 Voltage \u00B7 Finish \u00B7 EM \u00B7 Sensor) \u00B7 1 auto-locked
   (-3N1 CCTSELECT capability) \u00B7 2 field-set DIP (WATTSELECT, CCTSELECT) \u2014
   informational only.
   SKU pattern (per James 2026-05-02):
       LCNP3W{housing}-3N1-{voltage}{finish}{/EM?}{/MSP-?}
   Examples:
       LCNP3W100-3N1-UD                     \u2190 default \u00B7 100W DIP \u00B7 5000K DIP
       LCNP3W100-3N1-UD/EM20                \u2190 + 20W EM battery
       LCNP3W100-3N1-UD/MSP-ACS             \u2190 + \u24B6CS DLC NLC sensor
       LCNP3W100-3N1-UD/EM20/MSP-ACS        \u2190 + EM + sensor
       LCNP3W40-3N1-URAL7016/EM08/MSP-NLC   \u2190 LCNP3W40 \u00B7 custom RAL \u00B7 EM + SILVAIR
       LCNP3W100-3N1-HVD                    \u2190 HV 277-480V high-voltage variant
   Datasheet rated: 120 lm/W typical (5000K).
   LM-79 measured: 137 lm/W at 5000K \u00B7 143 lm/W at 4000K (peak \u2014 see Section 7).
   ============================================================================= */
(function() {
  // Lumens at 5000K (datasheet anchor) \u2014 same flat 120 lm/W across wattage steps
  var LUMEN = {
    '40':  { '20':  '2,400', '30':  '3,600', '40':  '4,800' },
    '100': { '60':  '7,200', '80':  '9,600', '100': '12,000' }
  };
  var HID = {
    '40':  { '20': '75W MH',  '30': '100W MH', '40': '175W MH' },
    '100': { '60': '250W MH', '80': '320W MH', '100': '400W MH' }
  };
  var WATTS = {
    '40':  ['20', '30', '40'],
    '100': ['60', '80', '100']
  };
  var CCT_LABEL  = { '35': '3500K', '40': '4000K', '50': '5000K' };
  var FINISH_LBL = {
    'D':   'Dark Bronze (QS)',
    'B':   'Black (MTO)',
    'S':   'Silver (MTO)',
    'W':   'White (MTO)',
    'RAL': 'Custom RAL (MTO)'
  };
  var VOLTAGE_LBL = {
    'U':  'U \u00B7 120-277V universal (QS)',
    'HV': 'HV \u00B7 277-480V high-voltage (MTO)'
  };
  var EM_LBL = {
    '':     '\u2014 none \u2014',
    'EM08': '/EM08 \u00B7 8W EBBU (recommended for 3W40)',
    'EM20': '/EM20 \u00B7 20W EBBU (recommended for 3W100)'
  };
  var SENSOR_LBL = {
    '':           '\u2014 none \u2014',
    'MSP-BLS':    '/MSP-BLS \u00B7 Bi-Level PIR (basic occupancy)',
    'MSP-BLS-5D': '/MSP-BLS-5D \u00B7 Bi-Level + Manual Dials',
    'MSP-ACS':    '/MSP-ACS \u00B7 \u24B6CS DLC NLC Bluetooth Mesh + SaaS',
    'MSP-NLC':    '/MSP-NLC \u00B7 SILVAIR SIG-Qualified Bluetooth Mesh'
  };

  // ---- RAL Classic validation table (ported from Illuminator v2) ----
  // 213 official RAL Classic codes (numbered ranges with intentional gaps).
  // SKU only emits /RAL{####} when typed code is in this Set.
  // Source: RAL Farben e.V. official Classic system.
  var RAL_VALID = new Set([
    1000,1001,1002,1003,1004,1005,1006,1007,1011,1012,1013,1014,1015,1016,1017,1018,1019,1020,1021,1023,1024,1026,1027,1028,1032,1033,1034,1035,1036,1037,
    2000,2001,2002,2003,2004,2005,2007,2008,2009,2010,2011,2012,2013,
    3000,3001,3002,3003,3004,3005,3007,3009,3011,3012,3013,3014,3015,3016,3017,3018,3020,3022,3024,3026,3027,3028,3031,3032,3033,
    4001,4002,4003,4004,4005,4006,4007,4008,4009,4010,4011,4012,
    5000,5001,5002,5003,5004,5005,5007,5008,5009,5010,5011,5012,5013,5014,5015,5017,5018,5019,5020,5021,5022,5023,5024,5025,5026,
    6000,6001,6002,6003,6004,6005,6006,6007,6008,6009,6010,6011,6012,6013,6014,6015,6016,6017,6018,6019,6020,6021,6022,6024,6025,6026,6027,6028,6029,6032,6033,6034,6035,6036,6037,6038,
    7000,7001,7002,7003,7004,7005,7006,7008,7009,7010,7011,7012,7013,7015,7016,7021,7022,7023,7024,7026,7030,7031,7032,7033,7034,7035,7036,7037,7038,7039,7040,7042,7043,7044,7045,7046,7047,7048,
    8000,8001,8002,8003,8004,8007,8008,8011,8012,8014,8015,8016,8017,8019,8022,8023,8024,8025,8028,8029,
    9001,9002,9003,9004,9005,9006,9007,9010,9011,9016,9017,9018,9022,9023
  ]);
  // Friendly names for the most common architectural / industrial codes.
  // Anything not in this map still validates \u2014 we just show "Valid" with the number.
  var RAL_NAMES = {
    1013:'Oyster White', 1015:'Light Ivory', 1018:'Zinc Yellow', 1023:'Traffic Yellow',
    2003:'Pastel Orange', 2004:'Pure Orange', 2008:'Bright Red Orange',
    3000:'Flame Red', 3003:'Ruby Red', 3020:'Traffic Red',
    5002:'Ultramarine Blue', 5005:'Signal Blue', 5010:'Gentian Blue', 5012:'Light Blue', 5015:'Sky Blue', 5017:'Traffic Blue',
    6005:'Moss Green', 6018:'Yellow Green', 6029:'Mint Green',
    7016:'Anthracite Grey', 7021:'Black Grey', 7022:'Umbra Grey', 7035:'Light Grey', 7037:'Dusty Grey', 7042:'Traffic Grey A', 7043:'Traffic Grey B',
    8004:'Copper Brown', 8011:'Nut Brown', 8017:'Chocolate Brown', 8019:'Grey Brown', 8022:'Black Brown',
    9001:'Cream', 9002:'Grey White', 9003:'Signal White', 9005:'Jet Black', 9006:'White Aluminium', 9007:'Grey Aluminium', 9010:'Pure White', 9016:'Traffic White', 9017:'Traffic Black', 9018:'Papyrus White'
  };
  // Hex approximations for the architectural / outdoor-fixture-relevant codes.
  // Used to drive the preview-image color overlay + badge swatch chip.
  // Anything not in this map falls back to a neutral grey (#7a7a7a).
  var RAL_HEX = {
    1013:'#E9E5CE', 1015:'#E6D2B5', 1018:'#FAAD2A', 1023:'#F0CA00',
    2003:'#F58220', 2004:'#E25303', 2008:'#F44611',
    3000:'#AF2B1E', 3003:'#A52019', 3020:'#CC0605',
    5002:'#20214F', 5005:'#1E2460', 5010:'#0E294B', 5012:'#3F888F', 5015:'#2271B3', 5017:'#063971',
    6005:'#2F4538', 6018:'#57A639', 6029:'#20603D',
    7016:'#293133', 7021:'#23282B', 7022:'#332F2C', 7035:'#C5C7C4', 7037:'#7D7F7D', 7042:'#8D948D', 7043:'#4E5754',
    8004:'#8E402A', 8011:'#5A3A29', 8017:'#45322E', 8019:'#403A3A', 8022:'#1B1B1B',
    9001:'#FDF4E3', 9002:'#E7EBDA', 9003:'#F4F4F4', 9005:'#0A0A0A', 9006:'#A5A5A5', 9007:'#8F8F8F', 9010:'#F7F9EF', 9016:'#F6F6F6', 9017:'#0E0E10', 9018:'#CFD3CD'
  };

  function defaultState() {
    return {
      housing: '100',
      voltage: 'U',
      finish:  'D',
      ralCode: '',
      em:      '',
      sensor:  '',
      watt:    '100',  // factory default for LCNP3W100
      cct:     '50'    // datasheet default 5000K
    };
  }
  var state = defaultState();

  function buildSku(s) {
    // Finish segment \u2014 RAL uses user-typed 4-digit code, ONLY emitted when
    // the code is in RAL_VALID. While the user is mid-typing or types an
    // invalid code, fall back to "RAL????" placeholder so the SKU display
    // signals "still incomplete" rather than rendering a fake catalog #.
    var fin;
    if (s.finish === 'RAL') {
      var isValid = s.ralCode && /^[0-9]{4}$/.test(s.ralCode) && RAL_VALID.has(parseInt(s.ralCode, 10));
      fin = isValid ? ('RAL' + s.ralCode) : 'RAL????';
    } else {
      fin = s.finish;
    }
    // Pattern: LCNP3W{housing}-3N1-{voltage}{finish}{/EM?}{/MSP-?}
    var sku = 'LCNP3W' + s.housing + '-3N1-' + s.voltage + fin;
    if (s.em)     sku += '/' + s.em;
    if (s.sensor) sku += '/' + s.sensor;
    return sku;
  }

  function renderWattChips() {
    var host = document.getElementById('cfgWattChips');
    if (!host) return;
    var watts = WATTS[state.housing] || WATTS['100'];
    var defaultWatt = watts[watts.length - 1];
    var html = '';
    watts.forEach(function(w, idx) {
      var isDefault = (w === defaultWatt);
      var isSelected = (w === state.watt);
      html += '<button type="button" class="cfg-chip cfg-chip-toggle' + (isSelected ? ' selected' : '') + '" ' +
              'data-field="watt" data-val="' + w + '" data-code="' + w + 'W" aria-pressed="' + isSelected + '">' +
              '<span class="cfg-chip-val">' + w + 'W' + (isDefault ? ' \u2605' : '') + '</span>' +
              '<span class="cfg-chip-code">DIP-' + (idx + 1) + (isDefault ? ' \u2605' : '') + '</span>' +
              '</button>';
    });
    host.innerHTML = html;
    host.querySelectorAll('.cfg-chip').forEach(function(chip) {
      chip.addEventListener('click', function() {
        host.querySelectorAll('.cfg-chip').forEach(function(c) { c.classList.remove('selected'); c.setAttribute('aria-pressed','false'); });
        chip.classList.add('selected');
        chip.setAttribute('aria-pressed', 'true');
        state.watt = chip.dataset.val;
        render();
      });
    });
  }

  function render() {
    document.getElementById('cfgCounterCount').textContent = '5';
    var sku = buildSku(state);
    document.getElementById('cfgSku').textContent = sku;

    // Tag (above preview image)
    var fLabel = FINISH_LBL[state.finish] ? FINISH_LBL[state.finish].split(' (')[0].toUpperCase() : 'DARK BRONZE';
    document.getElementById('cfgPreviewTag').textContent = 'LCNP3W' + state.housing + ' \u00B7 ' + fLabel;

    // Spec grid
    document.getElementById('cfgSpecModel').textContent  = 'LCNP3W' + state.housing;
    document.getElementById('cfgSpecVoltage').textContent = VOLTAGE_LBL[state.voltage] || VOLTAGE_LBL['U'];
    var finishDisplay = FINISH_LBL[state.finish] || FINISH_LBL['D'];
    if (state.finish === 'RAL' && state.ralCode && /^[0-9]{4}$/.test(state.ralCode)) {
      finishDisplay = 'Custom RAL ' + state.ralCode + ' (MTO)';
    }
    document.getElementById('cfgSpecFinish').textContent = finishDisplay;
    document.getElementById('cfgSpecEm').textContent     = EM_LBL[state.em] || EM_LBL[''];
    document.getElementById('cfgSpecSensor').textContent = SENSOR_LBL[state.sensor] || SENSOR_LBL[''];
    document.getElementById('cfgSpecWatt').textContent   = state.watt + 'W';
    document.getElementById('cfgSpecCct').textContent    = CCT_LABEL[state.cct] || '5000K';

    // Show/hide RAL input
    var ralWrap = document.getElementById('cfgRalInputWrap');
    if (ralWrap) ralWrap.style.display = (state.finish === 'RAL') ? 'block' : 'none';

    // Finish-aware preview image \u2014 apply CSS filter class to swap the photo's
    // tonal range to match the picked finish. Source photo is dark bronze;
    // CSS recipes approximate Black/Silver/White/RAL.
    var imgWrap = document.getElementById('cfgPreviewImgWrap');
    if (imgWrap) {
      imgWrap.classList.remove('fs-D', 'fs-B', 'fs-S', 'fs-W', 'fs-RAL', 'has-valid-ral');
      imgWrap.classList.add('fs-' + state.finish);
      // RAL badge + tint overlay only show when finish=RAL AND code is validated
      if (state.finish === 'RAL' && state.ralCode && /^[0-9]{4}$/.test(state.ralCode) && RAL_VALID.has(parseInt(state.ralCode, 10))) {
        imgWrap.classList.add('has-valid-ral');
        var num   = parseInt(state.ralCode, 10);
        var hex   = RAL_HEX[num] || '#7a7a7a';
        var name  = RAL_NAMES[num] || 'RAL Classic';
        var tint  = document.getElementById('cfgRalTint');
        var sw    = document.getElementById('cfgRalBadgeSwatch');
        var bnum  = document.getElementById('cfgRalBadgeNum');
        var bname = document.getElementById('cfgRalBadgeName');
        if (tint)  tint.style.background = hex;
        if (sw)    sw.style.background = hex;
        if (bnum)  bnum.textContent = 'RAL ' + state.ralCode;
        if (bname) bname.textContent = name;
      }
    }

    // Output cell \u2014 reveals LM-79 measured headroom over datasheet rating
    var lm = (LUMEN[state.housing] && LUMEN[state.housing][state.watt]) || '\u2014';
    document.getElementById('cfgSpecLumens').textContent =
      lm + ' lm \u00B7 datasheet rated 120 lm/W typical (LM-79 measured 137 lm/W at 5000K \u00B7 143 lm/W at 4000K \u2014 see Section 7)';

    // Update CCT chip notes \u2014 show lumen value at the active model+wattage for each CCT
    ['35','40','50'].forEach(function(cct) {
      var note = document.getElementById('cfgCctNote' + cct);
      if (note) note.textContent = lm + ' lm @ LCNP3W' + state.housing + ' \u00B7 ' + state.watt + 'W';
    });

    renderWattChips();

    // Submittal CTA \u2014 pass full state as query params
    var sub = document.getElementById('cfgCtaSubmittal');
    if (sub) {
      sub.href = 'submittal_template.html?product=navigator&sku=' + encodeURIComponent(sku) +
                 '&housing=' + state.housing +
                 '&wattage=' + state.watt +
                 '&cct=' + state.cct +
                 '&voltage=' + state.voltage +
                 '&finish=' + state.finish + (state.ralCode ? '&ral=' + state.ralCode : '') +
                 '&em=' + (state.em || '') +
                 '&sensor=' + (state.sensor || '');
    }

    var copyLabel = document.getElementById('cfgSkuCopyLabel');
    var copyBtn   = document.getElementById('cfgSkuCopy');
    if (copyLabel) copyLabel.textContent = 'Copy SKU';
    if (copyBtn)   copyBtn.classList.remove('copied');
  }

  function init() {
    // Wire chips for non-watt fields (housing, voltage, finish, em, sensor, cct)
    var chips = document.querySelectorAll('#configurator .cfg-chip:not([data-field="watt"])');
    chips.forEach(function(chip) {
      if (chip.classList.contains('locked')) return;
      chip.addEventListener('click', function() {
        var f = chip.dataset.field;
        var v = chip.dataset.val;
        // Single-pick group \u2014 deselect siblings, select this one
        var siblings = document.querySelectorAll('#configurator .cfg-chip[data-field="' + f + '"]');
        siblings.forEach(function(s) { s.classList.remove('selected'); s.setAttribute('aria-pressed', 'false'); });
        chip.classList.add('selected');
        chip.setAttribute('aria-pressed', 'true');
        state[f] = v;
        // Housing swap resets watt to housing's max default
        if (f === 'housing') {
          state.watt = WATTS[v][WATTS[v].length - 1];
        }
        render();
      });
    });

    // RAL Classic 4-digit input \u2014 live-validates against the official spec list.
    // Three feedback states:
    //   .hint    : empty or partial input (< 4 digits)
    //   .valid   : 4 digits AND the number is in RAL_VALID \u2014 SKU emits /RAL{####}
    //   .invalid : 4 digits but NOT in RAL_VALID \u2014 SKU keeps /RAL???? placeholder
    var ralInput   = document.getElementById('cfgRalInput');
    var ralWrap2   = document.getElementById('cfgRalInputWrap');
    var ralNameEl  = document.getElementById('cfgRalName');
    if (ralInput && ralWrap2) {
      ralInput.addEventListener('input', function() {
        // Strip non-digit characters as the user types
        var raw = (ralInput.value || '').replace(/\D/g, '').slice(0, 4);
        if (raw !== ralInput.value) ralInput.value = raw;

        ralWrap2.classList.remove('valid', 'invalid');
        if (raw.length === 0) {
          // Empty \u2014 neutral hint state
          state.ralCode = '';
        } else if (raw.length < 4) {
          // Mid-typing \u2014 neutral hint state, no SKU code yet
          state.ralCode = raw;  // keep partial so SKU shows RAL???? while typing
        } else {
          // Full 4 digits \u2014 validate against RAL_VALID Set
          var num = parseInt(raw, 10);
          state.ralCode = raw;
          if (RAL_VALID.has(num)) {
            ralWrap2.classList.add('valid');
            if (ralNameEl) {
              ralNameEl.textContent = 'RAL ' + raw + (RAL_NAMES[num] ? ' \u00B7 ' + RAL_NAMES[num] : '');
            }
          } else {
            ralWrap2.classList.add('invalid');
          }
        }
        render();
      });
    }

    // Reset
    var resetBtn = document.getElementById('cfgReset');
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        state = defaultState();
        var defaults = { housing: '100', voltage: 'U', finish: 'D', cct: '50', em: '', sensor: '' };
        Object.keys(defaults).forEach(function(f) {
          document.querySelectorAll('#configurator .cfg-chip[data-field="' + f + '"]').forEach(function(c) {
            var match = c.dataset.val === defaults[f];
            c.classList.toggle('selected', match);
            c.setAttribute('aria-pressed', match ? 'true' : 'false');
          });
        });
        if (ralInput) ralInput.value = '';
        render();
      });
    }

    // Copy SKU
    var copyBtn = document.getElementById('cfgSkuCopy');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        var sku = buildSku(state);
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(sku).then(function() {
            document.getElementById('cfgSkuCopyLabel').textContent = 'Copied!';
            copyBtn.classList.add('copied');
            setTimeout(function() {
              document.getElementById('cfgSkuCopyLabel').textContent = 'Copy SKU';
              copyBtn.classList.remove('copied');
            }, 1800);
          });
        }
      });
    }

    render();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>
