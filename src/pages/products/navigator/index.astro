  }
  .acc-card:hover { border-color: var(--brand-red); transform: translateY(-2px); }
  .acc-card.is-hidden { display: none; }
  .acc-card-img {
    background: var(--bg-darker);
    height: 168px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }
  .acc-card-img svg { width: 64%; height: 64%; color: rgba(255,255,255,0.55); }
  .acc-card-img .acc-card-photo {
    max-width: 86%;
    max-height: 86%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 8px 14px rgba(0,0,0,0.5));
  }
  .acc-card-img-tag {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 2;
    background: rgba(0,0,0,0.55);
    color: rgba(255,255,255,0.85);
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 2px;
    border: 1px solid rgba(255,255,255,0.10);
  }
  .acc-card-body {
    padding: 16px 16px 18px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 10px;
  }
  .acc-card-cat {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
