(function() {
  var COPY = {
    'bls':      'Two basic bi-level PIR sensor variants \u2014 both IR-remote commissioned, no network gateway, no IT support required. <strong><code>/MSP-BLS</code></strong> for standard automatic high/low power switching \u00B7 <strong><code>/MSP-BLS-5D</code></strong> adds five manual dial controls for site-tuned thresholds. Both: <strong>PIR \u00B7 30 ft mount-height \u00B7 12-24Vdc \u00B7 IP65 \u00B7 UL listed</strong>. Commissioning is IR-remote-driven via the optional <strong>RM-95</strong> IR controller (45 ft IR range \u00B7 2\u00D7 AAA \u00B7 IP20). Drives <strong>Title 24 \u00A7140.7 / IECC \u00A7C405.2 / ASHRAE 90.1</strong> bi-level controls credits without a third-party sensor BOM line and without networking complexity. Daylight-harvesting capable: adjust the daylight lux threshold (>50 lux), preset standby period, press MW/PIR button 3\u00D7 to enable. When the project needs occupancy bi-level but doesn\'t need networked controls, this is the spec.',

    'acs':      '<strong><code>/MSP-ACS</code> \u2014 DLC NLC-qualified networked lighting controls with SaaS capabilities.</strong> Bluetooth Mesh-based \u00B7 12-24Vdc \u00B7 PIR \u00B7 30 ft mount \u00B7 IP65 \u00B7 UL listed \u00B7 Fixture Mount. \u24B6CS delivers professional-grade networked lighting control with <strong>cloud-based management, energy analytics, and utility-rebate qualification</strong> \u2014 purpose-built for mid-size commercial and industrial facilities seeking measurable ROI and operational intelligence. Companion <strong>MSW-ACS Bluetooth Mesh controller</strong> (100 ft range \u00B7 IP65) extends the network. \u24B6CS is DLC NLC qualified \u2014 directly drives utility rebate eligibility under the 474 utility programs incentivizing networked lighting controls in 2025. Pick \u24B6CS when the spec asks for SaaS analytics, when the rebate channel is the priority, or when the project demands DLC NLC qualification on the controls module specifically.',

    'silvair':  '<strong><code>/MSP-NLC</code> \u2014 SIG-qualified Bluetooth Mesh enterprise controls (by SILVAIR).</strong> Bluetooth Mesh \u00B7 12-24Vdc \u00B7 PIR \u00B7 30 ft mount \u00B7 IP20 \u00B7 UL listed \u00B7 Fixture Mount. SILVAIR is a SIG-official Bluetooth Mesh standard \u2014 vendor-neutral, no gateway required, node-scheduling-based for sites that don\'t want internet dependency. Built for <strong>complex enterprise deployments</strong> where the lighting controls must integrate with a multi-vendor BMS, DALI gateway, or building-system fabric without proprietary lock-in. SILVAIR runs on node scheduling \u2014 each fixture stores its own schedule and can operate without an active cloud connection \u2014 eliminating the gateway/internet failure mode common to other mesh systems. Pick SILVAIR when the spec calls for vendor neutrality, when the building requires non-internet-dependent operation, or when the project will commission across multiple controls vendors.'
  };
  var LINK_LABEL = {
    'bls':      'Discover bi-level sensors \u2192',
    'acs':      'Discover \u24B6CS networked \u2192',
    'silvair':  'Discover SILVAIR mesh \u2192'
  };
  var LINK_HREF = {
    'bls':      '/products/controls/sensors/bi-level/',
    'acs':      '/products/controls/acs/',
    'silvair':  '/products/controls/silvair/'
  };

  function init() {
    var tabs = document.querySelectorAll('#controls .tac-callout-tab');
    var copy = document.getElementById('tacCalloutCopy');
    var linkAnchor = document.querySelector('#controls .tac-callout-link');
    var linkLabel  = document.querySelector('#controls .tac-callout-link span');
    var wave = document.getElementById('tacShockwave');
    if (!tabs.length || !copy) return;

    function ripple() {
      if (!wave) return;
      wave.classList.remove('is-rippling');
      void wave.offsetWidth;
      wave.classList.add('is-rippling');
    }

    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        var p = t.dataset.platform;
        copy.innerHTML = COPY[p] || COPY['bls'];
        if (linkLabel)  linkLabel.textContent  = LINK_LABEL[p] || LINK_LABEL['bls'];
        if (linkAnchor) linkAnchor.setAttribute('href', LINK_HREF[p] || LINK_HREF['bls']);
        ripple();
      });
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
