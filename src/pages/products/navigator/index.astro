  .acc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .acc-card {
    background: var(--bg-spec);
    border: 1px solid var(--line);
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
