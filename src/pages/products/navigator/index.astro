<script>
/* =============================================================================
   SECTION 3 \u2014 Navigator spec table model switcher.
   AUTHORITATIVE source: LCNP | Navigator | Datasheet.pdf (Zoho WorkDrive).
   Datasheet specs lumens at 5000K; 120 lm/W flat across every wattage and
   CCT setting per datasheet page 2 spec table. Per-CCT measured variance
   (if any) lives in Section 7 photometrics where the LM-79 detail is
   properly disclosed; the spec table uses datasheet nominals so the buyer
   cites the published numbers.
   2 model classes \u00D7 3 WATTSELECT settings each = 6 rows total.
   ============================================================================= */
(function() {
  var DATA = {
    '3W40': {
      'rows': [
        { w: '20W',    lm: '2,400',  lpw: '120 lm/W',  hid: '75W MH',  cct: '3500 / 4000 / 5000K' },
        { w: '30W',    lm: '3,600',  lpw: '120 lm/W',  hid: '100W MH', cct: '3500 / 4000 / 5000K' },
        { w: '40W \u2605',  lm: '<strong>4,800</strong>', lpw: '<strong>120 lm/W</strong>', hid: '175W MH', cct: '3500 / 4000 / 5000K' }
      ],
      'foot': '\u2605 <em><strong>LCNP3W40</strong> \u2014 the 40W-class housing covering the 75W to 175W metal halide retrofit lane in soffits, vestibule overhangs, low canopies, and school covered walkways. ' +
              'WATTSELECT field-pick at install: 20 / 30 / 40W via 3-position DIP \u2014 ' +
              '<strong>40W is the factory default setting</strong>. ' +
              'CCTSELECT field-pick at install: 3500K / 4000K / 5000K via DIP. ' +
              '4,800 lm @ 40W / 120 lm/W is the datasheet ceiling at 5000K. ' +
              'SKU pattern: <code>LCNP3W40-3N1-UD</code> \u2014 universal 120-277V QuickShip + 0-10V dim driver + 1/2" NPS knockouts on 3 sides + wet<span class="aa">\u24B6</span>GUARD sealing all standard. ' +
              'Optional <strong><code>/EM08</code> 8W emergency battery</strong> (recommended for the LCNP3W40 housing) + four <code>/MSP-XXX</code> sensor variants (BLS \u00B7 BLS-5D \u00B7 ACS \u00B7 NLC) \u2014 see configurator.</em>'
    },
    '3W100': {
      'rows': [
        { w: '60W',    lm: '7,200',  lpw: '120 lm/W',  hid: '250W MH', cct: '3500 / 4000 / 5000K' },
        { w: '80W',    lm: '9,600',  lpw: '120 lm/W',  hid: '320W MH', cct: '3500 / 4000 / 5000K' },
        { w: '100W \u2605', lm: '<strong>12,000</strong>', lpw: '<strong>120 lm/W</strong>', hid: '400W MH', cct: '3500 / 4000 / 5000K' }
      ],
      'foot': '\u2605 <em><strong>LCNP3W100</strong> \u2014 the line-topper for high-mount parking decks, big-box drive-throughs, gas-station canopies, and 400W MH 1:1 swap-outs. ' +
              'Same 10.06 \u00D7 10.06 \u00D7 2.73 in slim envelope as LCNP3W40 (one mounting hole pattern across the entire family \u2014 distributor stocking and installer training collapse to a single fixture footprint). ' +
              'WATTSELECT field-pick at install: 60 / 80 / 100W via 3-position DIP \u2014 ' +
              '<strong>100W is the factory default setting</strong>. CCTSELECT: 3500K / 4000K / 5000K via DIP. ' +
              '12,000 lm @ 100W / 120 lm/W replaces 400W metal halide at 5000K. ' +
              'SKU pattern: <code>LCNP3W100-3N1-UD</code> \u00B7 same 0-10V dim driver and universal voltage as LCNP3W40, heavier driver chamber (4.17 vs. 3.62 lb). ' +
              'Optional <strong><code>/EM20</code> 20W emergency battery</strong> (recommended for this 100W-class housing \u2014 sized to maintain code-compliant egress lumens during the 90-minute backup window) + four <code>/MSP-XXX</code> sensor variants. ' +
              '<strong>HV variant available (Made-to-Order)</strong> for 277-480V industrial canopies \u2014 the only LCNP canopy SKU with a high-voltage option.</em>'
    }
  };

  function init() {
    var tabs   = document.querySelectorAll('.spec-watt-tab[data-model]');
    var tbody  = document.getElementById('specTableBody');
    var tfoot  = document.getElementById('specTableFoot');
    if (!tabs.length || !tbody) return;

    function render(model) {
      var d = DATA[model];
      if (!d) return;
      tbody.innerHTML = d.rows.map(function(r) {
        var defaultClass = r.w.indexOf('\u2605') > -1 ? ' class="is-default"' : '';
        return '<tr' + defaultClass + '>' +
                 '<td>' + r.w   + '</td>' +
                 '<td>' + r.lm  + ' lm</td>' +
                 '<td>' + r.lpw + '</td>' +
                 '<td>' + r.hid + '</td>' +
                 '<td>' + r.cct + '</td>' +
               '</tr>';
      }).join('');
      tfoot.innerHTML = d.foot;
    }

    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        render(t.dataset.model);
      });
    });

    render('3W40');  // Default \u2014 LCNP3W40 (volume retrofit lane)
  }

  // Zoom modal for dimensions drawing
  function initZoom() {
    var btn = document.getElementById('dimZoomBtn');
    var modal = document.getElementById('dimZoomModal');
    var close = document.getElementById('dimZoomClose');
    if (!btn || !modal) return;
    btn.addEventListener('click', function() { modal.classList.add('open'); });
    modal.addEventListener('click', function(e) {
      if (e.target === modal) modal.classList.remove('open');
    });
    if (close) close.addEventListener('click', function() { modal.classList.remove('open'); });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') modal.classList.remove('open');
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { init(); initZoom(); });
  } else { init(); initZoom(); }
})();
</script>

