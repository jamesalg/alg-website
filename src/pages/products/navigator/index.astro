  }
  .acc-pill:hover { color: var(--text-primary); border-color: var(--text-primary); }
  .acc-pill.active { background: var(--brand-red); border-color: var(--brand-red); color: white; }
  .acc-pill .acc-pill-count {
    font-size: 10px;
    font-weight: 600;
