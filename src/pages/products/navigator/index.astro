  .acc-card-sku {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-top: -4px;
  }
  .acc-card-cta {
    margin-top: auto;
    padding-top: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-secondary);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.18s, gap 0.18s;
  }
  .acc-card:hover .acc-card-cta { color: var(--brand-red); gap: 10px; }

  /* Modal */
  .acc-modal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.78);
    z-index: 1100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 32px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .acc-modal.open { display: flex; }
  .acc-modal-panel {
    background: var(--bg-spec);
    border: 1px solid var(--line-medium);
    border-radius: 4px;
    width: 100%;
    max-width: 920px;
    max-height: 90vh;
    overflow: auto;
    position: relative;
  }
  .acc-modal-grid { display: grid; grid-template-columns: 0.85fr 1fr; gap: 0; }
  .acc-modal-img {
    background: var(--bg-darker);
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--line);
    min-height: 360px;
    max-height: 480px;
    padding: 28px;
    position: relative;
  }
  .acc-modal-img svg { width: 90%; height: 90%; max-width: 360px; color: rgba(255,255,255,0.78); }
  .acc-modal-img img {
    max-width: 90%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 12px 24px rgba(0,0,0,0.6));
  }
  .acc-modal-img-cat {
    position: absolute;
    top: 16px;
    left: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-red);
    background: rgba(243,39,64,0.10);
    border: 1px solid rgba(243,39,64,0.35);
    padding: 4px 10px;
    border-radius: 2px;
  }
  .acc-modal-body {
    padding: 32px 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .acc-modal-title { font-size: 22px; font-weight: 700; line-height: 1.2; color: var(--text-primary); margin: 0; }
  .acc-modal-sku {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }
  .acc-modal-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .acc-modal-specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .acc-spec-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
  }
  .acc-spec-row:nth-last-child(-n+2) { border-bottom: none; }
  .acc-spec-row:nth-child(odd) { padding-right: 18px; }
  .acc-spec-row:nth-child(even) { padding-left: 18px; border-left: 1px solid var(--line); }
  .acc-spec-key {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .acc-spec-val {
    font-size: 13.5px;
    color: var(--text-primary);
    font-weight: 600;
    line-height: 1.4;
  }
  .acc-modal-ctas { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 4px; }
  .acc-modal-cta {
    flex: 1;
    min-width: 170px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 13px 18px;
    border-radius: 2px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.18s;
    border: 1px solid transparent;
    white-space: nowrap;
    text-decoration: none;
  }
  .acc-modal-cta.primary { background: var(--brand-red); color: white; }
  .acc-modal-cta.primary:hover { background: var(--brand-red-deep); }
  .acc-modal-cta.outline {
    background: transparent;
    color: var(--text-secondary);
    border-color: var(--line-medium);
  }
  .acc-modal-cta.outline:hover { color: var(--text-primary); border-color: var(--text-primary); }
  .acc-modal-cta svg { width: 14px; height: 14px; }
  .acc-modal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 38px;
    height: 38px;
    background: rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.15);
    color: white;
    border-radius: 2px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: all 0.18s;
  }
  .acc-modal-close:hover { background: var(--brand-red); border-color: var(--brand-red); }
  .acc-modal-close svg { width: 16px; height: 16px; }
  @media (max-width: 1100px) {
    .acc-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .acc-grid { grid-template-columns: 1fr; }
    .acc-modal-grid { grid-template-columns: 1fr; }
    .acc-modal-img { min-height: 220px; border-right: none; border-bottom: 1px solid var(--line); }
    .acc-modal-specs { grid-template-columns: 1fr; }
    .acc-spec-row:nth-child(odd) { padding-right: 0; }
    .acc-spec-row:nth-child(even) { padding-left: 0; border-left: none; }
    .acc-spec-row { border-bottom: 1px solid var(--line); }
    .acc-spec-row:last-child { border-bottom: none; }
    .acc-title { font-size: 28px; }
  }

  /* ============================================================================
     SECTION 7 — Photometrics (polar plots derived from Guardian IES files)
     ============================================================================ */
  .photo-section {
    background: var(--bg-page);
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .photo-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .photo-head { text-align: center; margin-bottom: 48px; }
  .photo-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: inline-flex;
    align-items: center;
