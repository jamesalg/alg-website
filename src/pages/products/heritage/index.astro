  };

  // CFG-STATE-1: Derive ship-tier from selected chip badges, NOT from
  // ZOHO_CATALOG match alone. The catalog map is a name overlay; the
  // chip badges (QS/MTO/WB) are the source of truth for lead time. An
  // all-QS \u00E0-la-carte combo ships QuickShip even when not pre-bundled.
  function deriveShipTier(state) {
    if (state.finish === 'RAL' && state.ralCode) return 'MTO'; // custom paint = factory work
    var section = document.getElementById('configurator');
    if (!section) return 'QS';
    var keys = ['housing','voltage','finish','optic','mount','ps','sensor'];
    var worst = 'QS';
    for (var i = 0; i < keys.length; i++) {
      var k = keys[i], v = state[k];
      if (v === '' || v == null) continue;
      var chipEl = section.querySelector('.cfg-chip[data-field="' + k + '"][data-val="' + v + '"]');
      if (!chipEl) continue;
      if (chipEl.querySelector('.cfg-chip-stock.mto')) return 'MTO';
      if (chipEl.querySelector('.cfg-chip-stock.wb'))  worst = 'WB';
    }
    return worst;
  }

  function checkZohoMatch(currentSku) {
    var match = ZOHO_CATALOG[currentSku];
    var tier  = deriveShipTier(state);
    var iconEl  = document.getElementById('cfgZohoMatchIcon');
    var textEl  = document.getElementById('cfgZohoMatchText');
    var stockEl = document.getElementById('cfgZohoMatchStock');
    var rowEl   = document.getElementById('cfgZohoMatch');
    if (!iconEl || !textEl || !stockEl || !rowEl) return;

    // Public-site copy posture (CFG-ZOHO-1 + CFG-STATE-1):
    //   - Tier = QS / WB / MTO derived from chip badges (CFG-STATE-1)
    //   - Catalog map adds the bundle name when matched (overlay, not gate)
    //   - DO NOT show stock numbers, warehouse breakdowns, or pricing tiers
    //   - For pricing/availability, route to "Pricing & Availability" CTA
    //     (rep-desk-gated \u00B7 authenticates before disclosing)
    var palette = {
      QS:  { border: 'rgba(95,199,122,0.40)', bg: 'rgba(95,199,122,0.06)', color: '#6fd789',
             icon: '<polyline points="20 6 9 17 4 12"/>' },
      WB:  { border: 'rgba(96,168,255,0.40)', bg: 'rgba(96,168,255,0.06)', color: '#7fb6ff',
             icon: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>' },
      MTO: { border: 'rgba(255,159,28,0.36)', bg: 'rgba(255,159,28,0.05)', color: '#ffb14d',
             icon: '<circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16v.01"/>' }
    }[tier];

    rowEl.style.border = '1px solid ' + palette.border;
    rowEl.style.background = palette.bg;
    iconEl.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="' + palette.color + '" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">' + palette.icon + '</svg>';

    var labelHtml, ctaHtml;
    if (tier === 'QS') {
      if (match) {
        var typeLabel = (match.type === 'combo') ? 'Catalog combo SKU' : 'Catalog SKU';
        var sensorNote = match.sensorVariant ? ' \u00B7 <code>/BLS</code> = ' + match.sensorVariant : '';
        labelHtml = '<strong style="color:' + palette.color + ';">\u2713 ' + typeLabel + ' \u00B7 QuickShip</strong> \u00B7 ' + match.name + sensorNote;
      } else {
        labelHtml = '<strong style="color:' + palette.color + ';">\u2713 QuickShip \u00B7 \u00E0-la-carte assembly</strong>'
                  + '<br/><span style="color:var(--text-muted); font-size:10.5px;">All selected components in stock \u00B7 ships 2-3 day.</span>';
      }
      ctaHtml = '<a href="/pricing-availability/?sku=' + encodeURIComponent(currentSku) + '" style="color:' + palette.color + '; text-decoration:underline;">Pricing &amp; availability \u2192</a>';
    } else if (tier === 'WB') {
      labelHtml = '<strong style="color:' + palette.color + ';">Workbench Assembly \u00B7 ~1-3 wk</strong>'
                + '<br/><span style="color:var(--text-muted); font-size:10.5px;">One or more selected components are workbench-assembled to order.</span>';
      ctaHtml = '<a href="/contact/?type=quote&sku=' + encodeURIComponent(currentSku) + '" style="color:' + palette.color + '; text-decoration:underline;">Request quote \u2192</a>';
    } else { // MTO
      labelHtml = '<strong style="color:' + palette.color + ';">Custom build \u00B7 Made-to-Order \u00B7 ~4-6 wk</strong>'
                + '<br/><span style="color:var(--text-muted); font-size:10.5px;">One or more selected components are MTO (custom finish, MTO option, or non-stocked variant).</span>';
