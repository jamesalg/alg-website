  function init() {
    var grid     = document.getElementById('accGrid');
    var modal    = document.getElementById('accModal');
    var panel    = document.getElementById('accModalPanel');
    var closeBtn = document.getElementById('accModalClose');
    var imgWrap  = document.getElementById('accModalImg');
    var catEl    = document.getElementById('accModalCat');
    var titleEl  = document.getElementById('accModalTitle');
    var skuEl    = document.getElementById('accModalSku');
    var descEl   = document.getElementById('accModalDesc');
    var specsEl  = document.getElementById('accModalSpecs');
    var dsCta    = document.getElementById('accModalDsCta');
    var dsLbl    = document.getElementById('accModalDsLabel');
    var drillBox = document.getElementById('accModalDrill');
    var drillMeta= document.getElementById('accModalDrillMeta');
    var drillNote= document.getElementById('accModalDrillNote');
    var drillGrid= document.getElementById('accModalDrillGrid');
    var pills    = document.querySelectorAll('.acc-pill');
    if (!grid || !modal) return;
    var cards = grid.querySelectorAll('.acc-card');

    // ---- Filter pills (CFG-ACC-1) ----
    pills.forEach(function(p) {
      p.addEventListener('click', function() {
        pills.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-selected', 'false'); });
        p.classList.add('active');
        p.setAttribute('aria-selected', 'true');
        var f = p.dataset.filter;
        cards.forEach(function(c) {
          var match = (f === 'all' || c.dataset.cat === f);
          c.classList.toggle('is-hidden', !match);
        });
      });
    });

    // ---- Open modal ----
    function openModal(card) {
      var id = card.dataset.id;
      var d  = ACC[id];
      if (!d) { console.warn('acc-modal: no data for id', id); return; }
      catEl.textContent   = d.cat.replace(/\u24B6/g, '');
      titleEl.innerHTML   = d.title.replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
      skuEl.textContent   = d.sku;
      descEl.innerHTML    = d.desc;
      if (d.cat.indexOf('\u24B6') >= 0) {
        catEl.innerHTML = d.cat.replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
      }
      specsEl.innerHTML = d.specs.map(function(s) {
        var v = (s[1] || '').toString().replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
        return '<div class="acc-spec-row">' +
                 '<div class="acc-spec-key">' + s[0] + '</div>' +
                 '<div class="acc-spec-val">' + v + '</div>' +
               '</div>';
      }).join('');
      // Drill pattern block \u2014 Mount accessories carry a 'drillSvg' object pointing at
      // the polished SVG recreation of the source CAD drill template. The block shows
      // a thumbnail of the SVG inline + a "View Full Drill Pattern" CTA that opens the
      // SVG fullscreen in #drillModal. Letter (A/B/C/D) is the mapped source CAD letter
      // per James 2026-05-05: A\u2192/SP \u00B7 B\u2192/UA \u00B7 C\u2192/RS \u00B7 D\u2192/TN.
      // (The legacy 'drillTemplates' 9-button grid is kept as a no-op fallback for any
      // accessory that hasn't been migrated to the polished-SVG model yet.)
      if (drillBox && drillGrid && drillMeta && drillNote) {
        if (d.drillSvg && d.drillSvg.url) {
          drillBox.style.display = '';
          drillMeta.textContent = 'Mapped from ' + d.drillSvg.sourceLabel.split('\u00B7')[1].trim() + ' \u00B7 ' + d.drillSvg.sourceLabel.split('\u00B7')[2].trim();
          drillNote.textContent = '';
          // Use a <button> not an <a href="#"> so there's no default-navigation
          // contention with parent click handlers, and bind the click
          // directly to the freshly-created element below for max reliability.
          drillGrid.innerHTML =
            '<button type="button" class="acc-modal-drill-svg" data-drill-url="' + d.drillSvg.url +
              '" data-drill-letter="' + d.drillSvg.letter +
              '" data-drill-title="' + (d.title || '').replace(/"/g, '&quot;') +
              '" data-drill-source="' + d.drillSvg.sourceLabel.replace(/"/g, '&quot;') + '">' +
              '<img class="acc-modal-drill-svg-img" src="' + d.drillSvg.url + '" alt="' +
                (d.title || '').replace(/"/g, '&quot;') + ' drill pattern thumbnail" />' +
              '<span class="acc-modal-drill-svg-cta">' +
                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
                  '<polyline points="15 3 21 3 21 9"/>' +
                  '<polyline points="9 21 3 21 3 15"/>' +
                  '<line x1="21" y1="3" x2="14" y2="10"/>' +
                  '<line x1="3" y1="21" x2="10" y2="14"/>' +
                '</svg>' +
                '<span>View Full Drill Pattern</span>' +
              '</span>' +
            '</button>';
          // Direct click binding \u2014 bypass document delegation entirely.
          var drillBtn = drillGrid.querySelector('.acc-modal-drill-svg');
          if (drillBtn) {
            drillBtn.addEventListener('click', function(e) {
              e.preventDefault();
              e.stopPropagation();
              var drillModalEl = document.getElementById('drillModal');
              var drillImgEl   = document.getElementById('drillModalImg');
              var drillTitleEl = document.getElementById('drillModalTitle');
              var drillSrcEl   = document.getElementById('drillModalSource');
              var drillLtrEl   = document.getElementById('drillModalLetter');
              if (!drillModalEl || !drillImgEl) return;
              drillImgEl.src = drillBtn.getAttribute('data-drill-url');
              drillImgEl.alt = drillBtn.getAttribute('data-drill-title') + ' drill pattern \u00B7 full view';
              if (drillTitleEl) drillTitleEl.textContent = drillBtn.getAttribute('data-drill-title') + ' \u00B7 Drill Pattern';
              if (drillSrcEl)   drillSrcEl.textContent   = drillBtn.getAttribute('data-drill-source') || '';
              if (drillLtrEl)   drillLtrEl.textContent   = drillBtn.getAttribute('data-drill-letter') || '';
              drillModalEl.classList.add('open');
              document.body.style.overflow = 'hidden';
            });
          }
        } else if (Array.isArray(d.drillTemplates) && d.drillTemplates.length) {
          // Legacy multi-PDF fallback \u2014 kept for any non-migrated accessory.
          drillBox.style.display = '';
          drillMeta.textContent = d.drillTemplates.length + ' PDFs \u00B7 Heritage-I';
          drillNote.textContent = d.drillNote || '';
          drillGrid.innerHTML = d.drillTemplates.map(function(t) {
            var pending = t.pending || !t.url;
            var pendingClass = pending ? ' is-pending' : '';
            var hrefAttr = pending ? '#' : t.url;
            var ariaDis = pending ? ' aria-disabled="true"' : '';
            var pdfIcon = '<svg class="acc-modal-drill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';
            var tbcChip = pending ? '<span class="acc-modal-drill-btn-tbc">URL TBC</span>' : '';
            return '<a class="acc-modal-drill-btn' + pendingClass + '"' +
                     ' href="' + hrefAttr + '" target="_blank" rel="noopener"' +
                     ariaDis +
                     ' title="' + t.file + '">' +
                     pdfIcon +
                     '<span class="acc-modal-drill-btn-body">' +
                       '<span class="acc-modal-drill-btn-letter">' + t.letter + '</span>' +
                       '<span class="acc-modal-drill-btn-name">' + t.name + '</span>' +
                     '</span>' +
                     tbcChip +
                   '</a>';
          }).join('');
        } else {
          drillBox.style.display = 'none';
          drillGrid.innerHTML = '';
        }
      }
      // Conditional Datasheet CTA \u2014 only renders if the active accessory carries a `datasheet`.
      // Pending state (URL TBC) follows CFG-DOCS-1: greyed, click-disabled, "URL TBC" label.
      if (dsCta && dsLbl) {
        if (d.datasheet) {
          dsCta.style.display = '';
          if (d.datasheet.pending || !d.datasheet.url) {
            dsCta.classList.add('is-pending');
            dsCta.setAttribute('aria-disabled', 'true');
            dsCta.setAttribute('href', '#');
            dsCta.onclick = function(e) { e.preventDefault(); return false; };
            dsLbl.textContent = 'Datasheet \u00B7 URL TBC';
          } else {
            dsCta.classList.remove('is-pending');
            dsCta.removeAttribute('aria-disabled');
            dsCta.setAttribute('href', d.datasheet.url);
            dsCta.onclick = null;
            dsLbl.textContent = 'Datasheet';
          }
        } else {
          dsCta.style.display = 'none';
        }
      }
      // Clone the card's media (svg or photo) into the modal image area
      var srcMedia = card.querySelector('.acc-card-img svg, .acc-card-img img.acc-card-photo');
      Array.from(imgWrap.querySelectorAll('svg, img.acc-card-photo')).forEach(function(s){ s.remove(); });
      if (srcMedia) {
        var clone = srcMedia.cloneNode(true);
        if (clone.tagName === 'IMG') {
          clone.style.maxWidth = '88%';
          clone.style.maxHeight = '88%';
          clone.style.objectFit = 'contain';
          clone.style.filter = 'drop-shadow(0 12px 24px rgba(0,0,0,0.55))';
        } else {
          // SVG: keep natural width via percentage scale
          clone.removeAttribute('class');
          clone.style.width = '70%';
          clone.style.height = 'auto';
          clone.style.maxWidth = '320px';
        }
        imgWrap.appendChild(clone);
      }
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }

    cards.forEach(function(c) { c.addEventListener('click', function() { openModal(c); }); });
    modal.addEventListener('click', function(e) { if (!panel.contains(e.target)) closeModal(); });
    if (closeBtn) closeBtn.addEventListener('click', function(e) { e.stopPropagation(); closeModal(); });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

<!-- ============================================================================
     SECTION 9 — Configurator (Build Your Heritage · live SKU builder)
     -------------------------------------------------------------------------
     SKU PATTERN (per Active_SKUs sheet + datasheet page 3 + James 2026-05-02 PM):
       LSBX3W{150|300}-3H1-{U|H}{D|B|S|W|RAL####}{3|4|5}/RB3{/RS|/TN|/UA|/SP?}{/PS?}{/MSP-XXX?}
       Required-only standard SKU:  LSBX3W150-3H1-UD3/RB3
       With mount + photocell:      LSBX3W150-3H1-UD3/RB3/UA/PS
       With sensor + RAL:           LSBX3W300-3H1-HRAL70163/RB3/SP/MSP-ACS
       Fully-loaded:                LSBX3W150-3H1-UD3/RB3/UA/PS/MSP-NLC

       Element decode:
         LSBX3W150 / LSBX3W300  housing class (150W or 300W max)
         -3H1                   3-CCTselect Heritage-I series (locked)
         -U  · -H               voltage: U universal 120-277V (QS) ·
                                H high-voltage 277-480V (MTO · LSBX3W300 only)
         D · B · S · W · RAL####   finish (joins voltage with no separator)
         3 · 4 · 5              optic: III (QS) · IV / V (MTO accessory codes)
                                appends to finish with no separator (UD3, UD4, etc.)
         /RB3                   receptacle board: 3-pin photocell-ready · ALWAYS
                                emitted (every active Heritage carries the
                                top-of-housing twist-lock receptacle + shorting cap)
         /RS · /TN · /UA · /SP  mount adder (single-pick, optional · LSBX-H1/* SKUs)
         /PS                    photocell adder (independent toggle · sits in
                                the /RB3 receptacle in place of the shorting cap)
         /MSP-{BLS|BLS-5D|ACS|NLC}  sensor adder (single-pick · 4 variants)

     User-pickable fields (5 required + 4 optional):
       Required SKU Fields (LEFT column):
         1. Housing class    LSBX3W150 ★ (default) or LSBX3W300
         2. CCTSELECT        3H1 (auto-locked)
         3. Voltage          U ★ (default · QS) or H (MTO · LSBX3W300 only)
         4. Finish           D ★ | B | S | W | RAL####
       Optional SKU Add-ons (RIGHT column):
         5. Optic Type       3 ★ (default) | 4 (MTO) | 5 (MTO)
         6. Mount            None ★ | /RS | /TN | /UA | /SP (single-pick)
         7. Photocell        None ★ | /PS (toggle · independent)
         8. Sensor           None ★ | /MSP-BLS | /MSP-BLS-5D | /MSP-ACS | /MSP-NLC
       Field-set at install (informational, NOT in SKU):
         WATTSELECT (3 wattages per housing) + CCTSELECT (3000K/4000K/5000K)
     Default complete SKU: LSBX3W150-3H1-UD3/RB3

     CONSTRAINT: H voltage is only available on LSBX3W300. When LSBX3W150 is
     active, the H voltage chip becomes disabled — clicking it does nothing
     and the chip shows "LSBX3W300 only" in its code line. Auto-flip to U
     when housing changes from LSBX3W300 → LSBX3W150.

     CFG-2 SIMPLIFICATION: Heritage's hero-1 photo shows the housing with
     photocell receptacle on top — the optic faces DOWN (parking-lot pole)
     and is not visible at this angle. So the body/lens split (CFG-2A
     pattern from Navigator) is unnecessary for Heritage; the entire image
     filters cleanly with the finish CSS recipe. No separate lens layer.
     ============================================================================ -->
<section class="cfg-section" id="configurator" aria-label="Configurator · Build Your Heritage">
  <div class="cfg-inner">

    <div class="cfg-head">
      <p class="cfg-eyebrow" style="display:flex; justify-content:center;">Build Your Model</p>
      <h2 class="cfg-title" style="text-align:center;">Configure Your Heritage</h2>
      <p class="cfg-sub" style="text-align:center;">
        Selections build the SKU live. WATTSELECT + CCTSELECT are DIP-set at install — they do not appear in the SKU.
        <small>Required fields marked with <span style="color:var(--brand-red); font-weight:700">*</span>. See the legend for QS / MTO / DIP / LCK meanings.</small>
      </p>
    </div>

    <div class="cfg-counter-band">
      <div class="cfg-counter complete" id="cfgCounter"><strong id="cfgCounterCount">5</strong> of 5 SKU fields confirmed</div>
      <button type="button" class="cfg-reset" id="cfgReset">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 12a9 9 0 1 0 3-6.7"/><polyline points="3 4 3 10 9 10"/>
        </svg>
        Reset to defaults
      </button>
    </div>

    <!-- ====================================================================
         QUICK PICK · CATALOG COMBOS
         --------------------------------------------------------------------
         Surface the 2 pre-bundled SKUs in Zoho Books so site visitors
         discover them before building from scratch. Per CFG-ZOHO-1 cardinal-
         sin policy, each card carries ONLY public-safe content:
           • Bundle name + sensor-variant note (product-level facts)
           • Mount/photocell/sensor accessory codes (already on spec sheet)
           • QuickShip status (binary, not a stock count)
           • The full Catalog # (the SKU itself is public)
         No stock counts, no warehouse breakdowns, no trade-pricing. Anything
         commercial routes through "Pricing & availability" CTA below.
         Click → applies all 8 field selections + scrolls to the live preview.
         ==================================================================== -->
    <div class="cfg-quickpicks" aria-label="Pre-bundled catalog combos">
      <div class="cfg-quickpicks-head">
        <div class="cfg-quickpicks-title">Quick Pick · Catalog Combos · QuickShip</div>
        <div class="cfg-quickpicks-hint">Or build a custom configuration below ↓</div>
      </div>
      <div class="cfg-quickpicks-grid">

        <!-- Card 1 · UA + PS + BLS combo (PIR Bi-Level on /UA) -->
        <button type="button" class="cfg-quickpick-card" data-quickpick="ua-ps-bls">
          <span class="cfg-quickpick-card-tag">
            <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Catalog Combo · QuickShip
          </span>
          <div>
            <div class="cfg-quickpick-card-title">Universal Mount + /PS + PIR /BLS</div>
            <div class="cfg-quickpick-card-subtitle">150W · Type-III · Dark Bronze · 120-277V</div>
          </div>
          <div class="cfg-quickpick-card-ingredients">
            <code>/UA</code> Universal Mount
            <code>/PS</code> Integrated Photocell
            <code>/BLS</code> PIR Bi-Level
          </div>
          <div class="cfg-quickpick-card-sku">LSBX3W150-3H1-UD3/RB3/UA/PS/BLS</div>
          <span class="cfg-quickpick-card-cta">
            Apply this configuration
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </button>

        <!-- Card 2 · RS + PS + BLS combo (Microwave Bi-Level on /RS) -->
        <button type="button" class="cfg-quickpick-card" data-quickpick="rs-ps-bls">
          <span class="cfg-quickpick-card-tag">
            <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Catalog Combo · QuickShip
          </span>
          <div>
            <div class="cfg-quickpick-card-title">R/S Pole + /PS + Microwave /BLS</div>
            <div class="cfg-quickpick-card-subtitle">150W · Type-III · Dark Bronze · 120-277V</div>
          </div>
          <div class="cfg-quickpick-card-ingredients">
            <code>/RS</code> Round/Square Pole
            <code>/PS</code> Integrated Photocell
            <code>/BLS</code> Microwave Bi-Level
          </div>
          <div class="cfg-quickpick-card-sku">LSBX3W150-3H1-UD3/RB3/RS/PS/BLS</div>
          <span class="cfg-quickpick-card-cta">
            Apply this configuration
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </button>

      </div>
