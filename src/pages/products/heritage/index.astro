     Opens when the user clicks the SVG thumbnail / "View Full Drill Pattern" CTA
     inside a Mount accessory's acc-modal. Renders the polished SVG large enough
     to read all dimension callouts on a desktop screen.
     ============================================================================= -->
<div class="drill-modal" id="drillModal" role="dialog" aria-modal="true" aria-labelledby="drillModalTitle">
  <div class="drill-modal-panel">
    <div class="drill-modal-head">
      <div class="drill-modal-head-text">
        <h3 class="drill-modal-title" id="drillModalTitle">Drill Pattern</h3>
        <div class="drill-modal-source" id="drillModalSource">—</div>
      </div>
      <button type="button" class="drill-modal-close" id="drillModalClose"
              aria-label="Close drill pattern viewer"
              onclick="window.__closeDrillModal && window.__closeDrillModal();">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="pointer-events:none;">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="drill-modal-body">
      <img id="drillModalImg" src="" alt="" />
    </div>
    <div class="drill-modal-foot">
      <span>All dimensions in mm with [inch] equivalent · centerlines + callouts in <span class="aa">Ⓐ</span>LG red · refer to LSBX Heritage Install Guide for fastener spec.</span>
      <span class="drill-modal-foot-letter" id="drillModalLetter">A</span>
    </div>
  </div>
</div>

<script>
/* =============================================================================
   Drill-pattern fullscreen viewer wiring \u00B7 opens when an .acc-modal-drill-svg
   thumbnail is clicked. Reads data-* attributes for url, letter, title, source.
   ESC key + backdrop click close. Restores body scroll on close.
   ============================================================================= */
(function() {
  'use strict';
  var drillModal = document.getElementById('drillModal');
  if (!drillModal) return;
  var drillImg = document.getElementById('drillModalImg');
  var drillTitle = document.getElementById('drillModalTitle');
  var drillSource = document.getElementById('drillModalSource');
  var drillLetter = document.getElementById('drillModalLetter');
  var drillClose = document.getElementById('drillModalClose');

  function openDrill(url, letter, title, source) {
    drillImg.src = url;
    drillImg.alt = title + ' drill pattern \u00B7 full view';
    drillTitle.textContent = title + ' \u00B7 Drill Pattern';
    drillSource.textContent = source || '';
    drillLetter.textContent = letter || '';
    drillModal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeDrill() {
    drillModal.classList.remove('open');
    document.body.style.overflow = '';
    // Defer src clear so the close animation doesn't show a broken image.
    setTimeout(function() { drillImg.src = ''; }, 200);
  }

  // Expose globally so the inline onclick on the X button can call it
  // even if event delegation is somehow intercepted upstream.
  window.__closeDrillModal = closeDrill;
  window.__openDrillModal  = openDrill;

  // Belt-and-suspenders click bindings on the close button \u2014 both pointerup
  // and click fire, capture phase used so this runs before any bubble-phase
  // listeners that might stopPropagation.
  if (drillClose) {
    drillClose.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      closeDrill();
    }, true);
    drillClose.addEventListener('pointerup', function(e) {
      e.preventDefault();
      e.stopPropagation();
      closeDrill();
    }, true);
  }

  // Backdrop click closes the drill modal.
  drillModal.addEventListener('click', function(e) {
    if (e.target === drillModal) closeDrill();
  });

  // ESC closes the drill modal.
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && drillModal.classList.contains('open')) closeDrill();
  });

  // Legacy event-delegation fallback for any drill thumbnail that wasn't
  // bound directly via the openModal flow (e.g., if the modal HTML is
  // re-rendered by an external pass).
  document.addEventListener('click', function(e) {
    var trigger = e.target.closest && e.target.closest('.acc-modal-drill-svg');
    if (trigger && !trigger.__directlyBound) {
      e.preventDefault();
      openDrill(
        trigger.getAttribute('data-drill-url'),
        trigger.getAttribute('data-drill-letter'),
        trigger.getAttribute('data-drill-title'),
        trigger.getAttribute('data-drill-source')
      );
    }
  });
})();
</script>

