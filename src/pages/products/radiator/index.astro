<script>
/* =============================================================================
   SECTION 6 \u2014 Radiator contr\u24B6LS tab switcher: 2-tab layout (Synapse + DMX).
   Both tabs ride the shared LSPL-I1/* controller line \u2014 same ordering desk
   as Illuminator. Synapse SimplySNAP is the primary stadium-grade story
   (default tab); show\u2310ASYNC\u2122 DMX is the Radiator-III RGB show-light
   secondary that production page leaves out.
   Reuses .is-rippling shockwave handler from the canonical controls pattern.
   ============================================================================= */
(function() {
  var COPY = {
    'synapse': '<strong><code>LSPL-I1/C/WIFI</code> &mdash; Synapse SimplySNAP wireless base station.</strong> NEMA controller form factor &middot; one-year basic cloud included &middot; pairs with the SimplySNAP mesh network for centralized site management. <strong>Stadium-grade scheduling</strong> &middot; <strong>energy analytics</strong> &middot; <strong>remote commissioning</strong> via cloud dashboard. Each Radiator fixture joins as a node &mdash; spec writers manage hundreds of fixtures across multiple poles from one console. <strong>Open spec posture:</strong> Synapse rides the same SimplySNAP infrastructure used by other commercial-controls vendors &mdash; no proprietary lock-in like Musco Control-Link. Companion <strong><code>LSPL-I1/C/DMX</code></strong> retrofit external controller (IP65 &middot; 220-F) bridges to DMX consoles for Radiator-III show-light scenes on the same network.',

    'dmx':     '<strong><code>LSPL-I1/C/DMX</code> &mdash; show<span class="aa">\u24B6</span>SYNC&trade; external DMX controller.</strong> Stand-alone or networked operation &middot; IP65 &middot; pairs with industry-standard DMX consoles (ETC, MA, Avolites, Hog) and DALI bridge gateways. <strong>Programmable color scenes for Radiator-III RGB</strong> &mdash; halftime shows, player intros, walk-on moments, venue branding cycles, special-event lighting. <strong>Per-fixture or per-zone addressing</strong> &mdash; cross-arm pole arrays receive independent scene channels for synchronized stadium-wide effects. Direct head-to-head with Musco Show-Light&reg; (4 effects + 4 minutes custom programming &middot; bundled at premium pricing) and Cooper Ephesus Prism RGBA &mdash; show<span class="aa">\u24B6</span>SYNC matches both at fixture-as-spec pricing, no infrastructure lock-in. Synapse mesh and DMX run on the SAME LSPL-I1/* controller line &mdash; one console can drive both white field-illumination scenes and RGB show moments.',
  };
  var LINK_LABEL = {
    'synapse': 'Discover Synapse mesh \u2192',
    'dmx':     'Discover show\u24B6SYNC DMX \u2192'
  };
  var LINK_HREF = {
    'synapse': '/products/controls/synapse/',
    'dmx':     '/products/controls/showasync-dmx/'
  };

  function init() {
    var tabs = document.querySelectorAll('#controls .tac-callout-tab');
    var copy = document.getElementById('tacCalloutCopy');
    var linkAnchor = document.querySelector('#controls .tac-callout-link');
    var linkLabel  = document.querySelector('#controls .tac-callout-link span');
    var wave = document.getElementById('tacShockwave');
    if (!tabs.length || !copy) return;

    function ripple() {
      if (!wave) return;
      wave.classList.remove('is-rippling');
      void wave.offsetWidth;
      wave.classList.add('is-rippling');
    }

    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        var p = t.dataset.platform;
        copy.innerHTML = COPY[p] || COPY['synapse'];
        if (linkLabel)  linkLabel.textContent  = LINK_LABEL[p] || LINK_LABEL['synapse'];
        if (linkAnchor) linkAnchor.setAttribute('href', LINK_HREF[p] || LINK_HREF['synapse']);
        ripple();
      });
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
