<script>
/* =============================================================================
   SECTION 9 \u2014 Radiator Configurator engine.
   3 user choices (Series \u00B7 Wattage \u00B7 CCT) + 2 SKU add-ons (Optic \u00B7 TAA) +
   3 auto-locked fields (Voltage on R1-1200W, Finish+Mount, WATTSELECT DIPs).

   SKU pattern (per LSPL Radiator datasheet pg 3 ordering guide):
       LSPL-{wattage}-{cct}/{series}/{voltage}/B/TR/{optic}{/taa?}
   Examples:
       LSPL-850-57/R1/U/B/TR/O30                    \u2190 R1 default \u00B7 850W \u00B7 5700K \u00B7 QS
       LSPL-1200-57/R1/H/B/TR/O30                   \u2190 R1 1200W HV MTO variant
       LSPL-600-50/R2/U/B/TR/O30                    \u2190 R2 600W \u00B7 5000K \u00B7 QS
       LSPL-1200-40/R2/U/B/TR/O30                   \u2190 R2 1200W \u00B7 4000K \u00B7 QS
       LSPL-480-RGB/R3/U/B/TR/O30                   \u2190 R3 RGB show-light \u00B7 QS
       LSPL-1200-50/R2/U/B/TR/O20/TAA               \u2190 R2 flagship + 20\u00B0 optic + TAA MTO

   CONSTRAINTS: R1 1200W requires H voltage and stamps SKU as MTO. R3 480W
   is RGB only \u2014 CCT chip locks to 'RGB'. R2 supports 600W and 1200W with
   4000K or 5000K and either U or H voltage.
   ============================================================================= */
(function() {

  // Per-series wattage options (key + label + qs/mto + isDefault + WATTSELECT range note)
  var WATT_OPTIONS = {
    'R1': [
      { k: '850',  l: '850W \u2605',          status: 'qs',  def: true,  range: 'single-W (no WATTSELECT)' },
      { k: '1200', l: '1200W (HV MTO)',   status: 'mto', def: false, range: 'single-W \u00B7 requires H voltage', forceVoltage: 'H' }
    ],
    'R2': [
      { k: '600',  l: '600W',             status: 'qs',  def: false, range: 'WATTSELECT: 300/450/600W' },
      { k: '1200', l: '1200W \u2605',          status: 'qs',  def: true,  range: 'WATTSELECT: 800/1000/1200W' }
    ],
    'R3': [
      { k: '480',  l: '480W RGB',         status: 'qs',  def: true,  range: 'single-W \u00B7 RGB programmable via DMX' }
    ]
  };

  // Per-series CCT options (key + label + isDefault)
  var CCT_OPTIONS = {
    'R1': [{ k: '57',  l: '5700K (cool stadium)', def: true }],
    'R2': [{ k: '40',  l: '4000K (architectural)', def: false }, { k: '50', l: '5000K (industrial) \u2605', def: true }],
    'R3': [{ k: 'RGB', l: 'RGB (DMX programmable)', def: true }]
  };

  // 4 active catalog SKUs (per datasheet ordering guide pg 3)
  var CATALOG = {
    'r1-850':  { series: 'R1', watt: '850',  cct: '57',  voltage: 'U', optic: 'O30', taa: '', sku: 'LSPL-850-57/R1/U/B/TR/O30',  label: 'Radiator-I 850W traditional \u00B7 135 lm/W' },
    'r2-600':  { series: 'R2', watt: '600',  cct: '50',  voltage: 'U', optic: 'O30', taa: '', sku: 'LSPL-600-50/R2/U/B/TR/O30',  label: 'Radiator-II 600W mid-range \u00B7 142 lm/W' },
    'r2-1200': { series: 'R2', watt: '1200', cct: '50',  voltage: 'U', optic: 'O30', taa: '', sku: 'LSPL-1200-50/R2/U/B/TR/O30', label: 'Radiator-II 1200W flagship \u00B7 142 lm/W \u00B7 DLC Premium' },
    'r3-480':  { series: 'R3', watt: '480',  cct: 'RGB', voltage: 'U', optic: 'O30', taa: '', sku: 'LSPL-480-RGB/R3/U/B/TR/O30',  label: 'Radiator-III 480W RGB show-light' }
  };
  var SKU_TO_CATALOG = {};
  Object.keys(CATALOG).forEach(function(k) { SKU_TO_CATALOG[CATALOG[k].sku] = k; });

  // Lumens / efficacy per (series, watt, cct)
  function getOutput(series, watt, cct) {
    if (series === 'R1' && watt === '850') return { lm: '114,750 lm', lpw: '135 lm/W', dlc: 'DLC Premium', bug: 'NEMA 3 \u00B7 B5-U0-G2', note: 'Radiator-I traditional 5700K stadium flood \u00B7 clears DLC Premium 130 with 5 lm/W headroom' };
    if (series === 'R1' && watt === '1200') return { lm: 'TBC lm', lpw: 'TBC lm/W', dlc: 'DLC Premium', bug: 'NEMA 3 \u00B7 B5-U0-G5', note: 'Radiator-I 1200W high-voltage MTO variant \u00B7 5700K \u00B7 output values TBC pending engineering' };
    if (series === 'R2' && watt === '600' && cct === '40') return { lm: '85,200 lm', lpw: '142 lm/W', dlc: 'DLC Premium', bug: 'NEMA 3 \u00B7 B5-U0-G2', note: 'Radiator-II 600W at 4000K architectural neutral \u00B7 clears DLC Premium with 12 lm/W headroom' };
    if (series === 'R2' && watt === '600' && cct === '50') return { lm: '85,600 lm', lpw: '142 lm/W', dlc: 'DLC Premium', bug: 'NEMA 3 \u00B7 B5-U0-G2', note: 'Radiator-II 600W at 5000K industrial cool \u00B7 WATTSELECT 300/450/600W \u00B7 clears DLC Premium' };
    if (series === 'R2' && watt === '1200' && cct === '40') return { lm: '170,400 lm', lpw: '142 lm/W', dlc: 'DLC Premium', bug: 'NEMA 3 \u00B7 B5-U0-G5', note: 'Radiator-II 1200W flagship at 4000K \u00B7 WATTSELECT 800/1000/1200W \u00B7 highest single-fixture output in the line' };
    if (series === 'R2' && watt === '1200' && cct === '50') return { lm: '170,600 lm', lpw: '142 lm/W', dlc: 'DLC Premium', bug: 'NEMA 3 \u00B7 B5-U0-G5', note: 'Radiator-II 1200W flagship at 5000K \u00B7 the bid-sheet anchor \u00B7 170,600 lm at 142 lm/W \u00B7 the published-claim cell' };
    if (series === 'R3' && watt === '480') return { lm: '14,000 R / 11,000 G / 2,000 B lm', lpw: '~ additive', dlc: 'DLC Premium', bug: 'NEMA 3 \u00B7 B5-U0-G2', note: 'Radiator-III 480W RGB show\u24B6SYNC\u2122 \u00B7 per-color outputs combine additively \u00B7 pairs with LSPL-I1/C/DMX' };
    return { lm: '\u2014 pending \u2014', lpw: '\u2014', dlc: 'TBC', bug: 'NEMA 3', note: 'Output values TBC for this combination' };
  }

  function defaultState() {
    return {
      series:      'R1',
      watt:        '850',
      cct:         '57',
      voltage:     'U',
      finishmount: 'B/TR',
      optic:       'O30',
      taa:         ''
    };
  }
  var state = defaultState();

  // ---- Compute SKU ----
  function computeSku() {
    var s = state;
    var taaSeg = s.taa ? '/' + s.taa : '';
    return 'LSPL-' + s.watt + '-' + s.cct + '/' + s.series + '/' + s.voltage + '/' + s.finishmount + '/' + s.optic + taaSeg;
  }

  // CFG-STATE-1: Derive ship-tier from selected chip badges, NOT from a
  // hardcoded MTO list. The chip badges (QS/MTO/WB) are the source of truth.
  // Returns 'QS' | 'WB' | 'MTO'. Worst tier wins.
  function deriveShipTier() {
    // Radiator hard-coded MTO triggers: R1 1200W (HV-only variant) \u00B7 TAA-Compliant Mexico build
    if (state.series === 'R1' && state.watt === '1200') return 'MTO';
    if (state.taa === 'TAA') return 'MTO';
    if (state.voltage === 'H') return 'MTO'; // 347-480V is MTO across the line

    var section = document.getElementById('configurator');
    if (!section) return 'QS';
    var keys = ['series','watt','cct','voltage','optic','taa'];
    var worst = 'QS';
    for (var i = 0; i < keys.length; i++) {
      var k = keys[i], v = state[k];
      if (v === '' || v == null) continue;
      var chipEl = section.querySelector('.cfg-chip[data-field="' + k + '"][data-val="' + v + '"]');
      if (!chipEl) continue;
      if (chipEl.querySelector('.cfg-chip-stock.mto')) return 'MTO';
      if (chipEl.querySelector('.cfg-chip-stock.wb'))  worst = 'WB';
    }
    return worst;
  }
  // Legacy alias kept for any existing call-sites; routes through deriveShipTier
  function isMto() { return deriveShipTier() === 'MTO'; }

  // ---- Rebuild Wattage chips for active series ----
  function rebuildWattChips() {
    var wrap = document.getElementById('cfgWattChips');
    if (!wrap) return;
    var opts = WATT_OPTIONS[state.series] || [];
    if (!opts.find(function(o){ return o.k === state.watt; })) {
      var def = opts.find(function(o){ return o.def; }) || opts[0];
      state.watt = def.k;
    }
    wrap.innerHTML = opts.map(function(o) {
      var sel = (o.k === state.watt);
      return '<button type="button" class="cfg-chip' + (sel ? ' selected' : '') + '" data-field="watt" data-val="' + o.k + '" data-code="' + o.k + 'W" aria-pressed="' + sel + '">' +
        '<span class="cfg-chip-stock ' + o.status + '">' + o.status.toUpperCase() + '</span>' +
        '<span class="cfg-chip-val">' + o.l + '</span>' +
        '<span class="cfg-chip-code">' + o.range + '</span>' +
        '</button>';
    }).join('');
    wrap.querySelectorAll('.cfg-chip[data-field="watt"]').forEach(function(c) {
      c.addEventListener('click', function() {
        var v = c.dataset.val;
        state.watt = v;
        // R1 1200W requires H voltage
        var meta = WATT_OPTIONS[state.series].find(function(o){ return o.k === v; });
        if (meta && meta.forceVoltage) state.voltage = meta.forceVoltage;
        rebuildWattChips();
        rebuildCctChips();
        applyVoltageSync();
        renderWattselectPreview();
        refreshPreview();
      });
    });
  }

  function rebuildCctChips() {
    var wrap = document.getElementById('cfgCctChips');
    if (!wrap) return;
    var opts = CCT_OPTIONS[state.series] || [];
    if (!opts.find(function(o){ return o.k === state.cct; })) {
      var def = opts.find(function(o){ return o.def; }) || opts[0];
      state.cct = def.k;
    }
    wrap.innerHTML = opts.map(function(o) {
      var sel = (o.k === state.cct);
      var lockedClass = (opts.length === 1) ? ' locked' : '';
      return '<button type="button" class="cfg-chip' + lockedClass + (sel ? ' selected' : '') + '" data-field="cct" data-val="' + o.k + '" data-code="' + o.k + '" aria-pressed="' + sel + '">' +
        '<span class="cfg-chip-stock qs">QS</span>' +
        '<span class="cfg-chip-val">' + o.l + '</span>' +
        '<span class="cfg-chip-code">' + (opts.length === 1 ? 'only option' : '') + '</span>' +
        '</button>';
    }).join('');
    wrap.querySelectorAll('.cfg-chip[data-field="cct"]').forEach(function(c) {
      c.addEventListener('click', function() {
        if (c.classList.contains('locked')) return;
        state.cct = c.dataset.val;
        rebuildCctChips();
        refreshPreview();
      });
    });
  }

  // Force voltage to match constraint when wattage requires it
  function applyVoltageSync() {
    var voltageH = document.querySelector('.cfg-chip[data-field="voltage"][data-val="H"]');
    var voltageU = document.querySelector('.cfg-chip[data-field="voltage"][data-val="U"]');
    if (state.series === 'R1' && state.watt === '1200') {
      // Force H, lock chip
      state.voltage = 'H';
      if (voltageH) {
        voltageH.classList.add('selected');
        voltageH.setAttribute('aria-pressed', 'true');
      }
      if (voltageU) {
        voltageU.classList.remove('selected');
        voltageU.setAttribute('aria-pressed', 'false');
      }
    }
    // Update chips visual state
    document.querySelectorAll('.cfg-chip[data-field="voltage"]').forEach(function(c) {
      var sel = (c.dataset.val === state.voltage);
      c.classList.toggle('selected', sel);
      c.setAttribute('aria-pressed', sel ? 'true' : 'false');
    });
  }

  // WATTSELECT preview \u00B7 R2 only (informational chips, not in SKU)
  function renderWattselectPreview() {
    var fields = document.getElementById('cfgWattselectFields');
    var wrap = document.getElementById('cfgWattselectPreview');
    if (!fields || !wrap) return;
    if (state.series !== 'R2') {
      fields.innerHTML = '<div style="font-size:11px; color:var(--text-muted); font-style:italic; padding:8px 0;">WATTSELECT field-set DIPs apply to Radiator-II only. R1 (850W) and R3 (480W RGB) ship single-wattage.</div>';
      wrap.style.display = '';
      return;
    }
    var ladder = (state.watt === '600') ? ['300','450','600'] : ['800','1000','1200'];
    var max = ladder[ladder.length - 1];
    fields.innerHTML = '<div class="cfg-field" style="grid-column: 1 / -1;">' +
      '<div class="cfg-field-label">WATTSELECT &middot; 3-position DIP</div>' +
      '<div class="cfg-chips">' +
        ladder.map(function(w) {
          var isMax = (w === max);
          return '<button type="button" class="cfg-chip' + (isMax ? ' selected' : '') + '" disabled aria-pressed="' + isMax + '">' +
            '<span class="cfg-chip-stock dip">DIP</span>' +
            '<span class="cfg-chip-val">' + w + 'W' + (isMax ? ' &middot; max \u2605' : '') + '</span>' +
            '<span class="cfg-chip-code">field-set</span>' +
            '</button>';
        }).join('') +
      '</div>' +
      '' +
    '</div>';
  }

  // CFG-ZOHO-1 + CFG-STATE-1 \u2014 derive ship-tier from chip badges, use catalog map as name overlay
  function refreshZohoMatch() {
    var sku = computeSku();
    var matchKey = SKU_TO_CATALOG[sku];
    var tier = deriveShipTier();
    var el = document.getElementById('cfgZohoMatch');
    var icon = document.getElementById('cfgZohoMatchIcon');
    var text = document.getElementById('cfgZohoMatchText');
    var stockEl = document.getElementById('cfgZohoMatchStock');
    if (!el || !icon || !text || !stockEl) return;

    el.classList.remove('matches-bare', 'matches-combo', 'no-match');

    if (tier === 'QS') {
      el.classList.add('matches-bare');
      el.style.background = 'rgba(64,168,96,0.10)';
      el.style.border = '1px solid rgba(64,168,96,0.40)';
      icon.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#7fc998" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      if (matchKey) {
        text.innerHTML = '<strong style="color:#9bd6b1;">Catalog SKU \u00B7 QuickShip</strong> &middot; <span style="color:var(--text-secondary);">' + (CATALOG[matchKey].label) + '</span>';
      } else {
        text.innerHTML = '<strong style="color:#9bd6b1;">QuickShip \u00B7 \u00E0-la-carte assembly</strong> &middot; <span style="color:var(--text-secondary);">All selected components in stock \u2014 ships 2-3 day.</span>';
      }
      stockEl.textContent = 'QuickShip \u00B7 2-3 day';
      stockEl.style.color = '#9bd6b1';
    } else if (tier === 'WB') {
      el.classList.add('no-match');
      el.style.background = 'rgba(96,168,255,0.06)';
      el.style.border = '1px solid rgba(96,168,255,0.30)';
      icon.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#7fb6ff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>';
      text.innerHTML = '<strong style="color:#a8c9ff;">Workbench Assembly</strong> &middot; <span style="color:var(--text-secondary);">One or more components are workbench-assembled to order.</span>';
      stockEl.textContent = 'WB \u00B7 ~1-3 wk';
      stockEl.style.color = '#a8c9ff';
    } else { // MTO
      el.classList.add('no-match');
      el.style.background = 'rgba(255,159,28,0.08)';
      el.style.border = '1px solid rgba(255,159,28,0.40)';
      icon.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#ffb14d" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>';
      text.innerHTML = '<strong style="color:#ffb14d;">Custom build \u00B7 Made-to-Order</strong> &middot; <span style="color:var(--text-secondary);">One or more components are MTO (R1 1200W, TAA, /H voltage, or custom variant).</span>';
      stockEl.textContent = 'MTO \u00B7 ~4-6 wk';
      stockEl.style.color = '#ffb14d';
    }
  }

  // Live preview spec grid update
  function refreshPreview() {
    var s = state;
    var seriesLabel = ({'R1':'R1 \u00B7 Radiator-I traditional','R2':'R2 \u00B7 Radiator-II high-power','R3':'R3 \u00B7 Radiator-III RGB show-light'})[s.series];
    var wattLabel = (s.series === 'R3') ? '480W RGB' : (s.watt + 'W' + ((s.series==='R2') ? ' \u00B7 ' + (s.watt==='600' ? 'WATTSELECT 300/450/600' : 'WATTSELECT 800/1000/1200') : ''));
    var cctLabel = ({'40':'4000K (architectural)','50':'5000K (industrial)','57':'5700K (cool stadium)','RGB':'RGB \u00B7 DMX programmable'})[s.cct] || s.cct;
    var voltLabel = (s.voltage === 'U') ? 'U \u00B7 120-277V universal' : 'H \u00B7 347-480V high-voltage (MTO)';
    var opticLabel = (s.optic === 'O30') ? '/O30 \u00B7 30\u00B0' : '/O20 \u00B7 20\u00B0 (narrow)';
    var taaLabel = (s.taa === 'TAA') ? '/TAA \u00B7 TAA-Compliant (MTO)' : '\u2014 Standard non-TAA \u2014';

    document.getElementById('cfgSpecSeries').textContent = seriesLabel;
    document.getElementById('cfgSpecWatt').textContent = wattLabel;
    document.getElementById('cfgSpecCct').textContent = cctLabel;
    document.getElementById('cfgSpecVoltage').textContent = voltLabel;
    document.getElementById('cfgSpecOptic').textContent = opticLabel;
    document.getElementById('cfgSpecTaa').textContent = taaLabel;

    var out = getOutput(s.series, s.watt, s.cct);
    document.getElementById('cfgSpecDlc').textContent = out.dlc;
    document.getElementById('cfgSpecLumens').innerHTML = '<strong>' + out.lm + ' @ ' + out.lpw + '</strong> \u00B7 datasheet rated \u00B7 ' + out.bug;

    document.getElementById('cfgSku').textContent = computeSku();

    // Update voltage note based on series
    var voltNote = document.getElementById('cfgVoltageNote');
    if (s.series === 'R1' && s.watt === '1200') {
      voltNote.innerHTML = '<strong>R1 1200W requires H voltage</strong> &mdash; SKU stamped Made-to-Order. Pairs with TAA-Compliant variant for federal / GSA installs.';
    } else {
      voltNote.innerHTML = '<strong>U universal 120-277V \u2605</strong> is the QuickShip default. <strong>H 347-480V</strong> is Made-to-Order (R3 480W extends to 200-480V). <strong>R1 1200W requires H voltage</strong> &mdash; selecting that combination auto-stamps the SKU as MTO.';
    }

    // Counter
    var cnt = document.getElementById('cfgCounterCount');
    if (cnt) cnt.textContent = '3'; // Series + Watt + CCT (the 3 user-pickable required fields)

    refreshZohoMatch();
  }

  function handleChipClick(field, val) {
    if (field === 'series') {
      state.series = val;
      // Reset wattage and CCT to series defaults
      var wattOpts = WATT_OPTIONS[val];
      var cctOpts = CCT_OPTIONS[val];
      state.watt = (wattOpts.find(function(o){return o.def;}) || wattOpts[0]).k;
      state.cct  = (cctOpts.find(function(o){return o.def;}) || cctOpts[0]).k;
      // Apply forceVoltage if any
      var meta = wattOpts.find(function(o){ return o.k === state.watt; });
      state.voltage = (meta && meta.forceVoltage) ? meta.forceVoltage : 'U';
      rebuildWattChips();
      rebuildCctChips();
      applyVoltageSync();
      renderWattselectPreview();
    } else if (field === 'voltage') {
      // Block user-toggle to U if R1 1200W is locked to H
      if (state.series === 'R1' && state.watt === '1200' && val === 'U') return;
      state.voltage = val;
    } else if (field === 'optic') {
      state.optic = val;
    } else if (field === 'taa') {
      state.taa = val;
    } else if (field === 'finishmount' || field === 'cctcap') {
      return; // locked
    }

    document.querySelectorAll('.cfg-chip[data-field="' + field + '"]').forEach(function(c) {
      var sel = (c.dataset.val === val) || (field === 'series' && c.dataset.val === state.series);
      c.classList.toggle('selected', sel);
      c.setAttribute('aria-pressed', sel ? 'true' : 'false');
    });

    refreshPreview();
  }

  function applyQuickPick(key) {
    var cfg = CATALOG[key];
    if (!cfg) return;
    state.series = cfg.series;
    state.watt = cfg.watt;
    state.cct = cfg.cct;
    state.voltage = cfg.voltage;
    state.optic = cfg.optic;
    state.taa = cfg.taa;

    rebuildWattChips();
    rebuildCctChips();
    applyVoltageSync();
    renderWattselectPreview();

    ['series','voltage','optic','taa'].forEach(function(field) {
      document.querySelectorAll('.cfg-chip[data-field="' + field + '"]').forEach(function(c) {
        var sel = (c.dataset.val === state[field]);
        c.classList.toggle('selected', sel);
        c.setAttribute('aria-pressed', sel ? 'true' : 'false');
      });
    });

    refreshPreview();
    var preview = document.querySelector('.cfg-preview');
    if (preview) preview.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function bindReset() {
    var btn = document.getElementById('cfgReset');
    if (!btn) return;
    btn.addEventListener('click', function() {
      state = defaultState();
      rebuildWattChips();
      rebuildCctChips();
      applyVoltageSync();
      renderWattselectPreview();
      ['series','voltage','optic','taa'].forEach(function(field) {
        document.querySelectorAll('.cfg-chip[data-field="' + field + '"]').forEach(function(c) {
          var sel = (c.dataset.val === state[field]);
          c.classList.toggle('selected', sel);
          c.setAttribute('aria-pressed', sel ? 'true' : 'false');
        });
      });
      refreshPreview();
    });
  }

  function bindCopy() {
    var btn = document.getElementById('cfgSkuCopy');
    var label = document.getElementById('cfgSkuCopyLabel');
    if (!btn) return;
    btn.addEventListener('click', function() {
      var sku = document.getElementById('cfgSku').textContent;
      navigator.clipboard.writeText(sku).then(function() {
        if (label) {
          label.textContent = 'Copied!';
          setTimeout(function() { label.textContent = 'Copy SKU'; }, 1600);
        }
      }).catch(function() {});
    });
  }

  function bindSubmittalCta() {
    var btn = document.getElementById('cfgCtaSubmittal');
    if (!btn) return;
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var sku = computeSku();
      var params = [
        'product=radiator',
        'sku=' + encodeURIComponent(sku),
        'series=' + state.series,
        'wattage=' + state.watt,
        'cct=' + state.cct,
        'voltage=' + state.voltage,
        'optic=' + state.optic
      ];
      if (state.taa) params.push('taa=' + state.taa);
      var url = 'submittal_template.html?' + params.join('&');
      window.open(url, '_blank', 'noopener');
    });
  }

  function init() {
    document.querySelectorAll('.cfg-chip:not([data-field="watt"]):not([data-field="cct"])').forEach(function(chip) {
      var field = chip.dataset.field;
      var val = chip.dataset.val;
      if (!field) return;
      chip.addEventListener('click', function() {
        if (chip.classList.contains('locked')) return;
        handleChipClick(field, val);
      });
    });
    document.querySelectorAll('.cfg-quickpick-card').forEach(function(card) {
      card.addEventListener('click', function() { applyQuickPick(card.dataset.quickpick); });
    });
    rebuildWattChips();
    rebuildCctChips();
    applyVoltageSync();
    renderWattselectPreview();
    bindReset();
    bindCopy();
    bindSubmittalCta();
    refreshPreview();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
