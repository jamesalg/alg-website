  // CDN drawing \u2014 the only authoritative engineering drawing published today
  // (covers LSPL600 17.27\u00D717.29\u00D720.56 in and LSPL1200 20.56\u00D721.69\u00D722.50 in,
  // and R1 + R3 share the same housing/optical envelope as R2). Alt text
  // varies per series so screen readers + image SEO read the active context.
  var DIM_CDN = 'https://cdn.shopify.com/s/files/1/0543/2233/1841/t/3/assets/1a6ca870b907--Radiator-Dimensions.svg';
  var DIM_SRC = {
    'R1': DIM_CDN,
    'R2': DIM_CDN,
    'R3': DIM_CDN
  };
  var DIM_ALT = {
    'R1': 'Radiator-I 850W dimensions \u2014 shares LSPL housing envelope with R2 \u00B7 production engineering drawing showing front-face circle and side-profile heat-sink + trunnion mount profile \u00B7 sourced from production page (Shopify theme assets)',
    'R2': 'Radiator-II dimensions \u2014 production engineering drawing showing front-face circle and side-profile heat-sink + trunnion mount profile \u00B7 LSPL600 housing 17.27 \u00D7 17.29 \u00D7 20.56 in and LSPL1200 housing 20.56 \u00D7 21.69 \u00D7 22.50 in \u00B7 sourced from production page (Shopify theme assets)',
    'R3': 'Radiator-III 480W RGB dimensions \u2014 shares LSPL housing envelope with R2 \u00B7 production engineering drawing showing front-face circle and side-profile heat-sink + trunnion mount profile \u00B7 sourced from production page (Shopify theme assets)'
  };

  // Series tabs whose spec table is "dense" (>3 rows) get the .is-compact
  // tbody class to shrink per-row padding and font-size. Currently only R2
  // (8 rows) qualifies; R1 (2) and R3 (2) render at the full size.
  var COMPACT_SERIES = { 'R2': true };

  function init() {
    var tabs    = document.querySelectorAll('.spec-watt-tab[data-model]');
    var tbody   = document.getElementById('specTableBody');
    var tfoot   = document.getElementById('specTableFoot');
    var dimSub  = document.getElementById('specDimSub');
    var dimImg  = document.getElementById('dimImg');
    var zoomImg = document.getElementById('dimZoomImg');
    if (!tabs.length || !tbody) return;

    function render(model) {
      var d = DATA[model];
      if (!d) return;
      tbody.innerHTML = d.rows.map(function(r) {
        var defaultClass = r.w.indexOf('\u2605') > -1 ? ' class="is-default"' : '';
        return '<tr' + defaultClass + '>' +
                 '<td>' + r.w    + '</td>' +
                 '<td>' + r.cct  + '</td>' +
                 '<td>' + r.lm   + '</td>' +
                 '<td>' + r.lpw  + '</td>' +
                 '<td>' + r.volt + '</td>' +
                 '<td>' + r.cri  + '</td>' +
               '</tr>';
      }).join('');
      tbody.classList.toggle('is-compact', !!COMPACT_SERIES[model]);
      tfoot.innerHTML = d.foot;
      if (dimSub && DIM_SUB[model]) dimSub.innerHTML = DIM_SUB[model];
      if (dimImg && DIM_SRC[model]) {
        dimImg.src = DIM_SRC[model];
        dimImg.alt = DIM_ALT[model] || '';
      }
      if (zoomImg && DIM_SRC[model]) {
        zoomImg.src = DIM_SRC[model];
        zoomImg.alt = (DIM_ALT[model] || '') + ' (zoomed)';
      }
    }

    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        render(t.dataset.model);
      });
    });

    render('R1');  // Default \u2014 Radiator-I 850W (traditional sports lighter, datasheet's top-of-table)
  }

  // Zoom modal for dimensions drawing
  function initZoom() {
    var btn = document.getElementById('dimZoomBtn');
    var modal = document.getElementById('dimZoomModal');
    var close = document.getElementById('dimZoomClose');
    if (!btn || !modal) return;
    btn.addEventListener('click', function() { modal.classList.add('open'); });
    modal.addEventListener('click', function(e) {
      if (e.target === modal) modal.classList.remove('open');
    });
    if (close) close.addEventListener('click', function() { modal.classList.remove('open'); });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') modal.classList.remove('open');
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { init(); initZoom(); });
  } else { init(); initZoom(); }
})();
</script>

