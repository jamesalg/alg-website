    border-radius: 2px;
    transition: all 0.18s;
    min-width: 80px;
    font-weight: 700;
  }
  .photo-tab:hover { color: var(--text-primary); border-color: var(--text-primary); }
  .photo-tab.active {
    background: var(--brand-red);
    border-color: var(--brand-red);
    color: white;
  }
  .photo-display {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .photo-plot {
    background: #14171b;
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 16px;
    overflow: hidden;
    max-width: 640px;
    margin: 0 auto;
  }
  .photo-plot img { width: 100%; height: auto; display: block; }
  .photo-stats {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .photo-stat-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .photo-stat {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 18px 20px;
  }
  .photo-stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    letter-spacing: 0.14em;
    color: var(--text-muted);
