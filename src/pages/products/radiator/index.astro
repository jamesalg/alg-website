    var photoSection = document.getElementById('photometrics');
    var seriesTabs   = photoSection.querySelectorAll('.spec-watt-tab[data-photo-series]');
    var wattContainer= document.getElementById('photoWattTabs');
    var cctContainer = document.getElementById('photoCctTabs');
    var state        = { series: 'R2', watt: '1200', cct: '50' };

    function rebuildWattTabs() {
      var labels = WATT_LABELS[state.series];
      wattContainer.innerHTML = '';
      labels.forEach(function(spec) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'spec-watt-tab' + (spec.k === state.watt ? ' active' : '');
        btn.setAttribute('data-photo-watt', spec.k);
        btn.setAttribute('role', 'tab');
        btn.setAttribute('aria-selected', spec.k === state.watt ? 'true' : 'false');
        btn.textContent = spec.l;
        if (labels.length === 1) {
          btn.style.cursor = 'default';
          btn.disabled = true;
        }
        btn.addEventListener('click', function() {
          if (labels.length === 1) return;
          var tabs = wattContainer.querySelectorAll('.spec-watt-tab');
          tabs.forEach(function(x) {
            x.classList.remove('active');
            x.setAttribute('aria-selected', 'false');
          });
          btn.classList.add('active');
          btn.setAttribute('aria-selected', 'true');
          state.watt = spec.k;
          // When switching watt, snap CCT to the new W's default if current CCT isn't valid
          var validCcts = Object.keys(PHOTO[state.series][state.watt] || {});
          if (validCcts.indexOf(state.cct) < 0) {
            var d = (CCT_LABELS[state.series].find(function(x){return x.def;}) || CCT_LABELS[state.series][0]);
            state.cct = d.k;
            rebuildCctTabs();
          }
          render();
        });
        wattContainer.appendChild(btn);
      });
    }

    function rebuildCctTabs() {
      var labels = CCT_LABELS[state.series];
      cctContainer.innerHTML = '';
      labels.forEach(function(spec, idx) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'photo-tab' + (spec.k === state.cct ? ' active' : '');
        btn.setAttribute('data-cct', spec.k);
        btn.setAttribute('role', 'tab');
        btn.setAttribute('aria-selected', spec.k === state.cct ? 'true' : 'false');
        btn.textContent = spec.l;
        var isActive = (spec.k === state.cct);
        btn.style.cssText = 'flex:1; padding:10px 16px; border:0;' +
          (idx > 0 ? ' border-left:1px solid var(--line-medium);' : '') +
          ' cursor:' + (labels.length > 1 ? 'pointer' : 'default') + ';' +
          ' font-family:inherit; font-size:13px; letter-spacing:1px; font-weight:700;' +
          ' background:' + (isActive ? 'var(--brand-red)' : 'transparent') + ';' +
          ' color:' + (isActive ? 'white' : 'var(--text-secondary)') + ';';
        if (labels.length === 1) btn.disabled = true;
        btn.addEventListener('click', function() {
          if (labels.length === 1) return;
          var tabs = cctContainer.querySelectorAll('.photo-tab');
          tabs.forEach(function(x) {
            x.classList.remove('active');
            x.setAttribute('aria-selected', 'false');
            x.style.background = 'transparent';
            x.style.color = 'var(--text-secondary)';
          });
          btn.classList.add('active');
          btn.setAttribute('aria-selected', 'true');
          btn.style.background = 'var(--brand-red)';
          btn.style.color = 'white';
          state.cct = spec.k;
          render();
        });
        cctContainer.appendChild(btn);
      });
    }

    function render() {
      var sp = PHOTO[state.series];     if (!sp) return;
      var wp = sp[state.watt];          if (!wp) return;
      var d  = wp[state.cct];           if (!d)  return;

      img.alt = 'Radiator ' + state.series + ' \u00B7 ' + state.watt + 'W \u00B7 ' + (state.cct === 'RGB' ? 'RGB' : (state.cct + '00K')) + ' \u00B7 NEMA 3 forward-throw distribution \u00B7 LM-79 polar plot pending bundle parse';
      statPeak.textContent       = '\u2014 pending \u2014';
      if (statPeakSub) statPeakSub.textContent = 'LM-79 candela publishes with the IES bundle (' + d.subtag + ')';
      statLum.textContent        = d.lumens;
      statLpw.innerHTML          = d.lpw;
      statDraw.textContent       = d.draw;
      statDist.textContent       = d.dist;
      statFile.textContent       = d.file;
      statNote.innerHTML         = d.note;
    }

    seriesTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        seriesTabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        state.series = t.dataset.photoSeries;
        var defaults = SERIES_DEFAULT[state.series];
        state.watt = defaults.watt;
        state.cct  = defaults.cct;
        rebuildWattTabs();
        rebuildCctTabs();
        render();
      });
    });

    // Initial render
    rebuildWattTabs();
    rebuildCctTabs();
    render();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
<!-- ============================================================================
     SECTION 8 — Radiator "In the Box" · 4 standard components
     -------------------------------------------------------------------------
     Per datasheet page 5 "What is in the Box?": Radiator + Trunnion Mount.
     For the v2 PDP we expand this to the 4 functional components that ship
     factory-installed on every Radiator (mirrors Aura's CFG-ACC-1 pattern):

       1. pro<span class="aa">Ⓐ</span>PTICS™ Optic Assembly — UV-stabilized prismatic optic with
          NEMA 3 distribution, B5-U0-G2 BUG (B5-U0-G5 on the 1200W flagship),
          30° default beam (20° via /O20 swap)
       2. Sealed Cast-Aluminum Housing (wetGuard™) — IP65 wet-location,
          3G vibration-rated, low-profile to reduce wind load, polyester
          powder-coat Black finish, −40°F to 130°F operating envelope
       3. Universal-Voltage Driver + surge<span class="aa">Ⓐ</span>RMOR — 120-277V universal AC
          default (or 277-480V HV variant), 0-10V analog dim baseline,
          surge<span class="aa">Ⓐ</span>RMOR built-in surge protection up to 20kV @120-277V or
          40kV @347-480V, Osram 5050 LED chip
       4. Trunnion Mount (/TR) — standard mount baked into the SKU,
          U-bracket adjustable tilt. R1-YKA yoke, R1-SMB square beam,
          R2-SF600/1200 slip-fitter ship as separate ACCESSORY SKUs (see
          Section 8b · accessory swap kits for the mount that fits the pole)

     Optional / non-included items (Section 8b accessories ladder):
       Glare Control: R1-GS shield · R1-GV visor · R2-GV600/1200 visor
       Mount Adapters: R1-YKA yoke · R1-SMB square beam · R2-SF600/1200 slip
       Replacement Optics: 8 SKUs across 480/600/850/1200W × 20°/30°
       Surge SPDs: 10SP-277/480 · 20SP-277/480 (in-line, supplements onboard)
       Peripheral: R1-LSG / R2-LSG laser sight guides · C35 35-ft remote-
                   driver extension cord
       contr<span class="aa">Ⓐ</span>LS: LSPL-I1/C/DMX controller · LSPL-I1/C/WIFI Synapse base

     OPTIC FRAMING — pro<span class="aa">Ⓐ</span>PTICS™ ships at 30° default with 20° optic available
     as a separate optic-swap SKU (LSPL-R1/O20/* or LSPL-R2/O20/*). Same
     factory-installed posture as Heritage: spec writer picks at order time,
     fixture ships ready. Field-swappable optics (à la Keystone XFit OpticSwap)
     not Radiator's pattern.

     CFG-ACC-1 click-card → modal pattern with inboxModal* IDs to avoid
     collision with Section 8b's accModal* IDs.
     ============================================================================ -->
