/* =============================================================================
   CFG-NAV-1 \u00B7 Sticky-nav scroll-spy
   ----------------------------------------------------------------------------
   IntersectionObserver watches each section the sticky-nav links to. The link
   whose target is "most visible" gets '.is-current' (white bg + red text \u00B7 the
   visual inverse of '.primary'). One observer, one Map, one CSS class toggle.
   The Pricing & Availability primary button is NOT a section anchor (its href
   is /pricing-availability/), so it's excluded from the spy by the
   'a[href^="#"]' selector below.
   ============================================================================= */
(function() {
  var nav = document.querySelector('.sticky-nav');
  if (!nav) return;
  var links = Array.prototype.slice.call(nav.querySelectorAll('a[href^="#"]'));
  if (!links.length) return;
  var entries = [];
  links.forEach(function(a) {
    var id = a.getAttribute('href').slice(1);
    var sec = id ? document.getElementById(id) : null;
    if (sec) entries.push({ sec: sec, link: a, ratio: 0 });
  });
  if (!entries.length) return;
  function update() {
    var best = null, bestRatio = 0;
    entries.forEach(function(e) { if (e.ratio > bestRatio) { bestRatio = e.ratio; best = e; } });
    entries.forEach(function(e) { e.link.classList.toggle('is-current', e === best && bestRatio > 0); });
  }
  var io = new IntersectionObserver(function(items) {
    items.forEach(function(item) {
      entries.forEach(function(e) { if (e.sec === item.target) e.ratio = item.intersectionRatio; });
    });
    update();
  }, {
    rootMargin: '-20% 0px -55% 0px',
    threshold: [0, 0.1, 0.25, 0.5, 0.75, 1.0]
  });
  entries.forEach(function(e) { io.observe(e.sec); });
})();
</script>
</BaseLayout>
