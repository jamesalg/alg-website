    finishImg: {
      'B':   '/products/illuminator/assets/finishes/illuminator-finish-black.webp',
      'D':   '/products/illuminator/assets/finishes/illuminator-finish-bronze.webp',
      'S':   '/products/illuminator/assets/finishes/illuminator-finish-silver.webp',
