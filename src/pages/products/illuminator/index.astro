  function init() {
    var grid     = document.getElementById('accGrid');
    var modal    = document.getElementById('accModal');
    var panel    = document.getElementById('accModalPanel');
    var closeBtn = document.getElementById('accModalClose');
    var imgWrap  = document.getElementById('accModalImg');
    var catEl    = document.getElementById('accModalCat');
    var titleEl  = document.getElementById('accModalTitle');
    var skuEl    = document.getElementById('accModalSku');
    var descEl   = document.getElementById('accModalDesc');
    var specsEl  = document.getElementById('accModalSpecs');
    var pills    = document.querySelectorAll('.acc-pill');
    if (!grid || !modal) return;
    var cards = grid.querySelectorAll('.acc-card');

    // ---- Filter pills ----
    pills.forEach(function(p) {
      p.addEventListener('click', function() {
        pills.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-selected', 'false'); });
        p.classList.add('active');
        p.setAttribute('aria-selected', 'true');
        var f = p.dataset.filter;
        cards.forEach(function(c) {
          var match = (f === 'all' || c.dataset.cat === f);
          c.classList.toggle('is-hidden', !match);
        });
      });
    });

    // ---- Open modal ----
    function openModal(card) {
      var id = card.dataset.id;
      var d  = ACC[id];
      if (!d) { console.warn('acc-modal: no data for id', id); return; }
      // Populate static text
      catEl.textContent   = d.cat.replace(/Ⓐ/g, '');  // category badge — Ⓐ rendered separately below if needed
      titleEl.textContent = d.title;
      skuEl.textContent   = d.sku;
      descEl.textContent  = d.desc;
      // (Per-accessory Data Sheet CTA removed — accessories ship without individual spec sheets.
      //  Family-level Data Sheet lives in Section 9.)
      // Re-inject Ⓐ glyph in category badge if the category contains it
      if (d.cat.indexOf('Ⓐ') >= 0) {
        catEl.innerHTML = d.cat.replace(/Ⓐ/g, '<span class="aa" aria-hidden="true">Ⓐ</span>');
      }
      // Specs
      specsEl.innerHTML = d.specs.map(function(s) {
        return '<div class="acc-spec-row">' +
                 '<div class="acc-spec-key">' + s[0] + '</div>' +
                 '<div class="acc-spec-val">' + s[1] + '</div>' +
               '</div>';
      }).join('');
      // Clone the card's media (svg silhouette OR real product photo) into the
      // modal image area, preserving the .acc-modal-img-cat badge.
      var srcMedia = card.querySelector('.acc-card-img svg, .acc-card-img img.acc-card-photo');
      Array.from(imgWrap.querySelectorAll('svg, img.acc-card-photo')).forEach(function(s){ s.remove(); });
      if (srcMedia) {
        var clone = srcMedia.cloneNode(true);
        // For real photos, scale up in the modal (modal img-area is taller — let
        // the photo fill the available space, capped at the box).
        if (clone.tagName === 'IMG') {
          clone.style.width = '100%';
          clone.style.height = '100%';
          clone.style.maxWidth = '380px';
          clone.style.maxHeight = '320px';
          clone.style.objectFit = 'contain';
          clone.style.filter = 'drop-shadow(0 12px 20px rgba(0,0,0,0.55))';
        }
        imgWrap.appendChild(clone);
      }
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    // ---- Close modal ----
    function closeModal() {
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }

    cards.forEach(function(c) {
      c.addEventListener('click', function() { openModal(c); });
    });

    // Click outside the panel = close. Click inside = no-op.
    modal.addEventListener('click', function(e) {
      if (!panel.contains(e.target)) closeModal();
    });
    if (closeBtn) {
      closeBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        closeModal();
      });
    }
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();

// =============================================================================
// SECTION 8 — Configurator (Build Your Model)
// State engine + chip click handler + dependency rules + live SKU encoder.
// All chips have data-field + data-val + data-code; required fields are
// single-select, optional fields are toggle (click again to deselect).
// =============================================================================
(function() {
  // Required and optional field IDs — mirror the data-field attrs in the markup.
  // Mount is REQUIRED (datasheet — every order ships with one mounting option).
  var REQUIRED  = ['model', 'cct', 'voltage', 'optic', 'finish', 'mount', 'taa'];
  var OPTIONAL  = ['surge', 'controls', 'glare', 'laser'];
  // Multi-select fields — chip toggle is and/or (Set semantics) instead of single-pick.
  var MULTI     = ['controls', 'glare'];

  // SKU encoding rules — anchored to the canonical example LSPL600-50-HB/TR/TAA:
  //   prefix      LSPL{model}            — no separator (e.g. LSPL600)
  //   cct         -{40|50}               — leading dash
  //   voltage     -{U|H}                 — leading dash
  //   finish      {B|D|S|W|RAL#}         — NO separator (attached directly to voltage)
  //   optic       (blank for 35°)|/O20|/O55|/O90  — leading slash, omitted when default
  //   mount       /{TR|SF}               — leading slash (always present)
  //   taa         (blank)|/TAA           — leading slash, omitted when standard
  //   surge       /{10SP/277|...}        — leading slash (the inner /277 is part of the code)
  //   controls    /{DMX|WIFI}            — leading slash · multi-select · /DMX/WIFI possible
  //   glare       /{GS|GV}               — leading slash · multi-select · /GS/GV possible
  //   laser       /LSG                   — leading slash
  // SKU_ORDER drives the segment order after the prefix.
  var SKU_ORDER = ['cct', 'voltage', 'finish', 'optic', 'mount', 'taa', 'controls', 'glare', 'surge', 'laser'];
  // SEPARATOR map — how each segment attaches to the previous one.
  //   '-'  : leading dash    (cct, voltage)
  //   ''   : direct attach   (finish - sits flush with voltage)
  //   '/'  : leading slash   (everything else)
  var SEP = {
    cct: '-', voltage: '-', finish: '', optic: '/', mount: '/',
    taa: '/', controls: '/', glare: '/', surge: '/', laser: '/'
  };

  // Lookup tables for live spec computation.
  // Lumens / LPW reference the WATTSELECT max output per model (datasheet).
