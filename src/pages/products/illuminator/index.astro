    2003:'Pastel Orange', 2004:'Pure Orange', 2008:'Bright Red Orange',
    3000:'Flame Red', 3003:'Ruby Red', 3020:'Traffic Red',
    5002:'Ultramarine Blue', 5005:'Signal Blue', 5010:'Gentian Blue', 5012:'Light Blue', 5015:'Sky Blue', 5017:'Traffic Blue',
    6005:'Moss Green', 6018:'Yellow Green', 6029:'Mint Green',
    7016:'Anthracite Grey', 7021:'Black Grey', 7022:'Umbra Grey', 7035:'Light Grey', 7037:'Dusty Grey', 7042:'Traffic Grey A', 7043:'Traffic Grey B',
    8004:'Copper Brown', 8011:'Nut Brown', 8017:'Chocolate Brown', 8019:'Grey Brown', 8022:'Black Brown',
    9001:'Cream', 9002:'Grey White', 9003:'Signal White', 9005:'Jet Black', 9006:'White Aluminium', 9007:'Grey Aluminium', 9010:'Pure White', 9016:'Traffic White', 9017:'Traffic Black', 9018:'Papyrus White'
  };

  function init() {
    var section   = document.getElementById('configurator');
    if (!section) return;
    var counter   = document.getElementById('cfgCount');
    var counterEl = document.getElementById('cfgCounter');
    var resetBtn  = document.getElementById('cfgReset');
    var skuEl     = document.getElementById('cfgSku');
    var copyBtn   = document.getElementById('cfgSkuCopy');
    var copyLabel = document.getElementById('cfgSkuCopyLabel');
    var warning   = document.getElementById('cfgWarning');
    var ctaPrice  = document.getElementById('cfgCtaPrice');
    var ctaPdf    = document.getElementById('cfgCtaPdf');
    var chips     = section.querySelectorAll('.cfg-chip');
    var state     = Object.assign({}, DEFAULT_STATE);

    // ---- Chip click handler ----
    chips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        if (chip.classList.contains('disabled')) return;
        var field    = chip.dataset.field;
        var val      = chip.dataset.val;
        var isOpt    = OPTIONAL.indexOf(field) >= 0;
        var isMulti  = MULTI.indexOf(field) >= 0;

        if (isMulti) {
          // Multi-select: store as array. Click toggles on/off independently.
          var arr = Array.isArray(state[field]) ? state[field].slice() : [];
          var i = arr.indexOf(val);
          if (i >= 0) arr.splice(i, 1); else arr.push(val);
          if (arr.length === 0) delete state[field]; else state[field] = arr;
        } else if (isOpt && state[field] === val) {
          // Single-select optional: clicking the active chip clears it
          delete state[field];
        } else {
          // Single-select required (or first pick on optional)
          state[field] = val;
        }
        applyState();
      });
    });

    // ---- Reset all ----
    resetBtn.addEventListener('click', function() {
      state = Object.assign({}, DEFAULT_STATE);
      var ralInput = document.getElementById('cfgRalInput');
      if (ralInput) ralInput.value = '';
      applyState();
    });

    // ---- RAL number input handler ----
    var ralInput   = document.getElementById('cfgRalInput');
    var ralWrap    = document.getElementById('cfgRalInputWrap');
    var ralName    = document.getElementById('cfgRalName');
    if (ralInput && ralWrap) {
      ralInput.addEventListener('input', function() {
        // Strip non-digit characters as the user types.
        var raw = ralInput.value.replace(/\D/g, '').slice(0, 4);
        if (raw !== ralInput.value) ralInput.value = raw;

        ralWrap.classList.remove('valid', 'invalid');
        if (raw.length === 0) {
          delete state.finishRAL;
        } else if (raw.length < 4) {
          // Not enough digits yet — neutral state, but no SKU code
          delete state.finishRAL;
        } else {
          var num = parseInt(raw, 10);
          if (RAL_VALID.has(num)) {
            state.finishRAL = raw;
            ralWrap.classList.add('valid');
            if (ralName) ralName.textContent = 'RAL ' + raw + (RAL_NAMES[num] ? ' · ' + RAL_NAMES[num] : '');
          } else {
            delete state.finishRAL;
            ralWrap.classList.add('invalid');
          }
        }
        applyState();
      });
    }

    // ---- Apply state to UI ----
    function applyState() {
      // Update chip selected states (multi-select aware)
      chips.forEach(function(chip) {
        var f = chip.dataset.field;
        var v = chip.dataset.val;
        var sel;
        if (MULTI.indexOf(f) >= 0) {
          sel = Array.isArray(state[f]) && state[f].indexOf(v) >= 0;
        } else {
          sel = state[f] === v;
        }
        chip.classList.toggle('selected', sel);
        // Dependency: data-only-model attr restricts which model the chip is valid for.
        var onlyModel = chip.dataset.onlyModel;
        if (onlyModel) {
          var disabled = state.model && state.model !== onlyModel;
          chip.classList.toggle('disabled', !!disabled);
          // If currently selected but now disabled, clear it
          if (disabled && state[f] === v) delete state[f];
        }
      });

      // RAL input wrap visibility — only when Custom RAL is the active finish
      var ralWrapEl = document.getElementById('cfgRalInputWrap');
      if (ralWrapEl) ralWrapEl.classList.toggle('show', state.finish === 'RAL');

      // Required-counter — RAL finish counts as set ONLY when a valid RAL number is entered
      var ralPending = (state.finish === 'RAL' && !state.finishRAL);
      var filled = REQUIRED.filter(function(k) {
        if (k === 'finish' && ralPending) return false;
        return state[k] != null;
      }).length;
      counter.textContent = filled;
      counterEl.classList.toggle('complete', filled === REQUIRED.length);

      // SKU
      var complete = (filled === REQUIRED.length);
      renderSKU(complete);
      // Warning + CTAs
      warning.classList.toggle('show', !complete);
      ctaPrice.classList.toggle('disabled', !complete);
      ctaPdf.classList.toggle('disabled', !complete);
      copyBtn.disabled = !complete;
      // Reset copy-button state when SKU changes
      copyBtn.classList.remove('copied');
      copyLabel.textContent = 'Copy SKU';

      // Live specs
      renderSpecs();
    }

    // ---- SKU encoder ----
    // Walks SKU_ORDER and concatenates each segment with its SEP rule.
    // Multi-select fields (controls, glare) emit one /CODE per selected value.
    // Optic uses '' (blank) as its code when 35° is selected → no segment emitted.
    function renderSKU(complete) {
      var html = 'LSPL' + (state.model || '<span class="placeholder">[600|800]</span>');
      SKU_ORDER.forEach(function(k) {
        // Use hasOwnProperty so an EMPTY-STRING separator (finish: '') is preserved.
        // Earlier `SEP[k] || '/'` short-circuited the '' case → finish got a stray '/'.
        var sep = Object.prototype.hasOwnProperty.call(SEP, k) ? SEP[k] : '/';
        var val = state[k];
        var isReq = REQUIRED.indexOf(k) >= 0;
        var isMulti = MULTI.indexOf(k) >= 0;

        // No selection?
        if (val == null || (isMulti && (!Array.isArray(val) || val.length === 0))) {
          if (isReq) html += sep + '<span class="placeholder">' + placeholderFor(k) + '</span>';
          // Optional + unset → no segment emitted
          return;
        }

        // Finish = Custom RAL → special-case: emit the 4-digit code (or RAL#
        // placeholder) flush against voltage — Finish never adds a leading
        // separator, same rule as B / D / S / W.
        if (k === 'finish' && val === 'RAL') {
          if (state.finishRAL) {
            html += state.finishRAL;
          } else {
            html += '<span class="placeholder">RAL#</span>';
          }
          return;
        }

        if (isMulti) {
          // Emit one segment per selected value. SKU_ORDER preserves field order;
          // within a multi-field we emit values in the chip's source order (markup order).
          var orderedVals = [];
          section.querySelectorAll('.cfg-chip[data-field="' + k + '"]').forEach(function(c) {
            if (val.indexOf(c.dataset.val) >= 0) orderedVals.push(c.dataset.code);
          });
          orderedVals.forEach(function(code) {
            if (code) html += sep + code;
          });
          return;
        }

        // Single-select — look up the code from the matching chip
        var chip = section.querySelector('.cfg-chip[data-field="' + k + '"][data-val="' + val + '"]');
        var code = chip ? chip.dataset.code : '';
        if (code === '') return;          // default optic / standard TAA → blank
        html += sep + code;
      });
      skuEl.innerHTML = html;
    }
    function placeholderFor(k) {
      return ({
        cct:     '[CCT]',
        voltage: '[V]',
        finish:  '[FIN]',
        optic:   '[OPT]',
        mount:   '[MNT]',
        taa:     '[TAA]'
      })[k] || '[' + k.toUpperCase() + ']';
    }

    // ---- Live spec readout ----
    function renderSpecs() {
      setSpec('lumens',  state.model    ? SPEC_TABLE.model[state.model].lumensMax       : null);
      setSpec('lpw',     state.model    ? SPEC_TABLE.model[state.model].lpw             : null);
      setSpec('cct',     state.cct      ? SPEC_TABLE.cct[state.cct]                     : null);
      setSpec('voltage', state.voltage  ? SPEC_TABLE.voltage[state.voltage]             : null);
      setSpec('optic',   state.optic    ? SPEC_TABLE.optic[state.optic]                 : null);
      setSpec('peak',    (state.model && state.optic) ? SPEC_TABLE.peak[state.model + '_' + state.optic] || '—' : null);
      // Finish — for Custom RAL, show "RAL 9005 · Jet Black" (or just "RAL 9005") instead
      var finishVal = null;
      if (state.finish === 'RAL') {
        if (state.finishRAL) {
          var ralNum = parseInt(state.finishRAL, 10);
          finishVal = 'RAL ' + state.finishRAL + (RAL_NAMES[ralNum] ? ' · ' + RAL_NAMES[ralNum] : '');
        }
      } else if (state.finish) {
        finishVal = SPEC_TABLE.finish[state.finish];
      }
      setSpec('finish', finishVal);
      // Compliance auto-updates with TAA selection
      var compliance = 'DLC Premium · IP66';
      if (state.taa === 'TAA') compliance += ' · TAA Compliant';
      if (state.surge) compliance += ' · Surge-Protected';
      setSpec('compliance', compliance);
      // Swap the live-preview image src per selected finish.
      // Soft cross-fade: opacity 0 → swap src → opacity 1 (200ms).
      var previewImg = document.getElementById('cfgPreviewImg');
      var newSrc = state.finish ? SPEC_TABLE.finishImg[state.finish] : SPEC_TABLE.finishImg['B'];
      if (previewImg && newSrc && !previewImg.src.endsWith(newSrc)) {
        previewImg.style.opacity = '0';
        setTimeout(function() {
          previewImg.src = newSrc;
          previewImg.style.opacity = '1';
        }, 180);
      }
    }
    function setSpec(name, val) {
      var el = section.querySelector('[data-spec="' + name + '"]');
      if (!el) return;
      if (val == null || val === '—') {
        el.textContent = '—';
        el.classList.add('placeholder');
      } else {
        el.textContent = val;
        el.classList.remove('placeholder');
      }
    }

    // ---- Copy SKU ----
    copyBtn.addEventListener('click', function() {
      if (copyBtn.disabled) return;
      var txt = skuEl.textContent.trim();
      if (!txt) return;
      // Use Clipboard API where available, fallback to execCommand
      var done = function() {
        copyBtn.classList.add('copied');
        copyLabel.textContent = 'Copied ✓';
        setTimeout(function() {
          copyBtn.classList.remove('copied');
          copyLabel.textContent = 'Copy SKU';
        }, 1800);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(txt).then(done, done);
      } else {
        var ta = document.createElement('textarea');
        ta.value = txt;
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch(e){}
        document.body.removeChild(ta);
        done();
      }
    });

    // ---- Submittal PDF — opens /products/illuminator/submittal/index.html in new tab with full config in query string ----
    // The template auto-fills page-1 catalog number, quick specs, ordering-code matrix, and photometric data.
    // Manus replaces this with a real backend at /submittal-generator/?sku=… on production.
    function buildSubmittalUrl() {
      var sku = skuEl.textContent.trim();
      var params = new URLSearchParams({
        sku:     sku,
        wattage: state.model   || '600',
        optic:   state.optic   || '35',
        cct:     state.cct     || '50',
        voltage: state.voltage || '277',
        finish:  state.finish  === 'RAL' && state.finishRAL ? 'RAL' + state.finishRAL : (state.finish || 'B'),
        mount:   state.mount   || 'TR',
        taa:     (Array.isArray(state.compliance) && state.compliance.indexOf('TAA') >= 0) ? '1' : '0'
      });
      return '/products/illuminator/submittal/index.html?' + params.toString();
    }
    ctaPdf.addEventListener('click', function(e) {
      if (ctaPdf.classList.contains('disabled')) { e.preventDefault(); return; }
      // Update href to current configurator state immediately before navigation
      ctaPdf.setAttribute('href', buildSubmittalUrl());
    });

    // Initial render
    applyState();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();

// Section 3 — Motion video carousel
(function() {
  // Maps to production Shopify CDN clips. If a URL is blocked by CORS / network,
  // the player will skip to the next clip via the 'error' handler.
  var clips = [
    { url: 'https://cdn.shopify.com/videos/c/o/v/d0f16d0f39a949a0822b86691c6397f4.mp4', tag: 'WATTSELECT',          title: 'Field-selectable wattage — tune the output to the install.' },
    { url: 'https://cdn.shopify.com/videos/c/o/v/e1a878d2d424425e82457cf4edb1c01f.mp4', tag: 'POWERⒶIM™', title: '90° pivot hinge for full-range beam aiming and laser-sight install.' },
    { url: 'https://cdn.shopify.com/videos/c/o/v/c5fe1bd76a70465cb137b2e5d94d697c.mp4', tag: 'TRUNNION MOUNT',      title: 'Trunnion bracket — versatile, field-ready installation.' },
    { url: 'https://cdn.shopify.com/videos/c/o/v/9e12a3772f534811bfc9113271fe1bd7.mp4', tag: 'SLIP-FITTER',         title: 'Slip-fitter mount — pole-top mounting flexibility.' },
    { url: 'https://cdn.shopify.com/videos/c/o/v/fd80635e18bc4bab85116e63cffe2f7b.mp4', tag: 'STACKABLE DESIGN',    title: 'Stackable arrays for limitless field illumination.' },
    { url: 'https://cdn.shopify.com/videos/c/o/v/5051b441ef7145f68cd6e6b2695c74b5.mp4', tag: 'CONTRⒶLS-READY',  title: 'Synapse SimplySNAP integration — wireless networked control.' }
  ];
  function init() {
    var video    = document.getElementById('motionVideo');
    var caption  = document.getElementById('motionCaption');
    var dotsRow  = document.getElementById('motionDots');
    var progress = document.getElementById('motionProgressBar');
    if (!video || !caption || !dotsRow || !progress) return;
    var idx = 0;
    var ticker;

    function set(i) {
      idx = (i + clips.length) % clips.length;
      var c = clips[idx];
      video.src = c.url;
      video.load();
      var play = video.play();
      if (play && typeof play.catch === 'function') play.catch(function(){});
      caption.innerHTML =
        '<div class="motion-caption-eyebrow">' + (idx + 1).toString().padStart(2, '0') + ' / 06 · ' + c.tag + '</div>' +
        '<div class="motion-caption-title">' + c.title + '</div>';
      dotsRow.querySelectorAll('button').forEach(function(b, n) {
        b.classList.toggle('active', n === idx);
        b.setAttribute('aria-selected', n === idx ? 'true' : 'false');
      });
      progress.style.width = '0%';
    }

    // Build dots
    dotsRow.innerHTML = clips.map(function(c, n) {
      var num = (n + 1).toString().padStart(2, '0');
      return '<button type="button" data-i="' + n + '" role="tab"' +
             (n === 0 ? ' class="active" aria-selected="true"' : ' aria-selected="false"') +
             '>' + num + ' · ' + c.tag + '</button>';
    }).join('');
    dotsRow.querySelectorAll('button').forEach(function(b) {
      b.addEventListener('click', function() {
        clearInterval(ticker);
        set(parseInt(b.dataset.i, 10));
        startTicker();
      });
    });

    // Progress bar — animates to 100% over the auto-advance window
    function startTicker() {
      var DURATION = 6000; // 6s per clip auto-advance
      var start = Date.now();
      progress.style.width = '0%';
      ticker = setInterval(function() {
        var pct = Math.min(100, ((Date.now() - start) / DURATION) * 100);
        progress.style.width = pct + '%';
        if (pct >= 100) {
          clearInterval(ticker);
          set(idx + 1);
          startTicker();
        }
      }, 60);
    }

    // If a clip fails to load, skip to next after a brief moment
    video.addEventListener('error', function() {
      clearInterval(ticker);
      setTimeout(function() { set(idx + 1); startTicker(); }, 500);
    });

    set(0);
    startTicker();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();

</script>
</BaseLayout>
