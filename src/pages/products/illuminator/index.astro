// Dimensions zoom modal — click magnifier to open, click anywhere or ESC to close
(function() {
  function initZoom() {
    var btn      = document.querySelector('.spec-dim-zoom');
    var modal    = document.getElementById('zoomModal');
    var img      = document.getElementById('dimImg');
    var src      = document.getElementById('dimSvg');
    var dst      = document.getElementById('zoomContent');
    var closeBtn = document.getElementById('zoomClose');
    if (!btn || !modal || !dst || !(img || src)) {
      console.warn('zoom-modal: missing DOM nodes', {btn:!!btn, modal:!!modal, img:!!img, src:!!src, dst:!!dst});
      return;
    }
    function openModal(e) {
      if (e) { e.preventDefault(); e.stopPropagation(); }
      // Prefer the production drawing; fall back to inline SVG
      if (img && img.complete && img.naturalWidth > 0) {
        dst.innerHTML = '<img src="' + img.getAttribute('src') + '" alt="' + img.alt + '" />';
      } else if (src) {
        dst.innerHTML = src.outerHTML.replace(/\bdisplay\s*:\s*none[;]?/i, '');
      }
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeModal(e) {
      if (e) { e.preventDefault(); }
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }
    btn.addEventListener('click', openModal);
    modal.addEventListener('click', closeModal);
    if (closeBtn) closeBtn.addEventListener('click', function(e){ e.stopPropagation(); closeModal(e); });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initZoom);
  } else {
    initZoom();
  }
})();

// Section 5 — Total Adaptive Control: platform tab → swap sensor SVG, swap body copy, trigger ripple shockwave
(function() {
  var copy = {
    synapse: "Enterprise-grade networked lighting control with advanced commissioning, scalability, and cloud integration for large facilities and campuses. Mesh-network site management, theatrical RGBW show programs through DMX/DALI gateways, and dual sensor inputs for advanced automation.",
    acs:     "ALG’s in-house ⒶCS controls platform — daylight harvesting, occupancy sensing, and 0-10V dimming wired directly to the luminaire. Field-commissionable via DIP-switch or AURA app. Ideal for sealed-envelope installs without a wireless gateway.",
    bilevel: "Two-stage hardwired bi-level control — full output at occupancy, dimmed standby at vacancy. No commissioning, no gateway, no app. Drop-in compliance for ASHRAE 90.1 and Title 24 occupancy reduction requirements.",
    silvair: "SILVAIR Bluetooth Mesh — qualified mesh nodes built into the driver. Self-healing topology, no gateway required, full control via the SILVAIR commissioning app. Enterprise-scale deployments without the wired backhaul."
  };
  function init() {
    var tabs = document.querySelectorAll('.tac-callout-tab');
    var sensors = document.querySelectorAll('.tac-sensor-svg');
    var copyEl = document.getElementById('tacCalloutCopy');
    var wave = document.getElementById('tacShockwave');
    if (!tabs.length || !sensors.length || !wave) return;
    function select(platform) {
      tabs.forEach(function(t) {
        var isActive = t.dataset.platform === platform;
        t.classList.toggle('active', isActive);
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      sensors.forEach(function(s) {
        s.classList.toggle('is-active', s.dataset.platform === platform);
      });
      if (copyEl && copy[platform]) copyEl.textContent = copy[platform];
      // Trigger shockwave: remove + re-add class to restart animation
      wave.classList.remove('is-rippling');
      void wave.offsetWidth;
      wave.classList.add('is-rippling');
    }
    tabs.forEach(function(t) {
      t.addEventListener('click', function() { select(t.dataset.platform); });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();

// Section 6 — Photometrics: model + optic toggle drives polar plot SVG swap
(function() {
  // Real IES test data — peak candela and total lumens per (model × optic) combo
  // Polar plots: dark-theme semi-circle, IESNA conventions. Curves derived directly from the IES files
  // (same data the InventFine GPM-1800B test report rendered in each PDF page 3, just restyled to fit our palette).
  var data = {
    '600_20': { svg: '/products/illuminator/assets/photometrics/lspl600_20.svg', peak: '388,500', lumens: '94,439',  file: 'LSPL600-50-UBTR-600W-20D.IES' },
    '600_35': { svg: '/products/illuminator/assets/photometrics/lspl600_35.svg', peak: '176,443', lumens: '87,618',  file: 'LSPL600-277V-35D.IES' },
    '600_55': { svg: '/products/illuminator/assets/photometrics/lspl600_55.svg', peak: '102,154', lumens: '90,655',  file: 'LSPL600-50-UBTR-600W-55D.IES' },
    '600_90': { svg: '/products/illuminator/assets/photometrics/lspl600_90.svg', peak: '47,102',  lumens: '91,871',  file: 'LSPL600-50-UBTR-600W-90D.IES' },
    '800_20': { svg: '/products/illuminator/assets/photometrics/lspl800_20.svg', peak: '440,924', lumens: '121,000', file: 'LSPL800-277V-20D.IES' },
    '800_35': { svg: '/products/illuminator/assets/photometrics/lspl800_35.svg', peak: '245,983', lumens: '122,133', file: 'LSPL800-277V-35D.IES' },
    '800_55': { svg: '/products/illuminator/assets/photometrics/lspl800_55.svg', peak: '112,457', lumens: '119,689', file: 'LSPL800-277V-55D.IES' }
  };
  // Per datasheet all 4 optics are available across both models. IES file presence differs.
  var optics = { '600': ['20','35','55','90'], '800': ['20','35','55'] };
  var fallback = { '600': '35', '800': '35' };

  function init() {
    var img = document.getElementById('photoImg');
    var statPeak = document.getElementById('photoStatPeak');
    var statLum = document.getElementById('photoStatLumens');
    var statFile = document.getElementById('photoStatFile');
    if (!img || !statPeak) return;
    var modelTabs = document.querySelectorAll('.photo-tab[data-model]');
    var opticTabs = document.querySelectorAll('.photo-tab[data-optic]');
    var state = { model: '600', optic: '35' };  // 35° is the datasheet default optic
    // Mark the 35° optic tab active on initial load
    opticTabs.forEach(function(t) { t.classList.toggle('active', t.dataset.optic === state.optic); t.setAttribute('aria-selected', t.dataset.optic === state.optic ? 'true' : 'false'); });

    function refreshOpticTabs() {
      var available = optics[state.model];
      opticTabs.forEach(function(t) {
        var opt = t.dataset.optic;
        var isAvailable = available.indexOf(opt) >= 0;
        t.disabled = !isAvailable;
        t.style.opacity = isAvailable ? '1' : '0.3';
        t.style.cursor = isAvailable ? 'pointer' : 'not-allowed';
        t.title = isAvailable ? '' : 'IES test data not available for this combination';
      });
      // If current optic isn't available for new model, snap to the default
      if (available.indexOf(state.optic) < 0) state.optic = fallback[state.model];
      opticTabs.forEach(function(t) {
        t.classList.toggle('active', t.dataset.optic === state.optic);
        t.setAttribute('aria-selected', t.dataset.optic === state.optic ? 'true' : 'false');
      });
    }

    function render() {
      var key = state.model + '_' + state.optic;
      var d = data[key];
      if (!d) return;
      img.src = d.svg;
      img.alt = 'LSPL' + state.model + ' ' + state.optic + '° optic — luminous distribution';
      statPeak.textContent = d.peak + ' cd';
      statLum.textContent = d.lumens + ' lm';
      statFile.textContent = d.file;
    }

    modelTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        modelTabs.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-selected', 'false'); });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        state.model = t.dataset.model;
        refreshOpticTabs();
        render();
      });
    });
    opticTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        if (t.disabled) return;
        opticTabs.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-selected', 'false'); });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        state.optic = t.dataset.optic;
        render();
      });
    });

    refreshOpticTabs();
    render();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();

