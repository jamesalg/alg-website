      sku: 'PSB',
      model: 'Button Photocell \u00B7 NEMA 3-pin twist-lock',
      desc: 'Optional snap-in upgrade to the standard sensor cap port. Adds integrated dusk-to-dawn automation \u2014 fixture turns on at sundown and off at sunrise, no controls package, no commissioning. Specify with the /PSB suffix in the SKU. NEMA 3-pin twist-lock photocontrol mount accepts third-party photocells if required.',
      specs: [
        ['Type', 'Button photocell \u00B7 twist-lock'],
        ['Mount', 'NEMA 3-pin photocontrol port'],
        ['Operation', 'Dusk-to-dawn ON/OFF'],
        ['Compatibility', 'All Nightwatch SKUs \u00B7 replaces sensor cap'],
        ['Specify', 'Append /PSB suffix to the SKU'],
        ['Standard', 'Sensor cap is included from factory \u00B7 PSB is the optional upgrade']
      ]
    }
  };

  function init() {
    var grid     = document.getElementById('accGrid');
    var modal    = document.getElementById('accModal');
    var closeBtn = document.getElementById('accModalClose');
    var imgWrap  = document.getElementById('accModalImg');
    var catEl    = document.getElementById('accModalCat');
    var titleEl  = document.getElementById('accModalTitle');
    var skuEl    = document.getElementById('accModalSku');
    var descEl   = document.getElementById('accModalDesc');
    var specsEl  = document.getElementById('accModalSpecs');
    var dsLink   = document.getElementById('accModalDatasheet');
    var pills    = document.querySelectorAll('.acc-pill');
    if (!grid || !modal) return;
    var cards = grid.querySelectorAll('.acc-card');

    // Filter pills
    pills.forEach(function(p) {
      p.addEventListener('click', function() {
        pills.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-selected', 'false'); });
        p.classList.add('active');
        p.setAttribute('aria-selected', 'true');
        var f = p.dataset.filter;
        cards.forEach(function(c) {
          var match = (f === 'all' || c.dataset.cat === f);
          c.classList.toggle('is-hidden', !match);
        });
      });
    });

    function openModal(card) {
      var id = card.dataset.id;
      var d  = ACC[id];
      if (!d) { console.warn('acc-modal: no data for id', id); return; }
      catEl.textContent   = d.cat.replace(/\u24B6/g, '');
      titleEl.textContent = d.title;
      skuEl.innerHTML     = d.sku + (d.model && d.model !== d.sku ? '<div style="font-size:11px;color:var(--text-muted);font-weight:400;margin-top:2px;">' + d.model + '</div>' : '');
      descEl.textContent  = d.desc;
      if (d.cat.indexOf('\u24B6') >= 0) {
        catEl.innerHTML = d.cat.replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
      }
      if (dsLink) {
        if (d.datasheet) {
          dsLink.href = d.datasheet;
          dsLink.style.display = '';
        } else {
          dsLink.style.display = 'none';
          dsLink.removeAttribute('href');
        }
      }
      specsEl.innerHTML = d.specs.map(function(s) {
        return '<div class="acc-spec-row">' +
                 '<div class="acc-spec-key">' + s[0] + '</div>' +
                 '<div class="acc-spec-val">' + s[1] + '</div>' +
               '</div>';
      }).join('');
      var srcMedia = card.querySelector('.acc-card-img svg, .acc-card-img img.acc-card-photo');
      Array.from(imgWrap.querySelectorAll('svg, img.acc-card-photo')).forEach(function(s){ s.remove(); });
      if (srcMedia) {
        var clone = srcMedia.cloneNode(true);
        if (clone.tagName === 'IMG') {
          clone.style.maxWidth = '90%';
          clone.style.maxHeight = '90%';
          clone.style.objectFit = 'contain';
          clone.style.filter = 'drop-shadow(0 12px 24px rgba(0,0,0,0.6))';
        }
        imgWrap.appendChild(clone);
      }
      modal.classList.add('open');
    }
    function closeModal() { modal.classList.remove('open'); }

    cards.forEach(function(c) {
      c.addEventListener('click', function() { openModal(c); });
    });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

<!-- =============================================================================
     SECTION 9 — Configurator engine: state machine + SKU builder + previews
     5 required (series, model, voltage, finish, photocell) + 1 optional (em).
     Series choice filters which Model chips are visible AND auto-drives the
     distribution segment (S3N = blank, S3N2 = "BA" appended to finish).
     SKU pattern: LWPC{model}-{series}-U{D|B}[/BA][/PSB][/EM20]
     ============================================================================= -->
<script>
(function() {
  var REQUIRED = ['series', 'model', 'voltage', 'finish', 'photocell'];
  var OPTIONAL = ['em'];

  // Per-series \u2192 list of valid model values + per-model spec lookups.
  // Model values use 't' / 'n' suffixes for the duplicate LWPC100 case so
  // the chip data-val is unique while the SKU code stays clean.
  var MODELS_BY_SERIES = {
    'S3N': ['38', '65', '100t', '135'],
    'S3N2': ['30', '60', '100n']
  };

  // Per-(model) display data \u2014 page 2 model spec table + page 4 perf data.
  var MODEL_SPEC = {
    '38':   { name: 'LWPC38',  range: '17 / 23 / 31 / 38W',     lumensMax: '6,000 lm',  lpw: '158 lm/W' },
    '65':   { name: 'LWPC65',  range: '24 / 35 / 50 / 65W',     lumensMax: '10,000 lm', lpw: '154 lm/W' },
    '100t': { name: 'LWPC100', range: '43 / 62 / 85 / 100W',    lumensMax: '15,500 lm', lpw: '155 lm/W' },
    '135':  { name: 'LWPC135', range: '54 / 80 / 110 / 135W',   lumensMax: '20,000 lm', lpw: '148 lm/W' },
    '30':   { name: 'LWPC30',  range: '12 / 18 / 24 / 30W',     lumensMax: '4,400 lm',  lpw: '147 lm/W' },
    '60':   { name: 'LWPC60',  range: '24 / 36 / 48 / 60W',     lumensMax: '8,400 lm',  lpw: '140 lm/W' },
    '100n': { name: 'LWPC100', range: '40 / 60 / 80 / 100W',    lumensMax: '15,500 lm', lpw: '155 lm/W' }
  };

  var FINISH_LABEL = { 'D': 'Dark Bronze', 'B': 'Black (MTO)' };
  var FINISH_IMG   = {
    'D': '/products/nightwatch/assets/finishes/dark-bronze.webp',
    'B': '/products/nightwatch/assets/finishes/black.webp'
  };

  function init() {
    var section = document.getElementById('configurator');
    if (!section) return;

    // Default state: voltage + finish + photocell pre-locked. Series + model unset.
    var state = {
      series: null,    model: null,
      voltage: 'U',    finish: 'D',
      photocell: 'CAP',
      em: null
    };

    var skuEl       = document.getElementById('cfgSku');
    var copyBtn     = document.getElementById('cfgSkuCopy');
    var copyLabel   = document.getElementById('cfgSkuCopyLabel');
    var counterEl   = document.getElementById('cfgCounter');
    var counterCnt  = document.getElementById('cfgCounterCount');
    var resetBtn    = document.getElementById('cfgReset');
    var warnEl      = document.getElementById('cfgIncompleteWarning');
    var ctaPrice    = document.getElementById('cfgCtaPricing');
    var ctaPdf      = document.getElementById('cfgCtaPdf');
    var previewImg  = document.getElementById('cfgPreviewImg');

    function setSpec(name, val) {
      var el = section.querySelector('[data-spec="' + name + '"]');
      if (!el) return;
      if (val == null || val === '\u2014') {
        el.textContent = '\u2014';
        el.classList.add('placeholder');
      } else {
        el.textContent = val;
        el.classList.remove('placeholder');
      }
    }

    // ---- Filter the Model chips by current series ---------------------------
    function refreshModelChips() {
      var modelChips = section.querySelectorAll('.cfg-chip[data-field="model"]');
      modelChips.forEach(function(chip) {
        var fits = !state.series || chip.dataset.series === state.series;
        chip.style.display = fits ? '' : 'none';
        // If the currently-selected model isn't valid for the new series, clear it
        if (chip.dataset.val === state.model && !fits) state.model = null;
      });
      // If no series picked yet, hide all model chips and show a placeholder
      if (!state.series) {
        modelChips.forEach(function(chip) { chip.style.display = 'none'; });
      }
    }

    // ---- SKU builder --------------------------------------------------------
    function buildSku() {
      if (!state.series || !state.model) return null;
      var modelCode = MODEL_SPEC[state.model] ? MODEL_SPEC[state.model].name.replace('LWPC', '') : '';
      if (!modelCode) return null;
      var sku = 'LWPC' + modelCode + '-' + state.series + '-' + state.voltage + state.finish;
      // Auto-append "BA" to finish for Nightwatch-II (S3N2) \u2014 no slash separator
      if (state.series === 'S3N2') sku += 'BA';
      // Photocell \u2014 only adds suffix when PSB is selected (CAP = sensor cap default, no suffix)
      if (state.photocell === 'PSB') sku += '/PSB';
      if (state.em) sku += '/' + state.em;
      return sku;
    }

    function applyState() {
      // Refresh model chip visibility (series-driven filter)
      refreshModelChips();

      // Update chip selection visuals
      section.querySelectorAll('.cfg-chip').forEach(function(c) {
        var f = c.dataset.field, v = c.dataset.val;
        if (state[f] === v) c.classList.add('selected');
        else if (!c.classList.contains('locked')) c.classList.remove('selected');
      });

      // Counter \u2014 5 required fields
      var have = REQUIRED.filter(function(k) { return state[k]; }).length;
      counterCnt.textContent = have;
      counterEl.classList.toggle('complete', have === REQUIRED.length);

      // Resolved SKU
      var sku = buildSku();
      if (sku) {
        skuEl.innerHTML = sku;
        skuEl.classList.remove('placeholder');
      } else {
        skuEl.innerHTML = '<span class="placeholder">LWPC[30|38|60|65|100|135]-[S3N|S3N2]-U[D|B][BA][/PSB][/EM20]</span>';
      }
      copyBtn.disabled = !sku;

      // Live preview specs
      if (state.model && MODEL_SPEC[state.model]) {
        var m = MODEL_SPEC[state.model];
        setSpec('lumens',    m.lumensMax);
        setSpec('lpw',       m.lpw);
        setSpec('wattRange', m.range);
      } else {
        ['lumens', 'lpw', 'wattRange'].forEach(function(k) { setSpec(k, null); });
      }
      setSpec('voltage', state.voltage ? '120-277V Universal' : null);
      setSpec('finish',  state.finish  ? FINISH_LABEL[state.finish]  : null);
      // Distribution depends on series (drives the /BA segment)
      if (state.series === 'S3N') {
        setSpec('dist', 'Type-I \u00B7 Fixed Forward Throw');
      } else if (state.series === 'S3N2') {
        setSpec('dist', 'beam\u24B6DJUST\u2122 \u00B7 Type-I/II/III/IV');
      } else {
        setSpec('dist', null);
      }

      // Compliance \u2014 augments with optional adds
      var compliance = 'DLC \u00B7 UL \u00B7 cUL \u00B7 RoHS \u00B7 IP65 \u00B7 3G ANSI C136.31 \u00B7 BUG U0';
      if (state.photocell === 'PSB') compliance += ' \u00B7 Photocell';
      if (state.em) compliance += ' \u00B7 EM Backup';
      setSpec('compliance', compliance);

      // CTA states + warning
      var complete = (have === REQUIRED.length);
      ctaPrice.classList.toggle('disabled', !complete);
      ctaPdf.classList.toggle('disabled', !complete);
      warnEl.classList.toggle('show', !complete);

      // Preview image swap (cross-fade)
      var newSrc = state.finish ? FINISH_IMG[state.finish] : FINISH_IMG['D'];
      if (previewImg && newSrc && !previewImg.src.endsWith(newSrc)) {
        previewImg.style.opacity = '0';
        setTimeout(function() {
          previewImg.src = newSrc;
          previewImg.style.opacity = '1';
        }, 180);
      }
    }

    // Wire up chip clicks
    section.querySelectorAll('.cfg-chip').forEach(function(chip) {
      if (chip.classList.contains('locked')) return;
      chip.addEventListener('click', function() {
        var f = chip.dataset.field, v = chip.dataset.val;
        if (OPTIONAL.indexOf(f) >= 0) {
          state[f] = (state[f] === v) ? null : v;
        } else {
          state[f] = v;
        }
        applyState();
      });
    });

    // Reset
    resetBtn.addEventListener('click', function() {
      state = {
        series: null, model: null,
        voltage: 'U', finish: 'D',
        photocell: 'CAP',
        em: null
      };
      applyState();
    });

    // Copy SKU
    copyBtn.addEventListener('click', function() {
      var sku = buildSku();
      if (!sku) return;
      try {
        navigator.clipboard.writeText(sku);
        copyBtn.classList.add('copied');
        copyLabel.textContent = 'Copied!';
        setTimeout(function() {
          copyBtn.classList.remove('copied');
          copyLabel.textContent = 'Copy SKU';
        }, 1400);
      } catch (e) {}
    });

    // ---- Submittal PDF \u2014 opens submittal_template.html with full config in query string ----
    function buildSubmittalUrl() {
      var sku = buildSku() || 'LWPC65-S3N-UD/PSB';
      var modelCode = state.model && MODEL_SPEC[state.model] ? MODEL_SPEC[state.model].name.replace('LWPC', '') : '65';
      var params = new URLSearchParams({
        product:   'nightwatch',
        sku:       sku,
        wattage:   modelCode,
        series:    state.series    || 'S3N',
        voltage:   state.voltage   || 'U',
        finish:    state.finish    || 'D',
        photocell: state.photocell || 'CAP',
        em:        state.em        || ''
      });
      return 'submittal_template.html?' + params.toString();
    }
    ctaPdf.addEventListener('click', function(e) {
      if (ctaPdf.classList.contains('disabled')) { e.preventDefault(); return; }
      ctaPdf.setAttribute('href', buildSubmittalUrl());
    });

    // Initial render
    applyState();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>


<script>
/* =============================================================================
   CFG-NAV-1 \u00B7 Sticky-nav scroll-spy
   ----------------------------------------------------------------------------
   IntersectionObserver watches each section the sticky-nav links to. The link
   whose target is "most visible" gets '.is-current' (white bg + red text \u00B7 the
   visual inverse of '.primary'). One observer, one Map, one CSS class toggle.
   The Pricing & Availability primary button is NOT a section anchor (its href
   is /pricing-availability/), so it's excluded from the spy by the
   'a[href^="#"]' selector below.
   ============================================================================= */
(function() {
  var nav = document.querySelector('.sticky-nav');
  if (!nav) return;
  var links = Array.prototype.slice.call(nav.querySelectorAll('a[href^="#"]'));
  if (!links.length) return;
  var entries = [];
  links.forEach(function(a) {
    var id = a.getAttribute('href').slice(1);
    var sec = id ? document.getElementById(id) : null;
    if (sec) entries.push({ sec: sec, link: a, ratio: 0 });
  });
  if (!entries.length) return;
  function update() {
    var best = null, bestRatio = 0;
    entries.forEach(function(e) { if (e.ratio > bestRatio) { bestRatio = e.ratio; best = e; } });
    entries.forEach(function(e) { e.link.classList.toggle('is-current', e === best && bestRatio > 0); });
  }
  var io = new IntersectionObserver(function(items) {
    items.forEach(function(item) {
      entries.forEach(function(e) { if (e.sec === item.target) e.ratio = item.intersectionRatio; });
    });
    update();
  }, {
    rootMargin: '-20% 0px -55% 0px',
    threshold: [0, 0.1, 0.25, 0.5, 0.75, 1.0]
  });
  entries.forEach(function(e) { io.observe(e.sec); });
})();
</script>

<script>
// CFG-STATE-1 \u2014 derive ship-tier (QS / WB / MTO) from selected chip badges, render
// canonical 3-state status panel. Self-contained module \u00B7 no dependency on the
// configurator's state object \u00B7 re-derives by walking selected chips on every click.
// Custom RAL forces MTO (custom paint = factory work).
(function() {
  function deriveShipTier() {
    var section = document.getElementById('configurator');
    if (!section) return 'QS';
    var chips = section.querySelectorAll('.cfg-chip.selected, .cfg-chip[aria-pressed="true"]');
    var worst = 'QS';
    var sawCustomRal = false;
    chips.forEach(function(chip) {
      if (chip.dataset.field === 'finish' && chip.dataset.val === 'RAL') sawCustomRal = true;
      if (chip.querySelector('.cfg-chip-stock.mto')) worst = 'MTO';
      else if (chip.querySelector('.cfg-chip-stock.wb') && worst !== 'MTO') worst = 'WB';
    });
    if (sawCustomRal) {
      var input = document.getElementById('cfgRalInput');
      if (input && input.value && /^[0-9]{4}$/.test(input.value)) return 'MTO';
    }
    return worst;
  }
  function refreshShipTier() {
    var tier = deriveShipTier();
    var rowEl = document.getElementById('cfgShipTier');
    var iconEl = document.getElementById('cfgShipTierIcon');
    var textEl = document.getElementById('cfgShipTierText');
    var stockEl = document.getElementById('cfgShipTierStock');
    if (!rowEl || !iconEl || !textEl || !stockEl) return;
    if (tier === 'QS') {
      rowEl.style.background = 'rgba(95,199,122,0.08)';
      rowEl.style.border = '1px solid rgba(95,199,122,0.40)';
      iconEl.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#7fc998" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      textEl.innerHTML = '<strong style="color:#9bd6b1;">QuickShip \u00B7 \u00E0-la-carte assembly</strong> &middot; <span style="color:var(--text-secondary);">All selected components in stock \u2014 ships 2-3 day.</span>';
      stockEl.textContent = 'QuickShip \u00B7 2-3 day';
      stockEl.style.color = '#9bd6b1';
    } else if (tier === 'WB') {
      rowEl.style.background = 'rgba(96,168,255,0.08)';
      rowEl.style.border = '1px solid rgba(96,168,255,0.40)';
      iconEl.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#7fb6ff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>';
      textEl.innerHTML = '<strong style="color:#a8c9ff;">Workbench Assembly &middot; ~1-3 wk</strong> &middot; <span style="color:var(--text-secondary);">One or more selected components are workbench-assembled to order.</span>';
      stockEl.textContent = 'WB \u00B7 ~1-3 wk';
      stockEl.style.color = '#a8c9ff';
    } else {
      rowEl.style.background = 'rgba(255,159,28,0.08)';
      rowEl.style.border = '1px solid rgba(255,159,28,0.40)';
      iconEl.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#ffb14d" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>';
      textEl.innerHTML = '<strong style="color:#ffb14d;">Custom build &middot; Made-to-Order &middot; ~4-6 wk</strong> &middot; <span style="color:var(--text-secondary);">One or more selected components are MTO (custom finish, MTO option, or non-stocked variant).</span>';
      stockEl.textContent = 'MTO \u00B7 ~4-6 wk';
      stockEl.style.color = '#ffb14d';
    }
  }
  function init() {
    var section = document.getElementById('configurator');
    if (!section) return;
    section.addEventListener('click', function(e) {
      if (e.target.closest('.cfg-chip')) setTimeout(refreshShipTier, 50);
    });
    var ralInput = document.getElementById('cfgRalInput');
    if (ralInput) ralInput.addEventListener('input', function() { setTimeout(refreshShipTier, 50); });
    refreshShipTier();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
</BaseLayout>
