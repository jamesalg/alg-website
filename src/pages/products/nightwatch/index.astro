<!-- ============================================================================
     SECTION 9 — Configurator (Build Your Model · live SKU builder)
     Nightwatch's configurator is the most layered in the LWPC line because
     of the Nightwatch-I (S3N) vs Nightwatch-II (S3N2) sub-product split.
     User flow:
       1. Pick Series (S3N = Nightwatch-I Type-I  ·  S3N2 = Nightwatch-II beam<span class="aa">Ⓐ</span>DJUST)
       2. Series choice reveals 4 (S3N) or 3 (S3N2) Model chips
       3. Pick Model · Voltage (locked U) · Finish · Photocell mode
       4. Optionally add EM20
     SKU pattern:
       Nightwatch-I:  LWPC{model}-S3N-U{D|B}[/PSB][/EM20]
       Nightwatch-II: LWPC{model}-S3N2-U{D|B}BA[/PSB][/EM20]  (BA auto when S3N2)
     5 required fields · 1 optional · distribution segment auto-driven by series.
     ============================================================================ -->
<section class="cfg-section" id="configurator" aria-label="Configurator · Build Your Model">
  <div class="cfg-inner">

    <div class="cfg-head">
      <p class="cfg-eyebrow">Build Your Model</p>
      <h2 class="cfg-title">Configure Your Nightwatch</h2>
      <p class="cfg-sub">
        Selections build the SKU live. WATTselect + CCTselect are DIP-set at install — they do not appear in the SKU.
        <small>Required fields marked with <span style="color:var(--brand-red); font-weight:700">*</span>. See the legend for QS / MTO / WB meanings.</small>
      </p>
    </div>

    <div class="cfg-counter-band">
      <div class="cfg-counter" id="cfgCounter"><strong id="cfgCounterCount">3</strong> of 5 required fields locked in</div>
      <button type="button" class="cfg-reset" id="cfgReset">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 12a9 9 0 1 0 3-6.7"/><polyline points="3 4 3 10 9 10"/>
        </svg>
        Reset
      </button>
    </div>

    <div class="cfg-body">

      <!-- ============== REQUIRED COLUMN ============== -->
      <div class="cfg-col">
        <div class="cfg-col-head">
          <div class="cfg-col-title cfg-col-title-required">Required</div>
          <div class="cfg-col-meta">5 fields · all required</div>
        </div>
        <div class="cfg-fields">

          <!-- 1. Series — drives the model + distribution downstream -->
          <div class="cfg-field" data-field="series" style="grid-column: 1 / -1;">
            <div class="cfg-field-label">Series <span class="req">*</span></div>
            <div class="cfg-chips">
              <button type="button" class="cfg-chip" data-field="series" data-val="S3N" data-code="S3N">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">Nightwatch-I · Type-I</span>
                <span class="cfg-chip-code">-S3N</span>
              </button>
              <button type="button" class="cfg-chip" data-field="series" data-val="S3N2" data-code="S3N2">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">Nightwatch-II · beam<span class="aa">Ⓐ</span>DJUST</span>
                <span class="cfg-chip-code">-S3N2</span>
              </button>
            </div>
            <div class="cfg-field-note" style="font-size:11px; color:var(--text-muted); margin-top:6px; line-height:1.4;">S3N → Type-I fixed throw · S3N2 → beam<span class="aa">Ⓐ</span>DJUST Type-I/II/III/IV field-set.</div>
          </div>

          <!-- 2. Model — chip set re-renders based on series selection -->
          <div class="cfg-field" data-field="model" style="grid-column: 1 / -1;">
            <div class="cfg-field-label">Model Class <span class="req">*</span></div>
            <div class="cfg-chips" id="cfgModelChips">
              <!-- Nightwatch-I models (default-rendered via JS when series = S3N) -->
              <button type="button" class="cfg-chip" data-field="model" data-val="38"  data-code="38"  data-series="S3N">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">LWPC38 · 17 / 23 / 31 / 38W</span>
                <span class="cfg-chip-code">38</span>
              </button>
              <button type="button" class="cfg-chip" data-field="model" data-val="65"  data-code="65"  data-series="S3N">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">LWPC65 · 24 / 35 / 50 / 65W</span>
                <span class="cfg-chip-code">65</span>
              </button>
              <button type="button" class="cfg-chip" data-field="model" data-val="100t" data-code="100" data-series="S3N">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">LWPC100 · 43 / 62 / 85 / 100W</span>
                <span class="cfg-chip-code">100</span>
              </button>
              <button type="button" class="cfg-chip" data-field="model" data-val="135" data-code="135" data-series="S3N">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">LWPC135 · 54 / 80 / 110 / 135W</span>
                <span class="cfg-chip-code">135</span>
              </button>
              <!-- Nightwatch-II models (rendered when series = S3N2) -->
              <button type="button" class="cfg-chip" data-field="model" data-val="30"  data-code="30"  data-series="S3N2">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">LWPC30 · 12 / 18 / 24 / 30W</span>
                <span class="cfg-chip-code">30</span>
              </button>
              <button type="button" class="cfg-chip" data-field="model" data-val="60"  data-code="60"  data-series="S3N2">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">LWPC60 · 24 / 36 / 48 / 60W</span>
                <span class="cfg-chip-code">60</span>
              </button>
              <button type="button" class="cfg-chip" data-field="model" data-val="100n" data-code="100" data-series="S3N2">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">LWPC100 · 40 / 60 / 80 / 100W</span>
                <span class="cfg-chip-code">100</span>
              </button>
            </div>
            <div class="cfg-field-note" style="font-size:11px; color:var(--text-muted); margin-top:6px; line-height:1.4;">LWPC100 exists in both series — 100T (Nightwatch-I) vs 100N (Nightwatch-II).</div>
          </div>

          <!-- 3. Voltage (locked single value) -->
          <div class="cfg-field" data-field="voltage">
            <div class="cfg-field-label">Voltage <span class="req">*</span></div>
            <div class="cfg-chips">
              <button type="button" class="cfg-chip selected" data-field="voltage" data-val="U" data-code="U">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">120-277V Universal</span>
                <span class="cfg-chip-code">-U</span>
              </button>
            </div>
          </div>

          <!-- 4. Finish -->
          <div class="cfg-field" data-field="finish" style="grid-column: 1 / -1;">
            <div class="cfg-field-label">Finish <span class="req">*</span></div>
            <div class="cfg-chips">
              <button type="button" class="cfg-chip cfg-chip-finish selected" data-field="finish" data-val="D" data-code="D">
                <span class="cfg-finish-swatch" style="background:#3a2a1f;"></span>
                <span class="cfg-chip-val">Dark Bronze ★</span>
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-code">UD</span>
              </button>
              <button type="button" class="cfg-chip cfg-chip-finish" data-field="finish" data-val="B" data-code="B">
                <span class="cfg-finish-swatch" style="background:#0e0e0f;"></span>
                <span class="cfg-chip-val">Black</span>
                <span class="cfg-chip-stock mto">MTO</span>
                <span class="cfg-chip-code">UB</span>
              </button>
            </div>
          </div>

          <!-- 5. Photocell mode — sensor cap (default, no SKU suffix) vs PSB (adds /PSB) -->
          <div class="cfg-field" data-field="photocell" style="grid-column: 1 / -1;">
            <div class="cfg-field-label">Photocell <span class="req">*</span></div>
            <div class="cfg-chips">
              <button type="button" class="cfg-chip selected" data-field="photocell" data-val="CAP" data-code="">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">Sensor Cap (Std) ★</span>
                <span class="cfg-chip-code">— (no suffix)</span>
              </button>
              <button type="button" class="cfg-chip" data-field="photocell" data-val="PSB" data-code="PSB">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">Button Photocell · Dusk-to-Dawn</span>
                <span class="cfg-chip-code">/PSB</span>
              </button>
            </div>
            <div class="cfg-field-note" style="font-size:11px; color:var(--text-muted); margin-top:6px; line-height:1.4;">/PSB upgrades the included sensor cap to an integrated photocell.</div>
          </div>

        </div>
      </div>

      <!-- ============== OPTIONAL COLUMN ============== -->
      <!-- CFG-5a marker: cfg-col-legend-floor anchors the legend block to the bottom
           of the optional column so the marker key sits flush with the required-column
           floor across viewport sizes. -->
      <div class="cfg-col cfg-col-optional-flex cfg-col-legend-floor">
        <div class="cfg-col-head">
          <div class="cfg-col-title">Optional</div>
          <div class="cfg-col-meta">1 add-on group · const<span class="aa">Ⓐ</span>NT EM</div>
        </div>
        <div class="cfg-fields">

          <div class="cfg-field" data-field="em" style="grid-column: 1 / -1;">
            <div class="cfg-field-label">Emergency Backup</div>
            <div class="cfg-chips">
              <button type="button" class="cfg-chip cfg-chip-toggle" data-field="em" data-val="EM20" data-code="EM20">
                <span class="cfg-chip-stock wb">WB</span>
                <span class="cfg-chip-val">EM20 · 20W BBU · 90 min · <span class="aa">Ⓐ</span>rticGuard</span>
                <span class="cfg-chip-code">/EM20</span>
