<!-- Inline carousel JS — minimal 4-slide auto-rotator + click-to-jump dots -->
<script>
(function() {
  var track = document.getElementById('carouselTrack');
  var dots  = document.getElementById('carouselDots');
  if (!track || !dots) return;
  var slides = track.querySelectorAll('.carousel-slide');
  var dotEls = dots.querySelectorAll('span');
  var i = 0;
  function show(n) {
    i = (n + slides.length) % slides.length;
    track.style.transform = 'translateX(-' + (i * 100) + '%)';
    dotEls.forEach(function(d, k) { d.classList.toggle('active', k === i); });
  }
  dotEls.forEach(function(d, k) { d.addEventListener('click', function() { show(k); }); });
  // Auto-rotate every 5 seconds
  setInterval(function() { show(i + 1); }, 5000);
})();
</script>

<!-- =============================================================================
     SECTION 6 — contr<span class="aa">Ⓐ</span>LS · click ripple/shockwave handler
     Same pattern as Watchtower — but Nightwatch's contr<span class="aa">Ⓐ</span>LS section comes later
     (section will be added when we build Section 6). Handler initializes lazily
     and no-ops if the markup isn't present yet.
     ============================================================================= -->
<script>
(function() {
  function init() {
    var tabs = document.querySelectorAll('.tac-callout-tab');
    var wave = document.getElementById('tacShockwave');
    if (!tabs.length || !wave) return;
    function ripple() {
      wave.classList.remove('is-rippling');
      void wave.offsetWidth;
      wave.classList.add('is-rippling');
    }
    tabs.forEach(function(t) { t.addEventListener('click', ripple); });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

<!-- =============================================================================
     SECTION 3 — Model Specifications: series toggle + spec table renderer
     Lumens / efficacy from datasheet page 4 Performance Data (4000K column).
     Each row = one model class at MAX wattage; 4-WATTselect tunes 100/80/60/40%.
     ============================================================================= -->
<script>
(function() {
  // SPEC_TABLE: 2 series \u00D7 N model rows each.
  // Datasheet page 2 + page 4 Performance Data table (4000K column).
  // \u2605 marks the factory-default DIP wattage position (100% of max for each model).
  var SPEC_TABLE = {
    // Nightwatch-I \u00B7 S3N series \u00B7 Type-I fixed forward throw \u00B7 4 models
    's3n': [
      { model: 'LWPC38',  watt: '38W \u2605',  lumens: '6,000 lm',  lpw: '158 lm/W', dist: 'Type-I (fixed)', def: false, range: '17 / 23 / 31 / 38W' },
      { model: 'LWPC65',  watt: '65W \u2605',  lumens: '10,000 lm', lpw: '154 lm/W', dist: 'Type-I (fixed)', def: false, range: '24 / 35 / 50 / 65W' },
      { model: 'LWPC100', watt: '100W \u2605', lumens: '15,500 lm', lpw: '155 lm/W', dist: 'Type-I (fixed)', def: false, range: '43 / 62 / 85 / 100W' },
      { model: 'LWPC135', watt: '135W \u2605', lumens: '20,000 lm', lpw: '148 lm/W', dist: 'Type-I (fixed)', def: true,  range: '54 / 80 / 110 / 135W' }
    ],
    // Nightwatch-II \u00B7 S3N2 series \u00B7 beam\u24B6DJUST Type-I/II/III/IV \u00B7 3 models
    's3n2': [
      { model: 'LWPC30',  watt: '30W \u2605',  lumens: '4,400 lm',  lpw: '147 lm/W', dist: 'beam\u24B6DJUST \u00B7 Type-I/II/III/IV', def: false, range: '12 / 18 / 24 / 30W' },
      { model: 'LWPC60',  watt: '60W \u2605',  lumens: '8,400 lm',  lpw: '140 lm/W', dist: 'beam\u24B6DJUST \u00B7 Type-I/II/III/IV', def: false, range: '24 / 36 / 48 / 60W' },
      { model: 'LWPC100', watt: '100W \u2605', lumens: '15,500 lm', lpw: '155 lm/W', dist: 'beam\u24B6DJUST \u00B7 Type-I/II/III/IV', def: true,  range: '40 / 60 / 80 / 100W' }
    ]
  };

  function init() {
    var tabs = document.querySelectorAll('.spec-watt-tab');
    var body = document.getElementById('specTableBody');
    if (!tabs.length || !body) return;

    function render(series) {
      var rows = SPEC_TABLE[series] || [];
      body.innerHTML = rows.map(function(r) {
        // Render \u24B6 inline so it picks up the brand styling
        var distHtml = r.dist.replace(/\u24B6/g, '<span class="aa">\u24B6</span>');
        return '<tr' + (r.def ? ' class="is-default"' : '') + '>' +
                 '<td><strong>' + r.model + '</strong>' +
                   '<div style="font-size:11px;color:var(--text-muted);margin-top:2px;font-family:\'JetBrains Mono\',monospace;letter-spacing:0.04em;">' + r.range + '</div></td>' +
                 '<td>' + r.watt + '</td>' +
                 '<td>' + r.lumens + '</td>' +
                 '<td>' + r.lpw + '</td>' +
                 '<td>' + distHtml + '</td>' +
               '</tr>';
      }).join('');
    }

    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        render(t.dataset.series);
      });
    });

    // Initial render \u2014 Nightwatch-I S3N (default-active tab)
    var active = document.querySelector('.spec-watt-tab.active');
    render(active ? active.dataset.series : 's3n');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

<!-- =============================================================================
     SECTION 3 — Dimensions zoom modal: open on zoom-btn click, close on overlay click or Esc
     ============================================================================= -->
<script>
(function() {
  var modal    = document.getElementById('dimZoomModal');
  var openBtn  = document.getElementById('dimZoomBtn');
  var closeBtn = document.getElementById('dimZoomClose');
  if (!modal || !openBtn) return;
  function open()  { modal.classList.add('open'); }
  function close() { modal.classList.remove('open'); }
  openBtn.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  modal.addEventListener('click', function(e) { if (e.target === modal) close(); });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('open')) close();
  });
})();
</script>

