  // Distribution metadata (label + glyph icon code)
  var BA_META = {
    'BA0':  { label: 'Type-I',   detail: 'Forward throw \u00B7 nadir-peaked' },
    'BA15': { label: 'Type-II',  detail: 'Slight forward tilt' },
    'BA30': { label: 'Type-III', detail: 'Medium forward throw' },
    'BA45': { label: 'Type-IV',  detail: 'Wide forward throw' }
  };

  // Default ship-config wattage per model class (LV1 = 100%)
  var MODEL_LV_W = {
    'LWPC30':  { 'LV1': '30W', 'LV2': '24W', 'LV3': '18W', 'LV4': '12W' },
    'LWPC60':  { 'LV1': '60W', 'LV2': '48W', 'LV3': '36W', 'LV4': '24W' },
    'LWPC100': { 'LV1': '100W','LV2': '80W', 'LV3': '60W', 'LV4': '40W' }
  };

  /* ============== State + DOM refs ============== */
  var section = document.getElementById('photometrics');
  var img      = document.getElementById('photoImg');
  var statPeak = document.getElementById('photoStatPeak');
  var statLum  = document.getElementById('photoStatLumens');
  var statLpw  = document.getElementById('photoStatLpw');
  var statFile = document.getElementById('photoStatFile');
  var compareGrid = document.getElementById('photoCompareGrid');
  var compareMeta = document.getElementById('photoCompareMeta');
  if (!section || !img) return;

  var seriesTabs = section.querySelectorAll('.photo-series-tab');
  var nw1SizeTabs = section.querySelectorAll('.photo-tab[data-size]');
  var nw1CctTabs  = section.querySelectorAll('.photo-tab[data-cct]');
  var nw2ModelTabs = section.querySelectorAll('.photo-tab[data-nw2-model]');
  var nw2BaTabs    = section.querySelectorAll('.photo-tab[data-nw2-ba]');
  var nw2LvTabs    = section.querySelectorAll('.photo-tab[data-nw2-lv]');
  var nw2CctTabs   = section.querySelectorAll('.photo-tab[data-nw2-cct]');

  var state = {
    series: 'S3N',
    nw1: { size: 'LWPC65', cct: '50' },
    nw2: { model: 'LWPC100', ba: 'BA0', lv: 'LV1', cct: '50' }
  };

  function nw2SvgPath(model, ba, lv, cct) {
    var maxW = MODEL_LV_W[model]['LV1'];   // e.g. '100W'
    var modelFolder = maxW;                  // '30W' / '60W' / '100W'
    var actualW = MODEL_LV_W[model][lv];     // e.g. '60W' for LV3 of LWPC100
    var fname = model + '-S3N2-UD-BA-PSB_' + ba + '_' + lv + '-' + actualW + '_' + cct + '00K.svg';
    return '/products/nightwatch/assets/photometrics/nw2/' + modelFolder + '/' + fname;
  }
  function nw2IesName(model, ba, lv, cct) {
    var actualW = MODEL_LV_W[model][lv];
    return model + '-S3N2-UD-BA-PSB_' + ba + '_' + lv + '-' + actualW + '_' + cct + '00K.ies';
  }
  function nw2Key(model, ba, lv, cct) {
    return model + '_' + ba + '_' + lv + '_' + cct;
  }

  /* ============== Render ============== */
  function renderNw1() {
    var key = state.nw1.size + '_' + state.nw1.cct;
    var d = NW1_DATA[key];
    if (!d) return;
    img.src = d.svg;
    img.alt = state.nw1.size + ' \u00B7 ' + state.nw1.cct + '00K \u2014 Nightwatch-I full-cutoff polar plot';
    statPeak.textContent = d.peak;
    statLum.textContent  = d.lumens;
    statLpw.textContent  = d.lpw;
    statFile.textContent = d.file;
  }

  function renderNw2() {
    var s = state.nw2;
    var d = NW2_DATA[nw2Key(s.model, s.ba, s.lv, s.cct)];
    if (!d) return;
    img.src = nw2SvgPath(s.model, s.ba, s.lv, s.cct);
    img.alt = s.model + ' \u00B7 ' + BA_META[s.ba].label + ' (' + s.ba + ') \u00B7 ' + s.lv + ' (' + MODEL_LV_W[s.model][s.lv] + ') \u00B7 ' + s.cct + '00K \u2014 Nightwatch-II beam\u24B6DJUST polar plot';
    statPeak.textContent = d.peak + ' cd';
    statLum.textContent  = d.lumens + ' lm';
    statLpw.textContent  = d.lpw + ' lm/W efficacy \u00B7 ' + d.watts + 'W actual draw';
    statFile.textContent = nw2IesName(s.model, s.ba, s.lv, s.cct);

    // Update LV chip labels with the model-correct wattage values
    document.getElementById('photoNw2LV1Label').textContent = 'LV1 \u00B7 ' + MODEL_LV_W[s.model]['LV1'] + ' \u2605';
    document.getElementById('photoNw2LV2Label').textContent = 'LV2 \u00B7 ' + MODEL_LV_W[s.model]['LV2'];
    document.getElementById('photoNw2LV3Label').textContent = 'LV3 \u00B7 ' + MODEL_LV_W[s.model]['LV3'];
    document.getElementById('photoNw2LV4Label').textContent = 'LV4 \u00B7 ' + MODEL_LV_W[s.model]['LV4'];

    renderCompare();
  }

  function renderCompare() {
    var s = state.nw2;
    compareMeta.textContent = s.model + ' \u00B7 ' + s.lv + ' (' + MODEL_LV_W[s.model][s.lv] + ') \u00B7 ' + s.cct + '00K';
    var html = '';
    ['BA0','BA15','BA30','BA45'].forEach(function(ba) {
      var d = NW2_DATA[nw2Key(s.model, ba, s.lv, s.cct)];
      var src = nw2SvgPath(s.model, ba, s.lv, s.cct);
      var meta = BA_META[ba];
      var current = (ba === s.ba) ? ' is-current' : '';
      html +=
        '<button type="button" class="photo-compare-card' + current + '" data-compare-ba="' + ba + '" aria-label="Switch to ' + meta.label + ' beam shape">' +
          '<div class="photo-compare-card-img"><img src="' + src + '" alt="' + s.model + ' \u00B7 ' + meta.label + ' beam shape" loading="lazy" /></div>' +
          '<div class="photo-compare-card-label">' +
            '<span class="photo-compare-card-type">' + meta.label + '</span>' +
            '<span class="photo-compare-card-code">' + ba + '</span>' +
          '</div>' +
          '<div class="photo-compare-card-stat">' + (d ? d.peak + ' cd \u00B7 ' + d.lumens + ' lm' : '\u2014') + '</div>' +
        '</button>';
    });
    compareGrid.innerHTML = html;
    // Wire compare cards
    compareGrid.querySelectorAll('.photo-compare-card').forEach(function(card) {
      card.addEventListener('click', function() {
        var ba = card.dataset.compareBa;
        // Update state + sync the BA tab selection above
        state.nw2.ba = ba;
        nw2BaTabs.forEach(function(t) {
          var on = (t.dataset.nw2Ba === ba);
          t.classList.toggle('active', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        renderNw2();
      });
    });
  }

  function render() {
    section.dataset.series = state.series;
    if (state.series === 'S3N') renderNw1();
    else                         renderNw2();
  }

  /* ============== Wire tabs ============== */
  function wireTabGroup(tabs, onPick) {
    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-selected','false'); });
        t.classList.add('active');
        t.setAttribute('aria-selected','true');
        onPick(t);
      });
    });
  }

  wireTabGroup(seriesTabs, function(t) {
    state.series = t.dataset.series;
    render();
  });
  wireTabGroup(nw1SizeTabs, function(t) { state.nw1.size = t.dataset.size; render(); });
  wireTabGroup(nw1CctTabs,  function(t) { state.nw1.cct  = t.dataset.cct;  render(); });
  wireTabGroup(nw2ModelTabs, function(t) { state.nw2.model = t.dataset.nw2Model; render(); });
  wireTabGroup(nw2BaTabs,    function(t) { state.nw2.ba    = t.dataset.nw2Ba;    render(); });
  wireTabGroup(nw2LvTabs,    function(t) { state.nw2.lv    = t.dataset.nw2Lv;    render(); });
  wireTabGroup(nw2CctTabs,   function(t) { state.nw2.cct   = t.dataset.nw2Cct;   render(); });

  // Initial render
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', render);
  } else { render(); }
})();
</script>

