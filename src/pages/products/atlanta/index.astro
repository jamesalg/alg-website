    margin-top: 4px;
  }
  .photo-bug-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    color: white;
    background: rgba(243,39,64,0.25);
    border: 1px solid rgba(243,39,64,0.5);
    padding: 3px 8px;
    border-radius: 2px;
  }
  .photo-download {
