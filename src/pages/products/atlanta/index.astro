<script>
/* =============================================================================
   SECTION 9 \u2014 Atlanta Configurator engine
   2 user choices (Model class \u00B7 Finish) \u00B7 4 auto-locked (Series 3A1, CCT-prefix 3,
   Voltage U, Photocell /PS) \u00B7 2 field-set DIP (WATTSELECT, CCTSELECT) \u2014 informational only.
   SKU pattern: LWPA{model}-3A1-U{finish}/PS  (per datasheet ordering guide).
   Datasheet nominal output: 130 lm/W across every wattage and CCT setting.
   ============================================================================= */
(function() {
  // Lumen output by (model \u00B7 wattage) \u2014 datasheet nominal values
  // (per-CCT measured variance lives in Section 7 photometrics).
  var LUMEN = {
    '3W80':  { '40':  '5,200',  '60':  '7,800',  '80':  '10,400' },
    '3W120': { '80':  '10,400', '100': '13,000', '120': '15,600' }
  };
  var HID = {
    '3W80':  { '40':  '175W MH', '60':  '250W MH', '80':  '320W MH' },
    '3W120': { '80':  '320W MH', '100': '400W MH', '120': '450W MH' }
  };
  // Wattage settings per model class
  var WATTS = {
    '3W80':  ['40', '60', '80'],
    '3W120': ['80', '100', '120']
  };
  var CCT_LABEL  = { '30': '3000K', '40': '4000K', '50': '5000K' };
  var FINISH_LBL = {
    'D': 'Dark Bronze (QS)',
    'B': 'Black (QS)',
    'S': 'Silver (MTO)',
    'W': 'White (MTO)',
    'RAL': 'Custom RAL (MTO)'
  };

  // Default state \u2014 Atlanta opens with a complete working SKU
  // (LWPA3W80-3A1-UD/PS \u00B7 DIP-set 80W \u00B7 4000K \u2014 all factory defaults per datasheet)
  function defaultState() {
    return {
      model:    '3W80',
      finish:   'D',
      ralCode:  '',     // RAL Classic 4-digit code (only used when finish === 'RAL')
      watt:     '80',   // factory default for LWPA3W80
      cct:      '40'    // peak-efficacy CCT
    };
  }
  var state = defaultState();

  function buildSku(s) {
    // Finish segment handling \u2014 Custom RAL uses the user-typed 4-digit code.
    // If the user picks RAL but hasn't typed a code yet, emit "RAL????" as a
    // visible "still needs your input" placeholder rather than the broken
    // "RAL#" literal that was here before.
    var fin;
    if (s.finish === 'RAL') {
      fin = 'RAL' + (s.ralCode && /^[0-9]{4}$/.test(s.ralCode) ? s.ralCode : '????');
    } else {
      fin = s.finish;
    }
    return 'LWPA' + s.model + '-3A1-U' + fin + '/PS';
  }

  function renderWattChips() {
    var host = document.getElementById('cfgWattChips');
    if (!host) return;
    var watts = WATTS[state.model] || WATTS['3W80'];
    var defaultWatt = watts[watts.length - 1];  // factory default = max wattage
    var html = '';
    watts.forEach(function(w, idx) {
      var isDefault = (w === defaultWatt);
      var isSelected = (w === state.watt);
      html += '<button type="button" class="cfg-chip cfg-chip-toggle' + (isSelected ? ' selected' : '') + '" ' +
              'data-field="watt" data-val="' + w + '" data-code="' + w + 'W" aria-pressed="' + isSelected + '">' +
              '<span class="cfg-chip-val">' + w + 'W' + (isDefault ? ' \u2605' : '') + '</span>' +
              '<span class="cfg-chip-code">DIP-' + (idx + 1) + (isDefault ? ' \u2605' : '') + '</span>' +
              '</button>';
    });
    host.innerHTML = html;
    // Wire click handlers on the freshly rendered chips
    host.querySelectorAll('.cfg-chip').forEach(function(chip) {
      chip.addEventListener('click', function() {
        host.querySelectorAll('.cfg-chip').forEach(function(c) { c.classList.remove('selected'); c.setAttribute('aria-pressed','false'); });
        chip.classList.add('selected');
        chip.setAttribute('aria-pressed', 'true');
        state.watt = chip.dataset.val;
        render();
      });
    });
  }

  function render() {
    // Counter \u2014 all 6 fields always confirmed (every field has a default)
    document.getElementById('cfgCounterCount').textContent = '6';

    // SKU
    var sku = buildSku(state);
    document.getElementById('cfgSku').textContent = sku;

    // Tag (above preview image)
    var tag = document.getElementById('cfgPreviewTag');
    var fLabel = FINISH_LBL[state.finish] ? FINISH_LBL[state.finish].split(' (')[0].toUpperCase() : 'DARK BRONZE';
    tag.textContent = 'LWPA' + state.model + ' \u00B7 ' + fLabel;

    // Spec grid
    document.getElementById('cfgSpecModel').textContent  = 'LWPA' + state.model;
    var finishDisplay = FINISH_LBL[state.finish] || FINISH_LBL['D'];
    if (state.finish === 'RAL' && state.ralCode && /^[0-9]{4}$/.test(state.ralCode)) {
      finishDisplay = 'Custom RAL ' + state.ralCode + ' (MTO)';
    }
    document.getElementById('cfgSpecFinish').textContent = finishDisplay;
    document.getElementById('cfgSpecWatt').textContent   = state.watt + 'W';
    document.getElementById('cfgSpecCct').textContent    = CCT_LABEL[state.cct] || '4000K';

    // Show/hide RAL input wrap based on finish selection
    var ralWrap = document.getElementById('cfgRalInputWrap');
    if (ralWrap) ralWrap.style.display = (state.finish === 'RAL') ? 'block' : 'none';

    // Output (lumens \u00B7 efficacy \u00B7 always 130 lm/W per datasheet nominal)
    var lm = (LUMEN[state.model] && LUMEN[state.model][state.watt]) || '\u2014';
    document.getElementById('cfgSpecLumens').textContent = lm + ' lm \u00B7 130 lm/W';

    // Update CCT chip codes \u2014 show the lumen value at the active model+wattage for each CCT
    // (since datasheet nominal is flat 130 lm/W across all CCTs, the lumen value is the
    // same for all 3 CCT toggles \u2014 reinforces the WATTSELECT-as-primary-driver story)
    ['30','40','50'].forEach(function(cct) {
      var note = document.getElementById('cfgCctNote' + cct);
      if (note) note.textContent = lm + ' lm @ LWPA' + state.model + ' \u00B7 ' + state.watt + 'W';
    });

    // Re-render WATT chips when model changes
    renderWattChips();

    // Submittal CTA \u2014 pass full state as query params
    var sub = document.getElementById('cfgCtaSubmittal');
    if (sub) {
      sub.href = 'submittal_template.html?product=atlanta&sku=' + encodeURIComponent(sku) +
                 '&model=' + state.model +
                 '&wattage=' + state.watt +
                 '&cct=' + state.cct +
                 '&voltage=U' +
                 '&finish=' + state.finish;
    }

    // Reset SKU copy state
    var copyLabel = document.getElementById('cfgSkuCopyLabel');
    var copyBtn   = document.getElementById('cfgSkuCopy');
    if (copyLabel) copyLabel.textContent = 'Copy SKU';
    if (copyBtn)   copyBtn.classList.remove('copied');
  }

  function init() {
    // Wire chips for non-watt fields (model, finish, cct, locked chips)
    var chips = document.querySelectorAll('#configurator .cfg-chip:not([data-field="watt"])');
    chips.forEach(function(chip) {
      if (chip.classList.contains('locked')) return;
      chip.addEventListener('click', function() {
        var f = chip.dataset.field;
        var v = chip.dataset.val;
        var siblings = document.querySelectorAll('#configurator .cfg-chip[data-field="' + f + '"]');
        siblings.forEach(function(s) {
          s.classList.remove('selected');
          s.setAttribute('aria-pressed', 'false');
        });
        chip.classList.add('selected');
        chip.setAttribute('aria-pressed', 'true');
        state[f] = v;
        // Model swap resets watt to model's max default
        if (f === 'model') {
          state.watt = WATTS[v][WATTS[v].length - 1];
        }
        render();
      });
    });

    // RAL Classic 4-digit input \u2014 typing updates the SKU live
    var ralInput = document.getElementById('cfgRalInput');
    if (ralInput) {
      ralInput.addEventListener('input', function() {
        // Strip non-digits, cap at 4 chars
        var digits = (ralInput.value || '').replace(/[^0-9]/g, '').substring(0, 4);
        if (digits !== ralInput.value) ralInput.value = digits;
        state.ralCode = digits;
        render();
      });
    }

    // Reset
    var resetBtn = document.getElementById('cfgReset');
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        state = defaultState();
        var defaults = { model: '3W80', finish: 'D', cct: '40' };
        Object.keys(defaults).forEach(function(f) {
          document.querySelectorAll('#configurator .cfg-chip[data-field="' + f + '"]').forEach(function(c) {
            var match = c.dataset.val === defaults[f];
            c.classList.toggle('selected', match);
            c.setAttribute('aria-pressed', match ? 'true' : 'false');
          });
        });
        if (ralInput) ralInput.value = '';
        render();
      });
    }

    // Copy SKU
    var copyBtn = document.getElementById('cfgSkuCopy');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        var sku = buildSku(state);
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(sku).then(function() {
            document.getElementById('cfgSkuCopyLabel').textContent = 'Copied!';
            copyBtn.classList.add('copied');
            setTimeout(function() {
              document.getElementById('cfgSkuCopyLabel').textContent = 'Copy SKU';
              copyBtn.classList.remove('copied');
            }, 1800);
          });
        }
      });
    }

    render();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

