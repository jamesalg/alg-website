<script>
/* =============================================================================
   SECTION 7 \u2014 Atlanta Photometrics: 3 wattages \u00D7 3 CCTs = 9 LM-79 measured
   stat tuples. Polar SVG swaps per (wattage \u00D7 CCT). Stat panel updates per
   the same key. All numbers extracted from the in-image text labels in the
   staged IES SVGs (lumens \u00B7 efficacy \u00B7 actual draw \u00B7 peak cd).
   ============================================================================= */
(function() {
  // PHOTO[wattage][cct] returns { svg, peak, lumens, lpw, draw, file }
  // cct keys: '30' = 3000K \u00B7 '40' = 4000K \u00B7 '50' = 5000K
  var PHOTO = {
    '40': {
      '30': { svg: '../../luxoARCH_PolarPlots/Atlanta-I/LWPA40_3000K.svg', peak: '4,232 cd', lumens: '5,873 lm', lpw: '131 lm/W', draw: '44.7W (LM-79)', file: 'LWPA40_3000K.ies' },
      '40': { svg: '../../luxoARCH_PolarPlots/Atlanta-I/LWPA40_4000K.svg', peak: '3,257 cd', lumens: '6,200 lm', lpw: '<strong>142 lm/W</strong>', draw: '43.5W (LM-79)', file: 'LWPA40_4000K.ies' },
      '50': { svg: '../../luxoARCH_PolarPlots/Atlanta-I/LWPA40_5000K.svg', peak: '2,919 cd', lumens: '6,119 lm', lpw: '137 lm/W', draw: '44.6W (LM-79)', file: 'LWPA40_5000K.ies' }
    },
    '60': {
      '30': { svg: '../../luxoARCH_PolarPlots/Atlanta-I/LWPA60_3000K.svg', peak: '5,703 cd', lumens: '7,910 lm', lpw: '126 lm/W', draw: '62.7W (LM-79)', file: 'LWPA60_3000K.ies' },
      '40': { svg: '../../luxoARCH_PolarPlots/Atlanta-I/LWPA60_4000K.svg', peak: '4,460 cd', lumens: '8,482 lm', lpw: '<strong>140 lm/W</strong>', draw: '60.7W (LM-79)', file: 'LWPA60_4000K.ies' },
      '50': { svg: '../../luxoARCH_PolarPlots/Atlanta-I/LWPA60_5000K.svg', peak: '3,944 cd', lumens: '8,243 lm', lpw: '132 lm/W', draw: '62.4W (LM-79)', file: 'LWPA60_5000K.ies' }
    },
    '80': {
      '30': { svg: '../../luxoARCH_PolarPlots/Atlanta-I/LWPA80_3000K.svg', peak: '7,083 cd', lumens: '9,822 lm', lpw: '119 lm/W', draw: '82.3W (LM-79)', file: 'LWPA80_3000K.ies' },
      '40': { svg: '../../luxoARCH_PolarPlots/Atlanta-I/LWPA80_4000K.svg', peak: '5,678 cd', lumens: '10,779 lm', lpw: '<strong>136 lm/W</strong>', draw: '79.3W (LM-79)', file: 'LWPA80_4000K.ies' },
      '50': { svg: '../../luxoARCH_PolarPlots/Atlanta-I/LWPA80_5000K.svg', peak: '4,980 cd', lumens: '10,400 lm', lpw: '127 lm/W', draw: '82.2W (LM-79)', file: 'LWPA80_5000K.ies' }
    }
  };

  function init() {
    var img         = document.getElementById('photoImg');
    var statPeak    = document.getElementById('photoStatPeak');
    var statPeakSub = document.getElementById('photoStatPeakSub');
    var statLum     = document.getElementById('photoStatLumens');
    var statLpw     = document.getElementById('photoStatLpw');
    var statDraw    = document.getElementById('photoStatDraw');
    var statFile    = document.getElementById('photoStatFile');
    if (!img) return;

    var wattTabs = document.querySelectorAll('.spec-watt-tab[data-photo-watt]');
    var cctTabs  = document.querySelectorAll('.photo-tab[data-cct]');
    var state    = { watt: '80', cct: '40' };

    function render() {
      var p = PHOTO[state.watt];
      if (!p) return;
      var d = p[state.cct];
      if (!d) return;
      img.src = d.svg;
      img.alt = 'Atlanta LWPA' + state.watt + ' \u00B7 ' + state.watt + 'W setting \u00B7 ' + state.cct + '00K \u00B7 controlled forward-throw semi-cutoff with dark\u24B6RCH dark-sky design';
      statPeak.textContent = d.peak;
      if (statPeakSub) statPeakSub.textContent = 'forward throw at ' + state.watt + 'W \u00B7 ' + state.cct + '00K';
      statLum.textContent  = d.lumens;
      statLpw.innerHTML    = d.lpw;
      statDraw.textContent = d.draw;
      statFile.textContent = d.file;
    }

    wattTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        wattTabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        state.watt = t.dataset.photoWatt;
        render();
      });
    });

    cctTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        cctTabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
          x.style.background = 'transparent';
          x.style.color      = 'var(--text-secondary)';
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        t.style.background = 'var(--brand-red)';
        t.style.color      = 'white';
        state.cct = t.dataset.cct;
        render();
      });
    });

    render();
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

