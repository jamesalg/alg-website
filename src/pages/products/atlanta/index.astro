  .acc-modal-img img {
    max-width: 90%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 12px 24px rgba(0,0,0,0.6));
  }
  .acc-modal-img-cat {
    position: absolute;
    top: 16px;
    left: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-red);
    background: rgba(243,39,64,0.10);
    border: 1px solid rgba(243,39,64,0.35);
    padding: 4px 10px;
    border-radius: 2px;
  }
  .acc-modal-body {
    padding: 32px 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .acc-modal-title { font-size: 22px; font-weight: 700; line-height: 1.2; color: var(--text-primary); margin: 0; }
  .acc-modal-sku {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }
  .acc-modal-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .acc-modal-specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .acc-spec-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
  }
  .acc-spec-row:nth-last-child(-n+2) { border-bottom: none; }
  .acc-spec-row:nth-child(odd) { padding-right: 18px; }
  .acc-spec-row:nth-child(even) { padding-left: 18px; border-left: 1px solid var(--line); }
  .acc-spec-key {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .acc-spec-val {
    font-size: 13.5px;
    color: var(--text-primary);
    font-weight: 600;
    line-height: 1.4;
  }
  .acc-modal-ctas { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 4px; }
  .acc-modal-cta {
    flex: 1;
    min-width: 170px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 13px 18px;
    border-radius: 2px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.18s;
    border: 1px solid transparent;
    white-space: nowrap;
    text-decoration: none;
  }
  .acc-modal-cta.primary { background: var(--brand-red); color: white; }
  .acc-modal-cta.primary:hover { background: var(--brand-red-deep); }
  .acc-modal-cta.outline {
    background: transparent;
    color: var(--text-secondary);
    border-color: var(--line-medium);
  }
  .acc-modal-cta.outline:hover { color: var(--text-primary); border-color: var(--text-primary); }
  .acc-modal-cta svg { width: 14px; height: 14px; }
  .acc-modal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 38px;
    height: 38px;
    background: rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.15);
    color: white;
    border-radius: 2px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: all 0.18s;
  }
  .acc-modal-close:hover { background: var(--brand-red); border-color: var(--brand-red); }
  .acc-modal-close svg { width: 16px; height: 16px; }
  @media (max-width: 1100px) {
    .acc-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .acc-grid { grid-template-columns: 1fr; }
    .acc-modal-grid { grid-template-columns: 1fr; }
    .acc-modal-img { min-height: 220px; border-right: none; border-bottom: 1px solid var(--line); }
    .acc-modal-specs { grid-template-columns: 1fr; }
    .acc-spec-row:nth-child(odd) { padding-right: 0; }
    .acc-spec-row:nth-child(even) { padding-left: 0; border-left: none; }
    .acc-spec-row { border-bottom: 1px solid var(--line); }
    .acc-spec-row:last-child { border-bottom: none; }
    .acc-title { font-size: 28px; }
  }

  /* ============================================================================
     SECTION 7 — Photometrics (polar plots derived from Guardian IES files)
     ============================================================================ */
  .photo-section {
    background: var(--bg-page);
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .photo-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .photo-head { text-align: center; margin-bottom: 48px; }
  .photo-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .photo-eyebrow::before, .photo-eyebrow::after {
    content: ""; display: block; width: 28px; height: 1px; background: var(--brand-red);
  }
  .photo-title {
    font-size: 38px;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin-bottom: 12px;
    line-height: 1.05;
  }
  .photo-sub {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 720px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .photo-controls {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .photo-control-group { display: flex; flex-direction: column; align-items: center; gap: 10px; }
  .photo-control-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--text-muted);
    text-transform: uppercase;
  }
  .photo-control-tabs { display: flex; gap: 6px; }
  .photo-tab {
    background: transparent;
    border: 1px solid var(--line-medium);
    color: var(--text-secondary);
    padding: 9px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.18s;
    min-width: 80px;
    font-weight: 700;
  }
  .photo-tab:hover { color: var(--text-primary); border-color: var(--text-primary); }
  .photo-tab.active {
    background: var(--brand-red);
    border-color: var(--brand-red);
    color: white;
  }
  .photo-display {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .photo-plot {
    background: #14171b;
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 16px;
    overflow: hidden;
    max-width: 640px;
    margin: 0 auto;
  }
  .photo-plot img { width: 100%; height: auto; display: block; }
  .photo-stats {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .photo-stat-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .photo-stat {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 18px 20px;
  }
  .photo-stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    letter-spacing: 0.14em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .photo-stat-value {
    font-size: 24px;
    font-weight: 700;
    line-height: 1;
  }
  .photo-stat-sub {
    font-size: 12px;
    color: var(--text-secondary);
