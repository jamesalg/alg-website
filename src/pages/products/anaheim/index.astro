<script>
/* =============================================================================
   SECTION 9 \u2014 Anaheim Configurator engine
   6 user-pickable fields \u00B7 all default-selected at page load.
   Conditional enabling: S3N on LWPA40/80 only \u00B7 HV on LWPA40/67/80 only.
   SKU pattern: LWPA{watt}{-S3N|}-{cct|}{voltage}{finish}{/PA|}
   ============================================================================= */
(function() {
  // Lumen + HID-replacement lookup by (wattage \u00D7 CCT) \u2014 matches Section 3 + 7
  var DATA = {
    '12': { hid: '100W MH',           '40': { lm: '1,560',  lpw: '130' }, '50': { lm: '1,545',  lpw: '129' } },
    '27': { hid: '100W MH (high-out)', '40': { lm: '3,600',  lpw: '133' }, '50': { lm: '3,565',  lpw: '132' } },
    '40': { hid: '175W MH',           '40': { lm: '5,200',  lpw: '130' }, '50': { lm: '5,150',  lpw: '129' } },
    '67': { hid: '250W MH',           '40': { lm: '8,800',  lpw: '131' }, '50': { lm: '8,712',  lpw: '130' } },
    '80': { hid: '320W MH',           '40': { lm: '10,500', lpw: '131' }, '50': { lm: '10,395', lpw: '130' } }
  };

  // Conditional availability rules \u2014 which wattages support S3N / HV
  var ALLOWS_S3N = { '40': true, '80': true };
  var ALLOWS_HV  = { '40': true, '67': true, '80': true };

  // Display labels
  var FINISH_LABEL  = { 'B': 'Black (MTO)', 'D': 'Dark Bronze (QS)', 'W': 'White (MTO)' };
  var VOLTAGE_LABEL = { 'U': 'UNV \u00B7 120-277V', 'H': 'HV \u00B7 347-480V' };
  var CCT_LABEL     = { '40': '4000K', '50': '5000K' };

  // Default state \u2014 Anaheim opens with a complete working SKU (LWPA40-40UD)
  var defaultState = function() {
    return {
      wattage:   '40',
      series:    'S3',
      cct:       '40',
      voltage:   'U',
      finish:    'D',
      photocell: 'none'
    };
  };
  var state = defaultState();

  function buildSku(s) {
    var sku = 'LWPA' + s.wattage;
    if (s.series === 'S3N') sku += '-S3N';
    sku += '-';
    if (s.series === 'S3') sku += s.cct;       // CCT only when discrete-W
    sku += s.voltage + s.finish;
    if (s.photocell === 'PA') sku += '/PA';
    return sku;
  }

  function applyConditionals() {
    // If S3N selected on a non-eligible wattage \u2192 fall back to S3
    if (state.series === 'S3N' && !ALLOWS_S3N[state.wattage]) {
      state.series = 'S3';
      var s3Chip = document.querySelector('#configurator .cfg-chip[data-field="series"][data-val="S3"]');
      var s3nChip = document.querySelector('#configurator .cfg-chip[data-field="series"][data-val="S3N"]');
      if (s3Chip)  { s3Chip.classList.add('selected');     s3Chip.setAttribute('aria-pressed', 'true'); }
      if (s3nChip) { s3nChip.classList.remove('selected'); s3nChip.setAttribute('aria-pressed', 'false'); }
    }
    // If HV selected on a non-eligible wattage \u2192 fall back to UNV
    if (state.voltage === 'H' && !ALLOWS_HV[state.wattage]) {
      state.voltage = 'U';
      var uChip = document.querySelector('#configurator .cfg-chip[data-field="voltage"][data-val="U"]');
      var hChip = document.querySelector('#configurator .cfg-chip[data-field="voltage"][data-val="H"]');
      if (uChip) { uChip.classList.add('selected');   uChip.setAttribute('aria-pressed', 'true'); }
      if (hChip) { hChip.classList.remove('selected'); hChip.setAttribute('aria-pressed', 'false'); }
    }
    // Visually disable conditional chips when wattage doesn't support them
    var s3nChip = document.querySelector('#configurator .cfg-chip[data-field="series"][data-val="S3N"]');
    if (s3nChip) {
      var s3nOk = !!ALLOWS_S3N[state.wattage];
      s3nChip.classList.toggle('disabled', !s3nOk);
      s3nChip.style.opacity = s3nOk ? '' : '0.35';
      s3nChip.style.pointerEvents = s3nOk ? '' : 'none';
    }
    var hChip = document.querySelector('#configurator .cfg-chip[data-field="voltage"][data-val="H"]');
    if (hChip) {
      var hOk = !!ALLOWS_HV[state.wattage];
      hChip.classList.toggle('disabled', !hOk);
      hChip.style.opacity = hOk ? '' : '0.35';
      hChip.style.pointerEvents = hOk ? '' : 'none';
    }
  }

  function render() {
    applyConditionals();

    // Counter \u2014 all 6 fields always confirmed (every field has a default)
    document.getElementById('cfgCounterCount').textContent = '6';
    document.getElementById('cfgCounter').classList.add('complete');

    // SKU
    var sku = buildSku(state);
    document.getElementById('cfgSku').textContent = sku;

    // Tag (above preview image)
    var tag = document.getElementById('cfgPreviewTag');
    var fLabel = state.finish === 'D' ? 'DARK BRONZE' : (state.finish === 'B' ? 'BLACK' : 'WHITE');
    tag.textContent = 'LWPA' + state.wattage + ' \u00B7 ' + fLabel;

    // Spec grid
    document.getElementById('cfgSpecWattage').textContent = 'LWPA' + state.wattage + ' \u00B7 ' + state.wattage + 'W';
    document.getElementById('cfgSpecSeries').textContent =
      state.series === 'S3' ? 'S3 \u00B7 discrete-W' : 'S3N \u00B7 multi-W field-set';
    document.getElementById('cfgSpecCct').textContent =
      state.series === 'S3'
        ? CCT_LABEL[state.cct] + ' (in SKU)'
        : '3-CCTselect (DIP at install)';
    document.getElementById('cfgSpecVoltage').textContent = VOLTAGE_LABEL[state.voltage];
    document.getElementById('cfgSpecFinish').textContent = FINISH_LABEL[state.finish];
    document.getElementById('cfgSpecPhotocell').textContent =
      state.photocell === 'PA' ? '/PA \u00B7 button photocell' : '\u2014 none \u2014';

    // Output (lumens + efficacy) \u2014 always pulled from CCT 40 if S3N (since 4000K is the peak efficacy and DIP-default)
    var cctForLookup = state.series === 'S3' ? state.cct : '40';
    var d = DATA[state.wattage][cctForLookup];
    document.getElementById('cfgSpecLumens').textContent = d.lm + ' lm \u00B7 ' + d.lpw + ' lm/W';
    document.getElementById('cfgSpecHid').textContent = DATA[state.wattage].hid;

    // Image alt update
    var imgEl = document.getElementById('cfgPreviewImg');
    if (imgEl) imgEl.alt = 'Anaheim LWPA' + state.wattage + ' \u2014 ' + fLabel.toLowerCase() + ' finish preview';

    // Submittal CTA \u2014 pass full state as query params
    var sub = document.getElementById('cfgCtaSubmittal');
    if (sub) {
      sub.href = 'submittal_template.html?product=anaheim&sku=' + encodeURIComponent(sku) +
                 '&wattage=' + state.wattage +
                 '&series=' + state.series +
                 '&cct=' + state.cct +
                 '&voltage=' + state.voltage +
                 '&finish=' + state.finish +
                 '&photocell=' + (state.photocell === 'PA' ? 'PA' : 'none');
    }

    // Reset SKU copy state
    var copyLabel = document.getElementById('cfgSkuCopyLabel');
    var copyBtn   = document.getElementById('cfgSkuCopy');
    if (copyLabel) copyLabel.textContent = 'Copy SKU';
    if (copyBtn)   copyBtn.classList.remove('copied');
  }

  function init() {
    var chips = document.querySelectorAll('#configurator .cfg-chip');
    chips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        if (chip.classList.contains('disabled')) return;
        var f = chip.dataset.field;
        var v = chip.dataset.val;
        var siblings = document.querySelectorAll('#configurator .cfg-chip[data-field="' + f + '"]');
        siblings.forEach(function(s) {
          s.classList.remove('selected');
          s.setAttribute('aria-pressed', 'false');
        });
        chip.classList.add('selected');
        chip.setAttribute('aria-pressed', 'true');
        state[f] = v;
        render();
      });
    });

    // Reset
    var resetBtn = document.getElementById('cfgReset');
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        state = defaultState();
        // Reset chip selections to defaults
        var defaults = { wattage: '40', series: 'S3', cct: '40', voltage: 'U', finish: 'D', photocell: 'none' };
        Object.keys(defaults).forEach(function(f) {
          document.querySelectorAll('#configurator .cfg-chip[data-field="' + f + '"]').forEach(function(c) {
            var match = c.dataset.val === defaults[f];
            c.classList.toggle('selected', match);
            c.setAttribute('aria-pressed', match ? 'true' : 'false');
          });
        });
        render();
      });
    }

    // Copy SKU
    var copyBtn = document.getElementById('cfgSkuCopy');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        var sku = buildSku(state);
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(sku).then(function() {
            document.getElementById('cfgSkuCopyLabel').textContent = 'Copied!';
            copyBtn.classList.add('copied');
            setTimeout(function() {
              document.getElementById('cfgSkuCopyLabel').textContent = 'Copy SKU';
              copyBtn.classList.remove('copied');
            }, 1800);
          });
        }
      });
    }

    render();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

