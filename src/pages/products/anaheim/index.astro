  };
  var LINK_LABEL = {
    'dimming':   'Discover 1-10V dimming \u2192',
    'photocell': 'Configure /PA photocell \u2192'
  };

  function init() {
    var tabs = document.querySelectorAll('#controls .tac-callout-tab');
