        ['Gasket', 'IP65 wet-location \u00B7 neoprene \u00B7 drives rain off perimeter installs'],
        ['Material', 'Cast aluminum \u00B7 matches housing finish'],
        ['Service', 'Removable for re-lamp or wiring service \u00B7 single-screw release']
      ]
    }
  };

  function init() {
    var grid     = document.getElementById('accGrid');
    var modal    = document.getElementById('accModal');
    var closeBtn = document.getElementById('accModalClose');
    var imgWrap  = document.getElementById('accModalImg');
    var catEl    = document.getElementById('accModalCat');
    var titleEl  = document.getElementById('accModalTitle');
    var skuEl    = document.getElementById('accModalSku');
    var descEl   = document.getElementById('accModalDesc');
    var specsEl  = document.getElementById('accModalSpecs');
    if (!grid || !modal) return;
    var cards = grid.querySelectorAll('.acc-card');

    function openModal(card) {
      var id = card.dataset.id;
      var d  = ACC[id];
      if (!d) { console.warn('acc-modal: no data for id', id); return; }
      catEl.textContent   = d.cat.replace(/\u24B6/g, '');
      titleEl.textContent = d.title;
      skuEl.innerHTML     = d.sku + (d.model && d.model !== d.sku ? '<div style="font-size:11px;color:var(--text-muted);font-weight:400;margin-top:2px;">' + d.model + '</div>' : '');
      descEl.textContent  = d.desc;
      if (d.cat.indexOf('\u24B6') >= 0) {
        catEl.innerHTML = d.cat.replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
      }
      specsEl.innerHTML = d.specs.map(function(s) {
        var v = (s[1] || '').toString().replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
        return '<div class="acc-spec-row">' +
                 '<div class="acc-spec-key">' + s[0] + '</div>' +
                 '<div class="acc-spec-val">' + v + '</div>' +
               '</div>';
      }).join('');
      // Clone the card visual into the modal hero panel
      var srcMedia = card.querySelector('.acc-card-img svg, .acc-card-img img.acc-card-photo');
      Array.from(imgWrap.querySelectorAll('svg, img.acc-card-photo')).forEach(function(s){ s.remove(); });
      if (srcMedia) {
        var clone = srcMedia.cloneNode(true);
        if (clone.tagName === 'IMG') {
          clone.style.maxWidth = '90%';
          clone.style.maxHeight = '90%';
          clone.style.objectFit = 'contain';
          clone.style.filter = 'drop-shadow(0 12px 24px rgba(0,0,0,0.6))';
        }
        imgWrap.appendChild(clone);
      }
      modal.classList.add('open');
    }
    function closeModal() { modal.classList.remove('open'); }

    cards.forEach(function(c) {
      c.addEventListener('click', function() { openModal(c); });
    });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

<!-- ============================================================================
     SECTION 9 — Configurator (Build Your Anaheim · live SKU builder)
     -------------------------------------------------------------------------
     Anaheim is a 6-FIELD configurator — more complex than Wedge (2 fields)
     because Anaheim ships in 5 wattages with conditional series + voltage
     options. All 6 fields have sensible defaults so the user lands on a
     valid SKU; they tweak from there.

     User-pickable fields (defaults shown; ★ = pre-selected at page load):
       1. Wattage  — 12 / 27 / 40 ★ / 67 / 80W (the bid driver)
       2. Series   — S3 ★ (discrete-W) | S3N (multi-W field-set, LWPA40 & LWPA80 only)
       3. CCT      — 4000K ★ | 5000K (NOT 3000K — datasheet specs only these two)
       4. Voltage  — UNV ★ (120-277V) | HV (347-480V, LWPA40/67/80 only)
       5. Finish   — Black | Dark Bronze ★ | White (per brief: DB is default)
       6. Photocell — none ★ | /PA (optional cost-add per Section 6 framing)

     Conditional rules (enforced in JS):
       · S3N is enabled only when Wattage = 40 or 80 (per brief: only LWPA40-S3N
         and LWPA80-S3N exist as multi-watt variants).
       · HV is enabled only when Wattage >= 40 (per brief: 120-277V universal
         only at LWPA12/27; 347-480V option appears at LWPA40+).
       · When Wattage falls back to 12 or 27, S3N + HV auto-revert to S3 + UNV.
       · S3N variants ship with 3-CCTselect (DIP) — when Series = S3N, the CCT
         field's behavior shifts (the CCT segment is omitted from the SKU
         since CCT is field-set, not baked).

     SKU pattern: LWPA{watt}{-S3N|}-{cct|}{voltage}{finish}{/PA|}
       · LWPA40-40UD            → 40W, S3, 4000K, UNV, Dark Bronze
       · LWPA40-S3N-UD          → 40W S3N (CCT field-set), UNV, Dark Bronze
       · LWPA80-S3N-HB/PA       → 80W S3N (CCT field-set), HV, Black, /PA photocell
       · LWPA67-50HW            → 67W, S3, 5000K, HV, White

     Counter: "X of 6 fields confirmed." Default state = 6 of 6 (every field
     pre-selected). User clicks to change. Photocell at "none" still counts
     as confirmed (not picking it IS a decision).

     Finish-aware preview: only Dark Bronze hero photo is staged. v1 displays
     anaheim-hero-1.webp regardless of finish picked, with a code comment
     flagging Black + White renders as Rooster deliverable.

     Live preview swaps: SKU readout, spec grid (lumens by wattage × CCT),
     finish-swatch tag, ship-status (QS / MTO).
     ============================================================================ -->
