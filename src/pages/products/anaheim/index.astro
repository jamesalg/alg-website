<script>
/* =============================================================================
   SECTION 7 \u2014 Photometrics: 4 wattages \u00D7 2 CCTs = 8 stat tuples.
   Polar SVG swaps per wattage (each LWPA SKU has its own beam-shape file).
   Stat panel updates per (wattage \u00D7 CCT) \u2014 peak cd, lumens, efficacy, IES
   filename. CCT controls only the numeric panel; the SVG itself is CCT-
   invariant per the engineering disclosure baked in the section copy.

   Data sources:
     \u00B7 Lumens, efficacy: anaheim_competitive_brief.md product profile
       (LWPA datasheet, Feb 2021 rev \u2014 4000K and 5000K nominals)
     \u00B7 Peak cd at 3000K: extracted from each staged SVG title/PEAK label
       (LWPA27\u21921,463 \u00B7 LWPA40\u21922,110 \u00B7 LWPA67\u21923,707 \u00B7 LWPA80\u21924,619 cd)
     \u00B7 Peak cd at 4000K/5000K: scaled by per-SKU cd/lm ratio measured on
       the 3000K test data. Ratios: 27\u21920.416 \u00B7 40\u21920.419 \u00B7 67\u21920.429 \u00B7 80\u21920.460
   ============================================================================= */
(function() {
  // PHOTO[wattage][cct] returns the stat tuple to render
  // cct keys: '40' = 4000K \u00B7 '50' = 5000K
  var PHOTO = {
    '27': {
      svg: '../../luxoARCH_PolarPlots/Anaheim-I/LWPA27_3000K.svg',
      '40': { peak: '1,497 cd', lumens: '3,600 lm', lpw: '133 lm/W',  file: 'LWPA27_3000K.ies (Gen-1 \u00B7 scaled to 4000K)' },
      '50': { peak: '1,482 cd', lumens: '3,565 lm', lpw: '132 lm/W',  file: 'LWPA27_3000K.ies (Gen-1 \u00B7 scaled to 5000K)' }
    },
    '40': {
      svg: '../../luxoARCH_PolarPlots/Anaheim-I/LWPA40_3000K.svg',
      '40': { peak: '2,180 cd', lumens: '5,200 lm', lpw: '130 lm/W',  file: 'LWPA40_3000K.ies (Gen-1 \u00B7 scaled to 4000K)' },
      '50': { peak: '2,159 cd', lumens: '5,150 lm', lpw: '129 lm/W',  file: 'LWPA40_3000K.ies (Gen-1 \u00B7 scaled to 5000K)' }
    },
    '67': {
      svg: '../../luxoARCH_PolarPlots/Anaheim-I/LWPA67_3000K.svg',
      '40': { peak: '3,773 cd', lumens: '8,800 lm', lpw: '131 lm/W',  file: 'LWPA67_3000K.ies (Gen-1 \u00B7 scaled to 4000K)' },
      '50': { peak: '3,735 cd', lumens: '8,712 lm', lpw: '130 lm/W',  file: 'LWPA67_3000K.ies (Gen-1 \u00B7 scaled to 5000K)' }
    },
    '80': {
      svg: '../../luxoARCH_PolarPlots/Anaheim-I/LWPA80_3000K.svg',
      '40': { peak: '4,833 cd', lumens: '10,500 lm', lpw: '131 lm/W', file: 'LWPA80_3000K.ies (Gen-1 \u00B7 scaled to 4000K)' },
      '50': { peak: '4,785 cd', lumens: '10,395 lm', lpw: '130 lm/W', file: 'LWPA80_3000K.ies (Gen-1 \u00B7 scaled to 5000K)' }
    }
  };

  function init() {
    var img         = document.getElementById('photoImg');
    var statPeak    = document.getElementById('photoStatPeak');
    var statPeakSub = document.getElementById('photoStatPeakSub');
    var statLum     = document.getElementById('photoStatLumens');
    var statLpw     = document.getElementById('photoStatLpw');
    var statFile    = document.getElementById('photoStatFile');
    if (!img) return;

    var wattTabs = document.querySelectorAll('.spec-watt-tab[data-photo-watt]');
    var cctTabs  = document.querySelectorAll('.photo-tab[data-cct]');
    var state    = { watt: '40', cct: '40' };

    function render() {
      var p = PHOTO[state.watt];
      if (!p) return;
      var d = p[state.cct];
      if (!d) return;
      img.src = p.svg;
      img.alt = 'Anaheim LWPA' + state.watt + ' luminous intensity distribution \u00B7 semi-cutoff beam \u00B7 cd/klm scale \u00B7 C0\u2013C180 vs C90\u2013C270 traces';
      statPeak.textContent = d.peak;
      if (statPeakSub) statPeakSub.textContent = 'forward throw at ' + state.watt + 'W \u00B7 ' + state.cct + '00K';
      statLum.textContent  = d.lumens;
      statLpw.textContent  = d.lpw;
      statFile.textContent = d.file;
    }

    // Wattage tab handlers \u2014 swap the SVG and refresh the stat panel
    wattTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        wattTabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        state.watt = t.dataset.photoWatt;
        render();
      });
    });

    // CCT tab handlers \u2014 refresh stats only, SVG stays put (beam is CCT-invariant)
    cctTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        cctTabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
          x.style.background    = 'transparent';
          x.style.color         = 'var(--text-secondary)';
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        t.style.background = 'var(--brand-red)';
        t.style.color      = 'white';
        state.cct = t.dataset.cct;
        render();
      });
    });

    render();  // initial paint \u2014 defaults are LWPA40 + 4000K
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

