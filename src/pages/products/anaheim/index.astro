  }
  .acc-card:hover .acc-card-cta { color: var(--brand-red); gap: 10px; }

  /* Modal */
  .acc-modal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.78);
    z-index: 1100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 32px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .acc-modal.open { display: flex; }
  .acc-modal-panel {
    background: var(--bg-spec);
    border: 1px solid var(--line-medium);
    border-radius: 4px;
    width: 100%;
    max-width: 920px;
    max-height: 90vh;
    overflow: auto;
    position: relative;
  }
  .acc-modal-grid { display: grid; grid-template-columns: 0.85fr 1fr; gap: 0; }
  .acc-modal-img {
    background: var(--bg-darker);
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--line);
    min-height: 360px;
    max-height: 480px;
    padding: 28px;
    position: relative;
  }
  .acc-modal-img svg { width: 90%; height: 90%; max-width: 360px; color: rgba(255,255,255,0.78); }
  .acc-modal-img img {
    max-width: 90%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 12px 24px rgba(0,0,0,0.6));
  }
  .acc-modal-img-cat {
    position: absolute;
    top: 16px;
    left: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-red);
    background: rgba(243,39,64,0.10);
    border: 1px solid rgba(243,39,64,0.35);
    padding: 4px 10px;
    border-radius: 2px;
  }
  .acc-modal-body {
    padding: 32px 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .acc-modal-title { font-size: 22px; font-weight: 700; line-height: 1.2; color: var(--text-primary); margin: 0; }
  .acc-modal-sku {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }
  .acc-modal-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .acc-modal-specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .acc-spec-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
  }
  .acc-spec-row:nth-last-child(-n+2) { border-bottom: none; }
  .acc-spec-row:nth-child(odd) { padding-right: 18px; }
  .acc-spec-row:nth-child(even) { padding-left: 18px; border-left: 1px solid var(--line); }
  .acc-spec-key {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .acc-spec-val {
    font-size: 13.5px;
    color: var(--text-primary);
    font-weight: 600;
    line-height: 1.4;
  }
  .acc-modal-ctas { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 4px; }
  .acc-modal-cta {
    flex: 1;
    min-width: 170px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 13px 18px;
    border-radius: 2px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.18s;
    border: 1px solid transparent;
    white-space: nowrap;
    text-decoration: none;
  }
  .acc-modal-cta.primary { background: var(--brand-red); color: white; }
  .acc-modal-cta.primary:hover { background: var(--brand-red-deep); }
  .acc-modal-cta.outline {
    background: transparent;
    color: var(--text-secondary);
    border-color: var(--line-medium);
  }
  .acc-modal-cta.outline:hover { color: var(--text-primary); border-color: var(--text-primary); }
  .acc-modal-cta svg { width: 14px; height: 14px; }
  .acc-modal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 38px;
    height: 38px;
    background: rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.15);
    color: white;
    border-radius: 2px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: all 0.18s;
  }
  .acc-modal-close:hover { background: var(--brand-red); border-color: var(--brand-red); }
  .acc-modal-close svg { width: 16px; height: 16px; }
  @media (max-width: 1100px) {
    .acc-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .acc-grid { grid-template-columns: 1fr; }
    .acc-modal-grid { grid-template-columns: 1fr; }
    .acc-modal-img { min-height: 220px; border-right: none; border-bottom: 1px solid var(--line); }
    .acc-modal-specs { grid-template-columns: 1fr; }
    .acc-spec-row:nth-child(odd) { padding-right: 0; }
    .acc-spec-row:nth-child(even) { padding-left: 0; border-left: none; }
    .acc-spec-row { border-bottom: 1px solid var(--line); }
    .acc-spec-row:last-child { border-bottom: none; }
    .acc-title { font-size: 28px; }
  }

  /* ============================================================================
     SECTION 7 — Photometrics (polar plots derived from Guardian IES files)
     ============================================================================ */
  .photo-section {
    background: var(--bg-page);
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .photo-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .photo-head { text-align: center; margin-bottom: 48px; }
  .photo-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .photo-eyebrow::before, .photo-eyebrow::after {
    content: ""; display: block; width: 28px; height: 1px; background: var(--brand-red);
  }
  .photo-title {
    font-size: 38px;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin-bottom: 12px;
    line-height: 1.05;
  }
  .photo-sub {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 720px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .photo-controls {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .photo-control-group { display: flex; flex-direction: column; align-items: center; gap: 10px; }
  .photo-control-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--text-muted);
    text-transform: uppercase;
  }
  .photo-control-tabs { display: flex; gap: 6px; }
  .photo-tab {
    background: transparent;
    border: 1px solid var(--line-medium);
    color: var(--text-secondary);
    padding: 9px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.18s;
    min-width: 80px;
    font-weight: 700;
  }
  .photo-tab:hover { color: var(--text-primary); border-color: var(--text-primary); }
  .photo-tab.active {
    background: var(--brand-red);
    border-color: var(--brand-red);
    color: white;
  }
  .photo-display {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .photo-plot {
    background: #14171b;
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 16px;
    overflow: hidden;
    max-width: 640px;
    margin: 0 auto;
  }
  .photo-plot img { width: 100%; height: auto; display: block; }
  .photo-stats {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .photo-stat-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .photo-stat {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 18px 20px;
  }
  .photo-stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    letter-spacing: 0.14em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .photo-stat-value {
    font-size: 24px;
    font-weight: 700;
    line-height: 1;
  }
  .photo-stat-sub {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 4px;
  }
  .photo-bug {
    display: flex;
    gap: 8px;
    align-items: baseline;
    margin-top: 4px;
  }
  .photo-bug-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    color: white;
    background: rgba(243,39,64,0.25);
    border: 1px solid rgba(243,39,64,0.5);
    padding: 3px 8px;
    border-radius: 2px;
  }
  .photo-download {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--text-secondary);
    font-size: 13px;
    font-weight: 700;
    margin-top: 6px;
    transition: color 0.18s;
    text-decoration: none;
  }
  .photo-download:hover { color: var(--brand-red); }
  .photo-download svg { width: 14px; height: 14px; }
  @media (max-width: 1100px) {
    .photo-display { grid-template-columns: 1fr; }
    .photo-title { font-size: 28px; }
  }

  /* ============================================================================
     SECTION 6 — contrⒶLS · Multi-Functional / Bi-Level / Photocell
     Full-bleed dark backdrop with red dot mesh radiating from the centered
     control-panel image. Same pattern as Sentinel; Guardian-specific copy
     emphasizes the integrated dusk-to-dawn photocell + 0-10V dimming +
     sensor-ready terminals shipped on every fixture.
     ============================================================================ */
  .tac-section {
    position: relative;
    background: #0a0e14;
    overflow: hidden;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    min-height: 560px;
  }
  .tac-mesh-overlay {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1.2px 1.2px, rgba(243,39,64,0.78) 1.2px, transparent 1.6px);
    background-size: 14px 14px;
    -webkit-mask-image: radial-gradient(circle at 25% 50%,
      black 0%,
      rgba(0,0,0,0.95) 18%,
      rgba(0,0,0,0.72) 35%,
      rgba(0,0,0,0.42) 55%,
      rgba(0,0,0,0.18) 78%,
      rgba(0,0,0,0.05) 100%);
            mask-image: radial-gradient(circle at 25% 50%,
      black 0%,
      rgba(0,0,0,0.95) 18%,
      rgba(0,0,0,0.72) 35%,
      rgba(0,0,0,0.42) 55%,
      rgba(0,0,0,0.18) 78%,
      rgba(0,0,0,0.05) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .tac-shockwave {
    position: absolute;
    left: 25%;
    top: 50%;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 2px solid rgba(243, 39, 64, 0.85);
    transform: translate(-50%, -50%);
    pointer-events: none;
    opacity: 0;
    z-index: 1;
  }
  .tac-shockwave.is-rippling { animation: tac-shockwave 1.4s ease-out; }
  @keyframes tac-shockwave {
    0%   { width: 60px;   height: 60px;   opacity: 1; border-width: 3px; }
    60%  {                                opacity: 0.55; }
    100% { width: 1400px; height: 1400px; opacity: 0; border-width: 0.5px; }
  }
  .tac-sensor-area {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    pointer-events: none;
  }
  .tac-sensor-svg {
    position: absolute;
    width: 60%;
    max-width: 380px;
    height: auto;
    opacity: 0;
    transform: scale(0.94);
    transition: opacity 0.5s ease, transform 0.55s cubic-bezier(0.2, 0.6, 0.2, 1);
    filter: drop-shadow(0 16px 48px rgba(0,0,0,0.6));
  }
  .tac-sensor-svg.is-active {
    opacity: 0.96;
    transform: scale(1);
  }
  .tac-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 28%, rgba(10,14,20,0.4) 55%, rgba(10,14,20,0.7) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .tac-grid {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 88px 32px 96px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .tac-spacer { /* left half placeholder so backdrop sensor shows through */ }
  .tac-content { color: var(--text-primary); max-width: 580px; }
  .tac-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .tac-eyebrow::before {
    content: "";
    display: inline-block;
    width: 28px; height: 1px;
    background: var(--brand-red);
  }
  .tac-title {
    font-size: 38px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin-bottom: 18px;
    white-space: nowrap;
  }
  .tac-desc {
    font-size: 15.5px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 28px;
  }
  .tac-callout {
    border: 1px solid rgba(243,39,64,0.4);
    border-radius: 4px;
    background: rgba(20,23,27,0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    overflow: hidden;
  }
  .tac-callout-tabs { display: flex; background: rgba(0,0,0,0.25); }
  .tac-callout-tab {
    flex: 1;
    background: transparent;
    border: 0;
    padding: 13px 18px;
    font-family: inherit;
    font-size: 13px;
    font-weight: 700;
    color: var(--text-secondary);
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: background 0.18s, color 0.18s;
    border-right: 1px solid rgba(255,255,255,0.08);
    text-align: center;
  }
  .tac-callout-tab:last-child { border-right: 0; }
  .tac-callout-tab:hover { color: var(--text-primary); background: rgba(255,255,255,0.05); }
  .tac-callout-tab.active { background: var(--brand-red); color: white; }
  .tac-callout-body { padding: 22px 24px 22px; }
  .tac-callout-body p {
    font-size: 14px;
    color: var(--text-primary);
    line-height: 1.6;
    margin-bottom: 14px;
  }
  .tac-callout-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 13.5px;
    cursor: pointer;
    transition: color 0.18s;
    text-decoration: none;
  }
  .tac-callout-link:hover { color: var(--brand-red); }
  .tac-callout-link svg { width: 16px; height: 16px; color: var(--brand-red); flex-shrink: 0; }

  @media (max-width: 1100px) {
    .tac-grid { grid-template-columns: 1fr; gap: 32px; padding-top: 64px; }
    .tac-sensor-area { position: relative; width: 100%; height: 240px; }
    .tac-title { font-size: 30px; }
  }

  /* ============================================================================
     SECTION 4 — Highlights & Features (7-tile collage, parity w/ Sentinel pattern)
     ============================================================================ */
  .hf-section {
    background: var(--bg-page);
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .hf-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .hf-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--brand-red);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 16px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
  }
  .hf-eyebrow::before, .hf-eyebrow::after {
    content: ""; display: block;
    width: 28px; height: 1px;
    background: var(--brand-red);
  }
  .hf-title {
    text-align: center;
    font-size: 38px;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin-bottom: 12px;
    line-height: 1.05;
  }
  .hf-sub {
    text-align: center;
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: 48px;
    max-width: 780px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
  .hf-grid { display: grid; gap: 12px; }
  .hf-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .hf-tile {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    background: linear-gradient(135deg, #2a2e34 0%, #14171b 100%);
    aspect-ratio: 16/9;
    cursor: default;
    transition: transform 0.3s ease;
  }
  .hf-tile:hover { transform: translateY(-2px); }
  .hf-tile-hero { aspect-ratio: 24/9; }
  .hf-tile-image {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
  }
  .hf-tile-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }
  /* Per-tile crop adjustments for Guardian-specific photo framing */
  .hf-tile-hero .hf-tile-image img      { object-fit: cover; object-position: center 40%; }
  .hf-tile-grad-2 .hf-tile-image img    { object-fit: cover; object-position: center 50%; transform: scale(1.6); transform-origin: center 55%; }
  .hf-tile-grad-3 .hf-tile-image img    { object-fit: contain; transform: scale(1.05); }
  .hf-tile-grad-4 .hf-tile-image img    { object-fit: contain; transform: scale(0.95); }
  .hf-tile-grad-5 .hf-tile-image img    { object-fit: cover; object-position: center 45%; transform: scale(1.1); }
  .hf-tile-grad-6 .hf-tile-image img    { object-fit: contain; transform: scale(0.95); }
  .hf-tile-grad-7 .hf-tile-image img    { object-fit: contain; transform: scale(1.05); }
  .hf-tile-overlay {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 32px 36px 28px;
    background: linear-gradient(to top, rgba(0,0,0,0.92) 20%, rgba(0,0,0,0.5) 70%, transparent 100%);
    color: white;
  }
  .hf-tile-tag {
    font-family: 'JetBrains Mono', monospace;
