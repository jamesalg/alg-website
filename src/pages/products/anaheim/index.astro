  }
  .acc-card-body {
    padding: 16px 16px 18px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 10px;
  }
  .acc-card-cat {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brand-red);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .acc-card-title {
    font-size: 14.5px;
    font-weight: 700;
    line-height: 1.3;
