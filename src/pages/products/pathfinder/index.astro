<script>
/* =============================================================================
   SECTION 8 \u2014 Pathfinder "In the Box" modal wiring.
   3 entries \u00B7 all standard \u00B7 click-to-detail pattern from Atlanta scaffold.
   Per PDP_BUILD_PLAYBOOK rule #5: 2-CTA modal, no per-component datasheet.
   ============================================================================= */
(function() {
  var ACC = {
    'lens': {
      cat: 'Optic \u00B7 Pre-fitted',
      title: 'Anti-UV Prismatic Translucent Lens',
      sku: 'Pre-fitted \u00B7 IP65 sealed \u00B7 anti-UV',
      model: 'Anti-UV prismatic translucent optic \u00B7 concentric-facet light spread',
      desc: 'Beam-shaper on every Pathfinder. Anti-UV prismatic translucent lens with concentric facets &mdash; pulls the LED hot-spot into a uniform wide downward distribution, grades evenly across canopy and soffit. Sealed at the housing interface as part of the IP65 wet-location envelope.',
      specs: [
        ['Material', 'Anti-UV prismatic translucent (datasheet language)'],
        ['Distribution', 'Wide downward \u00B7 prismatic light spread \u00B7 symmetric'],
        ['Sealing', 'Bonded to housing \u00B7 part of IP65 wet-location envelope'],
        ['UV resistance', 'Anti-UV stabilized for outdoor exposure'],
        ['Service', 'Lens not field-replaceable; housing assembly is the service unit'],
        ['Effective for', 'Drive-thru canopies \u00B7 gas-station soffits \u00B7 parking-deck ceilings \u00B7 school covered walkways \u00B7 vestibule overhangs']
      ]
    },
    'driver': {
      cat: 'contr\u24B6LS \u00B7 Standard',
      title: '0-10V Dim Driver \u00B7 Universal Voltage',
      sku: '120-277V universal \u00B7 0-10V dim std \u00B7 factory-wired',
      model: '0-10V analog dim driver \u00B7 isolated \u00B7 100% to ~10% smooth dim',
      desc: '0-10V analog dim driver standard on every Pathfinder &mdash; no upsell. Universal 120-277VAC covers commercial-service canopies. Wire violet/grey 0-10V leads to a dimmer, DALI gateway, or scheduling system. Optional EMB05-CP/DB emergency battery + MSM-SDI/819/BLS bi-level microwave sensor layer on top &mdash; see Section 6.',
      specs: [
        ['Driver type', '0-10V analog dimming \u00B7 isolated \u00B7 100% to ~10% smooth dim'],
        ['Voltage range', '120-277V universal (datasheet \u2014 no HD variant published)'],
        ['Power factor', '> 0.90 at full load'],
        ['Total harmonic distortion', '< 20% at full load'],
        ['Operating temperature', '\u221240\u00B0F to 104\u00B0F (with EM battery: 50\u00B0F to 104\u00B0F)'],
        ['Optional add-ons', 'EMB05-CP/DB emergency battery \u00B7 MSM-SDI/819/BLS bi-level microwave sensor \u00B7 RM-SD/100S IR remote'],
        ['vs competition', 'RAB CCAN, Lithonia VCPG, Cooper Halo CDLS canopy lines often charge upgrade for 0-10V; Pathfinder ships it standard']
      ]
    },
    'mount': {
      cat: 'wet\u24B6GUARD \u00B7 Quick-Mount',
      title: 'External Quick-Mount Plate',
      sku: 'Pre-fitted \u00B7 IP65 sealed \u00B7 3 mounting modes',
      model: 'External quick-mount plate \u00B7 wet' + "\u24B6" + 'GUARD silicone sealing \u00B7 J-box / pendant / conduit',
      desc: 'One housing, three mounting modes. Factory-fitted external quick-mount plate for standard J-box surface install (canopy/soffit default). Same housing accepts a 3/4" pendant mount for stem-suspended applications, plus 1/2" NPS knockouts on three sides for surface conduit. wet' + "\u24B6" + 'GUARD silicone seal at the mount interface holds IP65 across &minus;40&deg;F to 104&deg;F. No second SKU.',
      specs: [
        ['Mode 1 \u00B7 J-box', 'External quick-mount plate \u00B7 standard J-box rough-in'],
        ['Mode 2 \u00B7 Pendant', '3/4" stem pendant compatible'],
        ['Mode 3 \u00B7 Surface conduit', '1/2" NPS conduit knockouts on three sides (top + left + right)'],
        ['Sealing', 'wet' + "\u24B6" + 'GUARD silicone \u00B7 IP65 wet-location \u00B7 \u221240\u00B0F to 104\u00B0F'],
        ['Material', 'Cast aluminum \u00B7 matches housing finish'],
        ['Compatibility', 'Drive-thru canopies \u00B7 gas-station soffits \u00B7 parking-deck ceilings \u00B7 school covered walkways'],
        ['Service', 'Driver chamber accessible via lid \u00B7 single-screw release']
      ]
    }
  };

  function init() {
    var grid     = document.getElementById('accGrid');
    var modal    = document.getElementById('accModal');
    var closeBtn = document.getElementById('accModalClose');
    var imgWrap  = document.getElementById('accModalImg');
    var catEl    = document.getElementById('accModalCat');
    var titleEl  = document.getElementById('accModalTitle');
    var skuEl    = document.getElementById('accModalSku');
    var descEl   = document.getElementById('accModalDesc');
    var specsEl  = document.getElementById('accModalSpecs');
    if (!grid || !modal) return;
    var cards = grid.querySelectorAll('.acc-card');

    function openModal(card) {
      var id = card.dataset.id;
      var d  = ACC[id];
      if (!d) { console.warn('acc-modal: no data for id', id); return; }
      catEl.textContent   = d.cat.replace(/\u24B6/g, '');
      titleEl.textContent = d.title;
      skuEl.innerHTML     = d.sku + (d.model && d.model !== d.sku ? '<div style="font-size:11px;color:var(--text-muted);font-weight:400;margin-top:2px;">' + d.model + '</div>' : '');
      descEl.textContent  = d.desc;
      if (d.cat.indexOf('\u24B6') >= 0) {
        catEl.innerHTML = d.cat.replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
      }
      specsEl.innerHTML = d.specs.map(function(s) {
        var v = (s[1] || '').toString().replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
        return '<div class="acc-spec-row">' +
                 '<div class="acc-spec-key">' + s[0] + '</div>' +
                 '<div class="acc-spec-val">' + v + '</div>' +
               '</div>';
      }).join('');
      var srcMedia = card.querySelector('.acc-card-img svg, .acc-card-img img.acc-card-photo');
      Array.from(imgWrap.querySelectorAll('svg, img.acc-card-photo')).forEach(function(s){ s.remove(); });
      if (srcMedia) {
        var clone = srcMedia.cloneNode(true);
        if (clone.tagName === 'IMG') {
          clone.style.maxWidth = '90%';
          clone.style.maxHeight = '90%';
          clone.style.objectFit = 'contain';
          clone.style.filter = 'drop-shadow(0 12px 24px rgba(0,0,0,0.6))';
        }
        imgWrap.appendChild(clone);
      }
      modal.classList.add('open');
    }
    function closeModal() { modal.classList.remove('open'); }

    cards.forEach(function(c) {
      c.addEventListener('click', function() { openModal(c); });
    });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

<!-- ============================================================================
     SECTION 9 — Configurator (Build Your Pathfinder · live SKU builder)
     -------------------------------------------------------------------------
     SKU PATTERN (per James 2026-05-01, multi-option clarification 2026-05-02):
       LCNP{060|110}-3CS/27VP1/{finish}{/BLS?}{/EM05?}
       Example default:     LCNP060-3CS/27VP1/DB
       Example w/ BLS:      LCNP060-3CS/27VP1/DB/BLS
       Example w/ EM05:     LCNP060-3CS/27VP1/DB/EM05
       Example w/ BOTH:     LCNP060-3CS/27VP1/DB/BLS/EM05  ← /BLS and /EM05 may coexist
       Example LCNP110+RAL: LCNP110-3CS/27VP1/RAL7016/BLS/EM05

       Element decode:
         LCNP060 / LCNP110  housing class
         -3CS               4-WATTSELECT × 3-CCTSELECT
         /27V               120-277V universal
         P1                 Pathfinder Series identifier (joins /27V; no separator)
         /DB                finish (DB | B | S | W | RAL{####})
         /BLS               Integrated Photocell (optional · independent toggle)
         /EM05              EMB05-CP/DB Emergency Battery (optional · independent toggle)
         When both BLS and EM05 are picked, /BLS appears before /EM05.

     User-pickable fields (4):
       1. Housing class    LCNP060 (25/36/48/60W) ★ or LCNP110 (45/65/90/110W)
       2. Finish           DB ★ | B | S | W | RAL####
       3. /BLS toggle      Integrated Photocell (independent toggle · default off)
       4. /EM05 toggle     Emergency Battery (independent toggle · default off)
     Auto-locked segments (always in SKU): -3CS · /27V · P1
     Field-set at install (informational toggle, NOT in SKU):
       WATTSELECT (4 wattages per housing) + CCTSELECT (3000K/4000K/5000K)
     Defaults: LCNP060 · Dark Bronze · No options · DIP 60W · 4000K.

     LABELING NOTE — BLS:
       James's spec labels /BLS as "Integrated Photocell" (configurator-side).
       Datasheet page 5 labels MSM-SDI/819/BLS as "Bi-Level Microwave Sensor"
       (Section 6 uses that name). Discrepancy flagged for engineering /
       marketing alignment — likely the BLS option bundles photocell +
       bi-level sensor functionality on the same suffix code. Coordinate
       with the rep desk for production-final naming.
     ============================================================================ -->
<section class="cfg-section" id="configurator" aria-label="Configurator · Build Your Pathfinder">
  <div class="cfg-inner">

    <div class="cfg-head">
      <p class="cfg-eyebrow" style="display:flex; justify-content:center;">Build Your Model</p>
