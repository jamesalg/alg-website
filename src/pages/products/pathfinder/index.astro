      <p class="cfg-sub" style="text-align:center;">
        Selections build the SKU live. WATTSELECT + CCTSELECT are DIP-set at install — they do not appear in the SKU.
        <small>Required fields marked with <span style="color:var(--brand-red); font-weight:700">*</span>. See the legend for QS / MTO / DIP / LCK meanings.</small>
      </p>
    </div>

    <div class="cfg-counter-band">
      <div class="cfg-counter complete" id="cfgCounter"><strong id="cfgCounterCount">6</strong> of 6 SKU fields confirmed</div>
      <button type="button" class="cfg-reset" id="cfgReset">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 12a9 9 0 1 0 3-6.7"/><polyline points="3 4 3 10 9 10"/>
        </svg>
        Reset to defaults
      </button>
    </div>

    <div class="cfg-body">

      <!-- ============== LEFT COLUMN · SKU FIELDS ============== -->
      <div class="cfg-col">
        <div class="cfg-col-head">
          <div class="cfg-col-title cfg-col-title-required">SKU Fields</div>
          <div class="cfg-col-meta">6 fields · 3 locked · 3 user-pickable</div>
        </div>
        <div class="cfg-fields">

          <!-- 1. Housing Class — USER CHOICE, defaults to LCNP060 ★ -->
          <div class="cfg-field" data-field="housing" style="grid-column: 1 / -1;">
            <div class="cfg-field-label">Housing Class <span class="req">*</span></div>
            <div class="cfg-chips">
              <button type="button" class="cfg-chip selected" data-field="housing" data-val="060" data-code="LCNP060" aria-pressed="true">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">LCNP060 · 25 / 36 / 48 / 60W ★</span>
                <span class="cfg-chip-code">LCNP060</span>
              </button>
              <button type="button" class="cfg-chip" data-field="housing" data-val="110" data-code="LCNP110" aria-pressed="false">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">LCNP110 · 45 / 65 / 90 / 110W</span>
                <span class="cfg-chip-code">LCNP110</span>
              </button>
            </div>
          </div>

          <!-- 2. CCTSELECT — 3CS (locked) -->
          <div class="cfg-field" data-field="cctcode" style="grid-column: 1 / -1;">
            <div class="cfg-field-label">CCTSELECT capability</div>
            <div class="cfg-chips">
              <button type="button" class="cfg-chip locked selected" data-field="cctcode" data-val="3CS" data-code="3CS" aria-pressed="true">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">3CS · 3-CCTSELECT (3000K / 4000K / 5000K)</span>
                <span class="cfg-chip-code">-3CS</span>
              </button>
            </div>
          </div>

          <!-- 3. Voltage — /27V (locked) -->
          <div class="cfg-field" data-field="voltage" style="grid-column: 1 / -1;">
            <div class="cfg-field-label">Voltage</div>
            <div class="cfg-chips">
              <button type="button" class="cfg-chip locked selected" data-field="voltage" data-val="27V" data-code="27V" aria-pressed="true">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">Universal · 120–277V</span>
                <span class="cfg-chip-code">/27V</span>
              </button>
            </div>
          </div>

          <!-- 4. Series — P1 (locked, joins /27V with no separator → /27VP1) -->
          <div class="cfg-field" data-field="series" style="grid-column: 1 / -1;">
            <div class="cfg-field-label">Pathfinder Series</div>
            <div class="cfg-chips">
              <button type="button" class="cfg-chip locked selected" data-field="series" data-val="P1" data-code="P1" aria-pressed="true">
