<script>
/* =============================================================================
   SECTION 9 \u2014 Pathfinder Configurator engine
   3 user choices (Housing \u00B7 Finish \u00B7 Option) \u00B7 3 auto-locked (-3CS, /27V, P1) \u00B7
   2 field-set DIP (WATTSELECT, CCTSELECT) \u2014 informational only.
   SKU pattern (per James 2026-05-01):
       LCNP{housing}-3CS/27VP1/{finish}{/option?}
   Examples:
       LCNP060-3CS/27VP1/DB           \u2190 default \u00B7 60W DIP \u00B7 4000K DIP
       LCNP060-3CS/27VP1/DB/BLS       \u2190 + Integrated Photocell option
       LCNP110-3CS/27VP1/RAL7016/EM05 \u2190 LCNP110 \u00B7 custom RAL \u00B7 EM battery
   Datasheet rated: 160 lm/W on LCNP060, 155 lm/W on LCNP110.
   LM-79 measured peak (Section 7): 142 lm/W at 27W/5000K UD on LCNP060.
   ============================================================================= */
(function() {
  var LUMEN = {
    '060': { '25': '3,700',  '36': '5,760',  '48': '7,680',  '60': '9,600' },
    '110': { '45': '6,975',  '65': '10,075', '90': '13,950', '110': '17,050' }
  };
  var EFF = { '060': '160 lm/W', '110': '155 lm/W' };
  var HID = {
    '060': { '25': '100W MH', '36': '150W MH', '48': '200W MH', '60': '250W MH' },
    '110': { '45': '175W MH', '65': '250W MH', '90': '320W MH', '110': '400W MH' }
  };
  var WATTS = {
    '060': ['25', '36', '48', '60'],
    '110': ['45', '65', '90', '110']
  };
  var CCT_LABEL  = { '30': '3000K', '40': '4000K', '50': '5000K' };
  var FINISH_LBL = {
    'DB': 'Dark Bronze (QS)', 'B': 'Black (QS)',
    'S': 'Silver (MTO)', 'W': 'White (MTO)', 'RAL': 'Custom RAL (MTO)'
  };
  // Option summary helper \u2014 both toggles are independent. /BLS and /EM05 may
  // coexist on the same SKU (per James 2026-05-02). When both are off, return
  // the "\u2014 none \u2014" string for the spec-grid display.
  function optionSummary(s) {
    var parts = [];
    if (s.bls)  parts.push('/BLS \u00B7 Integrated Photocell');
    if (s.em05) parts.push('/EM05 \u00B7 Emergency Battery');
    return parts.length ? parts.join(' \u00B7 ') : '\u2014 none \u2014';
  }

  function defaultState() {
    return { housing: '060', finish: 'DB', ralCode: '', bls: false, em05: false, watt: '60', cct: '40' };
  }
  var state = defaultState();

  function buildSku(s) {
    var fin;
    if (s.finish === 'RAL') {
      fin = 'RAL' + (s.ralCode && /^[0-9]{4}$/.test(s.ralCode) ? s.ralCode : '????');
    } else {
      fin = s.finish;
    }
    // Pattern: LCNP{housing}-3CS/27VP1/{finish}{/BLS?}{/EM05?}
    // /BLS appears before /EM05 when both are set.
    var sku = 'LCNP' + s.housing + '-3CS/27VP1/' + fin;
    if (s.bls)  sku += '/BLS';
    if (s.em05) sku += '/EM05';
    return sku;
  }

  function renderWattChips() {
    var host = document.getElementById('cfgWattChips');
    if (!host) return;
    var watts = WATTS[state.housing] || WATTS['060'];
    var defaultWatt = watts[watts.length - 1];
    var html = '';
    watts.forEach(function(w, idx) {
      var isDefault = (w === defaultWatt);
      var isSelected = (w === state.watt);
      html += '<button type="button" class="cfg-chip cfg-chip-toggle' + (isSelected ? ' selected' : '') + '" ' +
              'data-field="watt" data-val="' + w + '" data-code="' + w + 'W" aria-pressed="' + isSelected + '">' +
              '<span class="cfg-chip-val">' + w + 'W' + (isDefault ? ' \u2605' : '') + '</span>' +
              '<span class="cfg-chip-code">DIP-' + (idx + 1) + (isDefault ? ' \u2605' : '') + '</span>' +
              '</button>';
    });
    host.innerHTML = html;
    host.querySelectorAll('.cfg-chip').forEach(function(chip) {
      chip.addEventListener('click', function() {
        host.querySelectorAll('.cfg-chip').forEach(function(c) { c.classList.remove('selected'); c.setAttribute('aria-pressed','false'); });
        chip.classList.add('selected');
        chip.setAttribute('aria-pressed', 'true');
        state.watt = chip.dataset.val;
        render();
      });
    });
  }

  function render() {
    document.getElementById('cfgCounterCount').textContent = '6';
    var sku = buildSku(state);
    document.getElementById('cfgSku').textContent = sku;
    var fLabel = FINISH_LBL[state.finish] ? FINISH_LBL[state.finish].split(' (')[0].toUpperCase() : 'DARK BRONZE';
    document.getElementById('cfgPreviewTag').textContent = 'LCNP' + state.housing + ' \u00B7 ' + fLabel;
    document.getElementById('cfgSpecModel').textContent  = 'LCNP' + state.housing;
    var finishDisplay = FINISH_LBL[state.finish] || FINISH_LBL['DB'];
    if (state.finish === 'RAL' && state.ralCode && /^[0-9]{4}$/.test(state.ralCode)) {
      finishDisplay = 'Custom RAL ' + state.ralCode + ' (MTO)';
    }
    document.getElementById('cfgSpecFinish').textContent = finishDisplay;
    var optEl = document.getElementById('cfgSpecOption');
    if (optEl) optEl.textContent = optionSummary(state);
    document.getElementById('cfgSpecWatt').textContent   = state.watt + 'W';
    document.getElementById('cfgSpecCct').textContent    = CCT_LABEL[state.cct] || '4000K';
    var ralWrap = document.getElementById('cfgRalInputWrap');
    if (ralWrap) ralWrap.style.display = (state.finish === 'RAL') ? 'block' : 'none';
    var lm = (LUMEN[state.housing] && LUMEN[state.housing][state.watt]) || '\u2014';
    document.getElementById('cfgSpecLumens').textContent =
      lm + ' lm \u00B7 datasheet rated ' + (EFF[state.housing] || '160 lm/W') +
      ' (LM-79 measured peaks at 142 lm/W \u2014 see Section 7)';
    ['30','40','50'].forEach(function(cct) {
      var note = document.getElementById('cfgCctNote' + cct);
      if (note) note.textContent = lm + ' lm @ LCNP' + state.housing + ' \u00B7 ' + state.watt + 'W';
    });
    renderWattChips();
    var sub = document.getElementById('cfgCtaSubmittal');
    if (sub) {
      // Options encoded as comma-separated tokens. Submittal template parses
      // by ',' so coexisting BLS+EM05 round-trips cleanly.
      var optTokens = [];
      if (state.bls)  optTokens.push('BLS');
      if (state.em05) optTokens.push('EM05');
      sub.href = 'submittal_template.html?product=pathfinder&sku=' + encodeURIComponent(sku) +
                 '&housing=' + state.housing + '&wattage=' + state.watt +
                 '&cct=' + state.cct + '&voltage=27V' + '&series=P1' +
                 '&finish=' + state.finish + (state.ralCode ? '&ral=' + state.ralCode : '') +
                 '&option=' + optTokens.join(',');
    }
    var copyLabel = document.getElementById('cfgSkuCopyLabel');
    var copyBtn   = document.getElementById('cfgSkuCopy');
    if (copyLabel) copyLabel.textContent = 'Copy SKU';
    if (copyBtn)   copyBtn.classList.remove('copied');
  }

  function init() {
    // Independent-toggle fields \u2014 clicking flips selected state on this chip
    // alone (no sibling deselect). /BLS and /EM05 may coexist on the SKU.
    var INDEPENDENT_TOGGLE_FIELDS = ['bls', 'em05'];

    var chips = document.querySelectorAll('#configurator .cfg-chip:not([data-field="watt"])');
    chips.forEach(function(chip) {
      if (chip.classList.contains('locked')) return;
      chip.addEventListener('click', function() {
        var f = chip.dataset.field;
        var v = chip.dataset.val;

        if (INDEPENDENT_TOGGLE_FIELDS.indexOf(f) >= 0) {
          // Independent toggle \u2014 flip this chip alone
          var nowSelected = !chip.classList.contains('selected');
          chip.classList.toggle('selected', nowSelected);
          chip.setAttribute('aria-pressed', nowSelected ? 'true' : 'false');
          state[f] = nowSelected;
        } else {
          // Single-pick group \u2014 deselect siblings, select this one
          var siblings = document.querySelectorAll('#configurator .cfg-chip[data-field="' + f + '"]');
          siblings.forEach(function(s) { s.classList.remove('selected'); s.setAttribute('aria-pressed', 'false'); });
          chip.classList.add('selected');
          chip.setAttribute('aria-pressed', 'true');
          state[f] = v;
          if (f === 'housing') {
            state.watt = WATTS[v][WATTS[v].length - 1];
          }
        }
        render();
      });
    });
    var ralInput = document.getElementById('cfgRalInput');
    if (ralInput) {
      ralInput.addEventListener('input', function() {
        var digits = (ralInput.value || '').replace(/[^0-9]/g, '').substring(0, 4);
        if (digits !== ralInput.value) ralInput.value = digits;
        state.ralCode = digits;
        render();
      });
    }
    var resetBtn = document.getElementById('cfgReset');
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        state = defaultState();
        var defaults = { housing: '060', finish: 'DB', cct: '40' };
        Object.keys(defaults).forEach(function(f) {
          document.querySelectorAll('#configurator .cfg-chip[data-field="' + f + '"]').forEach(function(c) {
            var match = c.dataset.val === defaults[f];
            c.classList.toggle('selected', match);
            c.setAttribute('aria-pressed', match ? 'true' : 'false');
          });
        });
        // Independent-toggle fields reset to off
        ['bls', 'em05'].forEach(function(f) {
          document.querySelectorAll('#configurator .cfg-chip[data-field="' + f + '"]').forEach(function(c) {
            c.classList.remove('selected');
            c.setAttribute('aria-pressed', 'false');
          });
        });
        if (ralInput) ralInput.value = '';
        render();
      });
    }
    var copyBtn = document.getElementById('cfgSkuCopy');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        var sku = buildSku(state);
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(sku).then(function() {
            document.getElementById('cfgSkuCopyLabel').textContent = 'Copied!';
            copyBtn.classList.add('copied');
            setTimeout(function() {
              document.getElementById('cfgSkuCopyLabel').textContent = 'Copy SKU';
              copyBtn.classList.remove('copied');
            }, 1800);
          });
        }
      });
    }
    render();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

