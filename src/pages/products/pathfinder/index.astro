    gap: 18px;
  }
  .acc-modal-title { font-size: 22px; font-weight: 700; line-height: 1.2; color: var(--text-primary); margin: 0; }
  .acc-modal-sku {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }
  .acc-modal-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .acc-modal-specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .acc-spec-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
  }
  .acc-spec-row:nth-last-child(-n+2) { border-bottom: none; }
  .acc-spec-row:nth-child(odd) { padding-right: 18px; }
  .acc-spec-row:nth-child(even) { padding-left: 18px; border-left: 1px solid var(--line); }
  .acc-spec-key {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .acc-spec-val {
    font-size: 13.5px;
    color: var(--text-primary);
    font-weight: 600;
    line-height: 1.4;
  }
  .acc-modal-ctas { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 4px; }
  .acc-modal-cta {
    flex: 1;
    min-width: 170px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 13px 18px;
    border-radius: 2px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.18s;
