    .photo-title { font-size: 28px; }
  }

  /* ============================================================================
     SECTION 6 — contrⒶLS · Multi-Functional / Bi-Level / Photocell
     Full-bleed dark backdrop with red dot mesh radiating from the centered
     control-panel image. Same pattern as Sentinel; Guardian-specific copy
     emphasizes the integrated dusk-to-dawn photocell + 0-10V dimming +
     sensor-ready terminals shipped on every fixture.
     ============================================================================ */
  .tac-section {
    position: relative;
    background: #0a0e14;
    overflow: hidden;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    min-height: 560px;
  }
  .tac-mesh-overlay {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1.2px 1.2px, rgba(243,39,64,0.78) 1.2px, transparent 1.6px);
    background-size: 14px 14px;
    -webkit-mask-image: radial-gradient(circle at 25% 50%,
      black 0%,
      rgba(0,0,0,0.95) 18%,
      rgba(0,0,0,0.72) 35%,
      rgba(0,0,0,0.42) 55%,
      rgba(0,0,0,0.18) 78%,
      rgba(0,0,0,0.05) 100%);
            mask-image: radial-gradient(circle at 25% 50%,
      black 0%,
      rgba(0,0,0,0.95) 18%,
      rgba(0,0,0,0.72) 35%,
      rgba(0,0,0,0.42) 55%,
      rgba(0,0,0,0.18) 78%,
      rgba(0,0,0,0.05) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .tac-shockwave {
    position: absolute;
    left: 25%;
    top: 50%;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 2px solid rgba(243, 39, 64, 0.85);
    transform: translate(-50%, -50%);
    pointer-events: none;
    opacity: 0;
    z-index: 1;
  }
  .tac-shockwave.is-rippling { animation: tac-shockwave 1.4s ease-out; }
  @keyframes tac-shockwave {
    0%   { width: 60px;   height: 60px;   opacity: 1; border-width: 3px; }
    60%  {                                opacity: 0.55; }
    100% { width: 1400px; height: 1400px; opacity: 0; border-width: 0.5px; }
  }
  .tac-sensor-area {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    pointer-events: none;
  }
  .tac-sensor-svg {
    position: absolute;
    width: 60%;
    max-width: 380px;
    height: auto;
    opacity: 0;
    transform: scale(0.94);
    transition: opacity 0.5s ease, transform 0.55s cubic-bezier(0.2, 0.6, 0.2, 1);
    filter: drop-shadow(0 16px 48px rgba(0,0,0,0.6));
  }
  .tac-sensor-svg.is-active {
    opacity: 0.96;
    transform: scale(1);
  }
  .tac-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 28%, rgba(10,14,20,0.4) 55%, rgba(10,14,20,0.7) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .tac-grid {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 88px 32px 96px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .tac-spacer { /* left half placeholder so backdrop sensor shows through */ }
  .tac-content { color: var(--text-primary); max-width: 580px; }
  .tac-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .tac-eyebrow::before {
    content: "";
    display: inline-block;
    width: 28px; height: 1px;
    background: var(--brand-red);
  }
  .tac-title {
    font-size: 38px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin-bottom: 18px;
    white-space: nowrap;
  }
  .tac-desc {
    font-size: 15.5px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 28px;
  }
  .tac-callout {
    border: 1px solid rgba(243,39,64,0.4);
    border-radius: 4px;
    background: rgba(20,23,27,0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    overflow: hidden;
  }
  .tac-callout-tabs { display: flex; background: rgba(0,0,0,0.25); }
  .tac-callout-tab {
    flex: 1;
    background: transparent;
    border: 0;
    padding: 13px 18px;
    font-family: inherit;
    font-size: 13px;
    font-weight: 700;
    color: var(--text-secondary);
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: background 0.18s, color 0.18s;
    border-right: 1px solid rgba(255,255,255,0.08);
    text-align: center;
  }
  .tac-callout-tab:last-child { border-right: 0; }
  .tac-callout-tab:hover { color: var(--text-primary); background: rgba(255,255,255,0.05); }
  .tac-callout-tab.active { background: var(--brand-red); color: white; }
  .tac-callout-body { padding: 22px 24px 22px; }
  .tac-callout-body p {
    font-size: 14px;
    color: var(--text-primary);
    line-height: 1.6;
    margin-bottom: 14px;
  }
  .tac-callout-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 13.5px;
    cursor: pointer;
    transition: color 0.18s;
    text-decoration: none;
  }
  .tac-callout-link:hover { color: var(--brand-red); }
  .tac-callout-link svg { width: 16px; height: 16px; color: var(--brand-red); flex-shrink: 0; }

  @media (max-width: 1100px) {
    .tac-grid { grid-template-columns: 1fr; gap: 32px; padding-top: 64px; }
    .tac-sensor-area { position: relative; width: 100%; height: 240px; }
    .tac-title { font-size: 30px; }
  }

  /* ============================================================================
     SECTION 4 — Highlights & Features (7-tile collage, parity w/ Sentinel pattern)
     ============================================================================ */
  .hf-section {
    background: var(--bg-page);
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .hf-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .hf-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--brand-red);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 16px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
  }
  .hf-eyebrow::before, .hf-eyebrow::after {
    content: ""; display: block;
    width: 28px; height: 1px;
    background: var(--brand-red);
  }
  .hf-title {
    text-align: center;
    font-size: 38px;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin-bottom: 12px;
    line-height: 1.05;
  }
  .hf-sub {
    text-align: center;
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: 48px;
    max-width: 780px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
  .hf-grid { display: grid; gap: 12px; }
  .hf-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .hf-tile {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    background: linear-gradient(135deg, #2a2e34 0%, #14171b 100%);
    aspect-ratio: 16/9;
    cursor: default;
    transition: transform 0.3s ease;
  }
  .hf-tile:hover { transform: translateY(-2px); }
  .hf-tile-hero { aspect-ratio: 24/9; }
  .hf-tile-image {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
  }
  .hf-tile-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }
  /* Per-tile crop adjustments for Guardian-specific photo framing */
  .hf-tile-hero .hf-tile-image img      { object-fit: cover; object-position: center 40%; }
