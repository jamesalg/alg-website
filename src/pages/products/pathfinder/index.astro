<script>
/* =============================================================================
   SECTION 7 \u2014 Pathfinder Photometrics: 3 wattages \u00D7 2 CCTs = 6 LM-79 measured
   stat tuples on LCNP060. Polar SVG swaps per (wattage \u00D7 CCT). Stat panel
   updates per the same key. All numbers extracted from in-image text labels
   in the staged Pathfinder-I SVGs (lumens \u00B7 efficacy \u00B7 actual draw \u00B7 peak cd).
   3000K disabled (not staged); LCNP110 not in this section (use IES bundle).
   ============================================================================= */
(function() {
  // PHOTO[wattage][cct] returns { svg, peak, lumens, lpw, draw, file }
  // cct keys: '40' = 4000K \u00B7 '50' = 5000K (3000K disabled)
  var PHOTO = {
    '27': {
      '40': { svg: '../../luxoARCH_PolarPlots/Pathfinder-I/LCNP27_4000K_UD.svg', peak: '860 cd',   lumens: '3,747 lm', lpw: '140 lm/W',           draw: '26.8W (LM-79)', file: 'LCNP27_4000K_UD.ies' },
      '50': { svg: '../../luxoARCH_PolarPlots/Pathfinder-I/LCNP27_5000K_UD.svg', peak: '886 cd',   lumens: '3,876 lm', lpw: '<strong>142 lm/W</strong>', draw: '27.4W (LM-79)', file: 'LCNP27_5000K_UD.ies' }
    },
    '40': {
      '40': { svg: '../../luxoARCH_PolarPlots/Pathfinder-I/LCNP40_4000K_UD.svg', peak: '1,221 cd', lumens: '5,374 lm', lpw: '135 lm/W',           draw: '39.7W (LM-79)', file: 'LCNP40_4000K_UD.ies' },
      '50': { svg: '../../luxoARCH_PolarPlots/Pathfinder-I/LCNP40_5000K_UD.svg', peak: '1,279 cd', lumens: '5,524 lm', lpw: '<strong>139 lm/W</strong>', draw: '39.8W (LM-79)', file: 'LCNP40_5000K_UD.ies' }
    },
    '60': {
      '40': { svg: '../../luxoARCH_PolarPlots/Pathfinder-I/LCNP60_4000K_UD.svg', peak: '1,693 cd', lumens: '7,861 lm', lpw: '131 lm/W',           draw: '60.1W (LM-79)', file: 'LCNP60_4000K_UD.ies' },
      '50': { svg: '../../luxoARCH_PolarPlots/Pathfinder-I/LCNP60_5000K_UD.svg', peak: '1,731 cd', lumens: '8,062 lm', lpw: '<strong>134 lm/W</strong>', draw: '60.3W (LM-79)', file: 'LCNP60_5000K_UD.ies' }
    }
  };

  function init() {
    var img         = document.getElementById('photoImg');
    var statPeak    = document.getElementById('photoStatPeak');
    var statPeakSub = document.getElementById('photoStatPeakSub');
    var statLum     = document.getElementById('photoStatLumens');
    var statLpw     = document.getElementById('photoStatLpw');
    var statDraw    = document.getElementById('photoStatDraw');
    var statFile    = document.getElementById('photoStatFile');
    if (!img) return;

    // Scope to the photometrics section so we don't capture Section 3's spec-watt-tabs.
    var photoSection = document.getElementById('photometrics');
    var wattTabs = photoSection.querySelectorAll('.spec-watt-tab[data-photo-watt]');
    var cctTabs  = photoSection.querySelectorAll('.photo-tab[data-cct]');
    var state    = { watt: '60', cct: '50' };

    function render() {
      var p = PHOTO[state.watt];
      if (!p) return;
      var d = p[state.cct];
      if (!d) return;
      img.src = d.svg;
      img.alt = 'Pathfinder LCNP060 \u00B7 ' + state.watt + 'W setting \u00B7 ' + state.cct + '00K \u00B7 prismatic-lens canopy distribution \u00B7 LM-79 measured polar plot';
      statPeak.textContent = d.peak;
      if (statPeakSub) statPeakSub.textContent = 'downward throw at ' + state.watt + 'W \u00B7 ' + state.cct + '00K';
      statLum.textContent  = d.lumens;
      statLpw.innerHTML    = d.lpw;
      statDraw.textContent = d.draw;
      statFile.textContent = d.file + ' (LM-79 measured)';
    }

    wattTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        wattTabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        state.watt = t.dataset.photoWatt;
        render();
      });
    });

    cctTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        if (t.disabled) return;
        cctTabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
          x.style.background = 'transparent';
          if (!x.disabled) x.style.color = 'var(--text-secondary)';
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        t.style.background = 'var(--brand-red)';
        t.style.color      = 'white';
        state.cct = t.dataset.cct;
        render();
      });
    });

    render();
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

