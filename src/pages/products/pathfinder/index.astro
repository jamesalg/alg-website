  }
  .acc-modal-img-cat {
    position: absolute;
    top: 16px;
    left: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-red);
    background: rgba(243,39,64,0.10);
    border: 1px solid rgba(243,39,64,0.35);
