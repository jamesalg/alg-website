  /* Modal */
  .acc-modal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.78);
    z-index: 1100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 32px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .acc-modal.open { display: flex; }
  .acc-modal-panel {
    background: var(--bg-spec);
    border: 1px solid var(--line-medium);
    border-radius: 4px;
    width: 100%;
    max-width: 920px;
    max-height: 90vh;
    overflow: auto;
    position: relative;
  }
  .acc-modal-grid { display: grid; grid-template-columns: 0.85fr 1fr; gap: 0; }
  .acc-modal-img {
    background: var(--bg-darker);
