      <div class="cfg-preview-grid">
        <div class="cfg-preview-img fs-D" id="cfgPreviewImgWrap">
          <span class="cfg-preview-img-tag" id="cfgPreviewTag">LFLD3W80 · DARK BRONZE</span>
          <div class="cfg-preview-stack" id="cfgPreviewImg">
            <img class="cfg-preview-body-img"
                 src="/products/everest/assets/hero/everest-hero-1.webp"
                 alt="Everest LFLD3W80 housing · live finish preview"
                 id="cfgPreviewBodyImg" />
          </div>
        </div>
        <div class="cfg-preview-body">
          <div class="cfg-sku-block">
            <div class="cfg-sku-eyebrow">Catalog #</div>
            <div class="cfg-sku" id="cfgSku">LFLD3W80-3E1-UD/PS</div>
            <button type="button" class="cfg-sku-copy" id="cfgSkuCopy">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <span id="cfgSkuCopyLabel">Copy SKU</span>
            </button>
          </div>
          <!-- CFG-STATE-1: ship-tier indicator derived from chip badges (QS/MTO/WB).
               Shows "QuickShip · à-la-carte assembly" when every selected chip is QS,
               "Workbench Assembly" when any chip is WB, "Made-to-Order" when any chip
               is MTO or finish=Custom RAL. Updates on every chip click. -->
          <div id="cfgShipTier" style="margin: 12px 0 6px; padding: 10px 14px; border-radius: 3px; font-family: 'JetBrains Mono', monospace; font-size: 11px; line-height: 1.5; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
            <span id="cfgShipTierIcon" style="display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; flex-shrink: 0;"></span>
            <span id="cfgShipTierText" style="flex: 1; min-width: 200px;">— deriving ship tier —</span>
            <span id="cfgShipTierStock" style="font-size: 10px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--text-muted);"></span>
          </div>


          <div id="cfgMountSku" style="margin: 6px 0 12px; padding: 8px 14px; border-radius: 3px; font-family: 'JetBrains Mono', monospace; font-size: 11px; background: rgba(255,255,255,0.04); color: var(--text-secondary); display: none;">
            <span style="opacity:0.6;">+ Mount accessory:</span> <code id="cfgMountSkuCode">LFLD-KN</code>
