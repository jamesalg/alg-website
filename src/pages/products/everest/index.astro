              <button type="button" class="cfg-chip selected" data-field="cct" data-val="50" data-code="50" aria-pressed="true" data-info="dip-only">
                <span class="cfg-chip-stock" style="background:rgba(96,168,255,0.14); color:#7fb6ff; border:1px solid rgba(96,168,255,0.40);">DIP</span>
                <span class="cfg-chip-val">5000K · cool ★</span>
