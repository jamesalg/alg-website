    justify-content: center;
    gap: 40px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .photo-control-group { display: flex; flex-direction: column; align-items: center; gap: 10px; }
  .photo-control-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--text-muted);
    text-transform: uppercase;
  }
  .photo-control-tabs { display: flex; gap: 6px; }
  .photo-tab {
    background: transparent;
    border: 1px solid var(--line-medium);
    color: var(--text-secondary);
    padding: 9px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
