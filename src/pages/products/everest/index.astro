      cta: '/pdfs/lfld-e1-tn-spec.pdf', img: '<svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="40" y="70" width="160" height="68" rx="6" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.85)"/><path d="M 24 138 L 24 200 L 216 200 L 216 138" stroke="rgba(255,255,255,0.85)" stroke-width="3" fill="none"/><circle cx="40" cy="104" r="6" fill="rgba(255,255,255,0.85)"/><circle cx="200" cy="104" r="6" fill="rgba(255,255,255,0.85)"/><text x="120" y="115" font-family="JetBrains Mono, monospace" font-size="13" font-weight="700" text-anchor="middle" fill="#F32740" stroke="none">TRUNNION</text></svg>'
    },
    'mount-yk': {
      cat: 'Mount \u00B7 YK', title: 'Yoke Mount', sku: 'LFLD-YK',
      desc: 'Yoke mount with two side-pivot brackets for ground-stake, beam-clamp, or wall-flush installations. Compatible with all 3 Everest housings. \u00B1180\u00B0 vertical pivot &mdash; the most adjustable of the four mounts &mdash; commonly used for fa\u00E7ade up-light, monument signage, and walkway grade-mount applications where the aim must be fine-tuned post-install. Welded steel yoke arms \u00B7 stainless cross-pivot bolts \u00B7 factory-matched dark-bronze finish.',
