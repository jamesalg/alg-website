              <button type="button" class="cfg-chip" data-field="mount" data-val="SF" data-code="SF" aria-pressed="false">
                <span class="cfg-chip-stock qs">QS</span>
                <span class="cfg-chip-val">/SF · Slip-Fitter Mount</span>
                <span class="cfg-chip-code">/SF</span>
