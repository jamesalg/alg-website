        <!-- ===== DIP-set previews — informational, not in SKU ===== -->
        <div style="margin-top: 12px; padding-top: 18px; border-top: 1px solid var(--line); display:flex; align-items:center; gap:10px;">
          <div style="font-family:'JetBrains Mono', monospace; font-size:10.5px; letter-spacing:0.10em; text-transform:uppercase; font-weight:700; color:var(--text-secondary);">Field-Set at Install</div>
          <div style="font-family:'JetBrains Mono', monospace; font-size:9px; padding:2px 5px; border-radius:1px; background:rgba(96,168,255,0.14); color:#7fb6ff; border:1px solid rgba(96,168,255,0.40); letter-spacing:0.10em;">DIP</div>
        </div>
        <div class="cfg-fields" style="margin-top: 14px;">

          <!-- WATTSELECT — DIP preview, varies per housing -->
