    }
  };

  function init() {
    var modal = document.getElementById('accModal');
    if (!modal) return;
    var imgEl = document.getElementById('accModalImg');
    var catEl = document.getElementById('accModalCat');
    var titleEl = document.getElementById('accModalTitle');
    var skuEl = document.getElementById('accModalSku');
    var descEl = document.getElementById('accModalDesc');
    var ctaEl = document.getElementById('accModalCta');

    function open(id) {
      var d = DATA[id]; if (!d) return;
      imgEl.innerHTML = d.img;
      catEl.textContent = d.cat;
      titleEl.textContent = d.title;
      skuEl.innerHTML = '<code>' + d.sku + '</code>';
      descEl.innerHTML = d.desc;
      ctaEl.href = d.cta;
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
    }
    function close() {
      modal.classList.remove('open');
      modal.setAttribute('aria-hidden', 'true');
    }

    document.querySelectorAll('#accGrid .acc-card').forEach(function(c) {
      c.addEventListener('click', function() { open(c.dataset.id); });
    });
    document.querySelectorAll('[data-modal-close]').forEach(function(b) {
      b.addEventListener('click', close);
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) close();
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
