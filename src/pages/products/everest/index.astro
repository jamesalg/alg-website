<script>
/* =============================================================================
   SECTION 9 \u2014 Everest Configurator engine
   2 user choices (Housing + Finish) \u00B7 2 auto-locked (Voltage U + Photocell PS)
   1 optional add-on (Mount: KN / SF / TN / YK) with housing-compatibility
   constraints. WATTSELECT + CCTSELECT are field-set DIPs at install (preview-
   only \u00B7 do not appear in SKU).
   SKU pattern:
       LFLD{housing}-3E1-U{finish}/PS
   Mount accessory ordered separately as: LFLD-{KN|SF|TN|YK}
   Examples:
       LFLD3W80-3E1-UD/PS                      \u2190 default \u00B7 workhorse
       LFLD3W150-3E1-UD/PS  +  LFLD-TN        \u2190 largest housing + trunnion
       LFLD3W35-3E1-UB/PS                     \u2190 smallest housing \u00B7 Black MTO
   ============================================================================= */
(function() {
  // Per-housing wattage matrix (datasheet pg 2 Model Specifications)
  var WATT_OPTIONS = {
    '3W35':  [{ k: '15',  l: '15W'  }, { k: '20',  l: '20W'  }, { k: '35',  l: '35W \u2605' }],
    '3W80':  [{ k: '35',  l: '35W'  }, { k: '60',  l: '60W'  }, { k: '80',  l: '80W \u2605' }],
    '3W150': [{ k: '100', l: '100W' }, { k: '120', l: '120W' }, { k: '150', l: '150W \u2605' }]
  };
  var WATT_DEFAULT = { '3W35': '35', '3W80': '80', '3W150': '150' };
  var LUMENS_BY_HOUSING_W = {
    '3W35':  { '15': '2,100', '20': '2,800', '35': '4,900' },
    '3W80':  { '35': '4,900', '60': '8,400', '80': '11,200' },
    '3W150': { '100': '14,000', '120': '16,800', '150': '21,000' }
  };
  var SIZING_BY_HOUSING = {
    '3W35':  '6.93 \u00D7 5.89 \u00D7 2.29 in',
    '3W80':  '9.49 \u00D7 7.25 \u00D7 2.84 in',
    '3W150': '11.85 \u00D7 9.03 \u00D7 3.64 in'
  };
  var HOUSING_LABEL = {
    '3W35':  'LFLD3W35 \u00B7 Everest-I',
    '3W80':  'LFLD3W80 \u00B7 Everest-II',
    '3W150': 'LFLD3W150 \u00B7 Everest-III'
  };
  var FINISH_LBL = {
    'D': 'Dark Bronze (QS)',
    'B': 'Black (MTO)',
    'W': 'White (MTO)'
  };
  var FINISH_TAG = {
    'D': 'DARK BRONZE',
    'B': 'BLACK',
    'W': 'WHITE'
  };
  var FINISH_FILTER_CLASS = {
    'D': 'fs-D',
    'B': 'fs-B',
    'W': 'fs-W'
  };
  var MOUNT_LBL = {
    '':   '\u2014 none (mount sold separately) \u2014',
    'KN': '/KN \u00B7 Knuckle Mount (LFLD-KN)',
    'SF': '/SF \u00B7 Slip-Fitter Mount (LFLD-SF)',
    'TN': '/TN \u00B7 Trunnion Mount (LFLD-TN)',
    'YK': '/YK \u00B7 Yoke Mount (LFLD-YK)'
  };
  // Mount \u00D7 housing compatibility matrix
  var MOUNT_VALID = {
    '3W35':  { 'KN': true, 'SF': false, 'TN': false, 'YK': true },
    '3W80':  { 'KN': true, 'SF': true,  'TN': false, 'YK': true },
    '3W150': { 'KN': true, 'SF': true,  'TN': true,  'YK': true }
  };
  var CCT_LABEL = { '30': '3000K', '40': '4000K', '50': '5000K' };

  function defaultState() {
    return {
      housing: '3W80',
      voltage: 'U',
      finish:  'D',
      mount:   '',
      ps:      'PS',
      watt:    '80',  // factory default for LFLD3W80
      cct:     '50'   // datasheet default 5000K
    };
  }
  var state = defaultState();

  // Quick Pick combo presets
  var QUICKPICKS = {
    'ii-workhorse':  { housing: '3W80',  finish: 'D', mount: '', watt: '80',  cct: '50' },
    'iii-flagship':  { housing: '3W150', finish: 'D', mount: 'TN', watt: '150', cct: '50' }
  };

  function buildSku() {
    return 'LFLD' + state.housing + '-3E1-U' + state.finish + '/PS';
  }
  function mountSku() {
    return state.mount ? 'LFLD-' + state.mount : '';
  }

  function setChip(field, val) {
    document.querySelectorAll('.cfg-chip[data-field="' + field + '"]').forEach(function(c) {
      var match = c.getAttribute('data-val') === val;
      c.classList.toggle('selected', match);
      c.setAttribute('aria-pressed', match ? 'true' : 'false');
    });
  }

  function rebuildWattChips() {
    var container = document.getElementById('cfgWattChips');
    if (!container) return;
    var opts = WATT_OPTIONS[state.housing] || [];
    container.innerHTML = '';
    opts.forEach(function(o) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'cfg-chip' + (o.k === state.watt ? ' selected' : '');
      btn.setAttribute('data-field', 'watt');
      btn.setAttribute('data-val', o.k);
      btn.setAttribute('data-code', o.k);
      btn.setAttribute('aria-pressed', o.k === state.watt ? 'true' : 'false');
      btn.setAttribute('data-info', 'dip-only');
      btn.innerHTML =
        '<span class="cfg-chip-stock" style="background:rgba(96,168,255,0.14); color:#7fb6ff; border:1px solid rgba(96,168,255,0.40);">DIP</span>' +
        '<span class="cfg-chip-val">' + o.l + '</span>' +
        '<span class="cfg-chip-code">DIP set at install \u00B7 not in SKU</span>';
      btn.addEventListener('click', function() {
        state.watt = o.k;
        rebuildWattChips();
        render();
      });
      container.appendChild(btn);
    });
  }

  function applyMountConstraints() {
    var validMap = MOUNT_VALID[state.housing] || {};
    document.querySelectorAll('.cfg-chip[data-field="mount"]').forEach(function(c) {
      var v = c.getAttribute('data-val');
      if (v === '') { c.classList.remove('disabled'); return; }
      var ok = !!validMap[v];
      c.classList.toggle('disabled', !ok);
      c.style.opacity = ok ? '' : '0.4';
      c.style.pointerEvents = ok ? '' : 'none';
      // If currently-selected mount is no longer valid, snap back to None
      if (!ok && state.mount === v) {
        state.mount = '';
        setChip('mount', '');
      }
    });
  }

  function render() {
    // Update preview tag + finish filter
    var imgWrap = document.getElementById('cfgPreviewImgWrap');
    if (imgWrap) {
      ['fs-D', 'fs-B', 'fs-W'].forEach(function(c) { imgWrap.classList.remove(c); });
      imgWrap.classList.add(FINISH_FILTER_CLASS[state.finish] || 'fs-D');
    }
    var tag = document.getElementById('cfgPreviewTag');
    if (tag) tag.textContent = state.housing.toUpperCase().replace('3W', 'LFLD3W') + ' \u00B7 ' + (FINISH_TAG[state.finish] || 'DARK BRONZE');

    // SKU
    document.getElementById('cfgSku').textContent = buildSku();

    // Mount accessory line
    var mountWrap = document.getElementById('cfgMountSku');
    var mountCode = document.getElementById('cfgMountSkuCode');
    if (state.mount) {
      mountWrap.style.display = 'block';
      mountCode.textContent = mountSku();
    } else {
      mountWrap.style.display = 'none';
    }

    // Spec grid
    document.getElementById('cfgSpecHousing').textContent = HOUSING_LABEL[state.housing] || '\u2014';
    document.getElementById('cfgSpecFinish').textContent  = FINISH_LBL[state.finish] || '\u2014';
    document.getElementById('cfgSpecMount').textContent   = MOUNT_LBL[state.mount] || '\u2014 none \u2014';
    document.getElementById('cfgSpecWatt').textContent    = state.watt + 'W' + (state.watt === WATT_DEFAULT[state.housing] ? ' \u2605' : '');
    document.getElementById('cfgSpecCct').textContent     = (CCT_LABEL[state.cct] || '5000K') + (state.cct === '50' ? ' \u2605' : '');
    document.getElementById('cfgSpecSize').textContent    = SIZING_BY_HOUSING[state.housing] || '\u2014';
    var lumens = (LUMENS_BY_HOUSING_W[state.housing] || {})[state.watt] || '\u2014';
    document.getElementById('cfgSpecLumens').innerHTML    = lumens + ' lm \u00B7 140 lm/W flat across the matrix \u00B7 CRI &gt;80 \u00B7 DLC Listed';

    // Submittal CTA
    var sub = document.getElementById('cfgCtaSubmittal');
    if (sub) {
      // CFG-QA-1 \u00B7 param-name contract \u2014 submittal_template.html URL-param parser
      // reads 'wattage' (not 'watt'). Emit &wattage= here, otherwise the parser
      // falls through to the wattage default ('80') and the housing default-fill
      // resolves to 3W80 regardless of what the configurator picked.
      // Reproduce the bug by changing &wattage= back to &watt=, configuring 150W,
      // and clicking Generate Submittal \u2014 output renders LFLD3W80, not LFLD3W150.
      sub.href = 'submittal_template.html?product=everest&housing=' + state.housing + '&wattage=' + state.watt + '&cct=' + state.cct + '&voltage=U&finish=' + state.finish + '&mount=' + (state.mount || '');
    }

    // Counter band \u2014 Housing + Finish are the 2 user-pickable required fields
    var count = (state.housing ? 1 : 0) + (state.finish ? 1 : 0);
    document.getElementById('cfgCounterCount').textContent = count;
    var counter = document.getElementById('cfgCounter');
    if (counter) counter.classList.toggle('complete', count === 2);
  }

  function applyQuickPick(key) {
    var qp = QUICKPICKS[key];
    if (!qp) return;
    state.housing = qp.housing;
    state.finish  = qp.finish;
    state.mount   = qp.mount;
    state.watt    = qp.watt;
    state.cct     = qp.cct;
    setChip('housing', state.housing);
    setChip('finish', state.finish);
    setChip('mount', state.mount);
    setChip('cct', state.cct);
    rebuildWattChips();
    applyMountConstraints();
    render();
    // Scroll to LIVE PREVIEW
    var preview = document.querySelector('.cfg-preview-wrap');
    if (preview) preview.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function init() {
    // Wire chip clicks for housing / finish / mount / cct (watt rebuilt per-housing)
    document.querySelectorAll('.cfg-chip[data-field]').forEach(function(c) {
      var field = c.getAttribute('data-field');
      if (field === 'voltage' || field === 'ps') return;  // locked
      if (field === 'watt') return;  // dynamically built
      c.addEventListener('click', function() {
        if (c.classList.contains('disabled')) return;
        var val = c.getAttribute('data-val');
        state[field] = val;
        setChip(field, val);
        if (field === 'housing') {
          // Reset wattage to housing default; re-validate mount
          state.watt = WATT_DEFAULT[state.housing];
          rebuildWattChips();
          applyMountConstraints();
        }
        render();
      });
    });
    // Quick-pick cards
    document.querySelectorAll('.cfg-quickpick-card').forEach(function(c) {
      c.addEventListener('click', function() {
        applyQuickPick(c.getAttribute('data-quickpick'));
      });
    });
    // Reset button
    var reset = document.getElementById('cfgReset');
    if (reset) reset.addEventListener('click', function() {
      state = defaultState();
      setChip('housing', state.housing);
      setChip('finish', state.finish);
      setChip('mount', state.mount);
      setChip('cct', state.cct);
      rebuildWattChips();
      applyMountConstraints();
      render();
    });
    // Copy SKU button
    var copyBtn = document.getElementById('cfgSkuCopy');
    var copyLabel = document.getElementById('cfgSkuCopyLabel');
    if (copyBtn) copyBtn.addEventListener('click', function() {
      var sku = document.getElementById('cfgSku').textContent;
      var combined = sku + (state.mount ? ' + LFLD-' + state.mount : '');
      if (navigator.clipboard) navigator.clipboard.writeText(combined);
      if (copyLabel) {
        copyLabel.textContent = 'Copied!';
        setTimeout(function() { copyLabel.textContent = 'Copy SKU'; }, 1200);
      }
    });
    // Initial render
    rebuildWattChips();
    applyMountConstraints();
    render();
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
