  }
  .photo-stat-sub {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 4px;
  }
  .photo-bug {
    display: flex;
    gap: 8px;
    align-items: baseline;
    margin-top: 4px;
  }
  .photo-bug-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    color: white;
    background: rgba(243,39,64,0.25);
    border: 1px solid rgba(243,39,64,0.5);
    padding: 3px 8px;
    border-radius: 2px;
  }
  .photo-download {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--text-secondary);
    font-size: 13px;
    font-weight: 700;
    margin-top: 6px;
    transition: color 0.18s;
    text-decoration: none;
  }
  .photo-download:hover { color: var(--brand-red); }
  .photo-download svg { width: 14px; height: 14px; }
  @media (max-width: 1100px) {
    .photo-display { grid-template-columns: 1fr; }
    .photo-title { font-size: 28px; }
  }

  /* ============================================================================
     SECTION 6 — contrⒶLS · Multi-Functional / Bi-Level / Photocell
     Full-bleed dark backdrop with red dot mesh radiating from the centered
     control-panel image. Same pattern as Sentinel; Guardian-specific copy
     emphasizes the integrated dusk-to-dawn photocell + 0-10V dimming +
     sensor-ready terminals shipped on every fixture.
     ============================================================================ */
  .tac-section {
    position: relative;
    background: #0a0e14;
    overflow: hidden;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    min-height: 560px;
  }
  .tac-mesh-overlay {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1.2px 1.2px, rgba(243,39,64,0.78) 1.2px, transparent 1.6px);
    background-size: 14px 14px;
    -webkit-mask-image: radial-gradient(circle at 25% 50%,
      black 0%,
      rgba(0,0,0,0.95) 18%,
      rgba(0,0,0,0.72) 35%,
      rgba(0,0,0,0.42) 55%,
      rgba(0,0,0,0.18) 78%,
      rgba(0,0,0,0.05) 100%);
            mask-image: radial-gradient(circle at 25% 50%,
      black 0%,
      rgba(0,0,0,0.95) 18%,
      rgba(0,0,0,0.72) 35%,
      rgba(0,0,0,0.42) 55%,
      rgba(0,0,0,0.18) 78%,
      rgba(0,0,0,0.05) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .tac-shockwave {
    position: absolute;
    left: 25%;
    top: 50%;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 2px solid rgba(243, 39, 64, 0.85);
    transform: translate(-50%, -50%);
    pointer-events: none;
    opacity: 0;
    z-index: 1;
  }
  .tac-shockwave.is-rippling { animation: tac-shockwave 1.4s ease-out; }
  @keyframes tac-shockwave {
    0%   { width: 60px;   height: 60px;   opacity: 1; border-width: 3px; }
    60%  {                                opacity: 0.55; }
    100% { width: 1400px; height: 1400px; opacity: 0; border-width: 0.5px; }
  }
  .tac-sensor-area {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    pointer-events: none;
  }
  .tac-sensor-svg {
    position: absolute;
    width: 60%;
    max-width: 380px;
    height: auto;
    opacity: 0;
    transform: scale(0.94);
    transition: opacity 0.5s ease, transform 0.55s cubic-bezier(0.2, 0.6, 0.2, 1);
    filter: drop-shadow(0 16px 48px rgba(0,0,0,0.6));
  }
  .tac-sensor-svg.is-active {
    opacity: 0.96;
    transform: scale(1);
  }
  .tac-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 28%, rgba(10,14,20,0.4) 55%, rgba(10,14,20,0.7) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .tac-grid {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 88px 32px 96px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .tac-spacer { /* left half placeholder so backdrop sensor shows through */ }
  .tac-content { color: var(--text-primary); max-width: 580px; }
  .tac-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .tac-eyebrow::before {
    content: "";
    display: inline-block;
    width: 28px; height: 1px;
    background: var(--brand-red);
  }
  .tac-title {
    font-size: 38px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin-bottom: 18px;
    white-space: nowrap;
  }
  .tac-desc {
    font-size: 15.5px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 28px;
  }
  .tac-callout {
    border: 1px solid rgba(243,39,64,0.4);
    border-radius: 4px;
    background: rgba(20,23,27,0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    overflow: hidden;
  }
  .tac-callout-tabs { display: flex; background: rgba(0,0,0,0.25); }
  .tac-callout-tab {
    flex: 1;
    background: transparent;
    border: 0;
    padding: 13px 18px;
    font-family: inherit;
    font-size: 13px;
    font-weight: 700;
    color: var(--text-secondary);
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: background 0.18s, color 0.18s;
    border-right: 1px solid rgba(255,255,255,0.08);
    text-align: center;
  }
  .tac-callout-tab:last-child { border-right: 0; }
  .tac-callout-tab:hover { color: var(--text-primary); background: rgba(255,255,255,0.05); }
  .tac-callout-tab.active { background: var(--brand-red); color: white; }
  .tac-callout-body { padding: 22px 24px 22px; }
  .tac-callout-body p {
    font-size: 14px;
    color: var(--text-primary);
    line-height: 1.6;
    margin-bottom: 14px;
  }
  .tac-callout-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 13.5px;
    cursor: pointer;
    transition: color 0.18s;
    text-decoration: none;
  }
  .tac-callout-link:hover { color: var(--brand-red); }
  .tac-callout-link svg { width: 16px; height: 16px; color: var(--brand-red); flex-shrink: 0; }

  @media (max-width: 1100px) {
    .tac-grid { grid-template-columns: 1fr; gap: 32px; padding-top: 64px; }
    .tac-sensor-area { position: relative; width: 100%; height: 240px; }
    .tac-title { font-size: 30px; }
  }

  /* ============================================================================
     SECTION 4 — Highlights & Features (7-tile collage, parity w/ Sentinel pattern)
     ============================================================================ */
  .hf-section {
    background: var(--bg-page);
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .hf-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .hf-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--brand-red);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 16px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
  }
  .hf-eyebrow::before, .hf-eyebrow::after {
    content: ""; display: block;
    width: 28px; height: 1px;
    background: var(--brand-red);
  }
  .hf-title {
    text-align: center;
    font-size: 38px;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin-bottom: 12px;
    line-height: 1.05;
  }
  .hf-sub {
    text-align: center;
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: 48px;
    max-width: 780px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
  .hf-grid { display: grid; gap: 12px; }
  .hf-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .hf-tile {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    background: linear-gradient(135deg, #2a2e34 0%, #14171b 100%);
    aspect-ratio: 16/9;
    cursor: default;
    transition: transform 0.3s ease;
  }
  .hf-tile:hover { transform: translateY(-2px); }
  .hf-tile-hero { aspect-ratio: 24/9; }
  .hf-tile-image {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
  }
  .hf-tile-image img,
  .hf-tile-image video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }
  /* Video tiles cover-fill (sports clips are wider than the tile aspect; cover
     keeps the action centered without letterboxing). Per James 2026-05-03 PM:
     Section 4 uses production Shopify CDN .mp4 clips inline-autoplay-muted-loop
     so each feature claim sits adjacent to its proof video. */
  .hf-tile-image video { object-fit: cover; }
  /* Tile-specific crop adjustments. Some inherited from prior PDPs; overrides
     for Everest video tiles defined inline below. */
  .hf-tile-hero .hf-tile-image img      { object-fit: cover; object-position: center 40%; }
  .hf-tile-grad-2 .hf-tile-image img    { object-fit: cover; object-position: center 50%; transform: scale(1.6); transform-origin: center 55%; }
  .hf-tile-grad-3 .hf-tile-image img    { object-fit: contain; transform: scale(1.05); }
  .hf-tile-grad-4 .hf-tile-image img    { object-fit: contain; transform: scale(0.95); }
  .hf-tile-grad-5 .hf-tile-image img    { object-fit: cover; object-position: center 45%; transform: scale(1.1); }
  .hf-tile-grad-6 .hf-tile-image img    { object-fit: contain; transform: scale(0.95); }
  .hf-tile-grad-7 .hf-tile-image img    { object-fit: contain; transform: scale(1.05); }
  .hf-tile-overlay {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 32px 36px 28px;
    background: linear-gradient(to top, rgba(0,0,0,0.92) 20%, rgba(0,0,0,0.5) 70%, transparent 100%);
    color: white;
  }
  .hf-tile-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .hf-tile-overlay h3 {
    font-size: 30px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.005em;
    margin-bottom: 6px;
  }
  .hf-tile-hero .hf-tile-overlay h3 { font-size: 42px; }
  .hf-tile-overlay p {
    font-size: 14px;
    color: rgba(255,255,255,0.78);
    line-height: 1.55;
    max-width: 540px;
  }
  .hf-tile-grad-1 { background: linear-gradient(135deg, #2c2620 0%, #14110d 100%); }
  .hf-tile-grad-2 { background: linear-gradient(135deg, #1a3656 0%, #0a1a2e 100%); }
  .hf-tile-grad-3 { background: linear-gradient(135deg, #2a3338 0%, #14171b 100%); }
  .hf-tile-grad-4 { background: linear-gradient(135deg, #1c2a30 0%, #0e171b 100%); }
  .hf-tile-grad-5 { background: linear-gradient(135deg, #2a2520 0%, #14110d 100%); }
  .hf-tile-grad-6 { background: linear-gradient(135deg, #1a2e3a 0%, #0d1822 100%); }
  .hf-tile-grad-7 { background: linear-gradient(135deg, #2a2e34 0%, #14171b 100%); }
  @media (max-width: 900px) {
    .hf-row-2 { grid-template-columns: 1fr; }
    .hf-title { font-size: 28px; }
    .hf-tile-overlay h3 { font-size: 22px; }
    .hf-tile-hero .hf-tile-overlay h3 { font-size: 28px; }
  }

  /* Responsive — single-column hero on narrow screens */
  @media (max-width: 1024px) {
    .header-inner { padding: 14px 18px; }
    .hero-grid { grid-template-columns: 1fr; gap: 32px; }
    .hero h2 { font-size: 36px; white-space: normal; }
    .hero-stats { flex-wrap: wrap; }
    nav.primary { display: none; }
    .sticky-nav { width: calc(100% - 32px); overflow-x: auto; justify-content: flex-start; }
  }

  /* ============================================================================
     SECTION 10 — Documentation & Resources
     Spec-mode pattern: 4-card primary grid (Datasheet, Install Guide, IES bundle,
     Submittal Generator) + secondary quick-link row (Quick Sheet, Sell Sheet,
     Rebate Center, Warranty). Each card is a real download trigger. CSS lifted
     from Sentinel Section 9 — kept identical for visual consistency across PDPs.
     ============================================================================ */
  .docs-section {
    background: var(--bg-page);
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .docs-inner { max-width: 1400px; margin: 0 auto; padding: 0 32px; }
  .docs-head  { text-align: center; margin-bottom: 48px; }
  .docs-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.18em;
    color: var(--brand-red);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: inline-flex; align-items: center; gap: 12px;
  }
  .docs-eyebrow::before, .docs-eyebrow::after {
    content: ""; display: block; width: 28px; height: 1px; background: var(--brand-red);
  }
  .docs-title {
    font-size: 38px; font-weight: 700;
    letter-spacing: -0.005em; margin-bottom: 12px; line-height: 1.05;
  }
  .docs-sub {
    font-size: 15px; color: var(--text-secondary);
    max-width: 720px; margin: 0 auto; line-height: 1.6;
  }

  .docs-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 18px; margin-bottom: 32px;
  }
  .docs-card {
    background: var(--bg-spec); border: 1px solid var(--line);
    border-radius: 4px; padding: 28px 24px 24px;
    display: flex; flex-direction: column; gap: 14px;
    cursor: pointer; text-decoration: none; color: inherit;
    transition: border-color 0.2s, transform 0.2s, background 0.2s;
    position: relative; overflow: hidden;
  }
  .docs-card::before {
    content: ""; position: absolute; top: 0; left: 0;
    height: 3px; width: 0; background: var(--brand-red);
    transition: width 0.25s ease;
  }
  .docs-card:hover {
    border-color: rgba(243,39,64,0.45);
    transform: translateY(-2px); background: #2e3239;
  }
  .docs-card:hover::before { width: 100%; }

  .docs-card-head {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 14px;
  }
  .docs-card-icon {
    width: 56px; height: 56px;
    border-radius: 4px;
    background: rgba(243,39,64,0.10);
    border: 1px solid rgba(243,39,64,0.30);
    color: var(--brand-red);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .docs-card-icon svg { width: 28px; height: 28px; }
  .docs-card-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
  .docs-card-format {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--text-muted);
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--line-medium);
    padding: 3px 8px; border-radius: 1px;
  }
  .docs-card-size {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--text-muted); letter-spacing: 0.06em;
  }

  .docs-card-title {
    font-size: 18px; font-weight: 700;
    color: var(--text-primary); line-height: 1.25;
    letter-spacing: -0.005em;
  }
  .docs-card-desc {
    font-size: 13.5px; color: var(--text-secondary);
    line-height: 1.55; flex: 1;
  }
  .docs-card-foot {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 6px; padding-top: 14px;
    border-top: 1px solid var(--line);
  }
  .docs-card-cta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.10em; text-transform: uppercase;
    color: var(--brand-red);
    display: inline-flex; align-items: center; gap: 8px;
    transition: gap 0.18s;
  }
  .docs-card:hover .docs-card-cta { gap: 12px; }
  .docs-card-cta svg { width: 14px; height: 14px; }
  .docs-card-updated {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px; color: var(--text-muted); letter-spacing: 0.06em;
  }

  .docs-secondary {
    background: var(--bg-spec); border: 1px solid var(--line);
    border-radius: 4px; padding: 20px 24px;
    display: grid; grid-template-columns: auto 1fr;
    gap: 10px 28px; align-items: center;
  }
  .docs-secondary-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--brand-red);
    font-weight: 700; white-space: nowrap;
  }
  .docs-secondary-links { display: flex; flex-wrap: wrap; gap: 6px 22px; }
  .docs-secondary-link {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--text-secondary); font-size: 13px; font-weight: 600;
    transition: color 0.18s; white-space: nowrap; cursor: pointer;
    text-decoration: none;
  }
  .docs-secondary-link:hover { color: var(--brand-red); }
  .docs-secondary-link svg {
    width: 14px; height: 14px;
    color: var(--text-muted); transition: color 0.18s;
  }
  .docs-secondary-link:hover svg { color: var(--brand-red); }

  @media (max-width: 1280px) { .docs-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 1100px) { .docs-secondary { grid-template-columns: 1fr; gap: 10px; } }
  @media (max-width: 720px)  { .docs-grid { grid-template-columns: 1fr; } }
  /* 4-card grid resolves to 4 → 2 → 1 across breakpoints — matches the 3-card
     pattern from Atlanta but adds the IES Bundle as a peer of Datasheet
     after James 2026-05-02 elevated it from quick-link to primary card. */

  /* ============================================================================
     SECTION 11 — Wall Pack Family (direct siblings within the LWPF Wall Pack line).
     CSS lifted from Sentinel Section 10 — kept identical for visual consistency.
     Guardian uses a 4-card grid (Anaheim · Sentinel · Guardian · Nightwatch) so
     the SLIM positioning sits directly next to its CLASSIC counterpart.
     ============================================================================ */
  .wp-family-section {
    background: var(--bg-page);
    padding: 88px 0 96px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .wp-family-inner { max-width: 1400px; margin: 0 auto; padding: 0 32px; }
  .wp-family-head { text-align: center; margin-bottom: 40px; }
  .wp-family-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-top: 40px;
  }
  .wp-family-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.18em;
