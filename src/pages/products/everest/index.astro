  // Per-housing wattage tab specs
  var WATT_OPTIONS = {
    'E1': [{ k: '15',  l: '15W' },  { k: '20',  l: '20W' },  { k: '35',  l: '35W \u2605' }],
    'E2': [{ k: '35',  l: '35W' },  { k: '60',  l: '60W' },  { k: '80',  l: '80W \u2605' }],
    'E3': [{ k: '100', l: '100W' }, { k: '120', l: '120W' }, { k: '150', l: '150W \u2605' }]
  };
  var WATT_DEFAULT = { 'E1': '35', 'E2': '80', 'E3': '150' };

  var state = { housing: 'E2', watt: '80', cct: '50' };

  function rebuildWattTabs() {
    var container = document.getElementById('photoWattTabs');
    if (!container) return;
    var opts = WATT_OPTIONS[state.housing] || [];
    container.innerHTML = '';
    opts.forEach(function(o) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'spec-watt-tab' + (o.k === state.watt ? ' active' : '');
      btn.setAttribute('data-photo-watt', o.k);
      btn.setAttribute('role', 'tab');
      btn.setAttribute('aria-selected', o.k === state.watt ? 'true' : 'false');
      btn.textContent = o.l;
      btn.addEventListener('click', function() {
        state.watt = o.k;
        rebuildWattTabs();
        render();
      });
      container.appendChild(btn);
    });
  }

  function render() {
    var d = (PHOTO[state.housing] || {})[state.watt];
    if (!d) return;
    d = d[state.cct];
    if (!d) return;

    var img = document.getElementById('photoImg');
    if (img) {
      img.src = svgPath(HOUSING_MAX[state.housing], state.watt, state.cct);
      img.alt = HOUSING_LABEL[state.housing] + ' LFLD3W' + HOUSING_MAX[state.housing] + ' \u00B7 ' + state.watt + 'W setting \u00B7 ' + state.cct + '00K \u00B7 3E1 forward-throw glass-optic distribution \u00B7 LM-79 measured polar plot';
    }
    var elPeak = document.getElementById('photoStatPeak');
    var elPeakSub = document.getElementById('photoStatPeakSub');
    var elLumens = document.getElementById('photoStatLumens');
    var elLpw = document.getElementById('photoStatLpw');
    var elDraw = document.getElementById('photoStatDraw');
    var elFile = document.getElementById('photoStatFile');
    if (elPeak) elPeak.textContent = d.peak;
    if (elPeakSub) elPeakSub.textContent = '3E1 forward throw at ' + state.watt + 'W \u00B7 ' + state.cct + '00K';
    if (elLumens) elLumens.textContent = d.lumens;
    if (elLpw) elLpw.innerHTML = d.lpw;
    if (elDraw) elDraw.textContent = d.draw;
    if (elFile) elFile.textContent = 'LFLD3W' + HOUSING_MAX[state.housing] + '-3E1-UD-PS-' + state.watt + 'W-' + state.cct + 'K_IESNA2002.IES (LM-79 measured)';
  }

  function init() {
    document.querySelectorAll('[data-photo-housing]').forEach(function(b) {
      b.addEventListener('click', function() {
        document.querySelectorAll('[data-photo-housing]').forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        b.classList.add('active');
        b.setAttribute('aria-selected', 'true');
        state.housing = b.getAttribute('data-photo-housing');
        state.watt = WATT_DEFAULT[state.housing];
        rebuildWattTabs();
        render();
      });
    });
    document.querySelectorAll('[data-photo-cct]').forEach(function(b) {
      b.addEventListener('click', function() {
        document.querySelectorAll('[data-photo-cct]').forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
          x.style.background = 'transparent';
          x.style.color = 'var(--text-secondary)';
        });
        b.classList.add('active');
        b.setAttribute('aria-selected', 'true');
        b.style.background = 'var(--brand-red)';
        b.style.color = 'white';
        state.cct = b.getAttribute('data-photo-cct');
        render();
      });
    });
    rebuildWattTabs();
    render();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
