            <div class="cfg-spec-cell"><div class="cfg-spec-cell-key">Voltage</div><div class="cfg-spec-cell-val">U · 120-277V universal</div></div>
            <div class="cfg-spec-cell"><div class="cfg-spec-cell-key">Finish</div><div class="cfg-spec-cell-val" id="cfgSpecFinish">Dark Bronze (QS)</div></div>
            <div class="cfg-spec-cell"><div class="cfg-spec-cell-key">Photocell</div><div class="cfg-spec-cell-val">/PS · built-in (standard)</div></div>
            <div class="cfg-spec-cell"><div class="cfg-spec-cell-key">Mount</div><div class="cfg-spec-cell-val" id="cfgSpecMount">— none —</div></div>
            <div class="cfg-spec-cell"><div class="cfg-spec-cell-key">Wattage (DIP)</div><div class="cfg-spec-cell-val" id="cfgSpecWatt">80W ★</div></div>
            <div class="cfg-spec-cell"><div class="cfg-spec-cell-key">CCT (DIP)</div><div class="cfg-spec-cell-val" id="cfgSpecCct">5000K ★</div></div>
            <div class="cfg-spec-cell"><div class="cfg-spec-cell-key">Sizing</div><div class="cfg-spec-cell-val" id="cfgSpecSize">9.49 × 7.25 × 2.84 in</div></div>
            <div class="cfg-spec-cell" style="grid-column: 1 / -1;"><div class="cfg-spec-cell-key">Output</div><div class="cfg-spec-cell-val" id="cfgSpecLumens">11,200 lm · 140 lm/W flat across the matrix · CRI &gt;80 · DLC Listed</div></div>
          </div>

          <div class="cfg-cta-row">
