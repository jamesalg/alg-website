<script>
(function() {
  function init() {
    document.querySelectorAll('a.family-card[data-quickpick-target]').forEach(function(card) {
      card.addEventListener('click', function(e) {
        var key = card.dataset.quickpickTarget;
        if (!key) return;
        // Find the matching Quick Pick button in Section 9 and trigger it.
        var quickPick = document.querySelector('.cfg-quickpick-card[data-quickpick="' + key + '"]');
        if (quickPick) {
          e.preventDefault();
          quickPick.click();
          // The configurator's applyQuickPick() already scrolls into view.
        }
        // If the Quick Pick didn't bind (unlikely), let the anchor href handle the scroll.
      });
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

