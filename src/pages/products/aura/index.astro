            '<div class="aura-photo-stat-sub">' + d.efficacySub + '</div>' +
          '</div>' +
          '<div class="aura-photo-stat">' +
            '<div class="aura-photo-stat-key">HID Replacement</div>' +
            '<div class="aura-photo-stat-num">' + d.hidEquiv + '</div>' +
            '<div class="aura-photo-stat-sub">at max wattage</div>' +
          '</div>' +
          '<div class="aura-photo-stat">' +
            '<div class="aura-photo-stat-key">Beam</div>' +
            '<div class="aura-photo-stat-num" style="font-size:14px;">' + d.beam + '</div>' +
            '<div class="aura-photo-stat-sub">' + d.distribution + '</div>' +
          '</div>' +
        '</div>' +
        '<div class="aura-photo-card-foot">' + d.foot + '</div>';
      if (plotTitle) plotTitle.textContent = d.title.toUpperCase().replace(' \u00B7 LINE LEADER', '');
    }

    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        render(t.dataset.photoModel);
      });
    });

    // Default render: LCWS45 (line leader)
    render('LCWS45');
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

