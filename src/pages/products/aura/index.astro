<script>
/* =============================================================================
   SECTION 9 \u2014 Aura Configurator engine
   2 user choices (Housing, Finish) + 2 SKU add-ons (beam\u24B6DJUST, 0-10V dim) +
   3 DIP-set previews (W, CCT, DualCast) \u2014 informational only.

   SKU pattern (per Aura datasheet \u00B7 4 active SKUs in Active_SKUs spreadsheet):
       LCWS{housing}-3CS-27V{D|R}{3|4|6}/A1DC{/BA?}{/D?}/{finish}
   Examples:
       LCWS30-3CS-27VD4/A1DC/BA/DB                    \u2190 default \u00B7 30W DIP \u00B7 4000K DIP
       LCWS24-3CS-27VD3/A1DC/BA/DB                    \u2190 3" small architectural
       LCWS36-3CS-27VD6/A1DC/DB                       \u2190 6" facade \u00B7 NO /BA on this housing
       LCWS45-3CS-27VR6/A1DC/BA/DB                    \u2190 6"-R flagship \u00B7 138 lm/W
       LCWS45-3CS-27VR6/A1DC/BA/D/RAL7016             \u2190 flagship + dim + custom RAL

   CONSTRAINT: /BA is only valid on LCWS24, LCWS30, LCWS45. When housing
   flips to LCWS36, /BA auto-clears.
   CONSTRAINT: distribution character (D vs R) and diameter digit (3/4/6)
   are determined by housing \u2014 auto-locked, not user-pickable.
   ============================================================================= */
(function() {

  // Per-housing distribution + diameter fragments (auto-locked by housing)
  // Format: { distLetter: 'D' or 'R', diameter: '3'/'4'/'6', baAvailable: bool }
  var HOUSING_META = {
    '24': { distLetter: 'D', diameter: '3', baAvailable: true,  label: 'LCWS24 \u00B7 3" \u00B7 24W max',  retrofit: '50W MH',  peakLm: '2,900',  peakEff: '121' },
    '30': { distLetter: 'D', diameter: '4', baAvailable: true,  label: 'LCWS30 \u00B7 4" \u00B7 30W max',  retrofit: '75W MH',  peakLm: '3,660',  peakEff: '122' },
    '36': { distLetter: 'D', diameter: '6', baAvailable: false, label: 'LCWS36 \u00B7 6" \u00B7 36W max',  retrofit: '75W MH',  peakLm: '3,460',  peakEff: '107' },
    '45': { distLetter: 'R', diameter: '6', baAvailable: true,  label: 'LCWS45 \u00B7 6"-R \u00B7 45W max', retrofit: '100W MH', peakLm: '5,850', peakEff: '138' }
  };

  // WATTSELECT levels per housing (4 levels each, datasheet pg 4)
  var WATTS = {
    '24': ['10', '15', '19', '24'],
    '30': ['12', '18', '24', '30'],
    '36': ['15', '22', '30', '36'],
    '45': ['18', '27', '36', '45']
  };

  // Lumen output (datasheet pg 4 \u00B7 @ 4000K / 70\u00B0 beam) \u2014 peak per W cell
  // Used by spec preview to surface accurate output for the current W+CCT.
  // Data shape: HOUSING -> WATT -> { '30': lm, '40': lm, '50': lm }
  var LUMEN_4K = {
    '24': { '10': '1,200', '15': '1,800', '19': '2,300', '24': '2,900' },
    '30': { '12': '1,460', '18': '2,200', '24': '2,930', '30': '3,660' },
    '36': { '15': '1,440', '22': '2,110', '30': '2,880', '36': '3,460' },
    '45': { '18': '2,340', '27': '3,510', '36': '4,680', '45': '5,850' }
  };

  // Efficacy scales similarly across CCTs \u2014 peak posted is at 4000K
  var EFFICACY_4K = {
    '24': { '10': '120', '15': '120', '19': '121', '24': '121' },
    '30': { '12': '122', '18': '122', '24': '122', '30': '122' },
    '36': { '15': '96',  '22': '96',  '30': '96',  '36': '96'  },
    '45': { '18': '130', '27': '130', '36': '130', '45': '138' }
  };

  var CCT_LABEL  = { '30': '3000K', '40': '4000K', '50': '5000K' };
  var FINISH_LBL = {
    'DB':  'Dark Bronze (QS)',
    'B':   'Black (MTO)',
    'S':   'Silver (MTO)',
    'W':   'White (MTO)',
    'RAL': 'Custom RAL (MTO)'
  };
  var FINISH_SWATCH = {
    'DB':  'linear-gradient(145deg,#3a2d1f,#1f180f)',
    'B':   'linear-gradient(145deg,#1c1c1c,#080808)',
    'S':   'linear-gradient(145deg,#c8c9cb,#9b9d9f)',
    'W':   'linear-gradient(145deg,#f0ede5,#d8d4c8)',
    'RAL': 'linear-gradient(45deg,#a32,#3a8,#28b,#82a)'
  };
  var DUALCAST_LBL = {
    'up':   'UP \u00B7 Indirect',
    'full': 'FULL \u00B7 Up + Down',
    'down': 'DOWN \u00B7 Direct'
  };

  // ---- RAL Classic validation table (ported from Heritage/Navigator/Illuminator v2) ----
  var RAL_VALID = new Set([
    1000,1001,1002,1003,1004,1005,1006,1007,1011,1012,1013,1014,1015,1016,1017,1018,1019,1020,1021,1023,1024,1026,1027,1028,1032,1033,1034,1035,1036,1037,
    2000,2001,2002,2003,2004,2005,2007,2008,2009,2010,2011,2012,2013,
    3000,3001,3002,3003,3004,3005,3007,3009,3011,3012,3013,3014,3015,3016,3017,3018,3020,3022,3024,3026,3027,3028,3031,3032,3033,
    4001,4002,4003,4004,4005,4006,4007,4008,4009,4010,4011,4012,
    5000,5001,5002,5003,5004,5005,5007,5008,5009,5010,5011,5012,5013,5014,5015,5017,5018,5019,5020,5021,5022,5023,5024,5025,5026,
    6000,6001,6002,6003,6004,6005,6006,6007,6008,6009,6010,6011,6012,6013,6014,6015,6016,6017,6018,6019,6020,6021,6022,6024,6025,6026,6027,6028,6029,6032,6033,6034,6035,6036,6037,6038,
    7000,7001,7002,7003,7004,7005,7006,7008,7009,7010,7011,7012,7013,7015,7016,7021,7022,7023,7024,7026,7030,7031,7032,7033,7034,7035,7036,7037,7038,7039,7040,7042,7043,7044,7045,7046,7047,7048,
    8000,8001,8002,8003,8004,8007,8008,8011,8012,8014,8015,8016,8017,8019,8022,8023,8024,8025,8028,8029,
    9001,9002,9003,9004,9005,9006,9007,9010,9011,9016,9017,9018,9022,9023
  ]);
  var RAL_NAMES = {
    1013:'Oyster White', 1015:'Light Ivory', 1018:'Zinc Yellow', 1023:'Traffic Yellow',
    2003:'Pastel Orange', 2004:'Pure Orange', 2008:'Bright Red Orange',
    3000:'Flame Red', 3003:'Ruby Red', 3020:'Traffic Red',
    5002:'Ultramarine Blue', 5005:'Signal Blue', 5010:'Gentian Blue', 5012:'Light Blue', 5015:'Sky Blue', 5017:'Traffic Blue',
    6005:'Moss Green', 6018:'Yellow Green', 6029:'Mint Green',
    7016:'Anthracite Grey', 7021:'Black Grey', 7022:'Umbra Grey', 7035:'Light Grey', 7037:'Dusty Grey', 7042:'Traffic Grey A', 7043:'Traffic Grey B',
    8004:'Copper Brown', 8011:'Nut Brown', 8017:'Chocolate Brown', 8019:'Grey Brown', 8022:'Black Brown',
    9001:'Cream', 9002:'Grey White', 9003:'Signal White', 9005:'Jet Black', 9006:'White Aluminium', 9007:'Grey Aluminium', 9010:'Pure White', 9016:'Traffic White', 9017:'Traffic Black', 9018:'Papyrus White'
  };
  var RAL_HEX = {
    1013:'#E9E5CE', 1015:'#E6D2B5', 1018:'#FAAD2A', 1023:'#F0CA00',
    2003:'#F58220', 2004:'#E25303', 2008:'#F44611',
    3000:'#AF2B1E', 3003:'#A52019', 3020:'#CC0605',
    5002:'#20214F', 5005:'#1E2460', 5010:'#0E294B', 5012:'#3F888F', 5015:'#2271B3', 5017:'#063971',
    6005:'#2F4538', 6018:'#57A639', 6029:'#20603D',
    7016:'#293133', 7021:'#23282B', 7022:'#332F2C', 7035:'#C5C7C4', 7037:'#7D7F7D', 7042:'#8D948D', 7043:'#4E5754',
    8004:'#8E402A', 8011:'#5A3A29', 8017:'#45322E', 8019:'#403A3A', 8022:'#1B1B1B',
    9001:'#FDF4E3', 9002:'#E7EBDA', 9003:'#F4F4F4', 9005:'#0A0A0A', 9006:'#A5A5A5', 9007:'#8F8F8F', 9010:'#F7F9EF', 9016:'#F6F6F6', 9017:'#0E0E10', 9018:'#CFD3CD'
  };

  // ---- 4 active catalog SKUs (per Active_SKUs_WorkDrive_Links.xlsx) ----
  // Each Quick Pick card maps to one of these. CFG-ZOHO-1: no stock,
  // no pricing \u2014 only fixture-level facts that already live on the spec sheet.
  var CATALOG = {
    'lcws24': { housing: '24', finish: 'DB', ba: 'BA', dim: '', sku: 'LCWS24-3CS-27VD3/A1DC/BA/DB', label: '3" small architectural \u00B7 121 lm/W' },
    'lcws30': { housing: '30', finish: 'DB', ba: 'BA', dim: '', sku: 'LCWS30-3CS-27VD4/A1DC/BA/DB', label: '4" mid-range \u00B7 122 lm/W' },
    'lcws36': { housing: '36', finish: 'DB', ba: '',   dim: '', sku: 'LCWS36-3CS-27VD6/A1DC/DB',    label: '6" facade \u00B7 107 lm/W \u00B7 no /BA' },
    'lcws45': { housing: '45', finish: 'DB', ba: 'BA', dim: '', sku: 'LCWS45-3CS-27VR6/A1DC/BA/DB', label: '6"-R flagship \u00B7 138 lm/W \u00B7 clears DLC Premium' }
  };

  // Fast SKU-to-catalog reverse lookup
  var SKU_TO_CATALOG = {};
  Object.keys(CATALOG).forEach(function(k) { SKU_TO_CATALOG[CATALOG[k].sku] = k; });

  function defaultState() {
    return {
      housing: '30',     // LCWS30 4" \u2014 broadest application
      finish:  'DB',     // Dark Bronze QuickShip
      ralCode: '',
      ba:      'BA',     // beam\u24B6DJUST default ON for housings that support it
      dim:     '',       // 0-10V dim default OFF
      watt:    '30',     // factory default for LCWS30
      cct:     '40',     // 4000K default
      dualcast: 'full'   // FULL distribution default
    };
  }
  var state = defaultState();

  // ---- CFG-ZOHO-1: Catalog match indicator ----
  // CFG-STATE-1: Derive ship-tier from selected chip badges, NOT from
  // SKU_TO_CATALOG match alone. The catalog map is a name overlay; the
  // chip badges (QS/MTO/WB) are the source of truth for lead time. An
  // all-QS \u00E0-la-carte combo ships QuickShip even when not pre-bundled.
  function deriveShipTier() {
    if (state.finish === 'RAL' && state.ralCode) return 'MTO'; // custom paint = factory work
    var section = document.getElementById('configurator');
    if (!section) return 'QS';
    var keys = ['housing','finish','ba','dim'];
    var worst = 'QS';
    for (var i = 0; i < keys.length; i++) {
      var k = keys[i], v = state[k];
      if (v === '' || v == null) continue;
      var chipEl = section.querySelector('.cfg-chip[data-field="' + k + '"][data-val="' + v + '"]');
      if (!chipEl) continue;
      if (chipEl.querySelector('.cfg-chip-stock.mto')) return 'MTO';
      if (chipEl.querySelector('.cfg-chip-stock.wb'))  worst = 'WB';
    }
    return worst;
  }

  function refreshZohoMatch() {
    var sku = computeSku();
    var matchKey = SKU_TO_CATALOG[sku];
    var tier = deriveShipTier();
    var el = document.getElementById('cfgZohoMatch');
    var icon = document.getElementById('cfgZohoMatchIcon');
    var text = document.getElementById('cfgZohoMatchText');
    var stockEl = document.getElementById('cfgZohoMatchStock');
    if (!el || !icon || !text || !stockEl) return;

    el.classList.remove('matches-bare', 'matches-combo', 'no-match');

    if (tier === 'QS') {
      el.classList.add('matches-bare');
      el.style.background = 'rgba(64,168,96,0.10)';
      el.style.border = '1px solid rgba(64,168,96,0.40)';
      icon.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#7fc998" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      if (matchKey) {
        text.innerHTML = '<strong style="color:#9bd6b1;">Catalog SKU \u00B7 QuickShip</strong> &middot; <span style="color:var(--text-secondary);">' + (CATALOG[matchKey].label) + '</span>';
      } else {
        text.innerHTML = '<strong style="color:#9bd6b1;">QuickShip \u00B7 \u00E0-la-carte assembly</strong> &middot; <span style="color:var(--text-secondary);">All selected components in stock \u2014 ships 2-3 day.</span>';
      }
      stockEl.textContent = 'QuickShip \u00B7 2-3 day';
      stockEl.style.color = '#9bd6b1';
    } else if (tier === 'WB') {
      el.classList.add('no-match');
      el.style.background = 'rgba(96,168,255,0.06)';
      el.style.border = '1px solid rgba(96,168,255,0.30)';
      icon.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#7fb6ff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>';
      text.innerHTML = '<strong style="color:#a8c9ff;">Workbench Assembly</strong> &middot; <span style="color:var(--text-secondary);">One or more components are workbench-assembled to order.</span>';
      stockEl.textContent = 'WB \u00B7 ~1-3 wk';
      stockEl.style.color = '#a8c9ff';
    } else { // MTO
      el.classList.add('no-match');
      el.style.background = 'rgba(255,159,28,0.05)';
      el.style.border = '1px solid rgba(255,159,28,0.36)';
      icon.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#ffb14d" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="13"/><circle cx="12" cy="17" r="0.6" fill="currentColor"/></svg>';
      text.innerHTML = '<strong style="color:#ffb14d;">Custom build \u00B7 Made-to-Order</strong> &middot; <span style="color:var(--text-secondary);">One or more components are MTO (custom finish, MTO option, or non-stocked variant).</span>';
      stockEl.textContent = 'MTO \u00B7 ~4-6 wk';
      stockEl.style.color = '#ffb14d';
    }
  }

  // ---- SKU computation ----
  function computeSku() {
    var meta = HOUSING_META[state.housing];
    if (!meta) return '';
    var distSeg = '27V' + meta.distLetter + meta.diameter;
    var baSeg = (state.ba === 'BA' && meta.baAvailable) ? '/BA' : '';
    var dimSeg = (state.dim === 'D') ? '/D' : '';
    var finishSeg;
    if (state.finish === 'RAL' && state.ralCode && RAL_VALID.has(parseInt(state.ralCode, 10))) {
      finishSeg = '/RAL' + state.ralCode;
    } else if (state.finish === 'RAL') {
      finishSeg = '/RAL####'; // placeholder while user types
    } else {
      finishSeg = '/' + state.finish;
    }
    return 'LCWS' + state.housing + '-3CS-' + distSeg + '/A1DC' + baSeg + dimSeg + finishSeg;
  }

  // ---- WATTSELECT chip rebuild (dynamic per housing) ----
  function rebuildWattChips() {
    var wrap = document.getElementById('cfgWattChips');
    if (!wrap) return;
    var watts = WATTS[state.housing] || [];
    var max = watts[watts.length - 1];
    if (!watts.includes(state.watt)) state.watt = max;
    wrap.innerHTML = watts.map(function(w) {
      var isMax = (w === max);
      var isSelected = (w === state.watt);
      return '<button type="button" class="cfg-chip' + (isSelected ? ' selected' : '') + '" data-field="watt" data-val="' + w + '" data-code="' + w + 'W" aria-pressed="' + isSelected + '">' +
        '<span class="cfg-chip-stock dip">DIP</span>' +
        '<span class="cfg-chip-val">' + w + 'W' + (isMax ? ' &middot; max \u2605' : '') + '</span>' +
        '<span class="cfg-chip-code">DIP-' + (watts.indexOf(w) + 1) + '</span>' +
        '</button>';
    }).join('');
    // Re-bind chip handlers for the rebuilt chips
    wrap.querySelectorAll('.cfg-chip[data-field="watt"]').forEach(function(chip) {
      chip.addEventListener('click', function() { handleChipClick('watt', chip.dataset.val); });
    });
  }

  // ---- /BA availability rebuild (re-disable chip if housing flips to LCWS36) ----
  function refreshBaAvailability() {
    var meta = HOUSING_META[state.housing];
    var baChips = document.querySelectorAll('.cfg-chip[data-field="ba"]');
    if (!meta) return;
    if (!meta.baAvailable) {
      // Force /BA off; disable the BA chip visually
      state.ba = '';
      baChips.forEach(function(c) {
        if (c.dataset.val === 'BA') {
          c.classList.add('disabled');
          c.classList.remove('selected');
          c.setAttribute('aria-pressed', 'false');
          c.setAttribute('disabled', 'true');
        } else if (c.dataset.val === '') {
          c.classList.add('selected');
          c.setAttribute('aria-pressed', 'true');
        }
      });
    } else {
      baChips.forEach(function(c) {
        c.classList.remove('disabled');
        c.removeAttribute('disabled');
        if (c.dataset.val === state.ba) {
          c.classList.add('selected');
          c.setAttribute('aria-pressed', 'true');
        } else {
          c.classList.remove('selected');
          c.setAttribute('aria-pressed', 'false');
        }
      });
    }
  }

  // ---- Live preview spec grid update ----
  function refreshPreview() {
    var meta = HOUSING_META[state.housing] || HOUSING_META['30'];

    document.getElementById('cfgSpecHousing').textContent = meta.label;
    document.getElementById('cfgSpecDistribution').innerHTML =
      meta.distLetter + meta.diameter + ' &middot; ' +
      (meta.distLetter === 'D' ? 'Direct' : 'Round/Full') +
      ' &middot; ' + meta.diameter + '&quot; cylinder';

    // Finish display
    var finLabel = FINISH_LBL[state.finish] || '\u2014';
    if (state.finish === 'RAL' && state.ralCode && RAL_VALID.has(parseInt(state.ralCode, 10))) {
      var ralNum = parseInt(state.ralCode, 10);
      finLabel = 'RAL ' + state.ralCode + (RAL_NAMES[ralNum] ? ' \u00B7 ' + RAL_NAMES[ralNum] : '') + ' (MTO)';
    }
    document.getElementById('cfgSpecFinish').textContent = finLabel;

    // beam\u24B6DJUST display
    var baEl = document.getElementById('cfgSpecBa');
    if (!meta.baAvailable) {
      baEl.innerHTML = '\u2014 n/a on LCWS' + state.housing + ' \u2014';
    } else if (state.ba === 'BA') {
      baEl.innerHTML = '/BA \u00B7 50&deg;/60&deg;/70&deg; field-adjust';
    } else {
      baEl.innerHTML = '\u2014 omitted (fixed beam) \u2014';
    }

    // 0-10V Dim display
    document.getElementById('cfgSpecDim').textContent =
      (state.dim === 'D') ? '/D \u00B7 0-10V dim 100%-10%' : '\u2014 none (non-dim driver) \u2014';

    // Wattage + CCT + DualCast displays
    document.getElementById('cfgSpecWatt').textContent = state.watt + 'W';
    document.getElementById('cfgSpecCct').textContent = CCT_LABEL[state.cct] || '4000K';
    document.getElementById('cfgSpecDualcast').textContent = DUALCAST_LBL[state.dualcast] || 'FULL \u00B7 Up + Down';

    // Output line \u2014 uses 4000K table (CCT-invariant per datasheet pg 4)
    var lm = (LUMEN_4K[state.housing] && LUMEN_4K[state.housing][state.watt]) || meta.peakLm;
    var eff = (EFFICACY_4K[state.housing] && EFFICACY_4K[state.housing][state.watt]) || meta.peakEff;
    document.getElementById('cfgSpecLumens').innerHTML =
      '<strong>' + lm + ' lm &middot; ' + eff + ' lm/W</strong> at ' +
      (CCT_LABEL[state.cct] || '4000K') + ', 70&deg; beam (datasheet rated). See Section 7 for the full per-W &times; CCT matrix.';

    // SKU
    document.getElementById('cfgSku').textContent = computeSku();

    // ---- LIVE PREVIEW IMAGE \u00B7 finish-swap (CFG-2C filter recipes) ----
    // Toggle fs-D / fs-B / fs-S / fs-W / fs-RAL classes on the preview wrap.
    // Aura uses 'DB' as the SKU finish code but maps to 'fs-D' visual class
    // (Dark Bronze) \u2014 same swatch recipe across the luxo\u24B6RCH line.
    var imgWrap = document.getElementById('cfgPreviewImgWrap');
    var tagEl   = document.getElementById('cfgPreviewTag');
    var ralBadge = document.getElementById('cfgRalBadge');
    var ralBadgeNum = document.getElementById('cfgRalBadgeNum');
    var ralBadgeName = document.getElementById('cfgRalBadgeName');
    var ralBadgeSwatch = document.getElementById('cfgRalBadgeSwatch');
    var ralTint = document.getElementById('cfgRalTint');
    var cylBody = document.getElementById('cfgPreviewCylBody');

    if (imgWrap) {
      // Strip prior fs-* + has-valid-ral state
      imgWrap.classList.remove('fs-D', 'fs-B', 'fs-S', 'fs-W', 'fs-RAL', 'has-valid-ral');

      // Map SKU finish code to visual class
      var visualFinish = (state.finish === 'DB') ? 'D' : state.finish;
      imgWrap.classList.add('fs-' + visualFinish);

      // Reset cylinder body fill to the canonical bronze before applying overlays
      if (cylBody) cylBody.setAttribute('fill', '#5a3d2a');

      // Tag line: housing \u00B7 diameter \u00B7 finish name
      var meta = HOUSING_META[state.housing] || HOUSING_META['30'];
      var finishName;
      if (state.finish === 'RAL' && state.ralCode && RAL_VALID.has(parseInt(state.ralCode, 10))) {
        var ralNumX = parseInt(state.ralCode, 10);
        var hex = RAL_HEX[ralNumX] || '#888';
        finishName = 'RAL ' + state.ralCode + (RAL_NAMES[ralNumX] ? ' \u00B7 ' + RAL_NAMES[ralNumX] : '');
        // RAL tint overlay \u2014 paint the cylinder body with the user's hex
        if (cylBody) cylBody.setAttribute('fill', hex);
        if (ralTint) ralTint.style.background = hex;
        imgWrap.classList.add('has-valid-ral');
        if (ralBadge) {
          ralBadgeNum.textContent = 'RAL ' + state.ralCode;
          ralBadgeName.textContent = RAL_NAMES[ralNumX] || '\u2014';
          ralBadgeSwatch.style.background = hex;
        }
      } else {
        finishName = (FINISH_LBL[state.finish] || '').replace(/ \(.+?\)$/, '').toUpperCase();
        if (ralTint) ralTint.style.background = '';
      }
      if (tagEl) {
        tagEl.textContent = 'LCWS' + state.housing + ' \u00B7 ' + meta.diameter + '"' +
          (meta.distLetter === 'R' ? '-R' : '') + ' \u00B7 ' + finishName;
      }
    }

    refreshZohoMatch();
  }

  // ---- Chip click handler (universal) ----
  function handleChipClick(field, val) {
    if (field === 'housing') {
      state.housing = val;
      // Force watt to housing's max when switching housings
      var watts = WATTS[val] || [];
      state.watt = watts[watts.length - 1];
      rebuildWattChips();
      refreshBaAvailability();
    } else if (field === 'finish') {
      state.finish = val;
      var ralWrap = document.getElementById('cfgRalInputWrap');
      if (val === 'RAL') {
        ralWrap.style.display = '';
      } else {
        ralWrap.style.display = 'none';
        state.ralCode = '';
        document.getElementById('cfgRalInput').value = '';
        ralWrap.classList.remove('valid', 'invalid');
      }
    } else if (field === 'ba') {
      state.ba = val;
    } else if (field === 'dim') {
      state.dim = val;
    } else if (field === 'watt') {
      state.watt = val;
    } else if (field === 'cct') {
      state.cct = val;
    } else if (field === 'dualcast') {
      state.dualcast = val;
    } else if (field === 'cctcap' || field === 'voltage') {
      // Locked fields \u2014 no-op
      return;
    }

    // Update visual selection state on all chips for this field
    document.querySelectorAll('.cfg-chip[data-field="' + field + '"]').forEach(function(c) {
      var sel = (c.dataset.val === val);
      c.classList.toggle('selected', sel);
      c.setAttribute('aria-pressed', sel ? 'true' : 'false');
    });

    refreshPreview();
  }

  // ---- Quick Pick handler ----
  function applyQuickPick(key) {
    var cfg = CATALOG[key];
    if (!cfg) return;
    state.housing = cfg.housing;
    state.finish  = cfg.finish;
    state.ba      = cfg.ba;
    state.dim     = cfg.dim;
    var watts = WATTS[cfg.housing] || [];
    state.watt = watts[watts.length - 1];
    state.cct = '40';
    state.dualcast = 'full';
    state.ralCode = '';
    document.getElementById('cfgRalInput').value = '';

    // Update all visual chip states
    ['housing', 'finish', 'ba', 'dim', 'cct', 'dualcast'].forEach(function(field) {
      var v = state[field];
      document.querySelectorAll('.cfg-chip[data-field="' + field + '"]').forEach(function(c) {
        var sel = (c.dataset.val === v);
        c.classList.toggle('selected', sel);
        c.setAttribute('aria-pressed', sel ? 'true' : 'false');
      });
    });

    document.getElementById('cfgRalInputWrap').style.display = (state.finish === 'RAL') ? '' : 'none';
    rebuildWattChips();
    refreshBaAvailability();
    refreshPreview();

    // Smooth scroll to live preview
    var preview = document.querySelector('.cfg-preview');
    if (preview) preview.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  // ---- RAL input live validation ----
  function bindRalInput() {
    var input = document.getElementById('cfgRalInput');
    var wrap = document.getElementById('cfgRalInputWrap');
    var nameEl = document.getElementById('cfgRalName');
    if (!input || !wrap) return;
    input.addEventListener('input', function() {
      var v = input.value.replace(/\D/g, '').slice(0, 4);
      input.value = v;
      state.ralCode = v;
      wrap.classList.remove('valid', 'invalid');
      if (v.length === 4) {
        var num = parseInt(v, 10);
        if (RAL_VALID.has(num)) {
          wrap.classList.add('valid');
          nameEl.textContent = RAL_NAMES[num] || '\u2014';
        } else {
          wrap.classList.add('invalid');
        }
      }
      refreshPreview();
    });
  }

  // ---- Reset to defaults ----
  function bindReset() {
    var btn = document.getElementById('cfgReset');
    if (!btn) return;
    btn.addEventListener('click', function() {
      state = defaultState();
      ['housing', 'finish', 'ba', 'dim', 'cct', 'dualcast'].forEach(function(field) {
        var v = state[field];
        document.querySelectorAll('.cfg-chip[data-field="' + field + '"]').forEach(function(c) {
          var sel = (c.dataset.val === v);
          c.classList.toggle('selected', sel);
          c.setAttribute('aria-pressed', sel ? 'true' : 'false');
        });
      });
      document.getElementById('cfgRalInputWrap').style.display = 'none';
      document.getElementById('cfgRalInput').value = '';
      rebuildWattChips();
      refreshBaAvailability();
      refreshPreview();
    });
  }

  // ---- Copy SKU ----
  function bindCopy() {
    var btn = document.getElementById('cfgSkuCopy');
    var label = document.getElementById('cfgSkuCopyLabel');
    if (!btn) return;
    btn.addEventListener('click', function() {
      var sku = document.getElementById('cfgSku').textContent;
      navigator.clipboard.writeText(sku).then(function() {
        if (label) {
          label.textContent = 'Copied!';
          setTimeout(function() { label.textContent = 'Copy SKU'; }, 1600);
        }
      }).catch(function() {});
    });
  }

  // ---- Submittal CTA \u2014 opens submittal_template.html in new tab with SKU ----
  function bindSubmittalCta() {
    var btn = document.getElementById('cfgCtaSubmittal');
    if (!btn) return;
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var sku = computeSku();
      // submittal_template.html lives in the same directory; pass full state.
      var params = [
        'product=aura',
        'sku=' + encodeURIComponent(sku),
        'housing=' + state.housing,
        'wattage=' + state.watt,
        'cct=' + state.cct,
        'finish=' + state.finish,
        'ba=' + (state.ba || ''),
        'dim=' + (state.dim || ''),
        'dualcast=' + state.dualcast
      ];
      if (state.finish === 'RAL' && state.ralCode) params.push('ral=' + state.ralCode);
      var url = 'submittal_template.html?' + params.join('&');
      window.open(url, '_blank', 'noopener');
    });
  }

  // ---- Init ----
  function init() {
    // Bind static (non-watt) chips
    document.querySelectorAll('.cfg-chip:not([data-field="watt"])').forEach(function(chip) {
      var field = chip.dataset.field;
      var val = chip.dataset.val;
      if (!field) return;
      chip.addEventListener('click', function() {
        if (chip.classList.contains('locked') || chip.classList.contains('disabled')) return;
        handleChipClick(field, val);
      });
    });

    // Quick Pick handlers
    document.querySelectorAll('.cfg-quickpick-card').forEach(function(card) {
      card.addEventListener('click', function() {
        applyQuickPick(card.dataset.quickpick);
      });
    });

    rebuildWattChips();
    refreshBaAvailability();
    bindRalInput();
    bindReset();
    bindCopy();
    bindSubmittalCta();
    refreshPreview();
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

