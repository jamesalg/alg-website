       but maps to 'fs-D' visual class (Dark Bronze) — the visual class is housing-
       agnostic, only the body color changes. -->
  <div class="cfg-preview-wrap">
    <div class="cfg-preview">
      <div class="cfg-preview-grid">

        <!-- LEFT · live product image · finish-swap via CSS filter recipes.
             Aura ships with a styled cylinder placeholder until production
             photography lands. The placeholder is an inline SVG inside the
             .cfg-preview-body-img element so the same fs-* filter recipes
             apply (brightness · saturate · contrast). When real photo lands,
             swap the SVG for an <img class="cfg-preview-body-img"> tag — no
             other change required. -->
        <div class="cfg-preview-img fs-D" id="cfgPreviewImgWrap">
          <span class="cfg-preview-img-tag" id="cfgPreviewTag">LCWS30 &middot; 4&quot; &middot; DARK BRONZE</span>
          <div class="cfg-preview-stack" id="cfgPreviewImg">
            <!-- Inline cylinder SVG · same construct as Section 1 hero ·
                 .cfg-preview-body-img class so fs-* filter recipes apply -->
            <svg class="cfg-preview-body-img" viewBox="0 0 200 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" id="cfgPreviewSvg" style="width:78%; max-width:240px; height:auto;">
              <!-- Wall plate / J-box bracket -->
              <rect x="68" y="22" width="64" height="10" rx="2" fill="#2a2e35" stroke="#52575f" stroke-width="0.8"/>
              <!-- Photocell-ready cap (top dome) -->
              <ellipse cx="100" cy="42" rx="28" ry="6" fill="#3d2820" stroke="#5c3f31" stroke-width="0.6"/>
              <!-- Cylinder body (the part that swaps finish) -->
              <rect x="64" y="46" width="72" height="220" rx="3"
                    fill="#5a3d2a" stroke="#7a5538" stroke-width="0.8"
                    id="cfgPreviewCylBody"/>
              <!-- subtle vertical body highlight -->
              <rect x="68" y="50" width="3" height="212" rx="1.5" fill="rgba(255,255,255,0.10)"/>
              <rect x="129" y="50" width="3" height="212" rx="1.5" fill="rgba(0,0,0,0.18)"/>
              <!-- Up-light glow (top emission · DualCast UP) -->
              <ellipse cx="100" cy="48" rx="42" ry="6" fill="rgba(255,232,200,0.40)" filter="url(#auraGlow)"/>
              <!-- Down-light prismatic optic at the bottom -->
              <ellipse cx="100" cy="268" rx="34" ry="3" fill="#FFE3A0" stroke="#F5A85B" stroke-width="0.5"/>
              <!-- Down-light cone (DualCast DOWN) -->
              <path d="M 70 268 L 130 268 L 150 308 L 50 308 Z" fill="rgba(255,232,200,0.18)"/>
              <line x1="86" y1="268" x2="76" y2="305" stroke="rgba(255,232,200,0.45)" stroke-width="0.6"/>
              <line x1="100" y1="268" x2="100" y2="307" stroke="rgba(255,232,200,0.55)" stroke-width="0.7"/>
              <line x1="114" y1="268" x2="124" y2="305" stroke="rgba(255,232,200,0.45)" stroke-width="0.6"/>
              <!-- LED prismatic facets -->
              <line x1="86"  y1="268" x2="86"  y2="265" stroke="#F5A85B" stroke-width="0.7"/>
              <line x1="100" y1="268" x2="100" y2="265" stroke="#F5A85B" stroke-width="0.7"/>
              <line x1="114" y1="268" x2="114" y2="265" stroke="#F5A85B" stroke-width="0.7"/>
              <!-- Pending-photography watermark -->
