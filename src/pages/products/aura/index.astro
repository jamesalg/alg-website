    'LCWS36': {
      title: 'LCWS36 \u00B7 6"-D \u00B7 36W \u00B7 4000K',
      lumens: '3,460',
      efficacy: '96 lm/W',
      hidEquiv: '75W MH',
      distribution: 'DualCast (no beam\u24B6DJUST)',
      beam: 'Direct + Indirect tuned',
      foot: '<em>6-inch D-variant &mdash; tuned for Direct + Indirect distribution emphasis (softer wall-wash). Datasheet at 36W default / 4000K. <code>15W = 1,600 lm</code> \u00B7 <code>22W = 2,200 lm</code> \u00B7 <code>30W = 2,930 lm</code> \u00B7 <code>36W = 3,460 lm</code>. <strong>Honest framing:</strong> efficacy peaks at 107 lm/W (15W) and drops to 96 lm/W at max &mdash; trades top-end lm/W for the soft wash photometric. Spec LCWS45 R-variant when efficacy + DLC Premium are the bid drivers.</em>',
      lumensSub: 'datasheet \u00B7 36W default',
      efficacySub: 'D-variant \u00B7 soft wall-wash trade'
    },
    'LCWS45': {
      title: 'LCWS45 \u00B7 6"-R \u00B7 45W \u00B7 4000K \u00B7 Line Leader',
      lumens: '5,850',
      efficacy: '138 lm/W',
      hidEquiv: '100W MH',
      distribution: 'UP / FULL / DOWN',
      beam: '50\u00B0 / 60\u00B0 / 70\u00B0',
      foot: '<em>6-inch R-variant &mdash; the line leader. <strong>The only Aura housing that clears DLC Premium 130 lm/W floor across every WATTSELECT setting.</strong> Datasheet at 45W default / 4000K. <code>18W = 2,480 lm @ 138 lm/W</code> (peak efficacy at low end of the field-set range) \u00B7 <code>27W = 3,670 lm @ 136 lm/W</code> \u00B7 <code>36W = 4,790 lm @ 133 lm/W</code> \u00B7 <code>45W = 5,850 lm @ 130 lm/W</code>. The R-variant optic is tuned for higher peak efficacy than the LCWS36 D-variant. When efficacy + rebate eligibility are the bid drivers, this is the SKU.</em>',
      lumensSub: 'datasheet \u00B7 45W default',
      efficacySub: '\u2605 DLC Premium clears across line',
      isLeader: true
    }
