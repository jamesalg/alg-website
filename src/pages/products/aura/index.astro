<script>
/* =============================================================================
   SECTION 8 \u2014 Aura "In the Box" modal wiring (CFG-ACC-1).
   4 entries \u00B7 all factory-installed \u00B7 click-to-detail pattern from
   Heritage / Atlanta / Pathfinder scaffolding. 2-CTA modal, no per-card
   datasheet button (Datasheet lives in Section 10).
   ============================================================================= */
(function() {
  var INBOX = {
    'optic': {
      cat: 'Optic \u00B7 Pre-fitted',
      title: 'Prismatic Translucent Optic',
      sku: 'Pre-fitted \u00B7 UV-stabilized \u00B7 part of IP wet-location envelope',
      model: 'Prismatic optical design \u00B7 controlled distribution + uniformity',
      desc: 'Beam-shaper on every Aura. <strong>Prismatic translucent optic</strong> pulls the LED hot-spot into a controlled, uniform distribution and supports <strong>DualCast\u2122 UP / FULL / DOWN</strong> + <strong>beam<span class="aa">\u24B6</span>DJUST\u2122 50&deg; / 60&deg; / 70&deg;</strong> field-set on applicable SKUs. Sealed at the housing interface &mdash; part of the IP wet-location envelope. Engineered for architectural cylinder applications: hospitality entries, fa&ccedil;ade washes, retail perimeters, hospital exteriors.',
      specs: [
        ['Material', 'UV-stabilized prismatic translucent optic'],
        ['Distribution modes', 'UP / FULL / DOWN (DualCast\u2122 field-selectable)'],
        ['Beam angle', '50\u00B0 / 60\u00B0 / 70\u00B0 (beam\u24B6DJUST on LCWS24/30/45)'],
        ['Sealing', 'Bonded to cast-aluminum housing \u00B7 part of IP wet-location envelope'],
        ['UV resistance', 'UV-stabilized for outdoor exposure'],
        ['Service', 'Optic not field-replaceable \u00B7 housing assembly is the service unit']
      ]
    },
    'housing': {
      cat: 'Housing \u00B7 Pre-fitted',
      title: 'Sealed Cast-Aluminum Cylinder \u00B7 wet\u24B6GUARD',
      sku: 'Dark Bronze QS \u00B7 Black/Silver/White MTO \u00B7 Custom RAL Classic MTO',
      model: 'Sealed cast aluminum \u00B7 corrosion-resistant polyester powder-coat',
      desc: 'Sealed cast-aluminum cylinder with corrosion-resistant <strong>polyester powder-coat finish</strong>. Casting conducts heat away from the LED engine for thermal protection across the full operating range. Holds <strong>IP wet-location</strong> across <strong>&minus;40&deg;F to 122&deg;F</strong> &mdash; an 18&deg;F wider thermal envelope than Lithonia WMCL&rsquo;s typical &minus;40&deg;F to 104&deg;F. Color shift &lt;180K over warranty period &mdash; tighter than DLC&rsquo;s 200K consistency requirement.',
      specs: [
        ['Material', 'Sealed cast aluminum'],
        ['Finish', 'Dark Bronze QuickShip \u00B7 Black / Silver / White MTO \u00B7 Custom RAL Classic MTO'],
        ['Operating temperature', '\u221240\u00B0F to 122\u00B0F (industrial-grade)'],
        ['IP rating', 'Wet-location listed (UL / cUL)'],
        ['LED life', '50,000+ hours (LM-80 / TM-21 basis)'],
        ['Color shift', '<180K over warranty period (tighter than DLC 200K)']
      ]
    },
    'driver': {
      cat: 'contr\u24B6LS \u00B7 Standard',
      title: 'Universal-Voltage Driver \u00B7 0-10V Dim Optional',
      sku: '120-277V universal \u00B7 PF >0.90 \u00B7 THD <20% \u00B7 0-10V dim optional (/D)',
      model: 'Universal-voltage driver \u00B7 isolated \u00B7 0-10V dim 100%-10% optional',
      desc: 'Universal <strong>120-277VAC driver</strong> factory-installed on every Aura. Power factor <strong>&gt;0.90</strong>, THD <strong>&lt;20%</strong> across the load range. <strong>Optional 0-10V dim upgrade</strong> gives <strong>100% to ~10% smooth dim</strong> &mdash; wire violet/grey leads to a 0-10V dimmer, DALI gateway, or scheduling system. Heat-isolated from the LED module &mdash; no thermal foldback at low-dim states, no flicker on rebound. Pair with quick<span class="aa">\u24B6</span>DAPT for occupancy + photocell + scheduling on the same gateway as Atlanta and Sentinel.',
      specs: [
        ['Driver type', 'Universal-voltage \u00B7 isolated \u00B7 constant-current'],
        ['Voltage range', '120-277V universal AC (60 Hz)'],
        ['Power factor', '> 0.90 at full load'],
        ['Total harmonic distortion', '< 20% at full load'],
        ['Dim range (optional /D)', '100% to ~10% smooth (0-10V analog)'],
        ['Operating temperature', '\u221240\u00B0F to 122\u00B0F (matches housing range)']
      ]
    },
    'photocell': {
      cat: 'Photocell \u00B7 Pre-fitted',
      title: 'Photocell-Ready Cap \u00B7 Cap-On/Off Switch',
      sku: 'Cap installed = OFF \u00B7 cap removed = ON \u00B7 integrated sensor under cap',
      model: 'Removable cap mechanic \u00B7 cap on = photocell OFF \u00B7 cap off = photocell ON',
      desc: 'Clever UX. <strong>Photocell sensor</strong> sits in the top of the cylinder under a removable cap. <strong>Cap installed = photocell OFF</strong> (Aura runs on building-side relay or astronomical timer). <strong>Cap removed = photocell ON</strong> (Aura runs dusk-to-dawn from the integrated sensor). Contractor sets the project&rsquo;s preference at install with one swap, no rewiring, no second SKU. <strong>Honesty marker:</strong> Aura is photocell-ready, not photocell-included &mdash; the cap-removal mechanic activates the sensor that&rsquo;s already in the housing. No third-party photocell needed.',
      specs: [
        ['Type', 'Photocell-ready cap (integrated sensor underneath)'],
        ['Activation UX', 'Cap installed = OFF \u00B7 cap removed = ON'],
        ['Sensor', 'Integrated under cap \u00B7 activates on light exposure'],
        ['Mode pairing', 'Stacks with optional 0-10V dim if both are spec\'d'],
        ['SKU economics', 'Mechanic activates the in-housing sensor \u00B7 no third-party photocell needed'],
        ['Spec note', 'Photocell-ready, not photocell-included \u00B7 sensor is integral to the cap mechanic']
      ]
    }
  };

  function init() {
    var grid     = document.getElementById('inboxGrid');
    var modal    = document.getElementById('inboxModal');
    var closeBtn = document.getElementById('inboxModalClose');
    var imgWrap  = document.getElementById('inboxModalImg');
    var catEl    = document.getElementById('inboxModalCat');
    var titleEl  = document.getElementById('inboxModalTitle');
    var skuEl    = document.getElementById('inboxModalSku');
    var descEl   = document.getElementById('inboxModalDesc');
    var specsEl  = document.getElementById('inboxModalSpecs');
    if (!grid || !modal) return;
    var cards = grid.querySelectorAll('.acc-card');

    function openModal(card) {
      var id = card.dataset.id;
      var d  = INBOX[id];
      if (!d) { console.warn('inbox-modal: no data for id', id); return; }
      catEl.innerHTML  = d.cat.replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
      titleEl.innerHTML = d.title.replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
      skuEl.innerHTML  = d.sku + (d.model && d.model !== d.sku ? '<div style="font-size:11px;color:var(--text-muted);font-weight:400;margin-top:2px;">' + d.model + '</div>' : '');
      descEl.innerHTML = d.desc;
      specsEl.innerHTML = d.specs.map(function(s) {
        var v = (s[1] || '').toString().replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
        return '<div class="acc-spec-row">' +
                 '<div class="acc-spec-key">' + s[0] + '</div>' +
                 '<div class="acc-spec-val">' + v + '</div>' +
               '</div>';
      }).join('');
      var srcSvg = card.querySelector('.acc-card-img svg');
      Array.from(imgWrap.querySelectorAll('svg, img')).forEach(function(s){ s.remove(); });
      if (srcSvg) {
        var clone = srcSvg.cloneNode(true);
        clone.style.width = '70%';
        clone.style.height = 'auto';
        clone.style.maxWidth = '320px';
        imgWrap.appendChild(clone);
      }
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }

    cards.forEach(function(c) { c.addEventListener('click', function() { openModal(c); }); });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && modal.classList.contains('open')) closeModal(); });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

