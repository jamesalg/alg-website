<script>
/* =============================================================================
   SECTION 6 \u2014 Aura controls tab switcher.
   2-tab pattern (parity with Atlanta): 0-10V Dimming \u00B7 Photocell-Ready.
   Aura's datasheet does NOT list networked-mesh options (no /MSP-ACS, no
   /MSP-NLC), so this section stays simpler than Heritage / Navigator. Reuses
   the .is-rippling shockwave handler from the canonical controls pattern.
   ============================================================================= */
(function() {
  var COPY = {
    'dimming':   '<strong>0-10V analog dimming optional on every Aura SKU</strong> &mdash; the dimming driver upgrades the standard non-dim driver in the same housing. Wire violet/grey 0-10V leads from the isolated driver to a 0-10V dimmer, DALI gateway, or scheduling system &mdash; smooth dim from <strong>100% to ~10%</strong>. Driver: <strong>PF &gt;0.90 &middot; THD &lt;20%</strong> across the dim range. Heat-isolated from the LED module &mdash; no thermal foldback at low-dim states, no flicker on rebound. Pair with quick' + "\u24B6" + 'DAPT for occupancy + photocell + scheduling on the same gateway as Atlanta and Sentinel.',
    'photocell': '<strong>Photocell-Ready hardware standard on every Aura SKU</strong> &mdash; the photocell sensor sits in the top of the housing under a removable cap. <strong>Cap installed = photocell OFF</strong> (Aura runs on building-side relay or astronomical timer). <strong>Cap removed = photocell ON</strong> (Aura runs dusk-to-dawn from the integrated photocell). Contractor sets the project&rsquo;s preference at install with one cap swap, no rewiring, no second SKU. <strong>Honest framing:</strong> Aura is photocell-ready, not photocell-included &mdash; the cap-removal mechanic activates the integrated sensor that&rsquo;s already in the housing. No third-party photocell needed.'
  };
  var LINK_LABEL = {
    'dimming':   'Discover 0-10V dimming \u2192',
    'photocell': 'Discover photocell-ready \u2192'
  };

  function init() {
    var tabs = document.querySelectorAll('#controls .tac-callout-tab');
    var copy = document.getElementById('tacCalloutCopy');
    var link = document.querySelector('#controls .tac-callout-link span');
    var wave = document.getElementById('tacShockwave');
    var sensor = document.querySelector('#controls .aura-controls-placeholder');
    if (!tabs.length || !copy) return;

    function ripple() {
      if (!wave) return;
      wave.classList.remove('is-rippling');
      void wave.offsetWidth;
      wave.classList.add('is-rippling');
    }

    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        var p = t.dataset.platform;
        copy.innerHTML = COPY[p] || COPY['dimming'];
        if (link) link.textContent = LINK_LABEL[p] || LINK_LABEL['dimming'];
        if (sensor) sensor.dataset.platform = p;
        ripple();
      });
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

