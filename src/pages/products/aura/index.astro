  function init() {
    var tabs = document.querySelectorAll('#photometrics .spec-watt-tab[data-photo-model]');
    var card = document.getElementById('auraPhotoCard');
    var plotTitle = document.getElementById('plotTitle');
    if (!tabs.length || !card) return;

    function render(model) {
      var d = DATA[model];
      if (!d) return;
      var leaderClass = d.isLeader ? ' is-leader' : '';
      var headTag = d.isLeader ? '<span class="aura-photo-card-tag">\u2605 LINE LEADER</span>' : '<span class="aura-photo-card-tag">DATASHEET</span>';
      card.innerHTML =
        '<div class="aura-photo-card-head">' +
          '<div class="aura-photo-card-title">' + d.title + '</div>' +
          headTag +
        '</div>' +
        '<div class="aura-photo-stat-grid">' +
          '<div class="aura-photo-stat">' +
            '<div class="aura-photo-stat-key">Lumens</div>' +
            '<div class="aura-photo-stat-num' + leaderClass + '">' + d.lumens + '</div>' +
