   When IES files arrive: extend this DATA object with per-W \u00D7 per-CCT cells
   and parse the .IES files to render polar plot SVGs (mirror of the
   parse_ies_heritage.py / parse_ies_navigator.py toolchain).
   ============================================================================= */
(function() {
  var DATA = {
    'LCWS24': {
      title: 'LCWS24 \u00B7 3" \u00B7 24W \u00B7 4000K',
      lumens: '2,900',
      efficacy: '121 lm/W',
      hidEquiv: '50W MH',
      distribution: 'UP / FULL / DOWN',
      beam: '50\u00B0 / 60\u00B0 / 70\u00B0',
