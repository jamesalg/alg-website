<script>
/* =============================================================================
   SECTION 3 \u2014 Aura spec table model switcher.
   AUTHORITATIVE source: LCWS | Aura | Datasheet.pdf (Zoho WorkDrive \u00B7 5 pp).
   Per-row lumens + efficacy from datasheet PAGE 4 performance tables (4000K,
   the peak-efficacy CCT). 4 housing classes \u00D7 4 WATTSELECT settings = 16 rows.
   HID-replacement column maps from datasheet PAGE 2 Model Specifications at
   max wattage; sub-wattage HID values are interpolated trade-reference rather
   than datasheet-published.

   Per-row efficacy varies by W within a housing \u2014 opposite of Heritage where
   efficacy is flat at 150 lm/W across the matrix. Aura's LCWS45 hits 138 lm/W
   AT THE 18W SETTING (low end) and 130 lm/W at 45W max. This is normal LED
   behavior (driver loss + thermal derate at high current), and surfacing it
   accurately is the honesty CFG-RBT-1 requires.
   ============================================================================= */
(function() {
  var DATA = {
    'LCWS24': {
      'rows': [
        { w: '10W',     lm: '1,280',  lpw: '128 lm/W',  hid: '20W MH',   cct: '3000 / 4000 / 5000K' },
        { w: '15W',     lm: '1,900',  lpw: '126 lm/W',  hid: '35W MH',   cct: '3000 / 4000 / 5000K' },
        { w: '19W',     lm: '2,350',  lpw: '124 lm/W',  hid: '50W MH',   cct: '3000 / 4000 / 5000K' },
        { w: '24W \u2605',   lm: '<strong>2,900</strong>', lpw: '<strong>121 lm/W</strong>', hid: '50W MH',  cct: '3000 / 4000 / 5000K' }
      ],
      'foot': '\u2605 <em><strong>LCWS24</strong> &mdash; the 3-inch architectural cylinder for tight-throw entry vestibules, narrow corridors, hospitality drop-line walls, and pedestrian-scale fa&ccedil;ades. ' +
              '<strong>WATTSELECT</strong> field-pick at install: 10 / 15 / 19 / 24W via DIP &mdash; <strong>24W is the factory default</strong> at <strong>2,900 lm</strong> / <strong>121 lm/W</strong> peak (4000K). ' +
              '<strong>CCTSELECT</strong>: 3000K / 4000K / 5000K via DIP &mdash; 4000K is the peak-efficacy setting; 3000K loses ~10 lm/W; 5000K loses ~5 lm/W. ' +
              '<strong>DualCast\u2122</strong> UP / FULL / DOWN distribution + <strong>beam<span class="aa">\u24B6</span>DJUST\u2122</strong> 50&deg; / 60&deg; / 70&deg; field-set on this housing. ' +
              'Replaces 50W MH at max wattage. SKU: <code>LCWS24-3CS-27VD3/A1DC/BA/DB</code> &mdash; 120-277V universal &middot; 0-10V dim optional &middot; photocell-ready. ' +
              '<strong>Smallest lumen package in the line</strong> &mdash; for projects where the cylinder is decorative accent more than primary illumination.</em>'
    },
    'LCWS30': {
      'rows': [
        { w: '12W',     lm: '1,550',  lpw: '129 lm/W',  hid: '35W MH',   cct: '3000 / 4000 / 5000K' },
        { w: '18W',     lm: '2,270',  lpw: '126 lm/W',  hid: '50W MH',   cct: '3000 / 4000 / 5000K' },
        { w: '24W',     lm: '2,980',  lpw: '124 lm/W',  hid: '50W MH',   cct: '3000 / 4000 / 5000K' },
        { w: '30W \u2605',   lm: '<strong>3,660</strong>', lpw: '<strong>122 lm/W</strong>', hid: '75W MH',  cct: '3000 / 4000 / 5000K' }
      ],
      'foot': '\u2605 <em><strong>LCWS30</strong> &mdash; the 4-inch cylinder for the typical commercial-perimeter spec lane: hotel porte-coch&egrave;res, school covered walks, mid-rise fa&ccedil;ades, retail entries on a 4-inch architectural rhythm. ' +
              '<strong>WATTSELECT</strong>: 12 / 18 / 24 / 30W &mdash; <strong>30W default</strong> at <strong>3,660 lm</strong> / <strong>122 lm/W</strong> peak (4000K). ' +
              '<strong>DualCast\u2122</strong> + <strong>beam<span class="aa">\u24B6</span>DJUST\u2122</strong> 50/60/70&deg; field-set. ' +
              'Replaces 75W MH at 30W. SKU: <code>LCWS30-3CS-27VD4/A1DC/BA/DB</code>. ' +
              'Most-specified housing in the Aura family for general commercial perimeter applications.</em>'
    },
    'LCWS36': {
      'rows': [
        { w: '15W',     lm: '1,600',  lpw: '107 lm/W',  hid: '35W MH',   cct: '3000 / 4000 / 5000K' },
        { w: '22W',     lm: '2,200',  lpw: '100 lm/W',  hid: '50W MH',   cct: '3000 / 4000 / 5000K' },
        { w: '30W',     lm: '2,930',  lpw: '98 lm/W',   hid: '70W MH',   cct: '3000 / 4000 / 5000K' },
        { w: '36W \u2605',   lm: '<strong>3,460</strong>', lpw: '<strong>96 lm/W</strong>',  hid: '75W MH',  cct: '3000 / 4000 / 5000K' }
      ],
      'foot': '\u2605 <em><strong>LCWS36</strong> &mdash; the 6-inch (D-variant) cylinder, tuned for <strong>Direct + Indirect</strong> distribution emphasis. <strong>Honesty marker:</strong> efficacy on LCWS36 caps at <strong>107 lm/W</strong> at the 15W setting and falls to <strong>96 lm/W</strong> at 36W max &mdash; this housing trades peak efficacy for a softer wall-wash photometric. For the 6-inch high-efficacy lane, spec the <strong>LCWS45</strong> R-variant instead at 138 lm/W peak. ' +
              '<strong>WATTSELECT</strong>: 15 / 22 / 30 / 36W &mdash; <strong>36W default</strong> at <strong>3,460 lm</strong>. ' +
              '<strong>DualCast\u2122</strong> only &mdash; <strong>no beam<span class="aa">\u24B6</span>DJUST</strong> on this SKU per the Active_SKUs spreadsheet Item Name. ' +
              'SKU: <code>LCWS36-3CS-27VD6/A1DC/DB</code> &mdash; no <code>/BA</code> beam-adjust suffix.</em>'
    },
    'LCWS45': {
      'rows': [
        { w: '18W',     lm: '2,480',  lpw: '<strong>138 lm/W</strong>', hid: '35W MH',  cct: '3000 / 4000 / 5000K' },
        { w: '27W',     lm: '3,670',  lpw: '136 lm/W',  hid: '70W MH',   cct: '3000 / 4000 / 5000K' },
        { w: '36W',     lm: '4,790',  lpw: '133 lm/W',  hid: '100W MH',  cct: '3000 / 4000 / 5000K' },
        { w: '45W \u2605',   lm: '<strong>5,850</strong>', lpw: '<strong>130 lm/W</strong>', hid: '100W MH', cct: '3000 / 4000 / 5000K' }
      ],
      'foot': '\u2605 <em><strong>LCWS45</strong> &mdash; the line leader. The <strong>only Aura housing that clears DLC Premium 130 lm/W</strong> across every WATTSELECT setting. <strong>138 lm/W peak at 18W</strong> at 4000K (low end of the field-set range), <strong>130 lm/W at 45W max</strong> &mdash; both above the DLC Premium floor. ' +
              '<strong>5,850 lm at 45W</strong> is the largest lumen package in the family, replacing 100W MH at max wattage. ' +
              '<strong>WATTSELECT</strong>: 18 / 27 / 36 / 45W &mdash; <strong>45W default</strong>. ' +
              '<strong>DualCast\u2122</strong> + <strong>beam<span class="aa">\u24B6</span>DJUST\u2122</strong> 50/60/70&deg; both standard. ' +
              'SKU: <code>LCWS45-3CS-27VR6/A1DC/BA/DB</code> &mdash; the "R" diameter variant indicates the round-distribution optic tuned for higher peak efficacy than the LCWS36 D-variant. ' +
              'When the project asks for spec-grade architectural cylinder performance and rebate-ready efficacy on the same wall, this is the SKU.</em>'
    }
  };

  function init() {
    var tabs   = document.querySelectorAll('.spec-watt-tab[data-model]');
    var tbody  = document.getElementById('specTableBody');
    var tfoot  = document.getElementById('specTableFoot');
    if (!tabs.length || !tbody) return;

    function render(model) {
      var d = DATA[model];
      if (!d) return;
      tbody.innerHTML = d.rows.map(function(r) {
        var defaultClass = r.w.indexOf('\u2605') > -1 ? ' class="is-default"' : '';
        return '<tr' + defaultClass + '>' +
                 '<td>' + r.w   + '</td>' +
                 '<td>' + r.lm  + ' lm</td>' +
                 '<td>' + r.lpw + '</td>' +
                 '<td>' + r.hid + '</td>' +
                 '<td>' + r.cct + '</td>' +
               '</tr>';
      }).join('');
      tfoot.innerHTML = d.foot;
    }

    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        render(t.dataset.model);
      });
    });

    // Default render \u2014 LCWS45 (the line leader)
    render('LCWS45');

    // Dimensions zoom \u2014 clone the SVG into the modal on open
    var zoomBtn   = document.getElementById('dimZoomBtn');
    var zoomModal = document.getElementById('dimZoomModal');
    var zoomClose = document.getElementById('dimZoomClose');
    var zoomImg   = document.getElementById('dimZoomImg');
    var dimSvg    = document.getElementById('dimSvg');
    if (zoomBtn && zoomModal && zoomImg && dimSvg) {
      zoomBtn.addEventListener('click', function() {
        zoomImg.innerHTML = '';
        var clone = dimSvg.cloneNode(true);
        clone.removeAttribute('id');
        clone.style.width = '100%';
        clone.style.height = 'auto';
        zoomImg.appendChild(clone);
        zoomModal.classList.add('open');
      });
      function closeZoom() { zoomModal.classList.remove('open'); }
      zoomClose.addEventListener('click', closeZoom);
      zoomModal.addEventListener('click', function(e) { if (e.target === zoomModal) closeZoom(); });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && zoomModal.classList.contains('open')) closeZoom();
      });
    }
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

