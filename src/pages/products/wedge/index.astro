<script>
/* =============================================================================
   SECTION 9 \u2014 Wedge Configurator engine
   2 user choices (Model, Finish) \u00B7 4 auto-locked (Series, Voltage, /PS, /EM)
   1 field-set DIP (CCT) \u2014 informational only, not in SKU
   SKU pattern: LWPE{model}-S3W-U{finish}/PS/EM
   ============================================================================= */
(function() {
  // Lumen output by model + CCT \u2014 matches Section 3 spec table
  var LUMEN = {
    '10': { '30': { lm: '1,300', lpw: '130' }, '40': { lm: '1,400', lpw: '140' }, '50': { lm: '1,350', lpw: '135' } },
    '20': { '30': { lm: '2,550', lpw: '128' }, '40': { lm: '2,660', lpw: '133' }, '50': { lm: '2,600', lpw: '130' } }
  };

  // Default state: Model defaults to LWPE20 (\u2605), Finish blank, CCT default 5000K
  var state = {
    model:    '20',    // user choice \u2014 defaults to LWPE20
    series:   'S3W',
    voltage:  'U',
    finish:   null,    // user choice
    photocell:'PS',
    em:       'EM',
    cct:      '50'     // DIP default \u00B7 5000K
  };

  // Finish-aware preview images (background already removed)
  var FINISH_IMG = {
    'B': '/products/wedge/assets/hero/wedge-hero-1-black.webp',
    'D': '/products/wedge/assets/hero/wedge-hero-1.webp'
  };

  function render() {
    // Counter \u2014 4 always locked (S3W, U, PS, EM) + Model default (5) + Finish (when picked) = 6
    var counterEl = document.getElementById('cfgCounter');
    var countEl   = document.getElementById('cfgCounterCount');
    var locked = 4 + (state.model ? 1 : 0) + (state.finish ? 1 : 0);
    countEl.textContent = locked;
    counterEl.classList.toggle('complete', locked === 6);

    // SKU
    var skuEl = document.getElementById('cfgSku');
    var fin = state.finish || '<span class="placeholder">_</span>';
    skuEl.innerHTML = 'LWPE' + state.model + '-S3W-U' + fin + '/PS/EM';

    // Preview image swap by finish (defaults to Black photo when unconfigured)
    var imgEl = document.getElementById('cfgPreviewImg');
    if (imgEl) {
      var src = state.finish ? FINISH_IMG[state.finish] : FINISH_IMG['B'];
      if (imgEl.getAttribute('src') !== src) imgEl.setAttribute('src', src);
      imgEl.alt = 'Wedge LWPE' + state.model + ' \u2014 ' + (state.finish === 'D' ? 'Dark Bronze' : 'Black') + ' finish preview';
    }

    // Tag
    var tag = document.getElementById('cfgPreviewTag');
    if (state.finish) {
      tag.textContent = 'LWPE' + state.model + ' \u00B7 ' + (state.finish === 'D' ? 'DARK BRONZE' : 'BLACK');
    } else {
      tag.textContent = 'LWPE' + state.model + ' \u00B7 UNCONFIGURED';
    }

    // Spec grid \u00B7 model
    document.getElementById('cfgSpecModel').textContent = 'LWPE' + state.model;

    // Spec grid \u00B7 finish
    var sf = document.getElementById('cfgSpecFinish');
    if (state.finish) {
      sf.classList.remove('placeholder');
      sf.textContent = (state.finish === 'D') ? 'Dark Bronze (MTO)' : 'Black (QuickShip)';
    } else {
      sf.classList.add('placeholder');
      sf.textContent = '\u2014 pick one \u2014';
    }

    // Spec grid \u00B7 CCT + output
    var cctMap = { '30': '3000K', '40': '4000K', '50': '5000K' };
    document.getElementById('cfgSpecCCT').textContent = cctMap[state.cct];
    var d = LUMEN[state.model][state.cct];
    document.getElementById('cfgSpecLumens').textContent = d.lm + ' lm \u00B7 ' + d.lpw + ' lm/W';

    // CCT chip codes \u2014 update with current model's lumen values so chips
    // reflect what the contractor will see at install.
    document.getElementById('cfgCctNote30').textContent = LUMEN[state.model]['30'].lm + ' lm @ LWPE' + state.model + ' \u00B7 ' + LUMEN[state.model]['30'].lpw + ' lm/W';
    document.getElementById('cfgCctNote40').textContent = LUMEN[state.model]['40'].lm + ' lm @ LWPE' + state.model + ' \u00B7 ' + LUMEN[state.model]['40'].lpw + ' lm/W \u2605';
    document.getElementById('cfgCctNote50').textContent = LUMEN[state.model]['50'].lm + ' lm @ LWPE' + state.model + ' \u00B7 ' + LUMEN[state.model]['50'].lpw + ' lm/W';

    // Incomplete warning + CTA gating
    var warn = document.getElementById('cfgIncomplete');
    var pricingCta = document.getElementById('cfgCtaPricing');
    var submittalCta = document.getElementById('cfgCtaSubmittal');
    if (!state.finish) {
      warn.classList.add('show');
      pricingCta.classList.add('disabled');
      submittalCta.classList.add('disabled');
    } else {
      warn.classList.remove('show');
      pricingCta.classList.remove('disabled');
      submittalCta.classList.remove('disabled');
      // Submittal link: pass SKU + DIP context as query params
      var sku = 'LWPE' + state.model + '-S3W-U' + state.finish + '/PS/EM';
      // CFG-QA-1: emit canonical 'wattage=' (not 'model=') so the submittal template
      // reads it on the primary path, not the legacy fallback. Wedge models are 10W
      // and 20W \u2014 the model number IS the wattage, so wattage=state.model is semantically
      // correct and matches every other product PDP's URL parameter contract.
      submittalCta.href = 'submittal_template.html?product=wedge&sku=' + encodeURIComponent(sku) + '&wattage=' + state.model + '&cct=' + state.cct + '&voltage=U&finish=' + state.finish;
    }

    // SKU copy reset
    var copyLabel = document.getElementById('cfgSkuCopyLabel');
    var copyBtn   = document.getElementById('cfgSkuCopy');
    copyLabel.textContent = 'Copy SKU';
    copyBtn.classList.remove('copied');
  }

  function init() {
    // Wire all chips
    var chips = document.querySelectorAll('#configurator .cfg-chip');
    chips.forEach(function(chip) {
      if (chip.classList.contains('locked')) return;
      chip.addEventListener('click', function() {
        var f = chip.dataset.field;
        var v = chip.dataset.val;
        var siblings = document.querySelectorAll('#configurator .cfg-chip[data-field="' + f + '"]');
        siblings.forEach(function(s) {
          s.classList.remove('selected');
          s.setAttribute('aria-pressed', 'false');
        });
        chip.classList.add('selected');
        chip.setAttribute('aria-pressed', 'true');
        state[f] = v;
        render();
      });
    });

    // Reset \u2014 restores Model default (LWPE20), clears Finish, restores CCT default (5000K)
    var resetBtn = document.getElementById('cfgReset');
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        state.model = '20';
        state.finish = null;
        state.cct = '50';
        document.querySelectorAll('#configurator .cfg-chip[data-field="model"]').forEach(function(c) {
          c.classList.toggle('selected', c.dataset.val === '20');
          c.setAttribute('aria-pressed', c.dataset.val === '20' ? 'true' : 'false');
        });
        document.querySelectorAll('#configurator .cfg-chip[data-field="finish"]').forEach(function(c) {
          c.classList.remove('selected'); c.setAttribute('aria-pressed', 'false');
        });
        document.querySelectorAll('#configurator .cfg-chip[data-field="cct"]').forEach(function(c) {
          c.classList.toggle('selected', c.dataset.val === '50');
          c.setAttribute('aria-pressed', c.dataset.val === '50' ? 'true' : 'false');
        });
        render();
      });
    }

    // Copy SKU
    var copyBtn = document.getElementById('cfgSkuCopy');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        if (!state.finish) return;
        var sku = 'LWPE' + state.model + '-S3W-U' + state.finish + '/PS/EM';
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(sku).then(function() {
            document.getElementById('cfgSkuCopyLabel').textContent = 'Copied!';
            copyBtn.classList.add('copied');
            setTimeout(function() {
              document.getElementById('cfgSkuCopyLabel').textContent = 'Copy SKU';
              copyBtn.classList.remove('copied');
            }, 1800);
          });
        }
      });
    }

    render();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

