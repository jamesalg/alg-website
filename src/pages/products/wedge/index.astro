/* =============================================================================
   SECTION 6 \u2014 Tab switcher: swap the callout body copy and sensor caption
   based on the active platform (photocell \u00B7 em). Reuses the .is-rippling
   shockwave handler already initialized further down.
   ============================================================================= */
(function() {
  var COPY = {
    'photocell': 'Integrated photocontrol ships pre-installed and wired into the driver \u2014 automatic on at sundown, off at sunrise. Unique vs Ramparts: Wedge\'s photocell is <strong>switchable</strong> \u2014 flip the on/off override at install when a separate control system manages switching, without ripping the photocell out. The sensor lives on the top face of the housing (visible to the right) and uses a low-light threshold to trigger the switching event. No bi-level dimming, no microwave occupancy sensor, no commissioning. Drop the fixture in, wire 120-277V to the J-box, walk away.',
    'em':        'The 4W const\u24B6NT-Ready emergency battery is built into every Wedge \u2014 not an optional /EM module. On AC loss, the EM driver kicks in within milliseconds and sustains <strong>~700 lm of egress output for 90 to 180 minutes</strong> depending on ambient temperature (180 min @ 65\u2013104\u00B0F, 100 min @ -4\u00B0F). Meets NFPA 101 / NEC 700 egress requirements without a separate luminaire on the wall. <strong>TestSure\u2122</strong> button on the housing runs a one-tap diagnostic \u2014 green LED for ready, red for service. Same naming and same UX on Sentinel, Guardian, Watchtower, and Nightwatch \u2014 the family lexicon for built-in egress.'
  };
  var LINK_LABEL = {
    'photocell': 'Discover Photocell controls \u2192',
    'em':        'Discover const\u24B6NT-Ready EM \u2192'
  };

  function init() {
    var tabs = document.querySelectorAll('#controls .tac-callout-tab');
    var copy = document.getElementById('tacCalloutCopy');
    var link = document.querySelector('#controls .tac-callout-link span');
    if (!tabs.length || !copy) return;
    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        var p = t.dataset.platform;
        copy.innerHTML = COPY[p] || COPY['photocell'];
        if (link) link.textContent = LINK_LABEL[p] || LINK_LABEL['photocell'];
      });
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

