<script>
/* =============================================================================
   SECTION 3 \u2014 Spec table model switcher.
   Wedge has 2 discrete model SKUs (LWPE10, LWPE20). Each tab swaps the
   table body to show that model's 3-CCT performance lineup, plus a
   model-specific footer with the actual draw, weight, and differentiator note.
   Lumen values come from the LWPE Wedge datasheet, page 2 Performance Data.
   Actual-draw values (17.5W, 25.1W) come from the corresponding archival IES
   files (LWPE17 / LWPE25 LM-79 test reports).
   ============================================================================= */
(function() {
  var DATA = {
    '10': [
      { cct: '3000K',   lumens: '1,300 lm', lpw: '130 lm/W',           cri: '\u2265 80', volt: '120-277V', def: false },
      { cct: '4000K \u2605', lumens: '1,400 lm', lpw: '<strong>140 lm/W</strong> (peak)', cri: '\u2265 80', volt: '120-277V', def: true  },
      { cct: '5000K',   lumens: '1,350 lm', lpw: '135 lm/W',           cri: '\u2265 80', volt: '120-277V', def: false }
    ],
    '20': [
      { cct: '3000K',   lumens: '2,550 lm', lpw: '128 lm/W',           cri: '\u2265 80', volt: '120-277V', def: false },
      { cct: '4000K \u2605', lumens: '2,660 lm', lpw: '<strong>133 lm/W</strong> (peak)', cri: '\u2265 80', volt: '120-277V', def: true  },
      { cct: '5000K',   lumens: '2,600 lm', lpw: '130 lm/W',           cri: '\u2265 80', volt: '120-277V', def: false }
    ]
  };
  var FOOT = {
    '10': '\u2605 <em>LWPE10 \u00B7 <strong>17.5W actual draw</strong> \u00B7 1.8 lb \u00B7 single-envelope housing. ' +
          'This is the model that delivers the <strong>140 lm/W top-of-class efficacy</strong> at the 4000K DIP setting \u2014 ' +
          'the lowest-watt, highest-efficacy spec in the mini wall pack category. Best for residential entries, low-traffic ' +
          'apartment hallways, and anywhere energy code rebate eligibility matters more than peak output.</em>',
    '20': '\u2605 <em>LWPE20 \u00B7 <strong>25.1W actual draw</strong> \u00B7 2.1 lb \u00B7 same housing as LWPE10. ' +
          'The higher-output SKU \u2014 pick this when the entryway feeds a parking lot or back lot and the project needs ' +
          'the brighter throw. <strong>4000K is the peak-efficacy CCT</strong> (133 lm/W) for the 20W model. CRI \u2265 80 ' +
          'across all 3 CCTs. Wattage is fixed per SKU \u2014 pick the model up front, then DIP only the CCT at install.</em>'
  };

  function init() {
    var tabs   = document.querySelectorAll('.spec-watt-tab[data-model]');
    var tbody  = document.getElementById('specTableBody');
    var tfoot  = document.getElementById('specTableFoot');
    if (!tabs.length || !tbody) return;

    function render(model) {
      tbody.innerHTML = DATA[model].map(function(r) {
        return '<tr class="' + (r.def ? 'is-default' : '') + '">' +
                 '<td>' + r.cct    + '</td>' +
                 '<td>' + r.lumens + '</td>' +
                 '<td>' + r.lpw    + '</td>' +
                 '<td>' + r.cri    + '</td>' +
                 '<td>' + r.volt   + '</td>' +
               '</tr>';
      }).join('');
      tfoot.innerHTML = FOOT[model];
    }

    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        tabs.forEach(function(x) {
          x.classList.remove('active');
          x.setAttribute('aria-selected', 'false');
        });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        render(t.dataset.model);
      });
    });

    // Default render \u2014 LWPE20 (the higher-output default)
    render('20');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>

