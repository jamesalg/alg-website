      stockEl.textContent = 'MTO \u00B7 ~4-6 wk';
      stockEl.style.color = '#ffb14d';
    }
  }
  function init() {
    var section = document.getElementById('configurator');
    if (!section) return;
    section.addEventListener('click', function(e) {
      if (e.target.closest('.cfg-chip')) setTimeout(refreshShipTier, 50);
    });
    var ralInput = document.getElementById('cfgRalInput');
    if (ralInput) ralInput.addEventListener('input', function() { setTimeout(refreshShipTier, 50); });
    refreshShipTier();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
</BaseLayout>
