      cat: 'Egress \u00B7 const\u24B6NT-Ready',
      title: '4W Emergency Backup + TestSure\u2122',
      sku: '/EM \u00B7 standard SKU segment',
      model: 'const\u24B6NT-Ready 4W battery driver + TestSure\u2122 diagnostic',
      desc: 'Built-in 4W emergency battery driver. On AC loss, sustains ~700 lm of egress output for 90 to 180 minutes (depending on temperature: 180 min @ 65\u2013104\u00B0F, 160 min @ 32\u00B0F, 100 min @ \u22124\u00B0F). Meets NFPA 101 / NEC 700 egress requirements without a second luminaire on the wall. TestSure\u2122 button on the housing runs a one-tap diagnostic \u2014 green LED for ready, red for service. const\u24B6NT-Ready is Archipelago\'s family lexicon for built-in egress: same naming and same UX on Sentinel, Guardian, Watchtower, Nightwatch.',
      specs: [
        ['EM Driver', '4W const\u24B6NT-Ready \u00B7 UL 924 listed'],
        ['Runtime by temp', '180 min @ 65\u2013104\u00B0F \u00B7 160 min @ 32\u00B0F \u00B7 100 min @ \u22124\u00B0F'],
        ['EM Output', '~700 lm during emergency operation'],
        ['Compliance', 'NFPA 101 \u00B7 NEC 700'],
        ['TestSure\u2122', 'One-tap push-button diagnostic \u00B7 green LED for ready, red for service'],
        ['Spec on SKU', '/EM \u2014 standard segment, never optional']
      ]
    },
    'mount': {
      cat: 'Wall Mount \u00B7 Included',
      title: 'J-Box Adapter + Mounting Hardware',
      sku: 'Pre-fitted \u00B7 4 stainless screws',
      model: 'Wall-mount J-box adapter + 4 corner anchor screws',
      desc: 'Wall-mount junction box adapter ships pre-fitted to every Wedge. Captures the supply wiring behind the fixture, hides the rough-in opening, and provides the structural anchor point for the four corner mounting screws (also included). Compatible with single-gang and 4-inch octagonal rough-in boxes for new construction or remodel. No separate hardware purchase, no contractor sourcing.',
      specs: [
        ['Type', 'Wall-mount J-box adapter \u00B7 pre-fitted to housing'],
        ['Mounting', '4 corner screws \u00B7 stainless steel \u00B7 included'],
        ['Wall opening', 'Compatible with single-gang or 4\u2033 octagonal rough-in'],
        ['Wire entry', 'Top knockout \u00B7 rear knockout'],
        ['Material', 'Cast aluminum \u00B7 matches housing finish'],
        ['Service', 'Removable for re-lamp or wiring service']
      ]
    }
  };

  function init() {
    var grid     = document.getElementById('accGrid');
    var modal    = document.getElementById('accModal');
    var closeBtn = document.getElementById('accModalClose');
    var imgWrap  = document.getElementById('accModalImg');
    var catEl    = document.getElementById('accModalCat');
    var titleEl  = document.getElementById('accModalTitle');
    var skuEl    = document.getElementById('accModalSku');
    var descEl   = document.getElementById('accModalDesc');
    var specsEl  = document.getElementById('accModalSpecs');
    var dsLink   = document.getElementById('accModalDatasheet');
    if (!grid || !modal) return;
    var cards = grid.querySelectorAll('.acc-card');

    function openModal(card) {
      var id = card.dataset.id;
      var d  = ACC[id];
      if (!d) { console.warn('acc-modal: no data for id', id); return; }
      catEl.textContent   = d.cat.replace(/\u24B6/g, '');
      titleEl.textContent = d.title;
      skuEl.innerHTML     = d.sku + (d.model && d.model !== d.sku ? '<div style="font-size:11px;color:var(--text-muted);font-weight:400;margin-top:2px;">' + d.model + '</div>' : '');
      descEl.textContent  = d.desc;
      if (d.cat.indexOf('\u24B6') >= 0) {
        catEl.innerHTML = d.cat.replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
      }
      specsEl.innerHTML = d.specs.map(function(s) {
        var v = (s[1] || '').toString().replace(/\u24B6/g, '<span class="aa" aria-hidden="true">\u24B6</span>');
        return '<div class="acc-spec-row">' +
                 '<div class="acc-spec-key">' + s[0] + '</div>' +
                 '<div class="acc-spec-val">' + v + '</div>' +
               '</div>';
      }).join('');
      if (dsLink) {
        if (d.datasheet) {
          dsLink.href = d.datasheet;
          dsLink.style.display = '';
        } else {
          dsLink.style.display = 'none';
          dsLink.removeAttribute('href');
        }
      }
      // Clone the card visual into the modal hero panel
      var srcMedia = card.querySelector('.acc-card-img svg, .acc-card-img img.acc-card-photo');
      Array.from(imgWrap.querySelectorAll('svg, img.acc-card-photo')).forEach(function(s){ s.remove(); });
      if (srcMedia) {
        var clone = srcMedia.cloneNode(true);
        if (clone.tagName === 'IMG') {
          clone.style.maxWidth = '90%';
          clone.style.maxHeight = '90%';
          clone.style.objectFit = 'contain';
          clone.style.filter = 'drop-shadow(0 12px 24px rgba(0,0,0,0.6))';
        }
        imgWrap.appendChild(clone);
      }
      modal.classList.add('open');
    }
    function closeModal() { modal.classList.remove('open'); }

    cards.forEach(function(c) {
      c.addEventListener('click', function() { openModal(c); });
    });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
