      stockEl.textContent = 'QuickShip \u00B7 2-3 day';
      stockEl.style.color = '#9bd6b1';
    } else if (tier === 'WB') {
      rowEl.style.background = 'rgba(96,168,255,0.08)';
      rowEl.style.border = '1px solid rgba(96,168,255,0.40)';
      iconEl.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#7fb6ff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>';
