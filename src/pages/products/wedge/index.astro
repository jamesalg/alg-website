<!-- =============================================================================
     SECTION 7 — Photometrics: CCT toggle at 20W max, swap stats only.
     All 3 CCT buttons (3000K / 4000K / 5000K) show the same polar plot SVG
     since beam shape is CCT-invariant. Lumens, efficacy, and peak intensity
     update per the datasheet model-spec table at 20W max.
     ============================================================================= -->
<script>
(function() {
  // Per-CCT data at 20W max \u2014 all from the datasheet model-spec table.
  // Peak intensity is linear-scaled from the 3000K IES (1,212 cd at 2,450 lm)
  // assuming uniform beam shape: cd/lm = 1212/2450 \u2248 0.495.
  var DATA = {
    '30': { svg: '/products/ramparts/assets/photometrics/ramparts_20w_30k.svg', peak: '1,212 cd', lumens: '2,450 lm', lpw: '124 lm/W efficacy', file: 'LWPE-20WBMDA1-abW30-120V-8.ies' },
    '40': { svg: '/products/ramparts/assets/photometrics/ramparts_20w_30k.svg', peak: '1,361 cd', lumens: '2,750 lm', lpw: '139 lm/W efficacy', file: 'LWPE-20WBMDA1-abW30-120V-8.ies (4000K \u00B7 scaled)' },
    '50': { svg: '/products/ramparts/assets/photometrics/ramparts_20w_30k.svg', peak: '1,311 cd', lumens: '2,650 lm', lpw: '134 lm/W efficacy', file: 'LWPE-20WBMDA1-abW30-120V-8.ies (5000K \u00B7 scaled)' }
  };

  function init() {
    var img         = document.getElementById('photoImg');
    var statPeak    = document.getElementById('photoStatPeak');
    var statPeakSub = document.getElementById('photoStatPeakSub');
    var statLum     = document.getElementById('photoStatLumens');
    var statLpw     = document.getElementById('photoStatLpw');
    var statFile    = document.getElementById('photoStatFile');
    if (!img) return;

    var cctTabs = document.querySelectorAll('.photo-tab[data-cct]');
    var state = { cct: '50' };

    function render() {
      var d = DATA[state.cct];
      if (!d) return;
      img.src = d.svg;
      img.alt = 'LWPE20 \u00B7 20W \u00B7 ' + state.cct + '00K \u00B7 103\u00B0 prismatic forward throw';
      statPeak.textContent = d.peak;
      // Sub-text follows the active CCT toggle so the label always matches the value above
      if (statPeakSub) statPeakSub.textContent = 'forward throw at 20W \u00B7 ' + state.cct + '00K';
      statLum.textContent  = d.lumens;
      statLpw.textContent  = d.lpw;
      statFile.textContent = d.file;
    }

    cctTabs.forEach(function(t) {
      t.addEventListener('click', function() {
        cctTabs.forEach(function(x) { x.classList.remove('active'); x.setAttribute('aria-selected','false'); });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        state.cct = t.dataset.cct;
        render();
      });
    });

    render();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>


<script>
/* =============================================================================
   CFG-NAV-1 \u00B7 Sticky-nav scroll-spy
   ----------------------------------------------------------------------------
   IntersectionObserver watches each section the sticky-nav links to. The link
   whose target is "most visible" gets '.is-current' (white bg + red text \u00B7 the
   visual inverse of '.primary'). One observer, one Map, one CSS class toggle.
   The Pricing & Availability primary button is NOT a section anchor (its href
   is /pricing-availability/), so it's excluded from the spy by the
   'a[href^="#"]' selector below.
   ============================================================================= */
(function() {
  var nav = document.querySelector('.sticky-nav');
  if (!nav) return;
  var links = Array.prototype.slice.call(nav.querySelectorAll('a[href^="#"]'));
  if (!links.length) return;
  var entries = [];
  links.forEach(function(a) {
    var id = a.getAttribute('href').slice(1);
    var sec = id ? document.getElementById(id) : null;
    if (sec) entries.push({ sec: sec, link: a, ratio: 0 });
  });
  if (!entries.length) return;
  function update() {
    var best = null, bestRatio = 0;
    entries.forEach(function(e) { if (e.ratio > bestRatio) { bestRatio = e.ratio; best = e; } });
    entries.forEach(function(e) { e.link.classList.toggle('is-current', e === best && bestRatio > 0); });
  }
  var io = new IntersectionObserver(function(items) {
    items.forEach(function(item) {
      entries.forEach(function(e) { if (e.sec === item.target) e.ratio = item.intersectionRatio; });
    });
    update();
  }, {
    rootMargin: '-20% 0px -55% 0px',
    threshold: [0, 0.1, 0.25, 0.5, 0.75, 1.0]
  });
  entries.forEach(function(e) { io.observe(e.sec); });
})();
</script>

<script>
