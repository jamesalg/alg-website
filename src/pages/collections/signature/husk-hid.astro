const skus = [
  { sku: 'LCRN1227-CSMG', watt: '12 / 18 / 27W', cct: '3000 / 4000 / 5000K', lumens: '3,780 / 4,185 / 4,050', replaces: '60W CFL · 100W MH/HPS/HID', voltage: '120–277V', sr: 'LCRN1227-CSMG/SR' },
  { sku: 'LCRN2745-CSMG', watt: '27 / 36 / 45W', cct: '3000 / 4000 / 5000K', lumens: '6,300 / 6,975 / 6,750', replaces: '100W CFL · 150W MH/HPS/HID', voltage: '120–277V', sr: 'LCRN2745-CSMG/SR' },
  { sku: 'LCRN4565-CSMG', watt: '45 / 55 / 65W', cct: '3000 / 4000 / 5000K', lumens: '9,450 / 10,450 / 10,000', replaces: '150W MH/HPS/HID', voltage: '120–277V', sr: 'LCRN4565-CSMG/SR' },
  { sku: 'LCRN6590-CSMG', watt: '65 / 80 / 90W', cct: '3000 / 4000 / 5000K', lumens: '13,650 / 15,400 / 14,850', replaces: '250W MH/HPS/HID', voltage: '120–277V', sr: 'LCRN6590-CSMG/SR' },
  { sku: 'LCRN60120-CSMG', watt: '60 / 90 / 120W', cct: '3000 / 4000 / 5000K', lumens: '12,600 / 14,700 / 14,400', replaces: '200W CFL · 400W MH/HPS/HID', voltage: '120–277V', sr: 'LCRN60120-CSMG/SR' },
  { sku: 'LCRN60120-CSHG', watt: '60 / 90 / 120W', cct: '3000 / 4000 / 5000K', lumens: '12,600 / 14,700 / 18,000', replaces: '200W CFL · 400W MH/HPS/HID', voltage: '277–480V', sr: 'LCRN60120-CSHG/SR' },
  { sku: 'LCRN100150-CSMG', watt: '100 / 120 / 150W', cct: '3000 / 4000 / 5000K', lumens: '20,550 / 23,100 / 21,750', replaces: '400W MH/HPS/HID', voltage: '120–277V', sr: 'LCRN100150-CSMG/SR' },
  { sku: 'LCRN200300-CSMG', watt: '200 / 240 / 300W', cct: '3000 / 4000 / 5000K', lumens: '41,700 / 46,200 / 44,100', replaces: '700W MH/HPS/HID', voltage: '120–277V', sr: 'LCRN200300-CSMG/SR' },
];
---
<BaseLayout
  title="The Husk — HID Retrofit | signⒶTURE | Archipelago Lighting Group"
  description="The Husk: 7 SKUs, 63 configurations, 12–300W input, replaces 50–700W legacy MH/HPS/HID. E39 mogul base. Ballast bypass. 120–480V. The signⒶTURE commercial HID retrofit."
  bodyClass="page-husk-family"
>
<style>
  :root {
    --husk-accent: #F32740;
    --husk-warm: #F5C24A;
    --husk-navy: #0A1628;
    --husk-paper: #F8F6F2;
    --husk-paper2: #F0EDE7;
    --husk-ink: #111111;
    --husk-mono: 'JetBrains Mono', ui-monospace, monospace;
    --husk-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .husk-paper  { background: var(--husk-paper); color: var(--husk-ink); }
  .husk-paper2 { background: var(--husk-paper2); color: var(--husk-ink); }
  .husk-dark   { background: var(--husk-navy); color: white; }
  .husk-char   { background: #0F0F0F; color: white; }
  .husk-eyebrow { font-family: var(--husk-mono); font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; }
  .husk-eyebrow-rule::before { content: ""; display: inline-block; width: 28px; height: 1px; background: var(--husk-accent); vertical-align: middle; margin-right: 12px; }
  .husk-accent-text { color: var(--husk-accent); }
  .husk-warm-text { color: var(--husk-warm); }
  .husk-h1 { font-family: var(--husk-sans); font-weight: 800; letter-spacing: -0.025em; line-height: 1.0; }
  .husk-h2 { font-family: var(--husk-sans); font-weight: 800; letter-spacing: -0.02em; line-height: 1.05; }
  .husk-stat-num { font-family: var(--husk-sans); font-weight: 900; font-size: 1.75rem; letter-spacing: -0.02em; line-height: 1; color: var(--husk-accent); }
  .husk-stat-label { font-family: var(--husk-mono); font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.65; margin-top: 4px; }
  .husk-btn { display: inline-flex; align-items: center; gap: 6px; padding: 12px 24px; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em; text-decoration: none; cursor: pointer; border: none; transition: background 0.15s; font-family: var(--husk-mono); }
  .husk-btn-primary { background: var(--husk-accent); color: white; }
  .husk-btn-primary:hover { background: #d01f33; }
  .husk-btn-outline { background: transparent; color: var(--husk-ink); border: 1.5px solid rgba(17,17,17,0.3); }
  .husk-btn-outline:hover { border-color: var(--husk-ink); }
  .husk-btn-ghost { background: transparent; color: var(--husk-ink); }
  .husk-btn-ghost:hover { text-decoration: underline; }
  .husk-trust-badge { font-family: var(--husk-mono); font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 4px 10px; border: 1px solid rgba(17,17,17,0.2); display: inline-block; }
  .husk-voltage-tag { font-family: var(--husk-mono); font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 10px; border: 1px solid rgba(17,17,17,0.15); background: rgba(17,17,17,0.04); display: inline-block; }
  .husk-voltage-tag-red { border-color: rgba(243,39,64,0.4); background: rgba(243,39,64,0.06); color: var(--husk-accent); }
  .husk-photo-ph { background: #1a1a1a; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; }
  .husk-photo-ph-text { font-family: var(--husk-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; text-align: center; padding: 2rem; border: 1px dashed rgba(255,255,255,0.12); margin: 2rem; color: rgba(255,255,255,0.4); }
  .husk-spec-row { display: grid; grid-template-columns: 1fr 2fr; gap: 1rem; padding: 0.75rem 0; border-bottom: 1px solid rgba(17,17,17,0.08); font-size: 0.875rem; }
  .husk-spec-row dt { font-family: var(--husk-mono); font-size: 0.7rem; letter-spacing: 0.08em; opacity: 0.7; }
  .husk-spec-row dd { margin: 0; }
  .husk-spec-block-num { font-family: var(--husk-mono); font-size: 0.6rem; letter-spacing: 0.18em; color: var(--husk-accent); }
  .husk-candor { background: rgba(245,194,74,0.12); border-left: 3px solid var(--husk-warm); padding: 1.5rem 2rem; }
  .husk-candor-ey { font-family: var(--husk-mono); color: #8a6510; font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; }
  .husk-sku-table { width: 100%; background: white; border: 1px solid rgba(17,17,17,0.1); font-family: var(--husk-mono); font-size: 0.68rem; }
  .husk-sku-table th { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid rgba(17,17,17,0.1); font-weight: 700; letter-spacing: 0.1em; opacity: 0.7; }
  .husk-sku-table td { padding: 0.6rem 1rem; border-bottom: 1px solid rgba(17,17,17,0.06); }
  .husk-sku-table tr:hover td { background: rgba(243,39,64,0.03); }
  .husk-cert-cell { padding: 1rem; border: 1px solid rgba(17,17,17,0.1); background: white; display: flex; flex-direction: column; gap: 4px; }
  .husk-cert-mark { font-family: var(--husk-mono); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; }
  .husk-cert-detail { font-size: 0.75rem; opacity: 0.65; }
  .husk-sister-card { display: block; padding: 1.25rem; border: 1px solid rgba(17,17,17,0.1); background: white; text-decoration: none; color: inherit; transition: border-color 0.15s; }
  .husk-sister-card:hover { border-color: var(--husk-accent); }
  .husk-breadcrumb { border-bottom: 1px solid rgba(17,17,17,0.1); background: white; }
  .husk-breadcrumb__inner { max-width: 1536px; margin: 0 auto; padding: 12px 24px; font-family: var(--husk-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.7; }
  .husk-breadcrumb a { color: inherit; text-decoration: none; }
  .husk-breadcrumb a:hover { color: var(--husk-accent); opacity: 1; }
  .husk-sensor-callout { background: rgba(22,163,74,0.08); border: 1px solid rgba(22,163,74,0.3); padding: 1.5rem 2rem; }
</style>

<div class="husk-breadcrumb">
  <div class="husk-breadcrumb__inner">
    <a href="/">HOME</a> ›
    <a href="/products/">PRODUCTS</a> ›
    <a href="/products/lamps/">LAMPS</a> ›
    <a href="/collections/signature/">SIGN<span class="aa">Ⓐ</span>TURE</a> ›
    THE HUSK
  </div>
</div>

<main id="main">

<!-- HERO -->
<section class="husk-paper" aria-labelledby="husk-hero-h1">
  <div style="max-width:1536px;margin:0 auto;padding:4rem 1.5rem;display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;" class="husk-hero-grid">
    <div class="husk-photo-ph">
      <div class="husk-photo-ph-text">HUSK PRODUCT PHOTOGRAPHY<br><span style="opacity:0.5;">— ROOSTER CREATIVE DELIVERABLE —</span><br><br><span style="opacity:0.5;">E39 MOGUL BASE · LAMP &amp; FIXTURE CUTAWAY</span></div>
    </div>
    <div>
      <p class="husk-eyebrow husk-eyebrow-rule" style="opacity:0.6;margin-bottom:1.5rem;"><span class="husk-accent-text">SIGN<span class="aa">Ⓐ</span>TURE ·</span> HID RETROFIT · E39 MOGUL BASE</p>
      <h1 id="husk-hero-h1" class="husk-h1" style="font-size:clamp(2.5rem,5vw,3.75rem);margin-bottom:1.5rem;">The Husk</h1>
      <p style="font-size:0.95rem;line-height:1.7;margin-bottom:1.5rem;opacity:0.9;max-width:36rem;">One commercial-grade LED replaces a span of legacy metal-halide and high-pressure-sodium wattages. Drop in, bypass the ballast, done. Six SKUs ship at 120–277V; the LCRN60120-CSHG variant covers 277–480V applications.</p>
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:1.5rem;">
        <span class="husk-voltage-tag">BALLAST BYPASS</span>
        <span class="husk-voltage-tag">LINE VOLTAGE DIRECT</span>
        <span class="husk-voltage-tag">120–277V (-CSMG · 6 SKUs)</span>
        <span class="husk-voltage-tag husk-voltage-tag-red">277–480V (-CSHG · LCRN60120 only)</span>
      </div>
      <dl style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem 2rem;margin-bottom:2rem;">
        <div><dd class="husk-stat-num">7 SKUs</dd><dt class="husk-stat-label">3-WATTselect × 3-CCTselect each</dt></div>
        <div><dd class="husk-stat-num">12–300W</dd><dt class="husk-stat-label">Input wattage span (per datasheet)</dt></div>
        <div><dd class="husk-stat-num">50–700W</dd><dt class="husk-stat-label">Legacy MH/HPS/HID replaced</dt></div>
        <div><dd class="husk-stat-num">150 lm/W</dd><dt class="husk-stat-label">Efficacy (typ. at 5000K)</dt></div>
      </dl>
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:1.5rem;">
        <span class="husk-trust-badge">DLC LISTED</span>
        <span class="husk-trust-badge">UL LISTED</span>
        <span class="husk-trust-badge">120–480V</span>
        <span class="husk-trust-badge">IP64</span>
        <span class="husk-trust-badge">5-YEAR WARRANTY</span>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:12px;">
        <a href="/support/sample-request?subject=Husk+HID+Quote" class="husk-btn husk-btn-primary">REQUEST AURA QUOTE</a>
        <a href="https://algportal.archipelagolighting.com" class="husk-btn husk-btn-outline" target="_blank" rel="noopener">SHOP STOCK &amp; BUY</a>
        <a href="#resources" class="husk-btn husk-btn-ghost">DOCUMENTATION ↓</a>
      </div>
    </div>
  </div>
</section>
<style>
  @media (max-width: 768px) { .husk-hero-grid { grid-template-columns: 1fr !important; } }
</style>

<!-- SKU CONSOLIDATION -->
<section class="husk-dark" aria-labelledby="husk-consol-h2">
  <div style="max-width:1536px;margin:0 auto;padding:5rem 1.5rem;">
    <p class="husk-eyebrow" style="color:var(--husk-warm);margin-bottom:1.5rem;">SKU CONSOLIDATION · WATTSELECT × CCTSELECT</p>
    <h2 id="husk-consol-h2" class="husk-h2" style="font-size:clamp(1.75rem,3.5vw,3rem);margin-bottom:1rem;">Seven SKUs. <span class="husk-warm-text">Sixty-three configurations.</span></h2>
    <div style="display:grid;grid-template-columns:5fr 7fr;gap:3rem;align-items:center;" class="husk-consol-grid">
      <div>
        <div style="display:flex;align-items:baseline;gap:1.5rem;">
          <div style="font-size:4.5rem;font-weight:900;color:rgba(255,255,255,0.25);font-family:var(--husk-sans);">13</div>
          <div style="font-size:2rem;color:rgba(255,255,255,0.4);">→</div>
          <div style="font-size:4.5rem;font-weight:900;color:var(--husk-warm);font-family:var(--husk-sans);">7</div>
        </div>
        <p class="husk-eyebrow" style="opacity:0.6;margin-top:0.75rem;">LEGACY HID WATTAGES · HUSK SKUS</p>
      </div>
      <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);padding:1.5rem;">
        <p class="husk-eyebrow" style="opacity:0.7;margin-bottom:1rem;">WATTAGE COVERAGE · LEGACY MH/HPS → HUSK SKU</p>
        <div style="height:12px;background:rgba(255,255,255,0.1);border-radius:6px;margin-bottom:0.75rem;overflow:hidden;">
          <div style="height:100%;background:linear-gradient(to right,var(--husk-warm),var(--husk-accent));border-radius:6px;"></div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(7,1fr);font-family:var(--husk-mono);font-size:0.6rem;text-align:center;opacity:0.8;">
          <div>50W</div><div>70W</div><div>100W</div><div>175W</div><div>250W</div><div>400W</div><div>700W</div>
        </div>
        <p class="husk-eyebrow" style="opacity:0.5;margin-top:1.5rem;line-height:1.7;">7 SKUS · LCRN1227 · LCRN1827 · LCRN2727 · LCRN4527 · LCRN6527 · LCRN12027 · LCRN200300 · ALL CSMG SUFFIX (CCT 2700K · MOGUL E39)</p>
      </div>
    </div>
  </div>
</section>
<style>
  @media (max-width: 768px) { .husk-consol-grid { grid-template-columns: 1fr !important; } }
</style>

<!-- FIND MY HID WIZARD -->
<section class="husk-paper2" aria-labelledby="husk-wizard-h2">
  <div style="max-width:1536px;margin:0 auto;padding:5rem 1.5rem;">
    <p class="husk-eyebrow husk-eyebrow-rule husk-accent-text" style="margin-bottom:1.5rem;">FIND MY HID</p>
    <h2 id="husk-wizard-h2" class="husk-h2" style="font-size:clamp(1.5rem,3vw,2.5rem);margin-bottom:1rem;">Tell us what you're replacing. We'll tell you what to order — and how long the rewire takes.</h2>
    <p style="opacity:0.7;max-width:36rem;margin-bottom:2rem;font-size:0.9rem;">Three questions. One SKU recommendation with per-fixture labor estimate.</p>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.5rem;max-width:56rem;" class="husk-wizard-grid">
      <div style="padding:1.5rem;border:1px solid rgba(17,17,17,0.1);background:white;">
        <h3 style="font-weight:600;font-size:0.95rem;margin-bottom:1rem;">What HID lamp are you replacing?</h3>
        <div style="display:flex;flex-direction:column;gap:8px;font-size:0.85rem;">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="radio" name="lamp-type" value="mh"> Metal Halide (MH)</label>
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="radio" name="lamp-type" value="hps"> High-Pressure Sodium (HPS)</label>
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="radio" name="lamp-type" value="hid"> Generic HID / Unknown</label>
        </div>
      </div>
      <div style="padding:1.5rem;border:1px solid rgba(17,17,17,0.1);background:white;">
        <h3 style="font-weight:600;font-size:0.95rem;margin-bottom:1rem;">What's the fixture / install path?</h3>
        <div style="display:flex;flex-direction:column;gap:8px;font-size:0.85rem;">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="radio" name="fixture-type" value="bypass"> Ballast bypass (recommended)</label>
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="radio" name="fixture-type" value="existing"> Keep existing ballast</label>
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="radio" name="fixture-type" value="new"> New fixture installation</label>
        </div>
      </div>
      <div style="padding:1.5rem;border:1px solid rgba(17,17,17,0.1);background:white;">
        <h3 style="font-weight:600;font-size:0.95rem;margin-bottom:1rem;">Building voltage at the fixture?</h3>
        <div style="display:flex;flex-direction:column;gap:8px;font-size:0.85rem;">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="radio" name="voltage" value="120-277"> 120–277V (standard)</label>
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="radio" name="voltage" value="277-480"> 277–480V (high-voltage)</label>
        </div>
      </div>
    </div>
    <style>
      @media (max-width: 768px) { .husk-wizard-grid { grid-template-columns: 1fr !important; } }
    </style>
    <p style="font-family:var(--husk-mono);font-size:0.65rem;letter-spacing:0.12em;opacity:0.5;margin-top:1.5rem;">CONTACT SALES FOR A FULL SPEC RESPONSE WITH PER-FIXTURE LABOR ESTIMATE · <a href="/support/sample-request?subject=Husk+HID+Spec" style="color:var(--husk-accent);text-decoration:none;">REQUEST AURA QUOTE →</a></p>
  </div>
</section>

<!-- STRUCTURED SPEC TABLE -->
<section class="husk-paper" aria-labelledby="husk-spec-h2">
  <div style="max-width:1536px;margin:0 auto;padding:5rem 1.5rem;">
    <p class="husk-eyebrow husk-eyebrow-rule husk-accent-text" style="margin-bottom:1.5rem;">FULL SPECIFICATION</p>
    <h2 id="husk-spec-h2" class="husk-h2" style="font-size:clamp(1.5rem,3vw,2.5rem);margin-bottom:3rem;">Five spec blocks. Anchored, exportable, signed.</h2>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;" class="husk-spec-grid">
      <article id="spec-electrical">
        <p class="husk-spec-block-num" style="margin-bottom:0.5rem;">01</p>
        <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:1rem;">Electrical &amp; Driver</h3>
        <dl>
          <div class="husk-spec-row"><dt>Input voltage</dt><dd>120–277V AC (-CSMG) · 277–480V AC (-CSHG)</dd></div>
          <div class="husk-spec-row"><dt>Wattage (WATTselect)</dt><dd>3-position dip-switch · per-SKU range (see SKU table)</dd></div>
          <div class="husk-spec-row"><dt>Power factor</dt><dd>≥0.90</dd></div>
          <div class="husk-spec-row"><dt>THD</dt><dd>≤20%</dd></div>
          <div class="husk-spec-row"><dt>Surge protection</dt><dd>4kV L-N per datasheet</dd></div>
          <div class="husk-spec-row"><dt>Driver type</dt><dd>Constant-current · integrated · non-dimmable (standard)</dd></div>
        </dl>
      </article>
      <article id="spec-photometric">
        <p class="husk-spec-block-num" style="margin-bottom:0.5rem;">02</p>
        <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:1rem;">Photometric</h3>
        <dl>
          <div class="husk-spec-row"><dt>Efficacy</dt><dd>Up to 150 lm/W (typ. at 5000K)</dd></div>
          <div class="husk-spec-row"><dt>CCT options (CCTselect)</dt><dd>3000K · 4000K · 5000K</dd></div>
          <div class="husk-spec-row"><dt>CRI</dt><dd>≥80 (standard) · ≥90 on request</dd></div>
          <div class="husk-spec-row"><dt>Beam angle</dt><dd>360° omnidirectional</dd></div>
          <div class="husk-spec-row"><dt>L70 life</dt><dd>&gt;50,000 hours</dd></div>
        </dl>
      </article>
      <article id="spec-materials">
        <p class="husk-spec-block-num" style="margin-bottom:0.5rem;">03</p>
        <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:1rem;">Materials &amp; Build</h3>
        <dl>
          <div class="husk-spec-row"><dt>Base</dt><dd>E39 mogul screw base</dd></div>
