<script>
  const wizard = document.getElementById('wizard');
  const resultCard = document.getElementById('wizard-result');

  const skuData = {
    rebate: { sku: 'ALG-HUSK-150W-4K', name: 'The Husk · 150W · 4000K · E39 Mogul Base', lumens: '21,000 lm', replaces: '250W MH / 200W HPS', certs: 'DLC Premium · BAA' },
    lumen: { sku: 'ALG-HUSK-240W-4K', name: 'The Husk · 240W · 4000K · E39 Mogul Base', lumens: '33,600 lm', replaces: '400W MH / 320W HPS', certs: 'DLC Premium · BAA' },
    baa: { sku: 'ALG-HUSK-150W-4K', name: 'The Husk · 150W · 4000K · E39 Mogul Base (BAA)', lumens: '21,000 lm', replaces: '250W MH / 200W HPS', certs: 'DLC Premium · BAA' }
  };

  wizard.querySelectorAll('.wizard__option').forEach(btn => {
    btn.addEventListener('click', () => {
      const step = btn.closest('.wizard__step');
      if (btn.dataset.next) {
        step.classList.remove('wizard__step--active');
        wizard.querySelector(`[data-step="${btn.dataset.next}"]`).classList.add('wizard__step--active');
      } else if (btn.dataset.result) {
        wizard.style.display = 'none';
        const d = skuData[btn.dataset.result] || skuData.rebate;
        document.getElementById('result-sku').textContent = d.sku;
        document.getElementById('result-name').textContent = d.name;
        document.getElementById('result-lumens').textContent = d.lumens;
        document.getElementById('result-replaces').textContent = d.replaces;
        document.getElementById('result-certs').textContent = d.certs;
        resultCard.classList.add('wizard-result--visible');
      }
    });
  });

  wizard.querySelectorAll('.wizard__back').forEach(btn => {
    btn.addEventListener('click', () => {
      const currentStep = btn.closest('.wizard__step');
      currentStep.classList.remove('wizard__step--active');
      wizard.querySelector(`[data-step="${btn.dataset.back}"]`).classList.add('wizard__step--active');
    });
  });

  document.getElementById('wizard-restart').addEventListener('click', () => {
    resultCard.classList.remove('wizard-result--visible');
    wizard.style.display = '';
    wizard.querySelectorAll('.wizard__step').forEach((s, i) => s.classList.toggle('wizard__step--active', i === 0));
  });

  const tocLinks = document.querySelectorAll('.spec-toc__link');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        tocLinks.forEach(l => l.classList.remove('spec-toc__link--active'));
        const active = document.querySelector(`.spec-toc__link[href="#${entry.target.id}"]`);
        if (active) active.classList.add('spec-toc__link--active');
      }
    });
  }, { rootMargin: '-20% 0px -60% 0px' });
  document.querySelectorAll('.spec-group').forEach(g => observer.observe(g));
</script>
