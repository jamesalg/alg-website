</style>

<script>
  /* Fix 4 (v2.4.1) - Application filter.
   * Clicking an app tile or a sidebar checkbox filters the all-families grid.
   * Tile click also scrolls to #sec-all-families.
   * Reset all clears all active filters. */
  (function () {
    const tiles = Array.from(document.querySelectorAll('.app-tile[data-app]'));
    const cbs   = Array.from(document.querySelectorAll('.app-filter-cb'));
    const cards = Array.from(document.querySelectorAll('#all-fam-grid .af-card[data-application]'));
    const countEl = document.querySelector('.grid-count');
    const resetBtn = document.querySelector('.filter-reset');
    const allFamSection = document.getElementById('sec-all-families');

    function getActive() {
      return cbs.filter(cb => cb.checked).map(cb => cb.value);
    }

    function applyFilter() {
      const active = getActive();
      let shown = 0;
      cards.forEach(function (card) {
        const app = card.dataset.application || '';
        const match = active.length === 0 || active.some(function (a) { return app.startsWith(a); });
        if (match) { card.removeAttribute('hidden'); shown++; }
        else { card.setAttribute('hidden', ''); }
      });
      if (countEl) {
        countEl.textContent = active.length === 0
          ? 'Showing 23 families'
          : 'Showing ' + shown + ' of 23 families';
      }
      tiles.forEach(function (tile) {
        const app = tile.dataset.app || '';
        tile.classList.toggle('is-active', active.indexOf(app) !== -1);
      });
    }

    tiles.forEach(function (tile) {
      tile.addEventListener('click', function () {
        const app = tile.dataset.app;
        const cb = cbs.find(function (c) { return c.value === app; });
        if (cb) { cb.checked = !cb.checked; }
        applyFilter();
        if (allFamSection) {
          allFamSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    cbs.forEach(function (cb) { cb.addEventListener('change', applyFilter); });

    if (resetBtn) {
      resetBtn.addEventListener('click', function (e) {
        e.preventDefault();
        cbs.forEach(function (cb) { cb.checked = false; });
        applyFilter();
      });
    }
  })();
</script>
