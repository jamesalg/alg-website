---
/**
 * collections/luxoarch.astro
 *
 * luxoⒶRCH Collection Page — v2.4.0
 * Outdoor lighting collection: 23 families, 269 SKUs, 8 applications.
 *
 * Uses BaseLayout (canonical Header + Footer via shared partials).
 * All Ⓐ via <BrandMark> component.
 * Page-specific styles inline in <style> block, scoped.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandMark from '../../components/BrandMark.astro';

const families = [
  { sub: 'SPORTS LIGHTING', tier: 'PRO',  name: 'Illuminator',   maxW: '800W',  skus: 11, dlc: true  },
  { sub: 'AREA LIGHT',      tier: 'PRO',  name: 'Liberty',       maxW: '450W',  skus: 24, dlc: true  },
  { sub: 'SPORTS LIGHTING', tier: 'PRO',  name: 'Radiator-II',   maxW: '1200W', skus: 10, dlc: true  },
  { sub: 'STRING LIGHT',    tier: 'ECO',  name: 'LSL Series',    maxW: 'n/a',   skus: 20, dlc: false },
  { sub: 'SPORTS LIGHTING', tier: 'PRO+', name: 'Beacon-I',      maxW: '1200W', skus: 3,  dlc: true  },
  { sub: 'FLOOD LIGHT',     tier: 'PRO+', name: 'Zion-II',       maxW: '300W',  skus: 16, dlc: true  },
  { sub: 'WALL PACK · ADJUSTABLE', tier: 'ECO', name: 'Anaheim', maxW: '80W',   skus: 10, dlc: true  },
  { sub: 'WALL PACK · FULL CUTOFF', tier: 'PRO', name: 'Nightwatch', maxW: '100W', skus: 10, dlc: true },
  { sub: 'AREA LIGHT',      tier: 'ECO',  name: 'Heritage',      maxW: '300W',  skus: 4,  dlc: true  },
  { sub: 'AREA LIGHT',      tier: 'PRO+', name: 'Rosetta-III',   maxW: '300W',  skus: 8,  dlc: true  },
  { sub: 'FLOOD LIGHT',     tier: 'ECO',  name: 'Everest',       maxW: '150W',  skus: 8,  dlc: true  },
  { sub: 'WALL PACK · CLASSIC', tier: 'ECO', name: 'Guardian',   maxW: '120W',  skus: 4,  dlc: true  },
  { sub: 'WALL PACK · CLASSIC', tier: 'PRO', name: 'Sentinel',   maxW: '120W',  skus: 5,  dlc: true  },
  { sub: 'WALL PACK · FULL CUTOFF', tier: 'ECO', name: 'Watchtower', maxW: '120W', skus: 5, dlc: true },
  { sub: 'CANOPY',          tier: 'PRO',  name: 'Pathfinder',    maxW: '110W',  skus: 4,  dlc: true  },
  { sub: 'CYLINDER',        tier: 'PRO',  name: 'Aura',          maxW: '45W',   skus: 4,  dlc: false },
  { sub: 'SPORTS LIGHTING', tier: 'PRO',  name: 'Radiator-I',    maxW: '1200W', skus: 2,  dlc: true  },
  { sub: 'WALL PACK · ARCHITECTURAL SLIM', tier: 'ECO', name: 'Shield', maxW: '120W', skus: 4, dlc: true },
  { sub: 'DOCK LIGHT',      tier: 'PRO',  name: 'Canadarm',      maxW: '60W',   skus: 2,  dlc: false },
  { sub: 'WALL PACK · ENTRYWAY', tier: 'ECO', name: 'Wedge-I',   maxW: '20W',   skus: 4,  dlc: true  },
  { sub: 'WALL PACK · ADJUSTABLE', tier: 'PRO', name: 'Atlanta', maxW: '120W',  skus: 2,  dlc: true  },
  { sub: 'WALL PACK · ENTRYWAY', tier: 'ECO', name: 'Ramparts',  maxW: '20W',   skus: 2,  dlc: true  },
  { sub: 'SPORTS LIGHTING', tier: 'PRO',  name: 'Radiator-III',  maxW: '480W',  skus: 1,  dlc: true  },
];

const tierColor: Record<string, string> = { 'PRO': '#F32740', 'PRO+': '#FFC107', 'ECO': '#5B8DEF' };
---
<BaseLayout
  title="luxoARCH Outdoor Collection — Archipelago Lighting Group"
  description="Outdoor lighting for the commercial perimeter. 23 active families, 269 active SKUs, ECO through PRO+."
  bodyClass="page-luxoarch"
>
  <!-- ================================================================
       BREADCRUMB BAND
       ================================================================ -->
  <div class="breadcrumb-band">
    <a href="/">Home</a>
    <span class="bc-sep">/</span>
    <a href="#">Products</a>
    <span class="bc-sep">/</span>
    <a href="#">Outdoor</a>
    <span class="bc-sep">/</span>
    <span class="bc-current"><BrandMark prefix="luxo" suffix="RCH" /></span>
  </div>

  <!-- ================================================================
       §2 HERO — dark band + gradient placeholder image strip
       ================================================================ -->
  <section class="hero-band" id="sec-hero">
    <div class="hero-top">
      <div class="hero-eyebrow">OUTDOOR · COLLECTION</div>
      <h1 class="hero-wordmark">LUXO<BrandMark prefix="" suffix="RCH" />
      </h1>
      <p class="hero-desc">Outdoor lighting for the commercial perimeter. 23 active families, 269 active SKUs, ECO through PRO+.</p>
      <div class="hero-pills">
        <span class="hero-pill">DLC PREMIUM</span>
        <span class="hero-pill">TAA AVAILABLE</span>
        <span class="hero-pill">5 US WAREHOUSES</span>
        <span class="hero-pill">3-DAY DELIVERY</span>
        <span class="hero-pill">8 APPLICATIONS</span>
      </div>
    </div>
    <!-- Fix 3 (v2.4.1): hero-image-strip removed; re-add in v2.4.x with hero-luxo.jpg -->
  </section>

  <!-- ================================================================
       §3 STAT STRIP — 4 columns on dark
       ================================================================ -->
  <section class="stat-strip" id="sec-stats">
    <div class="stat-col">
      <div class="stat-num">23</div>
      <div class="stat-label">Fixture Families</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-col">
      <div class="stat-num">269</div>
      <div class="stat-label">Active SKUs</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-col">
      <div class="stat-num">8</div>
      <div class="stat-label">Applications</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-col">
      <div class="stat-num stat-red">DLC</div>
      <div class="stat-label">Premium Listed</div>
    </div>
  </section>

  <!-- ================================================================
       §4 BROWSE BY APPLICATION — 8 SVG-icon tiles
       ================================================================ -->
  <section class="page-section" id="sec-apps">
    <div class="section-inner">
      <div class="sec-eyebrow">Browse by application</div>
      <div class="app-grid">

        <!-- Sports Lighting -->
        <div class="app-tile" data-app="Sports Lighting">
          <svg class="app-icon" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="14" cy="14" r="10" stroke="#8a8f99" stroke-width="1.5"/>
            <line x1="14" y1="4" x2="14" y2="24" stroke="#8a8f99" stroke-width="1.2"/>
            <line x1="4" y1="14" x2="24" y2="14" stroke="#8a8f99" stroke-width="1.2"/>
            <circle cx="14" cy="14" r="3" stroke="#8a8f99" stroke-width="1.2"/>
          </svg>
          <div class="app-name">Sports Lighting</div>
          <div class="app-sku">61 SKUs</div>
        </div>

        <!-- Area Light -->
        <div class="app-tile" data-app="Area Light">
          <svg class="app-icon" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <line x1="14" y1="4" x2="14" y2="14" stroke="#8a8f99" stroke-width="1.5"/>
            <rect x="6" y="14" width="16" height="4" rx="1" stroke="#8a8f99" stroke-width="1.2"/>
            <path d="M8 18 L6 24 M20 18 L22 24" stroke="#8a8f99" stroke-width="1.2"/>
            <line x1="6" y1="24" x2="22" y2="24" stroke="#8a8f99" stroke-width="1.2"/>
          </svg>
          <div class="app-name">Area Light</div>
          <div class="app-sku">90 SKUs</div>
        </div>

        <!-- Wall Pack -->
        <div class="app-tile" data-app="Wall Pack">
          <svg class="app-icon" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="5" y="8" width="18" height="12" rx="2" stroke="#8a8f99" stroke-width="1.5"/>
            <line x1="5" y1="20" x2="23" y2="20" stroke="#8a8f99" stroke-width="1.2"/>
            <path d="M9 20 L7 26 M19 20 L21 26" stroke="#8a8f99" stroke-width="1.2"/>
          </svg>
          <div class="app-name">Wall Pack</div>
          <div class="app-sku">52 SKUs</div>
        </div>

        <!-- Flood Light -->
        <div class="app-tile" data-app="Flood Light">
          <svg class="app-icon" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 4 L24 22 L4 22 Z" stroke="#8a8f99" stroke-width="1.5" stroke-linejoin="round"/>
            <line x1="14" y1="22" x2="14" y2="26" stroke="#8a8f99" stroke-width="1.2"/>
          </svg>
          <div class="app-name">Flood Light</div>
          <div class="app-sku">24 SKUs</div>
        </div>

        <!-- String Light -->
        <div class="app-tile" data-app="String Light">
          <svg class="app-icon" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 8 Q7 4 10 8 Q13 12 16 8 Q19 4 22 8 Q25 12 28 8" stroke="#8a8f99" stroke-width="1.5" fill="none"/>
            <circle cx="7" cy="8" r="2" stroke="#8a8f99" stroke-width="1.2"/>
            <circle cx="14" cy="10" r="2" stroke="#8a8f99" stroke-width="1.2"/>
            <circle cx="21" cy="8" r="2" stroke="#8a8f99" stroke-width="1.2"/>
          </svg>
          <div class="app-name">String Light</div>
          <div class="app-sku">20 SKUs</div>
        </div>

        <!-- Canopy -->
        <div class="app-tile" data-app="Canopy">
          <svg class="app-icon" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 18 Q14 6 24 18" stroke="#8a8f99" stroke-width="1.5" fill="none"/>
            <line x1="4" y1="18" x2="24" y2="18" stroke="#8a8f99" stroke-width="1.2"/>
            <rect x="11" y="18" width="6" height="4" rx="1" stroke="#8a8f99" stroke-width="1.2"/>
          </svg>
          <div class="app-name">Canopy</div>
          <div class="app-sku">7 SKUs</div>
        </div>

        <!-- Cylinder -->
        <div class="app-tile" data-app="Cylinder">
          <svg class="app-icon" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="10" y="4" width="8" height="20" rx="4" stroke="#8a8f99" stroke-width="1.5"/>
          </svg>
          <div class="app-name">Cylinder</div>
          <div class="app-sku">4 SKUs</div>
        </div>

        <!-- Dock Light -->
        <div class="app-tile" data-app="Dock Light">
          <svg class="app-icon" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <line x1="14" y1="4" x2="14" y2="14" stroke="#8a8f99" stroke-width="1.5"/>
            <path d="M14 14 Q20 14 22 20" stroke="#8a8f99" stroke-width="1.5" fill="none"/>
            <circle cx="22" cy="22" r="3" stroke="#8a8f99" stroke-width="1.2"/>
          </svg>
          <div class="app-name">Dock Light</div>
          <div class="app-sku">4 SKUs</div>
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================================
       §5 RED STAT BANNER — 6 columns on brand red
       ================================================================ -->
  <section class="red-banner" id="sec-red-banner">
    <div class="red-banner-inner">
      <div class="rb-col"><div class="rb-num">23</div><div class="rb-label">Families</div></div>
      <div class="rb-div"></div>
      <div class="rb-col"><div class="rb-num">269</div><div class="rb-label">Active SKUs</div></div>
      <div class="rb-div"></div>
      <div class="rb-col"><div class="rb-num">8</div><div class="rb-label">Applications</div></div>
      <div class="rb-div"></div>
      <div class="rb-col"><div class="rb-num">DLC</div><div class="rb-label">Premium</div></div>
      <div class="rb-div"></div>
      <div class="rb-col"><div class="rb-num">TAA</div><div class="rb-label">Available</div></div>
      <div class="rb-div"></div>
      <div class="rb-col"><div class="rb-num">5 US</div><div class="rb-label">Warehouses</div></div>
    </div>
  </section>

  <!-- ================================================================
       §6 FEATURED FAMILIES — 5 dark cards
       ================================================================ -->
  <section class="page-section" id="sec-featured">
    <div class="section-inner">
      <div class="sec-eyebrow">Featured families</div>
      <h2 class="sec-title">Five flagship families for the commercial perimeter.</h2>
      <p class="sec-sub">The most-specified <BrandMark prefix="luxo" suffix="RCH" /> families across stadium, parking, wall, and flood applications.</p>
      <div class="featured-grid">

        <!-- Card 1: Illuminator — line drawing provided -->
        <div class="fam-card">
          <div class="fam-card-top">
            <span class="fam-sub-tag">SPORTS LIGHTING</span>
            <span class="tier-badge tier-pro">PRO</span>
          </div>
          <div class="fam-img-wrap">
            <img src="/images/collections/luxoarch/line-drawings/line-illuminator.png" alt="Illuminator line drawing" class="fam-line-img" />
          </div>
          <div class="fam-card-bottom">
            <div class="fam-info">
              <div class="fam-name">Illuminator</div>
              <div class="fam-meta">800W max · 11 SKUs</div>
              <span class="dlc-pill">DLC</span>
            </div>
            <a href="#" class="fam-view">VIEW →</a>
          </div>
        </div>

        <!-- Card 2: Liberty — line drawing provided -->
        <div class="fam-card">
          <div class="fam-card-top">
            <span class="fam-sub-tag">AREA LIGHT</span>
            <span class="tier-badge tier-pro">PRO</span>
          </div>
          <div class="fam-img-wrap">
            <img src="/images/collections/luxoarch/line-drawings/line-liberty.png" alt="Liberty line drawing" class="fam-line-img" />
          </div>
          <div class="fam-card-bottom">
            <div class="fam-info">
              <div class="fam-name">Liberty</div>
              <div class="fam-meta">450W max · 24 SKUs</div>
              <span class="dlc-pill">DLC</span>
            </div>
            <a href="#" class="fam-view">VIEW →</a>
          </div>
        </div>

        <!-- Card 3: Beacon-I — grey block placeholder -->
        <div class="fam-card">
          <div class="fam-card-top">
            <span class="fam-sub-tag">SPORTS LIGHTING</span>
            <span class="tier-badge tier-proplus">PRO+</span>
          </div>
          <div class="fam-img-placeholder">Beacon-I</div>
          <div class="fam-card-bottom">
            <div class="fam-info">
              <div class="fam-name">Beacon-I</div>
              <div class="fam-meta">1200W max · 3 SKUs</div>
              <span class="dlc-pill">DLC</span>
            </div>
            <a href="#" class="fam-view">VIEW →</a>
          </div>
        </div>

        <!-- Card 4: Zion-II — grey block placeholder -->
        <div class="fam-card">
          <div class="fam-card-top">
            <span class="fam-sub-tag">FLOOD LIGHT</span>
            <span class="tier-badge tier-proplus">PRO+</span>
          </div>
          <div class="fam-img-placeholder">Zion-II</div>
          <div class="fam-card-bottom">
            <div class="fam-info">
              <div class="fam-name">Zion-II</div>
              <div class="fam-meta">300W max · 16 SKUs</div>
              <span class="dlc-pill">DLC</span>
            </div>
            <a href="#" class="fam-view">VIEW →</a>
          </div>
        </div>

        <!-- Card 5: Nightwatch — grey block placeholder -->
        <div class="fam-card">
          <div class="fam-card-top">
            <span class="fam-sub-tag">WALL PACK · FULL CUTOFF</span>
            <span class="tier-badge tier-pro">PRO</span>
          </div>
          <div class="fam-img-placeholder">Nightwatch</div>
          <div class="fam-card-bottom">
            <div class="fam-info">
              <div class="fam-name">Nightwatch</div>
              <div class="fam-meta">100W max · 10 SKUs</div>
              <span class="dlc-pill">DLC</span>
            </div>
            <a href="#" class="fam-view">VIEW →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================================
       §7 ALL FAMILIES — filter rail + 23-card grid
       ================================================================ -->
  <section class="page-section bg-tint" id="sec-all-families">
    <div class="section-inner section-inner--wide">
      <div class="sec-eyebrow">All families</div>
      <h2 class="sec-title">23 families. One outdoor portfolio.</h2>
      <div class="families-layout">

        <!-- Filter rail (decorative in v2.4.0) -->
        <aside class="filter-rail">
          <div class="filter-header">
            <span class="filter-title">FILTER BY</span>
            <a href="#" class="filter-reset">Reset all</a>
          </div>

          <div class="filter-group">
            <div class="filter-group-label">Application <span class="fg-arrow">▲</span></div>
            <div class="filter-options">
              <label class="filter-opt"><input type="checkbox" class="app-filter-cb" value="Sports Lighting" /> Sports Lighting <span class="fg-count">(6)</span></label>
              <label class="filter-opt"><input type="checkbox" class="app-filter-cb" value="Area Light" /> Area Light <span class="fg-count">(4)</span></label>
              <label class="filter-opt"><input type="checkbox" class="app-filter-cb" value="Wall Pack" /> Wall Pack <span class="fg-count">(10)</span></label>
              <label class="filter-opt"><input type="checkbox" class="app-filter-cb" value="Flood Light" /> Flood Light <span class="fg-count">(2)</span></label>
              <label class="filter-opt"><input type="checkbox" class="app-filter-cb" value="String Light" /> String Light <span class="fg-count">(1)</span></label>
              <label class="filter-opt"><input type="checkbox" class="app-filter-cb" value="Canopy" /> Canopy <span class="fg-count">(1)</span></label>
              <label class="filter-opt"><input type="checkbox" class="app-filter-cb" value="Cylinder" /> Cylinder <span class="fg-count">(1)</span></label>
              <label class="filter-opt"><input type="checkbox" class="app-filter-cb" value="Dock Light" /> Dock Light <span class="fg-count">(1)</span></label>
            </div>
          </div>

          <div class="filter-group">
            <div class="filter-group-label">Echelon <span class="fg-arrow">▲</span></div>
            <div class="filter-options">
              <label class="filter-opt"><input type="checkbox" disabled /> ECO <span class="fg-count">(12)</span></label>
              <label class="filter-opt"><input type="checkbox" disabled /> PRO <span class="fg-count">(9)</span></label>
              <label class="filter-opt"><input type="checkbox" disabled /> PRO+ <span class="fg-count">(3)</span></label>
            </div>
          </div>

          <div class="filter-group">
            <div class="filter-group-label">Max Wattage <span class="fg-arrow">▲</span></div>
            <div class="filter-options">
              <div class="range-placeholder">
                <div class="range-track"><div class="range-fill"></div></div>
                <div class="range-labels"><span>10W</span><span>1500W</span></div>
              </div>
            </div>
          </div>

          <div class="filter-group">
            <div class="filter-group-label">CCT <span class="fg-arrow">▲</span></div>
            <div class="filter-options">
              <label class="filter-opt"><input type="checkbox" disabled /> 2200K</label>
              <label class="filter-opt"><input type="checkbox" disabled /> 2700K</label>
              <label class="filter-opt"><input type="checkbox" disabled /> 3000K</label>
              <label class="filter-opt"><input type="checkbox" disabled /> 4000K</label>
              <label class="filter-opt"><input type="checkbox" disabled /> 5000K</label>
              <label class="filter-opt"><input type="checkbox" disabled /> 5700K</label>
            </div>
          </div>

          <div class="filter-group">
            <div class="filter-group-label">Voltage <span class="fg-arrow">▲</span></div>
            <div class="filter-options">
              <label class="filter-opt"><input type="checkbox" disabled /> 120-277V</label>
              <label class="filter-opt"><input type="checkbox" disabled /> 120V Only</label>
              <label class="filter-opt"><input type="checkbox" disabled /> 200-480V</label>
              <label class="filter-opt"><input type="checkbox" disabled /> 277-480V</label>
            </div>
          </div>

          <div class="filter-group">
            <div class="filter-group-label">DLC <span class="fg-arrow">▲</span></div>
            <div class="filter-options">
              <label class="filter-opt"><input type="checkbox" disabled /> DLC Premium</label>
              <label class="filter-opt"><input type="checkbox" disabled /> DLC Standard</label>
            </div>
          </div>

          <div class="filter-group">
            <div class="filter-group-label">TAA Compliant <span class="fg-arrow">▲</span></div>
            <div class="filter-options">
              <label class="filter-opt"><input type="checkbox" disabled /> TAA Compliant</label>
            </div>
          </div>

          <div class="filter-group">
            <div class="filter-group-label">Mount Type <span class="fg-arrow">▲</span></div>
            <div class="filter-options">
              <label class="filter-opt"><input type="checkbox" disabled /> Slip Fitter</label>
              <label class="filter-opt"><input type="checkbox" disabled /> Trunnion</label>
              <label class="filter-opt"><input type="checkbox" disabled /> Surface</label>
              <label class="filter-opt"><input type="checkbox" disabled /> Pendant</label>
              <label class="filter-opt"><input type="checkbox" disabled /> Knuckle</label>
            </div>
          </div>
        </aside>

        <!-- Grid column -->
        <div class="families-grid-col">
          <div class="grid-header">
            <span class="grid-count">Showing 23 families</span>
            <div class="sort-wrap">
              <select class="sort-select" disabled>
                <option>Sort: Featured</option>
                <option>Wattage Low to High</option>
                <option>Wattage High to Low</option>
                <option>A to Z</option>
              </select>
            </div>
          </div>

          <div class="all-fam-grid" id="all-fam-grid">
            {families.map((f) => (
              <div class="af-card" data-application={f.sub.split(' · ')[0]}>
                <div class="af-card-top">
                  <span class="fam-sub-tag">{f.sub}</span>
                  <span class={`tier-badge tier-${f.tier === 'PRO+' ? 'proplus' : f.tier.toLowerCase()}`}>{f.tier}</span>
                </div>
                <div class="fam-img-placeholder af-placeholder">{f.name}</div>
                <div class="af-card-bottom">
                  <div class="fam-info">
                    <div class="fam-name af-name">{f.name}</div>
                    <div class="fam-meta">{f.maxW !== 'n/a' ? `${f.maxW} max · ` : ''}{f.skus} SKUs</div>
                    {f.dlc && <span class="dlc-pill">DLC</span>}
                  </div>
                  <a href="#" class="fam-view">VIEW →</a>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================================
       §8 LEGACY PLACEHOLDER
       ================================================================ -->
  <section class="page-section" id="sec-legacy">
    <div class="section-inner">
      <div class="sec-eyebrow">Legacy · coming soon</div>
      <div class="legacy-box">
        <h3 class="legacy-h3">Replacement guidance for discontinued families.</h3>
