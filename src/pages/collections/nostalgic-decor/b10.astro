 * Route: /collections/nostalgic-decor/b10
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ResourceCard from '../../../components/ResourceCard.astro';

const resources = [
  {
    icon: 'PDF',
    title: 'Datasheet',
    desc: 'The Knoll B10 product datasheet',
    url: null,
    family: 'The Knoll B10',
    resource: 'Datasheet',
  },
  {
    icon: 'PDF',
    title: 'Installation Sheet',
    desc: 'Per-SKU install instructions',
    url: null,
    family: 'The Knoll B10',
    resource: 'Installation Sheet',
  },
  {
    icon: 'IES',
    title: 'IES Files',
    desc: 'Photometric data · per CCT and glass finish',
    url: null,
    family: 'The Knoll B10',
    resource: 'IES Files',
  },
  {
    icon: 'PDF',
    title: 'ALG Décor Lamps · Product Guide · Q2 2026',
