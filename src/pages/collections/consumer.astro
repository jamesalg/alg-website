---
/**
 * consumer.astro — Consumer & Retail Capabilities Overview
 * v2.5.6 Track C
 *
 * Bespoke statement page. NOT a product collection page.
 * Does NOT use CollectionPageLayout.
 * Exempt from Group H structural lock (H.1 only checks pages that use CollectionPageLayout).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Consumer & Retail — Archipelago Lighting Group"
  description="Six categories. Six aisles. One catalog. Archipelago's residential and retail capabilities for large retail buyers and OEM partners."
  bodyClass="page-consumer"
>

<!-- ============================================================
     BREADCRUMB
     ============================================================ -->
<nav class="bc-wrap" aria-label="Breadcrumb">
  <div class="bc-inner">
    <a href="/">HOME</a>
    <span class="bc-sep">›</span>
    <span>PRODUCTS</span>
    <span class="bc-sep">›</span>
    <span>RESIDENTIAL</span>
    <span class="bc-sep">›</span>
    <span class="bc-current">Consumer &amp; Retail</span>
  </div>
</nav>

<!-- ============================================================
     HERO
     ============================================================ -->
<section class="c-hero">
  <div class="c-hero-inner">
    <div class="c-hero-eyebrow">Consumer &amp; Retail · Capabilities Overview</div>
    <h1 class="c-hero-h1">Six categories. <span class="c-accent">Six aisles.</span><br>One catalog.</h1>
    <p class="c-hero-sub">From the garage to the garden, from the campsite to the cocktail party — Archipelago's residential and retail capabilities, organized the way your shoppers actually browse.</p>
    <div class="c-hero-meta">
      <span><strong>6</strong> categories</span>
      <span class="c-meta-dot">·</span>
      <span><strong>5</strong> retail brands</span>
      <span class="c-meta-dot">·</span>
      <span><strong>30+</strong> years supplying shelves</span>
    </div>
    <div class="c-hero-ctas">
      <a href="/support/catalog-request" class="c-btn-primary">Browse the Full Catalog</a>
      <a href="/support/capability-deck" class="c-btn-secondary">Request Capability Deck</a>
    </div>
  </div>
</section>

<!-- ============================================================
     SUB-TAGLINE
     ============================================================ -->
<div class="c-sub-tagline">
  <div class="c-sub-tagline-inner">
    House brand, co-brand, or OEM — built to match your planogram, your packaging standards, and your replenishment rhythm.
  </div>
</div>

<!-- ============================================================
     STICKY AISLE NAV
     ============================================================ -->
<div class="c-subnav-wrap" id="c-subnav">
  <div class="c-subnav">
    <a href="#home" class="c-subnav-item active" data-aisle="home">
      <span class="c-subnav-num">01</span>
      <span class="c-subnav-label">Home</span>
      <span class="c-subnav-dot"></span>
    </a>
    <a href="#garden" class="c-subnav-item" data-aisle="garden">
      <span class="c-subnav-num">02</span>
      <span class="c-subnav-label">Garden</span>
      <span class="c-subnav-dot"></span>
    </a>
    <a href="#work" class="c-subnav-item" data-aisle="work">
      <span class="c-subnav-num">03</span>
      <span class="c-subnav-label">Work</span>
      <span class="c-subnav-dot"></span>
    </a>
    <a href="#auto" class="c-subnav-item" data-aisle="auto">
      <span class="c-subnav-num">04</span>
      <span class="c-subnav-label">Auto</span>
      <span class="c-subnav-dot"></span>
    </a>
    <a href="#camping" class="c-subnav-item" data-aisle="camping">
      <span class="c-subnav-num">05</span>
      <span class="c-subnav-label">Camping</span>
      <span class="c-subnav-dot"></span>
    </a>
    <a href="#party" class="c-subnav-item" data-aisle="party">
      <span class="c-subnav-num">06</span>
      <span class="c-subnav-label">Party</span>
      <span class="c-subnav-dot"></span>
    </a>
  </div>
</div>

<!-- ============================================================
     NEW & EXPANDING CALLOUT
     ============================================================ -->
<section class="c-callout">
  <div class="c-callout-inner">
    <div class="c-callout-eyebrow">New &amp; Expanding in 2026</div>
    <ul class="c-callout-list">
      <li>Deeper "work + trade overlap": more magnetic, portable, and job-site SKUs built for repeat use</li>
      <li>Expanded outdoor durability: higher IP-rated options and improved weather sealing across more families</li>
      <li>More "spec-first" consumer products: real lumens, real runtimes, real materials — not seasonal throwaways</li>
      <li>Broader private-label readiness: more packaging formats and faster line refresh support</li>
    </ul>
  </div>
</section>

<!-- ============================================================
     CAPABILITY PROOF
     ============================================================ -->
<section class="c-cap">
  <div class="c-cap-inner">
    <div class="c-section-eyebrow">Capability Proof</div>
    <h2 class="c-cap-h2">We build residential and retail lighting like a commercial supplier: engineered, compliant, and ready to ship.</h2>
    <div class="c-cap-grid">
      <div class="c-cap-card">
        <div class="c-cap-card-num">01</div>
        <h3 class="c-cap-card-title">Compliance &amp; quality discipline</h3>
        <ul class="c-cap-card-list">
          <li>Safety-listed SKUs across core categories (UL/ETL where applicable)</li>
          <li>Outdoor-rated constructions available across multiple families (IP-rated options)</li>
          <li>Warranty-backed programs built for retail reality (not one-season products)</li>
        </ul>
      </div>
      <div class="c-cap-card">
        <div class="c-cap-card-num">02</div>
        <h3 class="c-cap-card-title">Supply chain + replenishment readiness</h3>
        <ul class="c-cap-card-list">
          <li>Stocked in US warehouses for fast replenishment and in-season continuity</li>
          <li>Retail-ready packaging support: multi-pack, PDQ shipper, and shelf-ready formats</li>
          <li>OEM/white-label experience supplying national retailers for three decades</li>
        </ul>
      </div>
      <div class="c-cap-card">
        <div class="c-cap-card-num">03</div>
        <h3 class="c-cap-card-title">Category architecture (how you win shelf space)</h3>
        <ul class="c-cap-card-list">
          <li>Families designed to merchandise cleanly: good/better/best ladders, feature callouts, and SKU rationalization</li>
          <li>"Aisle logic" that matches shopper intent, not internal part numbering</li>
        </ul>
      </div>
    </div>
    <div class="c-cap-ctas">
      <a href="/find-a-distributor" class="c-btn-primary">Find a Retailer</a>
      <a href="/support/line-review" class="c-btn-secondary">Request a Line Review</a>
    </div>
  </div>
</section>

<!-- ============================================================
     AISLE 01 — HOME
     ============================================================ -->
<section class="c-seg c-seg--home" id="home">
  <div class="c-seg-content">
    <div class="c-seg-label" style="color: var(--c-home);">
      <span class="c-seg-label-line" style="background: var(--c-home);"></span>
      Section 01 · Home
      <span class="c-seg-num">01 / 06</span>
    </div>
    <h2 class="c-seg-title">The catchall aisle — and the broadest reach.</h2>
    <p class="c-seg-lead">Garage lights, security floods, pathway markers, shop fixtures — everyday lighting that lives in every American home and the home-improvement aisle that supplies it.</p>
    <p class="c-seg-body">Built for the homeowner who knows what they need. Built for the retailer who needs SKUs that move. Impulse-friendly shop lights. Photocell-controlled security floods. Pathway lighting that borrows control know-how from commercial.</p>
    <div class="c-expanding">
      <div class="c-expanding-label">What's expanding</div>
      <ul>
        <li>More "grab-and-go" garage and utility formats</li>
        <li>More outdoor-ready options with upgraded durability</li>
        <li>Cleaner SKU architecture for easier resets and replenishment</li>
      </ul>
    </div>
    <div class="c-seg-ctas">
      <a href="/support/catalog-request?aisle=home" class="c-btn-primary">Browse Home Catalog</a>
      <a href="/find-a-distributor" class="c-btn-secondary">Find a Retailer</a>
    </div>
  </div>
  <div class="c-seg-visual">
    <svg class="c-seg-illust" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M50 200 L50 130 L200 50 L350 130 L350 200 Z" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.4)" stroke-width="2"/>
      <path d="M50 130 L200 50 L350 130" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2"/>
      <rect x="80" y="140" width="100" height="60" fill="rgba(255,255,255,0.12)" stroke="rgba(255,255,255,0.35)" stroke-width="1.5"/>
      <line x1="80" y1="160" x2="180" y2="160" stroke="rgba(255,255,255,0.25)"/>
      <line x1="80" y1="180" x2="180" y2="180" stroke="rgba(255,255,255,0.25)"/>
      <rect x="240" y="150" width="40" height="50" fill="rgba(255,255,255,0.12)" stroke="rgba(255,255,255,0.35)" stroke-width="1.5"/>
      <rect x="200" y="155" width="28" height="28" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.3)"/>
      <rect x="295" y="155" width="28" height="28" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.3)"/>
      <circle cx="110" cy="125" r="6" fill="#f0a932"/>
      <path d="M110,125 L70,200 L150,200 Z" fill="rgba(240,169,50,0.18)"/>
      <circle cx="260" cy="135" r="6" fill="#f0a932"/>
      <path d="M260,135 L235,200 L285,200 Z" fill="rgba(240,169,50,0.15)"/>
      <circle cx="310" cy="125" r="6" fill="#f0a932"/>
      <path d="M310,125 L290,200 L330,200 Z" fill="rgba(240,169,50,0.15)"/>
      <circle cx="80" cy="240" r="3" fill="#f0a932"/>
      <circle cx="120" cy="245" r="3" fill="#f0a932"/>
      <circle cx="160" cy="248" r="3" fill="#f0a932"/>
      <circle cx="200" cy="250" r="3" fill="#f0a932"/>
      <circle cx="240" cy="248" r="3" fill="#f0a932"/>
      <rect x="0" y="260" width="400" height="40" fill="rgba(0,0,0,0.2)"/>
      <text x="200" y="290" text-anchor="middle" fill="#9ec57a" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5">SECURITY · LANDSCAPE · GARAGE</text>
    </svg>
  </div>
</section>

<!-- ============================================================
     AISLE 02 — GARDEN
     ============================================================ -->
<section class="c-seg c-seg--garden c-seg--rev" id="garden">
  <div class="c-seg-content">
    <div class="c-seg-label" style="color: #9eddb5;">
      <span class="c-seg-label-line" style="background: #9eddb5;"></span>
      Section 02 · Garden &amp; Horticultural
      <span class="c-seg-num">02 / 06</span>
    </div>
    <h2 class="c-seg-title">Grow lights for the serious gardener.</h2>
    <p class="c-seg-lead">PolyGrow horticultural fixtures. Outdoor garden ambient lighting. Pathway and accent for the landscape that gets curated, not just maintained.</p>
    <p class="c-seg-body">The serious home gardener needs lighting the big-box generic LED aisle doesn't carry. PAR-tuned spectrum options, full-spectrum vegetative, and bloom-stage fixtures — plus outdoor accent / pathway for customers who care how the garden looks at night.</p>
    <div class="c-expanding">
      <div class="c-expanding-label">What's expanding</div>
      <ul>
        <li>Deeper horticultural spectrum options and form factors</li>
        <li>More outdoor-rated garden lighting that holds up season after season</li>
      </ul>
    </div>
    <div class="c-seg-ctas">
      <a href="/support/catalog-request?aisle=garden" class="c-btn-primary">Browse Garden Catalog</a>
      <a href="/collections/polygrow" class="c-btn-secondary">Explore PolyGrow</a>
    </div>
  </div>
  <div class="c-seg-visual">
    <svg class="c-seg-illust" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <ellipse cx="200" cy="80" rx="120" ry="50" fill="rgba(158,221,181,0.12)" stroke="rgba(158,221,181,0.4)" stroke-width="1.5"/>
      <line x1="200" y1="80" x2="200" y2="260" stroke="rgba(158,221,181,0.5)" stroke-width="2"/>
      <ellipse cx="140" cy="130" rx="60" ry="30" fill="rgba(158,221,181,0.1)" stroke="rgba(158,221,181,0.3)" stroke-width="1.5"/>
      <ellipse cx="260" cy="150" rx="60" ry="30" fill="rgba(158,221,181,0.1)" stroke="rgba(158,221,181,0.3)" stroke-width="1.5"/>
      <ellipse cx="170" cy="190" rx="50" ry="25" fill="rgba(158,221,181,0.08)" stroke="rgba(158,221,181,0.25)" stroke-width="1.5"/>
      <rect x="185" y="250" width="30" height="30" fill="rgba(158,221,181,0.15)" stroke="rgba(158,221,181,0.3)" stroke-width="1.5"/>
      <circle cx="200" cy="40" r="20" fill="rgba(240,169,50,0.3)" stroke="#f0a932" stroke-width="1.5"/>
      <line x1="200" y1="20" x2="200" y2="10" stroke="#f0a932" stroke-width="1.5"/>
      <line x1="214" y1="26" x2="221" y2="19" stroke="#f0a932" stroke-width="1.5"/>
      <line x1="220" y1="40" x2="230" y2="40" stroke="#f0a932" stroke-width="1.5"/>
      <text x="200" y="290" text-anchor="middle" fill="#9eddb5" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5">POLYGROW · PATHWAY · ACCENT</text>
    </svg>
  </div>
</section>

<!-- ============================================================
     AISLE 03 — WORK
     ============================================================ -->
<section class="c-seg c-seg--work" id="work">
  <div class="c-seg-content">
    <div class="c-seg-label" style="color: var(--c-work);">
      <span class="c-seg-label-line" style="background: var(--c-work);"></span>
      Section 03 · Work
      <span class="c-seg-num">03 / 06</span>
    </div>
    <h2 class="c-seg-title">Job-site lighting that takes a hit.</h2>
    <p class="c-seg-lead">Portable work lights. Magnetic shop lights. Temporary job-site fixtures. The lighting that goes in the back of the truck and comes home with paint on it.</p>
    <p class="c-seg-body">Built for the contractor who's tired of renting job-site lighting and decided to buy once. Drop-resistant housings. Magnetic mounts. Corded options for the trades that wire as they go.</p>
    <div class="c-expanding">
      <div class="c-expanding-label">What's expanding</div>
      <ul>
        <li>More contractor-grade durability features across the line</li>
        <li>More mounting versatility (magnetic, hook, clip, stand-ready)</li>
      </ul>
    </div>
    <div class="c-seg-ctas">
      <a href="/support/catalog-request?aisle=work" class="c-btn-primary">Browse Work Catalog</a>
      <a href="/support/for-contractors" class="c-btn-secondary">For Contractors</a>
    </div>
  </div>
  <div class="c-seg-visual">
    <svg class="c-seg-illust" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="120" y="80" width="160" height="100" rx="8" fill="rgba(201,168,118,0.15)" stroke="rgba(201,168,118,0.5)" stroke-width="2"/>
      <rect x="140" y="100" width="120" height="60" rx="4" fill="rgba(201,168,118,0.1)" stroke="rgba(201,168,118,0.3)" stroke-width="1.5"/>
      <circle cx="200" cy="130" r="25" fill="rgba(240,169,50,0.25)" stroke="#f0a932" stroke-width="1.5"/>
      <circle cx="200" cy="130" r="15" fill="rgba(240,169,50,0.4)"/>
      <line x1="200" y1="180" x2="200" y2="220" stroke="rgba(201,168,118,0.5)" stroke-width="3"/>
      <rect x="170" y="220" width="60" height="20" rx="4" fill="rgba(201,168,118,0.2)" stroke="rgba(201,168,118,0.4)" stroke-width="1.5"/>
      <circle cx="150" cy="250" r="12" fill="none" stroke="rgba(201,168,118,0.4)" stroke-width="1.5"/>
      <circle cx="250" cy="250" r="12" fill="none" stroke="rgba(201,168,118,0.4)" stroke-width="1.5"/>
      <text x="200" y="290" text-anchor="middle" fill="#c9a876" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5">PORTABLE · MAGNETIC · CORDED</text>
    </svg>
  </div>
</section>

<!-- ============================================================
     AISLE 04 — AUTO
     ============================================================ -->
<section class="c-seg c-seg--auto c-seg--rev" id="auto">
  <div class="c-seg-content">
    <div class="c-seg-label" style="color: #7aa6ff;">
      <span class="c-seg-label-line" style="background: #7aa6ff;"></span>
      Section 04 · Auto &amp; Utility
      <span class="c-seg-num">04 / 06</span>
    </div>
    <h2 class="c-seg-title">Trouble lights for the trouble-shooter.</h2>
    <p class="c-seg-lead">Inspection lighting. Mobile mechanic essentials. Truck-bed work lights — the aisle that lives next to the OBD-II scanner.</p>
    <p class="c-seg-body">Dropped-from-the-hood-prop tested. Magnetic mounts that stick to fenders. Hooks that hang anywhere. Cords long enough to reach the rear differential. New section, real products — starting with our 75-watt trouble light.</p>
    <!-- Featured product: CTL75-M -->
    <div class="c-fp">
      <div class="c-fp-thumb" aria-hidden="true">
        <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" width="40" height="40">
          <circle cx="30" cy="20" r="14" fill="none" stroke="#7aa6ff" stroke-width="1.5"/>
          <circle cx="30" cy="20" r="8" fill="rgba(122,166,255,0.3)"/>
          <line x1="30" y1="34" x2="30" y2="50" stroke="#7aa6ff" stroke-width="2"/>
          <rect x="20" y="50" width="20" height="6" rx="2" fill="rgba(122,166,255,0.3)" stroke="#7aa6ff" stroke-width="1"/>
        </svg>
      </div>
      <div class="c-fp-info">
        <div class="c-fp-eyebrow">Featured Product · Auto</div>
        <div class="c-fp-name">CTL75-M Trouble Light</div>
        <div class="c-fp-spec">75W max · Black + galvanized · Hook + magnetic · 25 ft cord</div>
      </div>
      <a href="/support/sample-request?sku=CTL75-M" class="c-fp-cta">View Product</a>
    </div>
    <div class="c-seg-ctas">
      <a href="/support/catalog-request?aisle=auto" class="c-btn-primary">Browse Auto Catalog</a>
      <a href="/find-a-distributor" class="c-btn-secondary">Find a Retailer</a>
    </div>
  </div>
  <div class="c-seg-visual">
    <svg class="c-seg-illust" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <ellipse cx="200" cy="200" rx="140" ry="50" fill="rgba(122,166,255,0.08)" stroke="rgba(122,166,255,0.2)" stroke-width="1"/>
      <rect x="80" y="120" width="240" height="80" rx="12" fill="rgba(122,166,255,0.08)" stroke="rgba(122,166,255,0.3)" stroke-width="1.5"/>
      <rect x="100" y="140" width="60" height="40" rx="4" fill="rgba(122,166,255,0.12)" stroke="rgba(122,166,255,0.25)" stroke-width="1"/>
      <rect x="240" y="140" width="60" height="40" rx="4" fill="rgba(122,166,255,0.12)" stroke="rgba(122,166,255,0.25)" stroke-width="1"/>
      <circle cx="130" cy="200" r="20" fill="none" stroke="rgba(122,166,255,0.4)" stroke-width="2"/>
      <circle cx="270" cy="200" r="20" fill="none" stroke="rgba(122,166,255,0.4)" stroke-width="2"/>
      <circle cx="200" cy="100" r="18" fill="rgba(240,220,180,0.3)" stroke="#f0dca0" stroke-width="1.5"/>
      <path d="M200,100 L160,200 L240,200 Z" fill="rgba(240,220,180,0.1)"/>
      <text x="200" y="275" text-anchor="middle" fill="#7aa6ff" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5">INSPECTION · MAGNETIC · TROUBLE</text>
    </svg>
    <!-- Headlight beam effect -->
    <div class="c-auto-beam" aria-hidden="true"></div>
  </div>
</section>

<!-- ============================================================
     AISLE 05 — CAMPING
     ============================================================ -->
<section class="c-seg c-seg--camping" id="camping">
  <div class="c-seg-content">
    <div class="c-seg-label" style="color: #7adbb5;">
      <span class="c-seg-label-line" style="background: #7adbb5;"></span>
      Section 05 · Camping &amp; Outdoor Recreation
      <span class="c-seg-num">05 / 06</span>
    </div>
    <h2 class="c-seg-title">Solar work lights off the grid.</h2>
    <p class="c-seg-lead">USB-solar charged. Real output. Real runtime. Compact form factors that earn a spot in the gear bin.</p>
    <p class="c-seg-body">Built for overlanders who care about specs more than packaging claims: real lumens, USB-C charging, solar topping during daylight, and mounts that work on tents and rigs.</p>
    <!-- Featured product: SWL-1000 -->
    <div class="c-fp c-fp--camping">
      <div class="c-fp-thumb" aria-hidden="true">
        <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" width="40" height="40">
          <circle cx="30" cy="25" r="12" fill="none" stroke="#7adbb5" stroke-width="1.5"/>
          <circle cx="30" cy="25" r="6" fill="rgba(122,219,181,0.4)"/>
          <path d="M22,10 L30,5 L38,10" fill="none" stroke="#f0a932" stroke-width="1.5"/>
          <line x1="30" y1="37" x2="30" y2="50" stroke="#7adbb5" stroke-width="1.5"/>
          <rect x="22" y="50" width="16" height="6" rx="2" fill="rgba(122,219,181,0.2)" stroke="#7adbb5" stroke-width="1"/>
        </svg>
      </div>
      <div class="c-fp-info">
        <div class="c-fp-eyebrow">Featured Product · Camping</div>
        <div class="c-fp-name">SWL-1000 Solar Work Light</div>
        <div class="c-fp-spec">1000 lumen · USB-solar charging · 8 hr runtime · IPX5</div>
      </div>
      <a href="/support/sample-request?sku=SWL-1000" class="c-fp-cta">View Product</a>
    </div>
    <div class="c-expanding">
      <div class="c-expanding-label">What's expanding</div>
      <ul>
        <li>Deeper horticultural spectrum options and form factors</li>
        <li>More outdoor-rated options built for repeat seasons</li>
      </ul>
    </div>
    <div class="c-seg-ctas">
      <a href="/support/catalog-request?aisle=camping" class="c-btn-primary">Browse Camping Catalog</a>
      <a href="/find-a-distributor" class="c-btn-secondary">Find a Retailer</a>
    </div>
  </div>
  <div class="c-seg-visual">
    <!-- Stars -->
    <div class="c-camp-stars" aria-hidden="true">
      {[...Array(18)].map((_, i) => (
        <div class="c-star" style={`top:${Math.floor(Math.sin(i*7.3)*40+50)}%;left:${Math.floor(Math.cos(i*5.1)*40+50)}%;opacity:${0.4+Math.abs(Math.sin(i*2.7))*0.6};`}></div>
      ))}
    </div>
    <svg class="c-seg-illust" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
