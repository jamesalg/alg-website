<script>
// Sticky aisle nav: highlight active section on scroll
(function() {
  const items = document.querySelectorAll('.c-subnav-item');
  const sections = ['home','garden','work','auto','camping','party'].map(id => document.getElementById(id)).filter(Boolean);
  if (!sections.length) return;

  function updateActive() {
    const scrollY = window.scrollY + 160;
    let active = sections[0];
    for (const s of sections) {
      if (s.offsetTop <= scrollY) active = s;
    }
    items.forEach(item => {
      item.classList.toggle('active', item.dataset.aisle === active.id);
    });
  }

  window.addEventListener('scroll', updateActive, { passive: true });
  updateActive();
})();
</script>
