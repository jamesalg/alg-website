---
/**
 * tubulⒶRCH Collection Index
 * v2.7.10 — rebuilt to match mockup_tubulararch_v3.html
 * Route: /collections/tubulararch
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionAnchorNav from '../../components/CollectionAnchorNav.astro';

const anchorSections = [
  { id: 'sec-t8',  label: 'Workhorse T8' },
  { id: 'sec-t5',  label: 'Slim T5' },
  { id: 'sec-pl',  label: 'Compact PL' },
  { id: 'sec-pll', label: 'Long-Pin PLL' },
  { id: 'sec-u6',  label: 'U-Bend U6' },
];
---
<BaseLayout
  title="tubulⒶRCH — Linear LED Retrofit | Archipelago Lighting Group"
  description="Five families covering every fluorescent retrofit job — T5, T8, PL, PLL, U-bend. UL-certified, DLC-listed, structured spec data and verified compatibility."
  bodyClass="page-tubulararch-collection"
>
<style>
  :root {
    --ta-accent: #F32740;
    --ta-accent-dark: #C41E32;
    --ta-warm: #F5C24A;
    --ta-char: #1B1B1F;
    --ta-paper: #F5F5F7;
    --ta-paper2: #EBEBED;
    --ta-ink: #111111;
    --ta-mono: 'JetBrains Mono', 'Courier New', monospace;
  }
  .ta-dark  { background: var(--ta-char); color: #fff; }
  .ta-paper { background: var(--ta-paper); color: var(--ta-ink); }
  .ta-paper2{ background: var(--ta-paper2); color: var(--ta-ink); }
  .ta-eyebrow {
    font-family: var(--ta-mono);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .ta-eyebrow-rule::before {
    content: "";
    display: inline-block;
    width: 24px; height: 1px;
    background: currentColor;
    vertical-align: middle;
    margin-right: 12px;
  }
  .ta-eyebrow-red { color: var(--ta-accent); }
  .ta-h1 { font-family: 'Inter', system-ui, sans-serif; font-weight: 800; letter-spacing: -0.02em; line-height: 1.02; }
  .ta-accent { color: var(--ta-accent); }
  .ta-warm   { color: var(--ta-warm); }
  .ta-stat-num   { font-weight: 800; font-size: 2.25rem; letter-spacing: -0.03em; line-height: 1; }
  .ta-stat-label { font-family: var(--ta-mono); font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.7; margin-top: 4px; }
  .ta-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 12px 24px; font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.06em; text-decoration: none; cursor: pointer;
    border: none; transition: background 0.15s, color 0.15s, border-color 0.15s;
    font-family: var(--ta-mono);
  }
  .ta-btn-primary { background: var(--ta-accent); color: #fff; }
  .ta-btn-primary:hover { background: var(--ta-accent-dark); }
  .ta-btn-outline-light { background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,0.4); }
  .ta-btn-outline-light:hover { border-color: #fff; }
  .ta-btn-outline-dark { background: transparent; color: var(--ta-ink); border: 1.5px solid rgba(0,0,0,0.25); }
  .ta-btn-outline-dark:hover { border-color: var(--ta-ink); }
  /* Section nav */
  .ta-section-nav { background: white; border-top: 1px solid rgba(0,0,0,0.1); border-bottom: 1px solid rgba(0,0,0,0.1); position: sticky; top: 0; z-index: 10; }
  .ta-section-nav__inner { max-width: 1536px; margin: 0 auto; display: grid; grid-template-columns: repeat(5,1fr); }
  .ta-nav-tab { padding: 1.25rem 1rem; text-align: center; border-right: 1px solid rgba(0,0,0,0.08); cursor: pointer; transition: background 0.15s; }
  .ta-nav-tab:last-child { border-right: none; }
  .ta-nav-tab-num   { font-family: var(--ta-mono); font-size: 0.65rem; letter-spacing: 0.18em; opacity: 0.5; }
  .ta-nav-tab-label { font-family: var(--ta-mono); font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; margin-top: 0.4rem; }
  .ta-nav-tab-dot   { width: 6px; height: 6px; border-radius: 50%; background: rgba(0,0,0,0.2); margin: 0.4rem auto 0; }
  .ta-nav-tab.active .ta-nav-tab-dot { background: var(--ta-accent); }
  .ta-nav-tab.active .ta-nav-tab-num { color: var(--ta-accent); opacity: 1; }
  /* Family sections */
  .ta-family-sec { scroll-margin-top: 56px; }
  .ta-family-inner { max-width: 1536px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; }
  @media (max-width: 768px) { .ta-family-inner { grid-template-columns: 1fr; } }
  .ta-copy { padding: 4rem; }
  .ta-illust {
    aspect-ratio: 5/4; display: flex; align-items: center; justify-content: center;
    background: #1B1B1F; position: relative; overflow: hidden;
  }
  .ta-illust--light { background: var(--ta-paper); }
  .ta-illust-ph {
    font-family: var(--ta-mono); font-size: 10px; letter-spacing: 0.14em;
    text-transform: uppercase; text-align: center; padding: 2rem;
    border: 1px dashed rgba(255,255,255,0.12); margin: 2rem;
    width: calc(100% - 4rem); color: rgba(255,255,255,0.35);
  }
  .ta-illust-ph--light { color: rgba(0,0,0,0.3); border-color: rgba(0,0,0,0.12); }
  .ta-callout       { border-left: 3px solid var(--ta-accent); padding: 1rem 1.25rem; background: var(--ta-paper2); }
  .ta-callout-dark  { border-left: 3px solid var(--ta-warm); padding: 1rem 1.25rem; background: rgba(245,194,74,0.08); }
  .ta-callout-ey    { font-family: var(--ta-mono); color: var(--ta-accent); font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; }
  .ta-callout-ey-warm { color: var(--ta-warm); }
  /* Ballast matrix */
  .ta-matrix-row:hover { background: rgba(243,39,64,0.03); }
  /* Capability cards */
  .ta-card { background: white; padding: 2rem; border: 1px solid rgba(0,0,0,0.08); }
  .ta-card-num { font-family: var(--ta-mono); color: var(--ta-accent); font-size: 0.65rem; letter-spacing: 0.18em; }
  /* Breadcrumb */
  .ta-breadcrumb { border-bottom: 1px solid rgba(0,0,0,0.1); background: white; }
  .ta-breadcrumb__inner { max-width: 1536px; margin: 0 auto; padding: 12px 24px; font-family: var(--ta-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.7; }
  .ta-breadcrumb a { color: inherit; text-decoration: none; }
  .ta-breadcrumb a:hover { color: var(--ta-accent); opacity: 1; }
</style>

<!-- Breadcrumb -->
<div class="ta-breadcrumb">
  <div class="ta-breadcrumb__inner">
    <a href="/">HOME</a> ›
    <a href="/products/">PRODUCTS</a> ›
    <a href="/products/lamps/">LAMPS</a> ›
    TUBUL<span class="aa">Ⓐ</span>RCH
  </div>
</div>

<!-- Hero -->
<section class="ta-dark" style="padding:6rem 1.5rem;text-align:center;">
  <div style="max-width:1280px;margin:0 auto;">
    <p class="ta-eyebrow ta-eyebrow-rule" style="color:rgba(255,255,255,0.7);margin-bottom:2rem;">LINEAR LED RETROFIT · ENGINEERING-CREDIBILITY COLLECTION</p>
    <h1 class="ta-h1" style="font-size:clamp(2.5rem,7vw,4.5rem);color:#fff;margin-bottom:2rem;">Five form factors.<br><span class="ta-accent">One spec language.</span></h1>
    <p style="color:rgba(255,255,255,0.7);font-size:1.1rem;max-width:40rem;margin:0 auto 2.5rem;line-height:1.7;">From 2-foot T5 office lighting to 4-foot T8 warehouses to compact PL/PLL biax retrofits to U-bend recess fixtures. UL-certified, DLC-listed, and tested against the 200+ ballast models you actually have in the field.</p>
    <div style="display:flex;gap:3rem;justify-content:center;flex-wrap:wrap;margin-bottom:1.25rem;">
      <div><div class="ta-stat-num" style="color:#fff;">5</div><div class="ta-stat-label" style="color:rgba(255,255,255,0.7);">Families</div></div>
      <div><div class="ta-stat-num" style="color:#fff;">23</div><div class="ta-stat-label" style="color:rgba(255,255,255,0.7);">SKUs</div></div>
      <div><div class="ta-stat-num" style="color:#fff;">200+</div><div class="ta-stat-label" style="color:rgba(255,255,255,0.7);">Ballasts proven</div></div>
      <div><div class="ta-stat-num" style="color:#fff;">DLC</div><div class="ta-stat-label" style="color:rgba(255,255,255,0.7);">SSL Replacement Lamp QPL</div></div>
    </div>
    <p class="ta-eyebrow" style="color:var(--ta-warm);letter-spacing:0.18em;margin-bottom:2rem;">▸ 1 FAMILY SHIPPING NOW · 4 MORE Q3 <span class="cy">2026</span></p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#sec-t8" class="ta-btn ta-btn-primary">BROWSE FAMILIES →</a>
      <a href="/collections/tubulararch/t8/#wizard" class="ta-btn ta-btn-outline-light">FIND BY WHAT YOU'RE REPLACING</a>
    </div>
  </div>
</section>

<!-- Tagline band -->
<div class="ta-paper2" style="border-bottom:1px solid rgba(0,0,0,0.08);">
  <div style="max-width:1536px;margin:0 auto;padding:1.5rem;text-align:center;font-style:italic;opacity:0.7;">
    Engineered for spec writers. Stocked for distributors. Warrantied for the trades who install them.
  </div>
</div>

<!-- Sticky section nav -->
<div class="ta-section-nav" id="ta-section-nav">
  <div class="ta-section-nav__inner">
    <div class="ta-nav-tab active" data-nav-target="sec-t8">
      <div class="ta-nav-tab-num">01</div>
      <div class="ta-nav-tab-label">Workhorse T8</div>
      <div class="ta-nav-tab-dot"></div>
    </div>
    <div class="ta-nav-tab" data-nav-target="sec-t5">
      <div class="ta-nav-tab-num">02</div>
      <div class="ta-nav-tab-label">Slim T5</div>
      <div class="ta-nav-tab-dot"></div>
    </div>
    <div class="ta-nav-tab" data-nav-target="sec-pl">
      <div class="ta-nav-tab-num">03</div>
      <div class="ta-nav-tab-label">Compact PL</div>
      <div class="ta-nav-tab-dot"></div>
    </div>
    <div class="ta-nav-tab" data-nav-target="sec-pll">
      <div class="ta-nav-tab-num">04</div>
      <div class="ta-nav-tab-label">Long-Pin PLL</div>
      <div class="ta-nav-tab-dot"></div>
    </div>
    <div class="ta-nav-tab" data-nav-target="sec-u6">
      <div class="ta-nav-tab-num">05</div>
      <div class="ta-nav-tab-label">U-Bend U6</div>
      <div class="ta-nav-tab-dot"></div>
    </div>
  </div>
</div>

<!-- Section 01 — Workhorse T8 -->
<section class="ta-family-sec ta-paper" id="sec-t8">
  <div class="ta-family-inner">
    <div class="ta-illust">
      <div class="ta-illust-ph">T8 LAMP PHOTOGRAPHY<br>ROOSTER CREATIVE DELIVERABLE</div>
    </div>
    <div class="ta-copy">
      <p class="ta-eyebrow ta-eyebrow-rule" style="opacity:0.6;margin-bottom:1.5rem;"><span style="color:var(--ta-accent);">SECTION 01 ·</span> WORKHORSE T8 · 01 / 05</p>
      <h2 class="ta-h1" style="font-size:clamp(1.75rem,3.5vw,2.75rem);margin-bottom:2rem;">The four-foot tube that retired 25 legacy SKUs.</h2>
      <p style="font-size:1rem;line-height:1.7;margin-bottom:1.25rem;opacity:0.9;">The Workhorse T8 is the workhorse of fluorescent retrofit — 4-foot G13 bipin form factor that drops into the same socket as every legacy 32W T8 fluorescent. Where it differs: a single dip-switchable lamp body covers 10.5W, 12W, 14W, 15W, and 18W output, plus 5 CCTs from 3000K to 5000K. One part number on the truck. Twenty-five configurations on the job.</p>
      <p style="font-size:1rem;line-height:1.7;margin-bottom:2rem;opacity:0.85;">Type A+B hybrid means it works with your existing electronic ballast OR direct line voltage if the ballast is dead. The contractor decides at install time. The spec writer doesn't have to choose between two SKUs.</p>
      <div class="ta-callout" style="margin-bottom:2rem;">
        <p class="ta-callout-ey" style="margin-bottom:0.5rem;">WHO BUYS IT</p>
        <ul style="font-size:0.875rem;line-height:1.8;list-style:none;padding:0;margin:0;">
          <li>+ Facilities engineers replacing 32W F32T8 across multi-building portfolios</li>
          <li>+ Distributors stocking one part number for warehouse, retail, and office accounts</li>
          <li>+ Contractors who need ballast-bypass flexibility at the truck level</li>
        </ul>
      </div>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/collections/tubulararch/t8/" class="ta-btn ta-btn-primary">VIEW T8 SPEC</a>
        <a href="/collections/tubulararch/t8/#ies" class="ta-btn ta-btn-outline-dark">DOWNLOAD IES</a>
      </div>
    </div>
  </div>
</section>

<!-- Section 02 — Slim T5 -->
<section class="ta-family-sec ta-dark" id="sec-t5">
  <div class="ta-family-inner">
    <div class="ta-copy" style="order:1;">
      <p class="ta-eyebrow ta-eyebrow-rule" style="color:rgba(255,255,255,0.6);margin-bottom:1.5rem;"><span style="color:var(--ta-warm);">SECTION 02 ·</span> SLIM T5 · 02 / 05</p>
      <h2 class="ta-h1" style="font-size:clamp(1.75rem,3.5vw,2.75rem);color:#fff;margin-bottom:2rem;">Two diameters. Two install paths. Same spec voice.</h2>
      <p style="font-size:1rem;line-height:1.7;margin-bottom:1.25rem;color:rgba(255,255,255,0.8);">T5 is two distinct fixture populations: T5HE office linear (high-efficiency, 28W class, 4ft) and T5HO warehouse strips (high-output, 54W class, 4ft / 6ft / 8ft). The Slim T5 family covers both with form-factor parity to the legacy lamps and ballast-compatible LED retrofit.</p>
      <p style="font-size:1rem;line-height:1.7;margin-bottom:2rem;color:rgba(255,255,255,0.7);">When you spec a T5 retrofit, the question is rarely "which LED" — it's "which ballast was installed in 2009?" Slim T5 answers both UL Type A (electronic ballast required) and UL Type B (line-voltage bypass) so the spec doesn't depend on guesswork at the fixture.</p>
      <div class="ta-callout-dark" style="margin-bottom:2rem;">
        <p class="ta-callout-ey ta-callout-ey-warm" style="margin-bottom:0.5rem;">SHIPPING IN Q3 <span class="cy">2026</span></p>
        <ul style="font-size:0.875rem;line-height:1.8;list-style:none;padding:0;margin:0;color:rgba(255,255,255,0.85);">
          <li>+ T5HE base SKUs: 12W / 25W / 28W class · 3500K / 4000K / 5000K</li>
          <li>+ T5HO base SKUs: 24W / 40W / 54W class · matching CCT range</li>
          <li>+ Programmed-start ballast compatibility tested against 60+ models</li>
        </ul>
      </div>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/collections/tubulararch/t5/" class="ta-btn ta-btn-primary">NOTIFY ME WHEN SHIPPING</a>
        <a href="#ballast-matrix" class="ta-btn ta-btn-outline-light">SEE BALLAST COMPATIBILITY</a>
      </div>
    </div>
    <div class="ta-illust" style="order:2;">
      <div class="ta-illust-ph">T5 LAMP PHOTOGRAPHY<br>ROOSTER CREATIVE DELIVERABLE</div>
    </div>
  </div>
</section>

<!-- Section 03 — Compact PL -->
<section class="ta-family-sec ta-paper2" id="sec-pl">
  <div class="ta-family-inner">
    <div class="ta-illust ta-illust--light">
      <div class="ta-illust-ph ta-illust-ph--light">PL LAMP PHOTOGRAPHY<br>ROOSTER CREATIVE DELIVERABLE</div>
    </div>
    <div class="ta-copy">
      <p class="ta-eyebrow ta-eyebrow-rule" style="opacity:0.6;margin-bottom:1.5rem;"><span style="color:var(--ta-accent);">SECTION 03 ·</span> COMPACT PL · 03 / 05</p>
      <h2 class="ta-h1" style="font-size:clamp(1.75rem,3.5vw,2.75rem);margin-bottom:2rem;">Down-light fixtures don't deserve another CFL bulb run.</h2>
      <p style="font-size:1rem;line-height:1.7;margin-bottom:1.25rem;opacity:0.9;">Compact PL replaces the 2-pin and 4-pin biax CFLs that occupy roughly 40% of legacy commercial down-light fixtures. The lamps look like the originals (G24q-3 / G23 / 2G11), wire like the originals, and survive the dimming protocols their original ballasts use.</p>
      <p style="font-size:1rem;line-height:1.7;margin-bottom:2rem;opacity:0.8;">If your facility still has 26W quad-tube CFLs in 6-inch recessed cans, this is the family that retires them without a fixture replacement.</p>
      <div class="ta-callout" style="margin-bottom:2rem;">
        <p class="ta-callout-ey" style="margin-bottom:0.5rem;">SHIPPING IN Q3 <span class="cy">2026</span></p>
        <ul style="font-size:0.875rem;line-height:1.8;list-style:none;padding:0;margin:0;">
          <li>+ 13W / 18W / 26W base SKUs · matching pin configurations</li>
          <li>+ 0-10V dimming where the original ballast supports it</li>
          <li>+ DLC Listed (DLC SSL Replacement Lamp QPL) for utility-rebate eligibility</li>
        </ul>
      </div>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/collections/tubulararch/pl/" class="ta-btn ta-btn-primary">NOTIFY ME</a>
      </div>
    </div>
  </div>
</section>

<!-- Section 04 — Long-Pin PLL -->
<section class="ta-family-sec ta-dark" id="sec-pll">
  <div class="ta-family-inner">
    <div class="ta-copy" style="order:1;">
      <p class="ta-eyebrow ta-eyebrow-rule" style="color:rgba(255,255,255,0.6);margin-bottom:1.5rem;"><span style="color:var(--ta-warm);">SECTION 04 ·</span> LONG-PIN PLL · 04 / 05</p>
      <h2 class="ta-h1" style="font-size:clamp(1.75rem,3.5vw,2.75rem);color:#fff;margin-bottom:2rem;">The wraparound fixture's last fluorescent.</h2>
      <p style="font-size:1rem;line-height:1.7;margin-bottom:1.25rem;color:rgba(255,255,255,0.8);">PLL is the long single-ended biax — most often found in stairwell wraparounds, parking-deck downlights, and corridor strip fixtures from the late-90s commercial build cycle. Long-Pin PLL retires those without breaking the original fixture envelope.</p>
      <p style="font-size:1rem;line-height:1.7;margin-bottom:2rem;color:rgba(255,255,255,0.7);">The reality: most of those fixtures are still there because the building owner doesn't want to swap the housing. PLL gives them a 50,000-hour LED life cycle inside the fixture they already own.</p>
      <div class="ta-callout-dark" style="margin-bottom:2rem;">
        <p class="ta-callout-ey ta-callout-ey-warm" style="margin-bottom:0.5rem;">SHIPPING IN Q3 <span class="cy">2026</span></p>
        <ul style="font-size:0.875rem;line-height:1.8;list-style:none;padding:0;margin:0;color:rgba(255,255,255,0.85);">
          <li>+ 24W / 36W / 40W class · 2G11 long-pin base</li>
          <li>+ Universal 120-277V driver with DALI-2 capable variant Q4</li>
          <li>+ 50,000-hour rated life · L70 verified</li>
        </ul>
      </div>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/collections/tubulararch/pll/" class="ta-btn ta-btn-primary">NOTIFY ME</a>
      </div>
    </div>
    <div class="ta-illust" style="order:2;">
      <div class="ta-illust-ph">PLL LAMP PHOTOGRAPHY<br>ROOSTER CREATIVE DELIVERABLE</div>
    </div>
  </div>
</section>

<!-- Section 05 — U-Bend U6 -->
<section class="ta-family-sec ta-paper" id="sec-u6">
  <div class="ta-family-inner">
    <div class="ta-illust ta-illust--light">
      <div class="ta-illust-ph ta-illust-ph--light">U6 LAMP PHOTOGRAPHY<br>ROOSTER CREATIVE DELIVERABLE</div>
    </div>
    <div class="ta-copy">
      <p class="ta-eyebrow ta-eyebrow-rule" style="opacity:0.6;margin-bottom:1.5rem;"><span style="color:var(--ta-accent);">SECTION 05 ·</span> U-BEND U6 · 05 / 05</p>
      <h2 class="ta-h1" style="font-size:clamp(1.75rem,3.5vw,2.75rem);margin-bottom:2rem;">For the 2×2 troffers that never got swapped.</h2>
      <p style="font-size:1rem;line-height:1.7;margin-bottom:1.25rem;opacity:0.9;">U-Bend U6 retires the U-bent T8 fluorescent commonly found in 2-foot-square recessed troffers — the lamp that sits in roughly 30% of pre-2010 commercial ceiling grids. 6-inch leg spacing matches the original. Bipin sockets unchanged. The grid keeps its original geometry.</p>
      <p style="font-size:1rem;line-height:1.7;margin-bottom:2rem;opacity:0.8;">Most facilities have these as a "we'll get to it eventually" line item. U6 makes "eventually" cost the same as a tube swap.</p>
      <div class="ta-callout" style="margin-bottom:2rem;">
        <p class="ta-callout-ey" style="margin-bottom:0.5rem;">SHIPPING IN Q3 <span class="cy">2026</span></p>
        <ul style="font-size:0.875rem;line-height:1.8;list-style:none;padding:0;margin:0;">
          <li>+ 14W / 17W class · 6" leg spacing · G13 bipin</li>
          <li>+ Type A direct ballast OR Type B line-voltage bypass</li>
          <li>+ 25,000-hour life</li>
        </ul>
      </div>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/collections/tubulararch/u6/" class="ta-btn ta-btn-primary">NOTIFY ME</a>
      </div>
    </div>
  </div>
</section>

<!-- Ballast Compatibility Matrix -->
<section class="ta-paper2" id="ballast-matrix" style="border-top:1px solid rgba(0,0,0,0.1);">
  <div style="max-width:1536px;margin:0 auto;padding:6rem 1.5rem;">
    <p class="ta-eyebrow ta-eyebrow-rule ta-eyebrow-red" style="margin-bottom:1.5rem;">BALLAST COMPATIBILITY · 200+ MODELS PROVEN</p>
    <h2 class="ta-h1" style="font-size:clamp(1.75rem,3.5vw,2.75rem);max-width:56rem;margin-bottom:1rem;">Every retrofit assumes a ballast. Ours tells you which one.</h2>
    <p style="opacity:0.8;max-width:48rem;margin-bottom:3rem;line-height:1.7;">Across the five tubul<span class="aa">Ⓐ</span>RCH families, we maintain a versioned compatibility matrix against every ballast model we've tested in the field. Legend: ✓ verified pass · ⚠ pass with caveat · × known incompatibility · — not yet tested.</p>
    <div style="display:grid;grid-template-columns:5fr 7fr;gap:3rem;align-items:start;" class="ta-ballast-grid">
      <div>
