        <div><dd class="t8-stat-num">Type A+B</dd><dt class="t8-stat-label">UL hybrid retrofit type</dt></div>
      </dl>
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:1.5rem;">
        <span class="t8-trust-badge">cULus LISTED</span>
        <span class="t8-trust-badge">DLC LISTED</span>
        <span class="t8-trust-badge">UL TYPE A+B HYBRID</span>
        <span class="t8-trust-badge">5-YEAR WARRANTY</span>
