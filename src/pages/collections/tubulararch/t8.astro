---
/**
 * The Workshop T8 — Family Detail Page
 * v2.7.8 — engineering family detail with SKU infographic, Find My Tube wizard, structured spec table
 * Route: /collections/tubulararch/t8
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="The Workshop T8 — tubulⒶRCH | Archipelago Lighting Group"
  description="One dip-switchable T8 lamp replaces 25 legacy fluorescent SKUs. 4FT G13 bipin. UL Type A+B hybrid. DLC Premium. Verified ballast compatibility."
  bodyClass="page-t8-detail"
>
<style>
  .page-t8-detail {
    --accent: #F32740;
    --accent-dark: #C41E32;
    --fg: #111111;
    --fg-muted: #6B6B6B;
    --bg: #ffffff;
    --bg-alt: #f4f4f6;
    --border: #E5E5E5;
    --font-mono: 'Courier New', Courier, monospace;
    --inner: min(1280px, 100% - 64px);
  }
  .section-eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; }
  .section-title { font-size: clamp(22px, 3vw, 32px); font-weight: 700; color: var(--fg); margin: 0 0 12px; line-height: 1.2; }
  .section-sub { font-size: 16px; color: var(--fg-muted); max-width: 640px; margin: 0 0 32px; line-height: 1.6; }
  .btn { display: inline-flex; align-items: center; gap: 6px; padding: 12px 24px; border-radius: 4px; font-size: 14px; font-weight: 600; text-decoration: none; cursor: pointer; border: none; transition: background 0.15s, color 0.15s; }
  .btn--primary { background: var(--accent); color: #fff; }
  .btn--primary:hover { background: var(--accent-dark); }
  .btn--outline { background: transparent; color: var(--fg); border: 1.5px solid var(--border); }
  .btn--outline:hover { border-color: var(--fg); }
  /* Breadcrumb */
  .breadcrumb { background: #fff; border-bottom: 1px solid var(--border); padding: 12px 0; }
  .breadcrumb__inner { width: var(--inner); margin: 0 auto; font-size: 12px; color: var(--fg-muted); font-family: var(--font-mono); }
  .breadcrumb a { color: var(--fg-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb__sep { margin: 0 8px; }
  /* Hero */
  .family-hero { background: #111; color: #fff; padding: 64px 0; }
  .family-hero__inner { width: var(--inner); margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  @media (max-width: 768px) { .family-hero__inner { grid-template-columns: 1fr; } }
  .family-hero__visual { background: #1a1a1a; border-radius: 8px; height: 320px; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.3); font-size: 13px; text-align: center; border: 1px solid rgba(255,255,255,0.08); }
  .family-hero__eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #F32740; margin-bottom: 12px; }
  .family-hero__name { font-size: clamp(32px, 5vw, 56px); font-weight: 900; margin: 0 0 8px; line-height: 1.05; }
  .family-hero__sub { font-size: 16px; color: rgba(255,255,255,0.65); margin: 0 0 28px; line-height: 1.6; }
  .family-hero__stats { display: flex; gap: 32px; flex-wrap: wrap; margin-bottom: 28px; }
  .family-stat__value { font-size: 28px; font-weight: 800; color: #fff; line-height: 1; }
  .family-stat__label { font-size: 11px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 3px; }
  .family-hero__ctas { display: flex; gap: 10px; flex-wrap: wrap; }
  .family-hero .btn--outline { border-color: rgba(255,255,255,0.3); color: #fff; }
  .family-hero .btn--outline:hover { border-color: #fff; }
  .family-hero__badges { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 20px; }
  .trust-badge { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.1em; padding: 4px 10px; border-radius: 3px; border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.6); }
  /* SKU infographic */
  .sku-infographic { padding: 64px 0; background: var(--bg-alt); }
  .sku-infographic__inner { width: var(--inner); margin: 0 auto; }
  .consolidation-block { background: #fff; border-radius: 12px; border: 1.5px solid var(--border); padding: 40px; margin-top: 32px; }
  .consolidation-numbers { display: flex; align-items: center; gap: 32px; justify-content: center; flex-wrap: wrap; margin-bottom: 32px; }
  .consol-num { text-align: center; }
  .consol-num__value { font-size: 72px; font-weight: 900; line-height: 1; }
  .consol-num__value--legacy { color: var(--fg-muted); text-decoration: line-through; }
  .consol-num__value--alg { color: var(--accent); }
  .consol-num__label { font-size: 13px; color: var(--fg-muted); margin-top: 6px; }
  .consol-arrow { font-size: 40px; color: var(--accent); }
  .coverage-bar { margin-top: 24px; }
  .coverage-bar__label { font-family: var(--font-mono); font-size: 11px; color: var(--fg-muted); letter-spacing: 0.08em; margin-bottom: 8px; }
  .coverage-bar__track { height: 8px; background: var(--bg-alt); border-radius: 4px; overflow: hidden; }
  .coverage-bar__fill { height: 100%; background: linear-gradient(90deg, #F32740, #FF6B35); border-radius: 4px; width: 100%; }
  .coverage-bar__range { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 11px; color: var(--fg-muted); margin-top: 6px; }
  .dip-switch-note { background: #FFF3E0; border: 1.5px solid #FFB300; border-radius: 8px; padding: 16px 20px; margin-top: 24px; font-size: 14px; color: #E65100; }
  .dip-switch-note strong { color: #BF360C; }
  /* Wizard */
  .wizard-section { padding: 64px 0; background: #fff; }
  .wizard-section__inner { width: var(--inner); margin: 0 auto; }
  .wizard { background: var(--bg-alt); border-radius: 12px; border: 1.5px solid var(--border); padding: 40px; margin-top: 32px; max-width: 720px; }
  .wizard__step { display: none; }
  .wizard__step--active { display: block; }
  .wizard__step-header { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 16px; }
  .wizard__question { font-size: 20px; font-weight: 700; color: var(--fg); margin: 0 0 24px; }
  .wizard__options { display: flex; flex-direction: column; gap: 10px; }
  .wizard__option { display: flex; align-items: center; gap: 14px; padding: 14px 18px; background: #fff; border: 1.5px solid var(--border); border-radius: 8px; cursor: pointer; transition: border-color 0.15s; font-size: 14px; color: var(--fg); text-align: left; }
  .wizard__option:hover { border-color: var(--accent); }
  .wizard__option-icon { font-size: 20px; flex-shrink: 0; }
  .wizard__option-text strong { display: block; font-weight: 600; margin-bottom: 2px; }
  .wizard__option-text span { font-size: 12px; color: var(--fg-muted); }
  .wizard__back { font-family: var(--font-mono); font-size: 11px; color: var(--fg-muted); cursor: pointer; border: none; background: none; padding: 0; margin-top: 20px; letter-spacing: 0.06em; }
  .wizard__back:hover { color: var(--accent); }
  .wizard-result { display: none; background: #fff; border: 2px solid var(--accent); border-radius: 12px; padding: 32px; margin-top: 32px; max-width: 720px; }
  .wizard-result--visible { display: block; }
  .wizard-result__eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 12px; }
  .wizard-result__sku { font-size: 28px; font-weight: 900; color: var(--fg); margin: 0 0 6px; font-family: var(--font-mono); }
  .wizard-result__name { font-size: 16px; color: var(--fg-muted); margin: 0 0 24px; }
  .wizard-result__details { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
  @media (max-width: 480px) { .wizard-result__details { grid-template-columns: 1fr; } }
  .result-detail__label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; color: var(--fg-muted); text-transform: uppercase; margin-bottom: 4px; }
  .result-detail__value { font-size: 15px; font-weight: 600; color: var(--fg); }
  .wizard-result__ctas { display: flex; gap: 10px; flex-wrap: wrap; }
  .wizard-result__restart { font-family: var(--font-mono); font-size: 11px; color: var(--fg-muted); cursor: pointer; border: none; background: none; padding: 0; margin-top: 16px; letter-spacing: 0.06em; }
  .wizard-result__restart:hover { color: var(--accent); }
  /* Spec table */
  .spec-section { padding: 64px 0; background: var(--bg-alt); }
  .spec-section__inner { width: var(--inner); margin: 0 auto; display: grid; grid-template-columns: 200px 1fr; gap: 48px; align-items: start; }
  @media (max-width: 900px) { .spec-section__inner { grid-template-columns: 1fr; } }
  .spec-toc { position: sticky; top: 80px; }
  .spec-toc__title { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-muted); margin-bottom: 12px; }
  .spec-toc__list { list-style: none; padding: 0; margin: 0; }
  .spec-toc__item { margin-bottom: 4px; }
  .spec-toc__link { font-size: 13px; color: var(--fg-muted); text-decoration: none; padding: 6px 10px; display: block; border-radius: 4px; transition: background 0.15s, color 0.15s; border-left: 2px solid transparent; }
  .spec-toc__link:hover, .spec-toc__link--active { background: rgba(243,39,64,0.06); color: var(--accent); border-left-color: var(--accent); }
  .spec-group { background: #fff; border-radius: 8px; border: 1.5px solid var(--border); margin-bottom: 24px; overflow: hidden; }
  .spec-group__header { padding: 16px 24px; background: var(--bg-alt); border-bottom: 1px solid var(--border); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-muted); }
  .spec-table { width: 100%; border-collapse: collapse; }
  .spec-table th { text-align: left; padding: 10px 24px; font-size: 11px; font-family: var(--font-mono); letter-spacing: 0.06em; color: var(--fg-muted); border-bottom: 1px solid var(--border); background: #fafafa; }
  .spec-table td { padding: 10px 24px; font-size: 13px; color: var(--fg); border-bottom: 1px solid var(--border); }
  .spec-table tr:last-child td { border-bottom: none; }
  .spec-table td:first-child { color: var(--fg-muted); font-size: 12px; width: 40%; }
  .spec-table td:nth-child(2) { font-weight: 500; }
  .spec-note { padding: 12px 24px; background: #FFF8E1; border-top: 1px solid #FFE082; font-size: 12px; color: #795548; }
  .sensor-callout { background: #E8F5E9; border: 1.5px solid #A5D6A7; border-radius: 8px; padding: 20px 24px; margin: 16px 24px 24px; }
  .sensor-callout__title { font-size: 15px; font-weight: 700; color: #2E7D32; margin: 0 0 6px; }
  .sensor-callout__body { font-size: 13px; color: #388E3C; line-height: 1.5; margin: 0; }
  /* Docs */
  .docs-section { padding: 64px 0; background: #fff; }
  .docs-section__inner { width: var(--inner); margin: 0 auto; }
  .docs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; margin-top: 32px; }
  .doc-card { display: flex; align-items: center; gap: 14px; padding: 18px 20px; background: var(--bg-alt); border-radius: 8px; text-decoration: none; border: 1.5px solid var(--border); transition: border-color 0.15s; }
  .doc-card:hover { border-color: var(--accent); }
  .doc-card__icon { font-size: 24px; flex-shrink: 0; }
  .doc-card__name { font-size: 13px; font-weight: 600; color: var(--fg); }
  .doc-card__meta { font-size: 11px; color: var(--fg-muted); font-family: var(--font-mono); margin-top: 2px; }
  /* CTA band */
  .cta-band { padding: 64px 0; background: #111; text-align: center; color: #fff; }
  .cta-band__inner { width: var(--inner); margin: 0 auto; }
  .cta-band__title { font-size: clamp(24px, 4vw, 40px); font-weight: 800; margin: 0 0 12px; }
  .cta-band__sub { font-size: 16px; color: rgba(255,255,255,0.65); margin: 0 0 32px; }
  .cta-band__row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .cta-band .btn--outline { border-color: rgba(255,255,255,0.3); color: #fff; }
  .cta-band .btn--outline:hover { border-color: #fff; }
</style>

<nav class="breadcrumb">
  <div class="breadcrumb__inner">
    <a href="/">Home</a><span class="breadcrumb__sep">/</span>
    <a href="/collections/tubulararch">tubul<span class="aa">Ⓐ</span>RCH</a><span class="breadcrumb__sep">/</span>
    <span>The Workshop T8</span>
  </div>
</nav>

<section class="family-hero">
  <div class="family-hero__inner">
    <div class="family-hero__visual">T8 product photography<br>Rooster Creative deliverable</div>
    <div>
      <div class="family-hero__eyebrow">tubul<span class="aa">Ⓐ</span>RCH · Linear LED · T8</div>
      <h1 class="family-hero__name">The Workshop T8</h1>
      <p class="family-hero__sub">One dip-switchable lamp replaces 25 legacy fluorescent SKUs. 4FT G13 bipin. UL Type A+B hybrid — works with your existing ballast or bypasses it.</p>
      <div class="family-hero__stats">
        <div class="family-stat"><div class="family-stat__value">5</div><div class="family-stat__label">SKUs</div></div>
        <div class="family-stat"><div class="family-stat__value">25</div><div class="family-stat__label">Legacy replaced</div></div>
        <div class="family-stat"><div class="family-stat__value">10.5–18W</div><div class="family-stat__label">Wattage range</div></div>
        <div class="family-stat"><div class="family-stat__value">200+</div><div class="family-stat__label">Ballasts proven</div></div>
      </div>
      <div class="family-hero__ctas">
        <a href="/aura" class="btn btn--primary">Request AURA Quote</a>
        <a href="https://algportal.archipelagolighting.com" class="btn btn--outline" target="_blank" rel="noopener">SHOP Stock &amp; Buy</a>
        <a href="#docs" class="btn btn--outline">Documentation</a>
      </div>
      <div class="family-hero__badges">
        <span class="trust-badge">UL TYPE A+B</span>
        <span class="trust-badge">DLC PREMIUM</span>
        <span class="trust-badge">ENERGY STAR</span>
        <span class="trust-badge">BAA COMPLIANT</span>
      </div>
    </div>
  </div>
</section>

<section class="sku-infographic">
  <div class="sku-infographic__inner">
    <div class="section-eyebrow">SKU consolidation</div>
    <h2 class="section-title">One lamp. 25 legacy fluorescent SKUs retired.</h2>
    <p class="section-sub">A single dip-switch on the lamp body selects wattage output. One part number handles every job from 10.5W to 18W.</p>
    <div class="consolidation-block">
      <div class="consolidation-numbers">
        <div class="consol-num">
          <div class="consol-num__value consol-num__value--legacy">25</div>
          <div class="consol-num__label">Legacy fluorescent SKUs</div>
        </div>
        <div class="consol-arrow">→</div>
        <div class="consol-num">
          <div class="consol-num__value consol-num__value--alg">1</div>
          <div class="consol-num__label">Workshop T8 SKU</div>
        </div>
      </div>
      <div class="coverage-bar">
        <div class="coverage-bar__label">Wattage coverage range</div>
        <div class="coverage-bar__track"><div class="coverage-bar__fill"></div></div>
        <div class="coverage-bar__range"><span>10.5W</span><span>12W</span><span>14W</span><span>15W</span><span>18W</span></div>
      </div>
      <div class="dip-switch-note">
        <strong>Dip-switch selection:</strong> Set wattage output in the field using the 4-position DIP switch on the lamp body. No tools required. Settings are printed on the lamp label.
      </div>
    </div>
  </div>
</section>

<section class="wizard-section" id="find-my-tube">
  <div class="wizard-section__inner">
    <div class="section-eyebrow">Find My Tube</div>
    <h2 class="section-title">Tell us what you're replacing. We'll tell you exactly what to order.</h2>
    <p class="section-sub">Three questions. One SKU recommendation with dip-switch settings and rewire labor estimate.</p>
    <div class="wizard" id="wizard">
      <div class="wizard__step wizard__step--active" data-step="1">
        <div class="wizard__step-header">STEP 1 OF 3</div>
        <div class="wizard__question">What fluorescent tube are you replacing?</div>
        <div class="wizard__options">
          <button class="wizard__option" data-next="2" data-val="F32T8"><span class="wizard__option-icon">💡</span><div class="wizard__option-text"><strong>F32T8 — 4ft, 32W</strong><span>Most common office and commercial fixture</span></div></button>
          <button class="wizard__option" data-next="2" data-val="F25T8"><span class="wizard__option-icon">💡</span><div class="wizard__option-text"><strong>F25T8 — 3ft, 25W</strong><span>Shorter fixture, less common</span></div></button>
          <button class="wizard__option" data-next="2" data-val="F17T8"><span class="wizard__option-icon">💡</span><div class="wizard__option-text"><strong>F17T8 — 2ft, 17W</strong><span>Under-cabinet and task lighting</span></div></button>
          <button class="wizard__option" data-next="2" data-val="F40T8"><span class="wizard__option-icon">💡</span><div class="wizard__option-text"><strong>F40T8 — 4ft, 40W (older)</strong><span>Pre-1990s magnetic ballast fixtures</span></div></button>
        </div>
      </div>
      <div class="wizard__step" data-step="2">
        <div class="wizard__step-header">STEP 2 OF 3</div>
        <div class="wizard__question">What type of ballast is in the fixture?</div>
        <div class="wizard__options">
          <button class="wizard__option" data-next="3" data-val="instant-start"><span class="wizard__option-icon">⚡</span><div class="wizard__option-text"><strong>Electronic instant-start</strong><span>Most common in post-1995 fixtures.</span></div></button>
          <button class="wizard__option" data-next="3" data-val="programmed-start"><span class="wizard__option-icon">⏱️</span><div class="wizard__option-text"><strong>Electronic programmed-start</strong><span>Common with occupancy sensors.</span></div></button>
          <button class="wizard__option" data-next="3" data-val="magnetic"><span class="wizard__option-icon">🔧</span><div class="wizard__option-text"><strong>Magnetic ballast (older)</strong><span>Pre-1990s. Type B bypass recommended.</span></div></button>
          <button class="wizard__option" data-next="3" data-val="unknown"><span class="wizard__option-icon">❓</span><div class="wizard__option-text"><strong>I don't know</strong><span>We'll recommend the safest option</span></div></button>
        </div>
        <button class="wizard__back" data-back="1">← Back</button>
      </div>
      <div class="wizard__step" data-step="3">
        <div class="wizard__step-header">STEP 3 OF 3</div>
        <div class="wizard__question">What's your preferred install approach?</div>
        <div class="wizard__options">
          <button class="wizard__option" data-result="type-a" data-val="plug-and-play"><span class="wizard__option-icon">🔌</span><div class="wizard__option-text"><strong>Plug-and-play (Type A)</strong><span>Keep existing ballast. Faster install.</span></div></button>
          <button class="wizard__option" data-result="type-b" data-val="bypass"><span class="wizard__option-icon">✂️</span><div class="wizard__option-text"><strong>Ballast bypass (Type B)</strong><span>Remove ballast. Lower long-term cost.</span></div></button>
          <button class="wizard__option" data-result="type-ab" data-val="either"><span class="wizard__option-icon">🔄</span><div class="wizard__option-text"><strong>Either — recommend best option</strong><span>We'll pick based on your ballast type.</span></div></button>
        </div>
        <button class="wizard__back" data-back="2">← Back</button>
      </div>
    </div>
    <div class="wizard-result" id="wizard-result">
      <div class="wizard-result__eyebrow">RECOMMENDED SKU</div>
      <div class="wizard-result__sku" id="result-sku">ALG-T8-4FT-15W-840-AB</div>
      <div class="wizard-result__name" id="result-name">The Workshop T8 · 4FT · 15W · 4000K · Type A+B Hybrid</div>
      <div class="wizard-result__details">
        <div class="result-detail"><div class="result-detail__label">Wattage setting</div><div class="result-detail__value">15W (DIP: 1-ON, 2-OFF, 3-OFF, 4-OFF)</div></div>
        <div class="result-detail"><div class="result-detail__label">Install type</div><div class="result-detail__value" id="result-install">Type A+B Hybrid</div></div>
        <div class="result-detail"><div class="result-detail__label">Rewire labor est.</div><div class="result-detail__value" id="result-labor">0 min (Type A) or 8 min/fixture (Type B)</div></div>
        <div class="result-detail"><div class="result-detail__label">Ballast compatibility</div><div class="result-detail__value">Verified — 200+ ballasts</div></div>
      </div>
      <div class="wizard-result__ctas">
        <a href="/aura" class="btn btn--primary">Request Quote for This SKU</a>
        <a href="#" class="btn btn--outline">Download Spec Sheet</a>
      </div>
      <button class="wizard-result__restart" id="wizard-restart">Start over ↺</button>
    </div>
  </div>
</section>

<section class="spec-section" id="specs">
  <div class="spec-section__inner">
    <nav class="spec-toc">
      <div class="spec-toc__title">Spec sections</div>
      <ul class="spec-toc__list">
        <li class="spec-toc__item"><a href="#spec-optical" class="spec-toc__link spec-toc__link--active">Optical</a></li>
        <li class="spec-toc__item"><a href="#spec-electrical" class="spec-toc__link">Electrical</a></li>
        <li class="spec-toc__item"><a href="#spec-materials" class="spec-toc__link">Materials</a></li>
        <li class="spec-toc__item"><a href="#spec-environmental" class="spec-toc__link">Environmental</a></li>
        <li class="spec-toc__item"><a href="#spec-controls" class="spec-toc__link">Controls</a></li>
      </ul>
    </nav>
    <div class="spec-content">
      <div class="section-eyebrow">Structured specifications</div>
      <h2 class="section-title">Full spec data. Five sections.</h2>
      <div class="spec-group" id="spec-optical">
        <div class="spec-group__header">Optical</div>
        <table class="spec-table">
          <thead><tr><th>Parameter</th><th>Value</th><th>Notes</th></tr></thead>
          <tbody>
            <tr><td>Lumens (delivered)</td><td>1,600 – 2,200 lm</td><td>Varies by wattage setting</td></tr>
            <tr><td>Efficacy</td><td>Up to 140 lm/W</td><td>At 15W setting</td></tr>
            <tr><td>CCT options</td><td>3000K / 3500K / 4000K / 5000K</td><td>Separate SKU per CCT</td></tr>
