      <div style="display:flex;flex-wrap:wrap;gap:12px;">
        <a href="/support/sample-request?subject=Workhorse+T8+Quote" class="t8-btn t8-btn-primary">REQUEST AURA QUOTE</a>
        <a href="https://algportal.archipelagolighting.com" class="t8-btn t8-btn-outline" target="_blank" rel="noopener">SHOP STOCK &amp; BUY</a>
        <a href="#resources" class="t8-btn t8-btn-ghost">DOCUMENTATION ↓</a>
      </div>
    </div>
  </div>
</section>
<style>
  @media (max-width: 768px) { .t8-hero-grid { grid-template-columns: 1fr !important; } }
</style>

<!-- SKU CONSOLIDATION -->
<section class="t8-dark" aria-labelledby="t8-consol-h2">
  <div style="max-width:1536px;margin:0 auto;padding:5rem 1.5rem;">
    <p class="t8-eyebrow" style="color:var(--t8-warm);margin-bottom:1.5rem;">— SKU CONSOLIDATION</p>
    <h2 id="t8-consol-h2" class="t8-h2" style="font-size:clamp(1.75rem,3.5vw,3rem);margin-bottom:1rem;">One lamp. <span class="t8-warm-text">25 legacy fluorescent SKUs retired.</span></h2>
    <p style="opacity:0.7;max-width:42rem;margin-bottom:3rem;line-height:1.7;">A single dip-switch on the lamp body selects wattage output. CCT is selected by SKU suffix. One part number on the truck handles every job from 10.5W to 18W across 5 color temperatures.</p>
    <div style="display:grid;grid-template-columns:5fr 7fr;gap:3rem;align-items:center;" class="t8-consol-grid">
      <div>
        <div style="display:flex;align-items:baseline;gap:1.5rem;">
          <div style="font-size:4.5rem;font-weight:900;color:rgba(255,255,255,0.25);font-family:var(--t8-sans);">25</div>
          <div style="font-size:2rem;color:rgba(255,255,255,0.4);">→</div>
          <div style="font-size:4.5rem;font-weight:900;color:var(--t8-warm);font-family:var(--t8-sans);">5</div>
        </div>
        <p class="t8-eyebrow" style="opacity:0.6;margin-top:0.75rem;">LEGACY FLUORESCENT SKUS · WORKHORSE T8 BASE PART NUMBERS</p>
      </div>
      <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);padding:1.5rem;">
        <p class="t8-eyebrow" style="opacity:0.7;margin-bottom:1rem;">WATTAGE COVERAGE · DIP-SWITCH SELECTABLE</p>
        <div style="height:12px;background:rgba(255,255,255,0.1);border-radius:6px;margin-bottom:0.75rem;overflow:hidden;">
          <div style="height:100%;background:linear-gradient(to right,var(--t8-warm),var(--t8-accent));border-radius:6px;"></div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(5,1fr);font-family:var(--t8-mono);font-size:0.65rem;text-align:center;opacity:0.8;">
          <div>10.5W</div><div>12W</div><div>14W</div><div>15W</div><div>18W</div>
        </div>
        <p class="t8-eyebrow" style="opacity:0.5;margin-top:1.5rem;line-height:1.7;">CCT SELECTED BY SKU SUFFIX · 3000K / 3500K / 4000K / 5000K / 6500K · NET 25 ORDERABLE CONFIGURATIONS FROM 5 BASE PART NUMBERS</p>
      </div>
    </div>
  </div>
</section>
<style>
  @media (max-width: 768px) { .t8-consol-grid { grid-template-columns: 1fr !important; } }
</style>

<!-- FIND MY TUBE WIZARD -->
<section class="t8-paper2" aria-labelledby="t8-wizard-h2">
  <div style="max-width:1536px;margin:0 auto;padding:5rem 1.5rem;">
    <p class="t8-eyebrow t8-eyebrow-rule t8-accent-text" style="margin-bottom:1.5rem;">FIND MY TUBE WIZARD</p>
    <h2 id="t8-wizard-h2" class="t8-h2" style="font-size:clamp(1.5rem,3vw,2.5rem);margin-bottom:1rem;">What are you replacing?</h2>
    <p style="opacity:0.7;max-width:36rem;margin-bottom:2rem;font-size:0.9rem;">Select your existing tube type to confirm compatibility and get the right Workhorse T8 SKU.</p>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2rem;" class="t8-wizard-grid">
      <div style="padding:1.5rem;border:1.5px solid rgba(17,17,17,0.15);background:white;text-align:left;">
        <p style="font-family:var(--t8-mono);font-size:0.65rem;letter-spacing:0.14em;opacity:0.6;margin-bottom:0.5rem;">MOST COMMON</p>
