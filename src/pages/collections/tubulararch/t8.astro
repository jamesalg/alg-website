          <div class="t8-spec-row"><dt>EMC</dt><dd>FCC Part 15 Class B · ICES-003</dd></div>
          <div class="t8-spec-row"><dt>DLC</dt><dd>DLC Listed · DLC SSL Replacement Lamp QPL · per-SKU listing</dd></div>
          <div class="t8-spec-row"><dt>Warranty</dt><dd>5 years · pro-rated · field-failure replacement</dd></div>
        </dl>
      </article>
    </div>
  </div>
</section>
<style>
  @media (max-width: 900px) { .t8-spec-grid { grid-template-columns: 1fr !important; } }
