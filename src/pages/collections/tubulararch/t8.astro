        <p class="t8-spec-block-num" style="margin-bottom:0.5rem;">01</p>
        <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:1rem;">Physical</h3>
        <dl>
          <div class="t8-spec-row"><dt>Form factor</dt><dd>4ft linear T8 · G13 bipin (RoHS-compliant)</dd></div>
          <div class="t8-spec-row"><dt>Length</dt><dd>47.9 in (1217 mm)</dd></div>
          <div class="t8-spec-row"><dt>Diameter</dt><dd>1.0 in (25.4 mm)</dd></div>
          <div class="t8-spec-row"><dt>Weight</dt><dd>0.22 lb (100 g)</dd></div>
          <div class="t8-spec-row"><dt>Operating temp</dt><dd>-20°C to +45°C</dd></div>
        </dl>
      </article>
      <article>
        <p class="t8-spec-block-num" style="margin-bottom:0.5rem;">02</p>
        <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:1rem;">Photometrics</h3>
        <dl>
          <div class="t8-spec-row"><dt>Lumen output</dt><dd>1,600–2,200 lm (wattage-dependent)</dd></div>
          <div class="t8-spec-row"><dt>Efficacy</dt><dd>Up to 140 lm/W (18W / 4000K)</dd></div>
          <div class="t8-spec-row"><dt>CCT options</dt><dd>3000K · 3500K · 4000K · 5000K · 6500K</dd></div>
          <div class="t8-spec-row"><dt>CRI</dt><dd>≥80 (standard) · ≥90 available on request</dd></div>
