<!-- STRUCTURED SPEC TABLE -->
<section class="t8-paper" aria-labelledby="t8-spec-h2">
  <div style="max-width:1536px;margin:0 auto;padding:5rem 1.5rem;">
    <p class="t8-eyebrow t8-eyebrow-rule t8-accent-text" style="margin-bottom:1.5rem;">FULL SPECIFICATION</p>
    <h2 id="t8-spec-h2" class="t8-h2" style="font-size:clamp(1.5rem,3vw,2.5rem);margin-bottom:3rem;">The numbers that matter to a spec writer.</h2>
