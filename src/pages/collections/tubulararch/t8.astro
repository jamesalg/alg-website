<main id="main">

<!-- HERO -->
<section class="t8-paper" aria-labelledby="t8-hero-h1">
  <div style="max-width:1536px;margin:0 auto;padding:4rem 1.5rem;display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;" class="t8-hero-grid">
