<CollectionAnchorNav sections={anchorSections} />

<script>
  (function () {
    var tabs = document.querySelectorAll('.nd-nav-tab[data-nav-target]');
    var sectionIds = ['sec-saarinen','sec-eames','sec-knoll','sec-bauer','sec-heath','sec-eichler','sec-marshall'];
    var sections = sectionIds.map(function(id) { return document.getElementById(id); }).filter(Boolean);
    function setActive(id: string) {
      tabs.forEach(function(tab) {
        var t = tab as HTMLElement;
        t.classList.toggle('active', t.dataset.navTarget === id);
      });
    }
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var t = tab as HTMLElement;
        var target = t.dataset.navTarget;
        if (target) {
          var el = document.getElementById(target);
          if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) setActive(entry.target.id);
      });
    }, { threshold: 0.3, rootMargin: '-10% 0% -50% 0%' });
    sections.forEach(function(s) { if (s) observer.observe(s); });
  })();
  document.querySelectorAll('.cy').forEach(function(e) {
    (e as HTMLElement).textContent = String(new Date().getFullYear());
  });
</script>
