---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandMark from '../../components/BrandMark.astro';

/* v2.5.0: planoⒶRCH collection page.
 * Pixel-by-pixel mirror of luxoarch.astro structure.
 * Sort: ECO → PRO → PRO+, A→Z within tier (build-time, per v2.4.3 canonical pattern). */
const _TIER_ORDER: Record<string, number> = { 'ECO': 0, 'PRO': 1, 'PRO+': 2 };
const families = ([
  { sub: 'ARCHITECTURAL LINEAR', tier: 'ECO',  name: 'Lara',              maxW: '60W',  skus: 6,  dlc: true,  apps: 'architectural-linear' },
  { sub: 'PANEL',                tier: 'ECO',  name: 'proⒶRCH-II',       maxW: '30W',  skus: 7,  dlc: true,  apps: 'panel' },
  { sub: 'TROFFER',              tier: 'ECO',  name: 'proⒶRCH-T1',       maxW: '26W',  skus: 13, dlc: true,  apps: 'troffer' },
  { sub: 'TROFFER',              tier: 'ECO',  name: 'selectⒶRCH',       maxW: '40W',  skus: 6,  dlc: true,  apps: 'troffer' },
  { sub: 'DOWNLIGHT',            tier: 'ECO',  name: 'Solstice',          maxW: '22W',  skus: 7,  dlc: true,  apps: 'downlight' },
  { sub: 'TRACK LIGHT',          tier: 'ECO',  name: 'Trackstar',         maxW: '20W',  skus: 4,  dlc: false, apps: 'track-light' },
  { sub: 'TROFFER',              tier: 'PRO',  name: 'proⒶRCH-T2',       maxW: '30W',  skus: 2,  dlc: true,  apps: 'troffer' },
  { sub: 'RETROFIT PANEL',       tier: 'PRO',  name: 'retroⒶRCH-P1',     maxW: '26W',  skus: 12, dlc: true,  apps: 'retrofit-panel' },
  { sub: 'RETROFIT TROFFER',     tier: 'PRO',  name: 'retroⒶRCH-T1',     maxW: '26W',  skus: 12, dlc: true,  apps: 'retrofit-troffer' },
  { sub: 'DOWNLIGHT',            tier: 'PRO',  name: 'Solstice SafeZone', maxW: '26W',  skus: 4,  dlc: true,  apps: 'downlight' },
  { sub: 'DOWNLIGHT',            tier: 'PRO',  name: 'Stellar',           maxW: '22W',  skus: 1,  dlc: true,  apps: 'downlight' },
  { sub: 'WRAPAROUND',           tier: 'PRO',  name: 'Waymark',           maxW: '35W',  skus: 4,  dlc: true,  apps: 'wraparound' },
  { sub: 'DOWNLIGHT',            tier: 'PRO+', name: 'Astra',             maxW: '18W',  skus: 27, dlc: true,  apps: 'downlight' },
  { sub: 'ARCHITECTURAL LINEAR', tier: 'PRO+', name: 'Luna',              maxW: '50W',  skus: 5,  dlc: true,  apps: 'architectural-linear' },
  { sub: 'TROFFER',              tier: 'PRO+', name: 'Luxmark',           maxW: '35W',  skus: 6,  dlc: true,  apps: 'troffer' },
  { sub: 'PANEL',                tier: 'PRO+', name: 'proⒶRCH-III',      maxW: '30W',  skus: 13, dlc: true,  apps: 'panel' },
  { sub: 'DOWNLIGHT',            tier: 'PRO+', name: 'Spectra',           maxW: '30W',  skus: 3,  dlc: true,  apps: 'downlight' },
] as const).slice().sort((a: any, b: any) => {
  const td = (_TIER_ORDER[a.tier] ?? 99) - (_TIER_ORDER[b.tier] ?? 99);
  return td !== 0 ? td : a.name.localeCompare(b.name);
});

const tierColor: Record<string, string> = { 'PRO': '#F32740', 'PRO+': '#FFC107', 'ECO': '#5B8DEF' };
---
<BaseLayout
  title="planoARCH Indoor Collection — Archipelago Lighting Group"
  description="Commercial indoor lighting for offices, retail, healthcare, education, and hospitality. 17 active families, 132 active SKUs, ECO through PRO+."
  bodyClass="page-collection page-planoarch"
>

  <!-- §1 BREADCRUMB -->
  <nav class="breadcrumb-band" aria-label="Breadcrumb">
    <div class="bc-inner">
      <a href="/" class="bc-link">Home</a>
      <span class="bc-sep">›</span>
      <a href="/collections" class="bc-link">Products</a>
      <span class="bc-sep">›</span>
      <a href="/collections/indoor" class="bc-link">Indoor</a>
      <span class="bc-sep">›</span>
      <span class="bc-current">plano<span class="aa">Ⓐ</span>RCH</span>
    </div>
  </nav>

  <!-- §2 HERO -->
  <section class="persona-hero plano-hero" id="hero">
    <div class="hero-inner">
      <div class="hero-text-col">
        <span class="hero-eyebrow">INDOOR · COLLECTION</span>
        <h1 class="hero-wordmark">PLANO<span class="aa">Ⓐ</span>rch</h1>
        <p class="hero-desc">Commercial indoor lighting for offices, retail, healthcare, education, and hospitality. 17 active families, 132 active SKUs, ECO through PRO+.</p>
        <div class="hero-pills">
          <span class="hero-pill">DLC PREMIUM</span>
          <span class="hero-pill">TAA AVAILABLE</span>
          <span class="hero-pill">5 US WAREHOUSES</span>
          <span class="hero-pill">3-DAY DELIVERY</span>
          <span class="hero-pill">8 SUB-CATEGORIES</span>
        </div>
      </div>
      <div class="hero-photo-placeholder"></div>
    </div>
  </section>

  <!-- §3 STAT STRIP -->
  <section class="stat-strip" id="stats">
    <div class="stat-strip-inner">
      <div class="ss-stat"><span class="ss-num">17</span><span class="ss-lbl">Fixture Families</span></div>
      <div class="ss-stat"><span class="ss-num">132</span><span class="ss-lbl">Active SKUs</span></div>
      <div class="ss-stat"><span class="ss-num">8</span><span class="ss-lbl">Sub-categories</span></div>
      <div class="ss-stat"><span class="ss-num ss-red">DLC</span><span class="ss-lbl">Premium Listed</span></div>
    </div>
  </section>

  <!-- §4 BROWSE BY SUB-CATEGORY -->
  <section class="app-browse" id="apps">
    <div class="section-inner">
      <span class="sec-eyebrow">BROWSE BY SUB-CATEGORY</span>
      <h2 class="sec-h2">Eight indoor sub-categories.</h2>
      <div class="app-tile-grid">

        <button class="app-tile" data-app="downlight" aria-pressed="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="12" cy="8" r="4"/>
            <path d="M 8 12 L 6 20 M 16 12 L 18 20"/>
          </svg>
          <span class="app-label">Downlight</span>
          <span class="app-count">42 SKUs</span>
        </button>

        <button class="app-tile" data-app="troffer" aria-pressed="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="6" width="18" height="12" rx="1"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
            <line x1="3" y1="14" x2="21" y2="14"/>
          </svg>
          <span class="app-label">Troffer</span>
          <span class="app-count">27 SKUs</span>
        </button>

        <button class="app-tile" data-app="panel" aria-pressed="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="9" width="18" height="6" rx="0.5"/>
          </svg>
          <span class="app-label">Panel</span>
          <span class="app-count">20 SKUs</span>
        </button>

        <button class="app-tile" data-app="retrofit-panel" aria-pressed="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="11" width="14" height="4" rx="0.5"/>
            <path d="M 18 8 L 21 8 L 21 11 M 21 8 L 18 11"/>
          </svg>
          <span class="app-label">Retrofit Panel</span>
          <span class="app-count">12 SKUs</span>
        </button>

        <button class="app-tile" data-app="retrofit-troffer" aria-pressed="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="9" width="14" height="8" rx="1"/>
            <line x1="3" y1="13" x2="17" y2="13"/>
            <path d="M 18 5 L 21 5 L 21 8 M 21 5 L 18 8"/>
          </svg>
          <span class="app-label">Retrofit Troffer</span>
          <span class="app-count">12 SKUs</span>
        </button>

        <button class="app-tile" data-app="architectural-linear" aria-pressed="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="2" y="11" width="20" height="2" rx="1"/>
          </svg>
          <span class="app-label">Architectural Linear</span>
          <span class="app-count">11 SKUs</span>
        </button>

        <button class="app-tile" data-app="wraparound" aria-pressed="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="4" y="8" width="16" height="8" rx="3"/>
          </svg>
          <span class="app-label">Wraparound</span>
          <span class="app-count">4 SKUs</span>
        </button>

        <button class="app-tile" data-app="track-light" aria-pressed="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <line x1="3" y1="8" x2="21" y2="8"/>
            <circle cx="7" cy="13" r="2"/>
            <circle cx="12" cy="13" r="2"/>
            <circle cx="17" cy="13" r="2"/>
          </svg>
          <span class="app-label">Track Light</span>
          <span class="app-count">4 SKUs</span>
        </button>

      </div>
    </div>
  </section>

  <!-- §5 RED STAT BANNER -->
  <section class="red-stat-banner">
    <div class="rsb-inner">
      <div class="rsb-stat"><span class="rsb-num">17</span><span class="rsb-lbl">Families</span></div>
      <div class="rsb-stat"><span class="rsb-num">132</span><span class="rsb-lbl">Active SKUs</span></div>
      <div class="rsb-stat"><span class="rsb-num">8</span><span class="rsb-lbl">Sub-categories</span></div>
      <div class="rsb-stat"><span class="rsb-num">DLC</span><span class="rsb-lbl">Premium</span></div>
      <div class="rsb-stat"><span class="rsb-num">TAA</span><span class="rsb-lbl">Available</span></div>
      <div class="rsb-stat"><span class="rsb-num">5 US</span><span class="rsb-lbl">Warehouses</span></div>
    </div>
  </section>

  <!-- §6 FEATURED FAMILIES -->
  <section class="featured-fam" id="highlights">
    <div class="section-inner">
      <span class="sec-eyebrow">FEATURED FAMILIES</span>
      <h2 class="sec-h2">Five families worth specifying first.</h2>
      <p class="sec-sub">The most-specified plano<span class="aa">Ⓐ</span>RCH families across downlight, linear, troffer, panel, and track.</p>
      <div class="feat-fam-grid">

        <!-- Card 1: Astra PRO+ Downlight -->
        <div class="feat-card">
          <div class="feat-card-img grey-block">
            <span class="tier-badge pro-plus">PRO+</span>
          </div>
          <div class="feat-card-body">
            <span class="feat-sub">DOWNLIGHT</span>
            <h3 class="feat-name">Astra</h3>
            <div class="feat-meta">
              <span class="feat-maxw">18W max</span>
              <span class="feat-skus">27 SKUs</span>
              <span class="feat-dlc dlc-pill">DLC</span>
            </div>
            <a href="#" class="feat-cta">VIEW →</a>
          </div>
        </div>

        <!-- Card 2: Luna PRO+ Architectural Linear -->
        <div class="feat-card">
          <div class="feat-card-img grey-block">
            <span class="tier-badge pro-plus">PRO+</span>
          </div>
          <div class="feat-card-body">
            <span class="feat-sub">ARCHITECTURAL LINEAR</span>
            <h3 class="feat-name">Luna</h3>
            <div class="feat-meta">
              <span class="feat-maxw">50W max</span>
              <span class="feat-skus">5 SKUs</span>
              <span class="feat-dlc dlc-pill">DLC</span>
            </div>
            <a href="#" class="feat-cta">VIEW →</a>
          </div>
        </div>

        <!-- Card 3: Luxmark PRO+ Troffer -->
        <div class="feat-card">
          <div class="feat-card-img grey-block">
            <span class="tier-badge pro-plus">PRO+</span>
          </div>
          <div class="feat-card-body">
            <span class="feat-sub">TROFFER</span>
            <h3 class="feat-name">Luxmark</h3>
            <div class="feat-meta">
              <span class="feat-maxw">35W max</span>
              <span class="feat-skus">6 SKUs</span>
              <span class="feat-dlc dlc-pill">DLC</span>
            </div>
            <a href="#" class="feat-cta">VIEW →</a>
          </div>
        </div>

        <!-- Card 4: proⒶRCH-III PRO+ Panel -->
        <div class="feat-card">
          <div class="feat-card-img grey-block">
            <span class="tier-badge pro-plus">PRO+</span>
          </div>
          <div class="feat-card-body">
            <span class="feat-sub">PANEL</span>
            <h3 class="feat-name">pro<span class="aa">Ⓐ</span>RCH-III</h3>
            <div class="feat-meta">
              <span class="feat-maxw">30W max</span>
              <span class="feat-skus">13 SKUs</span>
              <span class="feat-dlc dlc-pill">DLC</span>
            </div>
            <a href="#" class="feat-cta">VIEW →</a>
          </div>
        </div>

        <!-- Card 5: Trackstar ECO Track Light -->
        <div class="feat-card">
          <div class="feat-card-img grey-block">
            <span class="tier-badge eco">ECO</span>
          </div>
          <div class="feat-card-body">
            <span class="feat-sub">TRACK LIGHT</span>
            <h3 class="feat-name">Trackstar</h3>
            <div class="feat-meta">
              <span class="feat-maxw">20W max</span>
              <span class="feat-skus">4 SKUs</span>
            </div>
            <a href="#" class="feat-cta">VIEW →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- §7 ALL FAMILIES -->
  <section class="all-families" id="families">
    <div class="section-inner af-layout">

      <!-- LEFT: Filter rail -->
      <aside class="filter-rail">
        <div class="filter-group">
          <h3 class="filter-group-title">Sub-category</h3>
          <label class="filter-opt"><input type="checkbox" class="app-filter-cb" name="filter-subcategory" value="downlight"> Downlight <span class="filter-count">(5)</span></label>
          <label class="filter-opt"><input type="checkbox" class="app-filter-cb" name="filter-subcategory" value="troffer"> Troffer <span class="filter-count">(4)</span></label>
          <label class="filter-opt"><input type="checkbox" class="app-filter-cb" name="filter-subcategory" value="panel"> Panel <span class="filter-count">(2)</span></label>
          <label class="filter-opt"><input type="checkbox" class="app-filter-cb" name="filter-subcategory" value="retrofit-panel"> Retrofit Panel <span class="filter-count">(1)</span></label>
          <label class="filter-opt"><input type="checkbox" class="app-filter-cb" name="filter-subcategory" value="retrofit-troffer"> Retrofit Troffer <span class="filter-count">(1)</span></label>
          <label class="filter-opt"><input type="checkbox" class="app-filter-cb" name="filter-subcategory" value="architectural-linear"> Architectural Linear <span class="filter-count">(2)</span></label>
          <label class="filter-opt"><input type="checkbox" class="app-filter-cb" name="filter-subcategory" value="wraparound"> Wraparound <span class="filter-count">(1)</span></label>
          <label class="filter-opt"><input type="checkbox" class="app-filter-cb" name="filter-subcategory" value="track-light"> Track Light <span class="filter-count">(1)</span></label>
        </div>
        <div class="filter-group">
          <h3 class="filter-group-title">Echelon</h3>
          <label class="filter-opt"><input type="checkbox" disabled> ECO <span class="filter-count">(6)</span></label>
          <label class="filter-opt"><input type="checkbox" disabled> PRO <span class="filter-count">(6)</span></label>
          <label class="filter-opt"><input type="checkbox" disabled> PRO+ <span class="filter-count">(5)</span></label>
        </div>
        <div class="filter-group">
          <h3 class="filter-group-title">Max Wattage</h3>
          <div class="filter-range-wrap">
            <input type="range" min="10" max="60" value="60" disabled class="filter-range" />
            <div class="filter-range-labels"><span>10W</span><span>60W</span></div>
          </div>
        </div>
        <div class="filter-group">
          <h3 class="filter-group-title">CCT</h3>
          <label class="filter-opt"><input type="checkbox" disabled> 2700K</label>
          <label class="filter-opt"><input type="checkbox" disabled> 3000K</label>
          <label class="filter-opt"><input type="checkbox" disabled> 3500K</label>
          <label class="filter-opt"><input type="checkbox" disabled> 4000K</label>
          <label class="filter-opt"><input type="checkbox" disabled> 5000K</label>
        </div>
        <div class="filter-group">
          <h3 class="filter-group-title">Voltage</h3>
          <label class="filter-opt"><input type="checkbox" disabled> 120-277V</label>
          <label class="filter-opt"><input type="checkbox" disabled> 120V Only</label>
        </div>
        <div class="filter-group">
          <h3 class="filter-group-title">DLC</h3>
          <label class="filter-opt"><input type="checkbox" disabled> DLC Premium</label>
          <label class="filter-opt"><input type="checkbox" disabled> DLC Standard</label>
        </div>
        <div class="filter-group">
          <h3 class="filter-group-title">TAA Compliant</h3>
          <label class="filter-opt"><input type="checkbox" disabled> TAA Compliant</label>
        </div>
        <div class="filter-group">
          <h3 class="filter-group-title">Mount Type</h3>
          <label class="filter-opt"><input type="checkbox" disabled> Recessed</label>
          <label class="filter-opt"><input type="checkbox" disabled> Surface</label>
          <label class="filter-opt"><input type="checkbox" disabled> Suspended</label>
          <label class="filter-opt"><input type="checkbox" disabled> Track</label>
        </div>
        <button class="filter-reset" id="reset-filter">Reset all</button>
      </aside>

      <!-- RIGHT: Grid -->
      <div class="af-grid-col">
        <div class="grid-header">
          <span class="grid-count" id="grid-count">Showing 17 families</span>
          <div class="sort-wrap">
            <select class="sort-select" disabled>
              <option>Sort: ECO → PRO+</option>
              <option>Wattage Low to High</option>
              <option>Wattage High to Low</option>
              <option>A to Z</option>
            </select>
          </div>
        </div>
        <div class="all-fam-grid" id="all-fam-grid">
          {families.map((f: any) => (
            <div class="af-card" data-subcategory={f.apps}>
              <div class="af-img grey-block">
                <span class="tier-badge" style={`background:${f.tier === 'PRO+' ? '#F32740' : f.tier === 'PRO' ? '#fff' : 'rgba(255,255,255,0.10)'}; color:${f.tier === 'PRO+' ? '#fff' : f.tier === 'PRO' ? '#F32740' : '#fff'}; border:${f.tier === 'PRO' ? '1.5px solid #F32740' : 'none'}`}>{f.tier}</span>
              </div>
              <div class="af-body">
                <span class="af-sub">{f.sub}</span>
                <h3 class="af-name">{f.name.includes('Ⓐ') ? <Fragment set:html={f.name.replace(/Ⓐ/g, '<span class="aa">Ⓐ</span>')} /> : f.name}</h3>
                <div class="af-meta">
                  <span class="af-maxw">{f.maxW}</span>
                  <span class="af-skus">{f.skus} SKUs</span>
                  {f.dlc && <span class="af-dlc dlc-pill">DLC</span>}
                </div>
                <a href="#" class="af-cta">VIEW →</a>
              </div>
            </div>
          ))}
        </div>
        <div class="af-no-results" id="no-results" style="display:none">
          <p>No families match the selected filters. <button class="reset-inline" id="reset-inline">Reset filters</button></p>
        </div>
      </div>

    </div>
  </section>

  <!-- §8 LEGACY -->
  <section class="legacy-section" id="legacy">
    <div class="section-inner">
      <span class="sec-eyebrow">LEGACY · COMING SOON</span>
      <h2 class="sec-h2">Replacement guidance for discontinued families.</h2>
      <p class="legacy-body">A cross-reference map for discontinued plano<span class="aa">Ⓐ</span>RCH families will route specifiers and contractors from a legacy SKU to the current-generation replacement family at the matching tier and sub-category. Expected publishing window: Q2 2026.</p>
      <a href="#" class="legacy-cta">Notify me when legacy mapping is published →</a>
    </div>
  </section>

  <!-- §9 GET STARTED -->
  <section class="get-started" id="get-started">
    <div class="section-inner">
      <span class="sec-eyebrow">GET STARTED</span>
      <h2 class="sec-h2">Four ways to move a plano<span class="aa">Ⓐ</span>RCH project forward.</h2>
      <p class="sec-sub">Layout, sample, distributor, or rep — pick the one that matches what you need next.</p>
      <div class="gs-grid">
        <div class="gs-card">
          <h3 class="gs-title">Request a Layout</h3>
          <p class="gs-body">Submit your floor plan. AGI32-grade photometric layout in 48 hours, no charge.</p>
          <a href="#" class="gs-cta">Request Layout →</a>
        </div>
        <div class="gs-card">
          <h3 class="gs-title">Request a Sample</h3>
          <p class="gs-body">Spec samples for active projects. Ships from the nearest of 5 US warehouses.</p>
          <a href="#" class="gs-cta">Request Sample →</a>
        </div>
        <div class="gs-card">
          <h3 class="gs-title">Find a Distributor</h3>
          <p class="gs-body">plano<span class="aa">Ⓐ</span>RCH ships through ALG's national distributor network.</p>
          <a href="/distributor" class="gs-cta">Find Distributor →</a>
        </div>
        <div class="gs-card">
          <h3 class="gs-title">Talk to a Rep</h3>
          <p class="gs-body">Regional rep coverage for spec support, pricing, and field walkthrough.</p>
          <a href="#" class="gs-cta">Find a Rep →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- §10 RELATED COLLECTIONS -->
  <section class="related-collections" id="related">
    <div class="section-inner">
      <span class="sec-eyebrow">RELATED COLLECTIONS</span>
      <h2 class="sec-h2">More from the <span class="aa">Ⓐ</span>RCH portfolio.</h2>
      <div class="rc-grid">
        <a href="/collections/luxoarch" class="rc-card">
          <span class="rc-eyebrow">OUTDOOR · COLLECTION</span>
          <h3 class="rc-name">luxo<span class="aa">Ⓐ</span>RCH</h3>
          <p class="rc-desc">Outdoor lighting for the commercial perimeter. 23 active families, 269 active SKUs.</p>
          <span class="rc-cta">Explore →</span>
        </a>
        <a href="#" class="rc-card">
          <span class="rc-eyebrow">INDOOR · COLLECTION</span>
          <h3 class="rc-name">lampar<span class="aa">Ⓐ</span>RCH</h3>
          <p class="rc-desc">Industrial linear high-bay and low-bay luminaires. Built for warehouse and manufacturing.</p>
          <span class="rc-cta">Coming soon →</span>
        </a>
        <a href="#" class="rc-card">
          <span class="rc-eyebrow">OUTDOOR · COLLECTION</span>
          <h3 class="rc-name">city<span class="aa">Ⓐ</span>RCH</h3>
          <p class="rc-desc">Street and roadway luminaires for municipal and utility applications.</p>
          <span class="rc-cta">Coming soon →</span>
        </a>
        <a href="#" class="rc-card">
