<script>
// ============================================================
// INTERACTIVE SUB-CATEGORY FILTER (live) + ANCHOR NAV
// ============================================================
(function () {
  const grid = document.getElementById('all-fam-grid');
  const countEl = document.getElementById('grid-count');
  const noResults = document.getElementById('no-results');
  const resetBtn = document.getElementById('reset-filter');
  const resetInline = document.getElementById('reset-inline');
  const cbs = Array.from(document.querySelectorAll<HTMLInputElement>('.app-filter-cb'));
  const appTiles = Array.from(document.querySelectorAll<HTMLButtonElement>('.app-tile'));

  function getActiveTokens(): string[] {
    return cbs.filter(cb => cb.checked).map(cb => cb.value);
  }

  function applyFilter() {
    const tokens = getActiveTokens();
    const cards = Array.from(grid!.querySelectorAll<HTMLElement>('.af-card'));
    let visible = 0;
    cards.forEach(card => {
      const cardApps = (card.dataset.subcategory || '').split(/\s+/);
      const show = tokens.length === 0 || tokens.some(t => cardApps.indexOf(t) !== -1);
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    if (countEl) countEl.textContent = tokens.length === 0 ? 'Showing 17 families' : `Showing ${visible} famil${visible === 1 ? 'y' : 'ies'}`;
    if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    // sync tile pressed state
    appTiles.forEach(tile => {
      const tok = tile.dataset.app || '';
      tile.setAttribute('aria-pressed', tokens.includes(tok) ? 'true' : 'false');
    });
  }

  cbs.forEach(cb => cb.addEventListener('change', applyFilter));

  appTiles.forEach(tile => {
    tile.addEventListener('click', () => {
      const tok = tile.dataset.app || '';
      const cb = cbs.find(c => c.value === tok);
      if (cb) {
        cb.checked = !cb.checked;
        applyFilter();
        const sec = document.getElementById('families');
        if (sec) sec.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  function resetAll() {
    cbs.forEach(cb => { cb.checked = false; });
    applyFilter();
  }
  if (resetBtn) resetBtn.addEventListener('click', resetAll);
  if (resetInline) resetInline.addEventListener('click', resetAll);

  // Anchor nav IntersectionObserver
  const dots = Array.from(document.querySelectorAll<HTMLElement>('.san-dot'));
  const sections = dots.map(d => document.querySelector(d.getAttribute('href') || '')).filter(Boolean) as Element[];
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = '#' + entry.target.id;
        dots.forEach(d => d.classList.toggle('active', d.getAttribute('href') === id));
      }
    });
  }, { threshold: 0.3 });
  sections.forEach(s => obs.observe(s));
})();
</script>
