<script>
  /* Interactive sub-category filter (live).
   * Checkbox name=filter-subcategory, value=kebab-case token.
   * Each .af-card has data-subcategory with a single token.
   * OR logic: card visible if any checked token matches its token. */
  (function () {
    var grid = document.getElementById('all-fam-grid');
    var countEl = document.getElementById('grid-count');
    var noResults = document.getElementById('no-results');
    var resetBtn = document.getElementById('reset-filter');
    var resetInline = document.getElementById('reset-inline');
    var cbs = Array.from(document.querySelectorAll('.app-filter-cb'));
    var appTiles = Array.from(document.querySelectorAll('.app-tile'));

    function getActiveTokens() {
      return cbs.filter(function (cb) { return (cb as HTMLInputElement).checked; })
        .map(function (cb) { return (cb as HTMLInputElement).value; });
    }

    function applyFilter() {
      var tokens = getActiveTokens();
      var cards = grid ? Array.from(grid.querySelectorAll('.af-card')) : [];
      var visible = 0;
      cards.forEach(function (card) {
        var cardApp = (card as HTMLElement).dataset.subcategory || '';
        var show = tokens.length === 0 || tokens.indexOf(cardApp) !== -1;
        (card as HTMLElement).classList.toggle('hidden', !show);
        if (show) visible++;
      });
      if (countEl) {
        countEl.textContent = tokens.length === 0
          ? 'Showing 17 families'
          : 'Showing ' + visible + ' famil' + (visible === 1 ? 'y' : 'ies');
      }
      if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
      /* sync tile pressed state */
      appTiles.forEach(function (tile) {
        var tok = (tile as HTMLElement).dataset.app || '';
        (tile as HTMLElement).setAttribute('aria-pressed', tokens.indexOf(tok) !== -1 ? 'true' : 'false');
      });
    }

    cbs.forEach(function (cb) { cb.addEventListener('change', applyFilter); });

    appTiles.forEach(function (tile) {
      tile.addEventListener('click', function () {
        var tok = (tile as HTMLElement).dataset.app || '';
        var cb = cbs.find(function (c) { return (c as HTMLInputElement).value === tok; }) as HTMLInputElement | undefined;
        if (cb) {
          cb.checked = !cb.checked;
          applyFilter();
          var sec = document.getElementById('sec-all-families');
          if (sec) sec.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    function resetAll() {
      cbs.forEach(function (cb) { (cb as HTMLInputElement).checked = false; });
      applyFilter();
    }
    if (resetBtn) resetBtn.addEventListener('click', resetAll);
    if (resetInline) resetInline.addEventListener('click', resetAll);
  })();
</script>
