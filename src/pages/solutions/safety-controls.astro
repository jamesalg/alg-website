<script>
  // Right-side dot anchor scrollspy
  const dots = document.querySelectorAll('.anchor-rail .anchor-dot');
  const sections = Array.from(dots).map(d => document.querySelector(d.getAttribute('href')));
  function spy() {
    let i = 0;
    for (let k = 0; k < sections.length; k++) {
      if (sections[k] && sections[k].getBoundingClientRect().top < window.innerHeight * 0.4) i = k;
    }
    dots.forEach((d, k) => d.classList.toggle('active', k === i));
  }
  window.addEventListener('scroll', spy, { passive: true });
  document.querySelectorAll('.cy').forEach(e => e.textContent = new Date().getFullYear());
</script>
