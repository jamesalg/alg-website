        { tier: 'EM15', sku: 'EM15-HMB/170DC', desc: '15W · 170VDC' },
        { tier: 'EM15 · /CL', sku: 'EM15-PMB/120AC', desc: '15W · /CL NLC' },
        { tier: 'EM20 · /AG', sku: 'EM20-CMB/150DC', desc: '20W · /AG READY' },
        { tier: 'EM20', sku: 'EM20-HMB/135AC', desc: '20W · TUBUL<span class="aa">Ⓐ</span>RCH' },
        { tier: 'EM25 · /CL', sku: 'EM25-PMB/120AC', desc: '25W · /CL NLC' },
      ].map(s => (
        <a href="/safety-controls/constant" class="block border border-black/10 bg-white hover:border-[#F32740] transition-colors overflow-hidden">
