---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ResourceCard from '../../../components/ResourceCard.astro';

const title = "EM20-CMB/260DC — constⒶNT Emergency LED Driver";
const description = "20W constant-power emergency LED driver. 90-min egress runtime. 100–347 VAC universal input. 90–260 VDC output. UL 924 listed. /AG ArcticGuard cold-pack adder available.";

const resources = [
  { label: 'Datasheet', description: 'EM20-CMB/260DC product datasheet', url: null, resource: 'Datasheet', family: 'EM20-CMB%2F260DC' },
  { label: 'Installation Sheet', description: 'Factory + field install instructions', url: null, resource: 'Installation+Sheet', family: 'EM20-CMB%2F260DC' },
  { label: 'Wiring Diagram', description: 'Constant-power emergency wiring', url: null, resource: 'Wiring+Diagram', family: 'EM20-CMB%2F260DC' },
  { label: "const<span class='aa'>Ⓐ</span>NT Product Guide", description: "2026 edition · 13-page catalog", url: null, resource: "Product+Guide", family: "const%E2%92%B6NT" },
];
---
<BaseLayout {title} {description}>
<style>
  :root {
    --accent: #F32740;
    --paper: #FAF8F4;
    --paper-2: #F1ECE3;
    --char: #111111;
    --warm: #F5C24A;
    --ink: #111111;
  }
  .section-bg-paper { background: var(--paper); color: var(--ink); }
  .section-bg-paper-2 { background: var(--paper-2); color: var(--ink); }
  .section-bg-dark { background: var(--char); color: white; }
  .accent-text { color: var(--accent); }
  .mono { font-family: ui-monospace, monospace; }
  .h1 { font-weight: 800; letter-spacing: -0.03em; line-height: 1.05; }
  .h2 { font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; }
  .eyebrow { font-family: ui-monospace, monospace; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; }
  .eyebrow-rule { display: flex; align-items: center; gap: 0.75rem; }
  .eyebrow-rule::before { content: ''; display: block; width: 2rem; height: 2px; background: currentColor; flex-shrink: 0; }
  .btn { display: inline-flex; align-items: center; padding: 0.75rem 1.5rem; font-family: ui-monospace, monospace; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; cursor: pointer; text-decoration: none; transition: background 0.15s, color 0.15s; }
  .btn-primary { background: var(--accent); color: white; }
  .btn-primary:hover { background: #C41E32; }
  .btn-outline-dark { border: 1px solid rgba(0,0,0,0.3); color: var(--ink); }
  .btn-outline-dark:hover { background: rgba(0,0,0,0.05); }
  .btn-ghost-dark { color: var(--ink); text-decoration: underline; }
  .btn-outline-light { border: 1px solid rgba(255,255,255,0.5); color: white; }
  .btn-outline-light:hover { background: rgba(255,255,255,0.1); }
  .stat-num-small { font-weight: 800; font-size: 1.75rem; letter-spacing: -0.025em; line-height: 1; }
  .stat-label { font-family: ui-monospace, monospace; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.7; margin-top: 0.25rem; }
  .icon-stat { width: 32px; height: 32px; flex-shrink: 0; }
  .trust-badge { display: inline-block; padding: 0.25rem 0.6rem; background: rgba(243,39,64,0.08); border: 1px solid rgba(243,39,64,0.2); font-family: ui-monospace, monospace; font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; }
  /* Spec layout */
  .spec-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; padding: 0.75rem 0; border-bottom: 1px solid rgba(0,0,0,0.06); }
  .spec-row dt { font-weight: 600; font-size: 0.875rem; }
  .spec-row dd { font-size: 0.875rem; opacity: 0.85; }
  .spec-block-num { font-family: ui-monospace, monospace; font-size: 0.65rem; letter-spacing: 0.2em; color: var(--accent); font-weight: 700; }
  .toc-link { display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.75rem; font-family: ui-monospace, monospace; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; color: var(--ink); opacity: 0.6; transition: opacity 0.15s; }
  .toc-link:hover, .toc-link.active { opacity: 1; color: var(--accent); }
  .toc-num { font-size: 0.6rem; opacity: 0.5; }
  /* Cert cells */
  .cert-cell { display: flex; flex-direction: column; gap: 0.25rem; padding: 1rem; background: white; border: 1px solid rgba(0,0,0,0.08); }
  .cert-mark { font-family: ui-monospace, monospace; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; }
  .cert-detail { font-size: 0.75rem; opacity: 0.7; }
  /* Candor block */
  .candor { border-left: 4px solid var(--warm); padding: 1.5rem 1.75rem; background: rgba(245,194,74,0.10); }
  /* Matrix table */
  .matrix-row { border-bottom: 1px solid rgba(0,0,0,0.06); }
  .matrix-row td { padding: 0.75rem 1rem; font-family: ui-monospace, monospace; font-size: 0.75rem; }
  /* Sister cards */
  .product-thumb { height: 80px; display: flex; align-items: center; justify-content: center; background: var(--paper-2); padding: 0.5rem; color: rgba(0,0,0,0.4); }
  /* Anchor rail */
  .anchor-rail { position: fixed; right: 16px; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 12px; z-index: 30; }
  .anchor-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(0,0,0,0.25); transition: background 0.2s, transform 0.2s; cursor: pointer; position: relative; display: block; }
  .anchor-dot:hover { background: rgba(0,0,0,0.6); transform: scale(1.3); }
  .anchor-dot.active { background: var(--accent); transform: scale(1.4); }
  .anchor-dot::before { content: attr(data-label); position: absolute; right: 18px; top: 50%; transform: translateY(-50%); background: var(--ink); color: white; padding: 5px 9px; font-family: ui-monospace, monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; white-space: nowrap; opacity: 0; pointer-events: none; transition: opacity 0.18s; }
  .anchor-dot:hover::before { opacity: 1; }
  .skip-link { position: absolute; left: -9999px; top: 0; padding: 1rem; background: var(--ink); color: white; }
  .skip-link:focus { left: 0; }
</style>

<a href="#main" class="skip-link">Skip to content</a>

<!-- Breadcrumb -->
<div class="border-b border-black/10 bg-white">
  <div class="max-w-screen-2xl mx-auto px-6 py-3 mono text-xs tracking-widest opacity-70">
    <a href="/" class="hover:text-[#F32740]">HOME</a> › <a href="/solutions/safety-controls" class="hover:text-[#F32740]">SAFETY &amp; CONTROLS</a> › <a href="/safety-controls/constant" class="hover:text-[#F32740]">CONST<span class="aa">Ⓐ</span>NT</a> › EM20-CMB/260DC
  </div>
</div>

<!-- Anchor rail -->
<aside class="anchor-rail" aria-label="On-page sections">
  <a href="#hero" class="anchor-dot active" data-label="Top" aria-label="Top"></a>
  <a href="#specs" class="anchor-dot" data-label="Specs" aria-label="Specs"></a>
  <a href="#candor" class="anchor-dot" data-label="Candor" aria-label="Candor"></a>
  <a href="#certs" class="anchor-dot" data-label="Certs" aria-label="Certs"></a>
  <a href="#ordering" class="anchor-dot" data-label="Ordering" aria-label="Ordering"></a>
  <a href="#resources" class="anchor-dot" data-label="Resources" aria-label="Resources"></a>
  <a href="#sisters" class="anchor-dot" data-label="Sisters" aria-label="Sisters"></a>
</aside>

<main id="main">

<!-- HERO -->
<section id="hero" class="section-bg-paper" aria-labelledby="hero-h1">
  <div class="max-w-screen-2xl mx-auto px-6 py-20 grid md:grid-cols-12 gap-12 items-start">
    <div class="md:col-span-7">
      <p class="eyebrow eyebrow-rule mb-6 opacity-60"><span class="accent-text">CONST<span class="aa">Ⓐ</span>NT ·</span> MID-POWER · FACTORY / FIELD INSTALL</p>
      <h1 id="hero-h1" class="h1 text-5xl md:text-6xl mb-6">EM20-CMB/260DC</h1>
      <p class="text-xl mb-3 opacity-85 font-semibold"><span class="aa">Ⓐ</span>rcticGuard-ready cold-pack emergency LED driver — high-voltage mid-power.</p>
      <p class="text-base leading-relaxed mb-8 opacity-90">20W constant-power emergency LED driver with LiFePO4 battery. Drives 90–260 VDC LED arrays at constant power. Universal 100–347 VAC input — one driver for every commercial building voltage. Specify the /AG adder for cold-pack operating range. Factory-install or field-install eligible.</p>
      <dl class="grid grid-cols-2 gap-x-8 gap-y-5 mb-8">
        <div class="flex items-center gap-3">
          <div class="icon-stat accent-text"><svg viewBox="0 0 64 64" class="w-full h-full" fill="currentColor"><path d="M36 4 L14 36 L28 36 L24 60 L50 26 L34 26 Z"/></svg></div>
          <div><dd class="stat-num-small">20 W</dd><dt class="stat-label">Emergency output</dt></div>
        </div>
        <div class="flex items-center gap-3">
          <div class="icon-stat accent-text"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><circle cx="32" cy="32" r="24"/><line x1="32" y1="14" x2="32" y2="32" stroke-width="3"/><line x1="32" y1="32" x2="44" y2="40" stroke-width="3"/></svg></div>
          <div><dd class="stat-num-small">90 min</dd><dt class="stat-label">Egress runtime</dt></div>
        </div>
        <div class="flex items-center gap-3">
          <div class="icon-stat accent-text"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><rect x="8" y="14" width="44" height="36" rx="3"/><line x1="52" y1="24" x2="58" y2="24"/><line x1="52" y1="40" x2="58" y2="40"/><path d="M16 32 L24 24 L24 30 L32 30 L32 38 L24 38 L24 44 Z" fill="currentColor" stroke="none"/></svg></div>
          <div><dd class="stat-num-small">100–347V</dd><dt class="stat-label">AC input range</dt></div>
        </div>
        <div class="flex items-center gap-3">
          <div class="icon-stat accent-text"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><line x1="32" y1="6" x2="32" y2="58"/><line x1="6" y1="32" x2="58" y2="32"/><line x1="13" y1="13" x2="51" y2="51"/><line x1="51" y1="13" x2="13" y2="51"/><circle cx="32" cy="32" r="4" fill="currentColor" stroke="none"/></svg></div>
          <div><dd class="stat-num-small">90–260V</dd><dt class="stat-label">DC output range</dt></div>
        </div>
      </dl>
      <div class="flex flex-wrap gap-2 mb-6">
        <span class="trust-badge">UL 924 LISTED</span>
        <span class="trust-badge">CSA C22.2 No.141</span>
        <span class="trust-badge">CEC TITLE 20</span>
        <span class="trust-badge">/AG READY</span>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/support/sample-request?subject=EM20-CMB%2F260DC+Quote" class="btn btn-primary">REQUEST QUOTE</a>
        <a href="https://algportal.archipelagolighting.com" class="btn btn-outline-dark" target="_blank" rel="noopener">SHOP STOCK &amp; BUY</a>
        <a href="#resources" class="btn btn-ghost-dark">DOCUMENTATION ↓</a>
      </div>
    </div>
    <div class="md:col-span-5 flex flex-col items-center justify-center">
      <div class="w-full aspect-square bg-[var(--paper-2)] flex items-center justify-center border border-black/10">
        <svg viewBox="0 0 200 200" class="w-3/4 h-3/4" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.4">
          <rect x="20" y="60" width="160" height="80" rx="4"/>
          <rect x="35" y="75" width="35" height="50" fill="currentColor" stroke="none" opacity="0.3"/>
          <rect x="130" y="75" width="35" height="50" fill="currentColor" stroke="none" opacity="0.3"/>
          <line x1="24" y1="60" x2="24" y2="140"/>
          <line x1="176" y1="60" x2="176" y2="140"/>
          <circle cx="100" cy="100" r="6" fill="currentColor" stroke="none"/>
          <line x1="100" y1="40" x2="100" y2="60"/>
          <line x1="100" y1="140" x2="100" y2="160"/>
        </svg>
      </div>
      <p class="mono text-[10px] tracking-widest opacity-50 mt-3 text-center">▸ PRODUCT PHOTO — REPLACE WITH ROOSTER CREATIVE PHOTOGRAPHY</p>
    </div>
  </div>
</section>

<!-- SPECS WITH STICKY TOC -->
<section id="specs" class="section-bg-paper" aria-labelledby="specs-h2">
  <div class="max-w-screen-2xl mx-auto px-6 py-20">
    <p class="eyebrow eyebrow-rule mb-6 accent-text">FULL SPECIFICATIONS · DATASHEET-ANCHORED</p>
    <h2 id="specs-h2" class="h2 text-4xl md:text-5xl mb-12 max-w-3xl">Performance, electrical, installation, compliance.</h2>
    <div class="grid md:grid-cols-12 gap-10">
      <aside class="md:col-span-3" aria-label="Spec TOC">
        <div class="sticky top-6">
          <p class="mono text-xs tracking-widest opacity-60 mb-3 px-3">SPEC SECTIONS</p>
          <nav class="flex flex-col gap-1">
            <a href="#spec-perf" class="toc-link active"><span class="toc-num">01</span> Performance</a>
            <a href="#spec-elec" class="toc-link"><span class="toc-num">02</span> Electrical</a>
            <a href="#spec-inst" class="toc-link"><span class="toc-num">03</span> Installation</a>
            <a href="#spec-const" class="toc-link"><span class="toc-num">04</span> Construction</a>
            <a href="#spec-comp" class="toc-link"><span class="toc-num">05</span> Compliance</a>
          </nav>
        </div>
      </aside>
      <div class="md:col-span-9 space-y-12">
        <article id="spec-perf">
          <p class="spec-block-num mb-2">01</p>
          <h3 class="font-bold text-2xl mb-4">Performance</h3>
          <dl>
            <div class="spec-row"><dt>Emergency output power</dt><dd>20 W (per datasheet)</dd></div>
            <div class="spec-row"><dt>Emergency runtime</dt><dd>90 minutes (per datasheet · NFPA 101 §7.9 minimum)</dd></div>
            <div class="spec-row"><dt>Output type</dt><dd>Constant power (per datasheet)</dd></div>
            <div class="spec-row"><dt>Recharge time</dt><dd>≤ 24 hours (per datasheet)</dd></div>
            <div class="spec-row"><dt>Battery type</dt><dd>LiFePO4 · 6.4V · 3000 mAh (per datasheet)</dd></div>
            <div class="spec-row"><dt>Battery cycles</dt><dd>500 full charge / discharge cycles (per datasheet)</dd></div>
            <div class="spec-row"><dt>Charging current</dt><dd>0–250 mA (per datasheet)</dd></div>
          </dl>
        </article>
        <article id="spec-elec">
          <p class="spec-block-num mb-2">02</p>
          <h3 class="font-bold text-2xl mb-4">Electrical</h3>
          <dl>
            <div class="spec-row"><dt>Input voltage</dt><dd>100–347 VAC (per datasheet)</dd></div>
            <div class="spec-row"><dt>Input frequency</dt><dd>50 / 60 Hz</dd></div>
            <div class="spec-row"><dt>Input current</dt><dd>100 mA max (per datasheet)</dd></div>
            <div class="spec-row"><dt>Input power</dt><dd>7 W max (per datasheet)</dd></div>
            <div class="spec-row"><dt>Output voltage</dt><dd>DC 36–150 V · 90–260 VDC operating envelope (per datasheet)</dd></div>
            <div class="spec-row"><dt>Output current</dt><dd>410–800 mA (per datasheet)</dd></div>
            <div class="spec-row"><dt>Power factor</dt><dd>&gt; 0.50 (per datasheet)</dd></div>
          </dl>
        </article>
        <article id="spec-inst">
          <p class="spec-block-num mb-2">03</p>
          <h3 class="font-bold text-2xl mb-4">Installation</h3>
          <dl>
            <div class="spec-row"><dt>Mounting type</dt><dd>Surface mount</dd></div>
            <div class="spec-row"><dt>Test switch</dt><dd>Test switch with red LED status indicator (per datasheet)</dd></div>
            <div class="spec-row"><dt>Wire type</dt><dd>UL 2464 · 24 AWG · 300V · 80°C</dd></div>
            <div class="spec-row"><dt>Wire length</dt><dd>550 mm (21.65 in) per datasheet</dd></div>
            <div class="spec-row"><dt>Install path</dt><dd>Factory or field (per datasheet)</dd></div>
          </dl>
        </article>
        <article id="spec-const">
          <p class="spec-block-num mb-2">04</p>
          <h3 class="font-bold text-2xl mb-4">Construction</h3>
          <dl>
            <div class="spec-row"><dt>Max. application</dt><dd>200 W or 4 A LED driver max (per datasheet)</dd></div>
            <div class="spec-row"><dt>Operating temperature</dt><dd>32°F to 122°F standard · 140°F upper bound with /AG (per datasheet)</dd></div>
            <div class="spec-row"><dt>/AG cold-pack range</dt><dd>−4°F to 140°F (per datasheet · LiFePO4 chemistry)</dd></div>
            <div class="spec-row"><dt>Storage temperature</dt><dd>158°F max (per datasheet)</dd></div>
            <div class="spec-row"><dt>Location rating</dt><dd>Dry, damp, extreme temp (per datasheet)</dd></div>
          </dl>
        </article>
        <article id="spec-comp">
          <p class="spec-block-num mb-2">05</p>
          <h3 class="font-bold text-2xl mb-4">Compliance &amp; warranty</h3>
          <dl>
            <div class="spec-row"><dt>Safety listings</dt><dd>UL 924 · CSA C22.2 No.141 (per datasheet)</dd></div>
            <div class="spec-row"><dt>Energy compliance</dt><dd>CEC Title 20 (per datasheet)</dd></div>
            <div class="spec-row"><dt>Install listing</dt><dd>UL listed for factory and field install (per datasheet)</dd></div>
            <div class="spec-row"><dt>Compatible fixture families</dt><dd>lampar<span class="aa">Ⓐ</span>RCH · luxo<span class="aa">Ⓐ</span>RCH (per datasheet)</dd></div>
            <div class="spec-row"><dt>Warranty</dt><dd>5-year limited (per datasheet)</dd></div>
          </dl>
        </article>
      </div>
    </div>
  </div>
</section>

<!-- CANDOR -->
<section id="candor" class="section-bg-paper-2">
  <div class="max-w-screen-2xl mx-auto px-6 py-12">
    <div class="candor max-w-4xl">
      <p class="mono text-xs tracking-widest mb-3" style="color:#8a6510">— ENGINEERING CANDOR · WHEN /AG IS REQUIRED VS. OPTIONAL</p>
      <h3 class="font-bold text-2xl mb-3">−4°F isn’t always free. Spec it when the room earns it.</h3>
      <p class="text-base leading-relaxed mb-3 opacity-90">Standard EM20-CMB/260DC operates 32°F to 122°F with a LiFePO4 battery rated for 500 full cycles. The /AG adder extends the lower bound to −4°F (and the upper bound to 140°F) — at the cost of made-to-order lead time and a price premium. Specify /AG for refrigerated warehouses, walk-in freezer egress, outdoor enclosures, and unconditioned attics. Skip /AG for office, healthcare, and education spaces where the conditioned envelope handles the temp range.</p>
      <p class="text-base leading-relaxed opacity-90">/XD (120-min extended discharge) is not currently offered on the EM20-CMB chassis. If 120-min egress is required by AHJ, specify EM08-HMB/170DC/XD or EM08-YTB/60DC/XD from the Tier 01 catalog.</p>
    </div>
  </div>
</section>

<!-- CERTS -->
<section id="certs" class="section-bg-paper" aria-labelledby="certs-h2">
  <div class="max-w-screen-2xl mx-auto px-6 py-16">
    <p class="eyebrow eyebrow-rule mb-6 accent-text">CERTIFICATIONS &amp; LISTINGS</p>
    <h2 id="certs-h2" class="h2 text-3xl md:text-4xl mb-8">Documented, not declared.</h2>
    <div class="grid md:grid-cols-4 gap-3">
      <div class="cert-cell"><span class="cert-mark">UL 924</span><span class="cert-detail">Emergency-driver listing (per datasheet)</span></div>
      <div class="cert-cell"><span class="cert-mark">CSA C22.2 No.141</span><span class="cert-detail">Emergency lighting (per datasheet)</span></div>
      <div class="cert-cell"><span class="cert-mark">CEC Title 20</span><span class="cert-detail">CA appliance efficiency (per datasheet)</span></div>
      <div class="cert-cell"><span class="cert-mark">Factory + Field</span><span class="cert-detail">Both install paths UL-listed</span></div>
      <div class="cert-cell"><span class="cert-mark">LiFePO4 Battery</span><span class="cert-detail">6.4V · 3000mAh · 500 cycles</span></div>
      <div class="cert-cell"><span class="cert-mark">Dry · Damp · Extreme</span><span class="cert-detail">Location rating per datasheet</span></div>
      <div class="cert-cell"><span class="cert-mark">5-Year Warranty</span><span class="cert-detail">Limited · standard (per datasheet)</span></div>
      <div class="cert-cell"><span class="cert-mark">100–347 VAC</span><span class="cert-detail">Universal building voltage</span></div>
    </div>
  </div>
</section>

<!-- ORDERING -->
<section id="ordering" class="section-bg-paper-2" aria-labelledby="ord-h2">
  <div class="max-w-screen-2xl mx-auto px-6 py-20">
    <p class="eyebrow eyebrow-rule mb-6 accent-text">ORDERING INFORMATION</p>
    <h2 id="ord-h2" class="h2 text-4xl md:text-5xl mb-4">Two orderable variants. One adder.</h2>
    <p class="opacity-80 max-w-3xl mb-8">From the EM20-CMB/260DC datasheet ordering block. Vendor MPN reference is BillDa BLD-CM20H-480800-20W (per datasheet).</p>
    <div class="overflow-x-auto">
      <table class="w-full bg-white border border-black/10 mono text-xs min-w-[680px] spec-table">
        <thead>
          <tr class="border-b border-black/10 font-bold tracking-wider opacity-70">
            <th scope="col" class="px-4 py-3 text-left">SKU</th>
            <th scope="col" class="px-4 py-3 text-left">DESCRIPTION</th>
            <th scope="col" class="px-4 py-3">EM W</th>
            <th scope="col" class="px-4 py-3">RUNTIME</th>
            <th scope="col" class="px-4 py-3 text-left">OPERATING TEMP</th>
            <th scope="col" class="px-4 py-3 text-left">VENDOR MPN</th>
          </tr>
        </thead>
        <tbody>
          <tr class="matrix-row"><td class="px-4 py-3">EM20-CMB/260DC</td><td class="px-4 py-3">Standard 20 W driver</td><td class="px-4 py-3 text-center">20W</td><td class="px-4 py-3 text-center">90 min</td><td class="px-4 py-3">32°F – 122°F</td><td class="px-4 py-3">BLD-CM20H-480800-20W</td></tr>
          <tr class="matrix-row"><td class="px-4 py-3">EM20-CMB/260DC/AG</td><td class="px-4 py-3">With <span class="aa">Ⓐ</span>rcticGuard cold-pack</td><td class="px-4 py-3 text-center">20W</td><td class="px-4 py-3 text-center">90 min</td><td class="px-4 py-3">−4°F – 140°F</td><td class="px-4 py-3">BLD-CM20H-480800-20W (with /AG cold-pack)</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- RESOURCES -->
<section id="resources" class="section-bg-paper">
  <div class="max-w-screen-2xl mx-auto px-6 py-16">
