</main>

<!-- DARK CTA -->
<section class="section-bg-dark">
  <div class="max-w-screen-xl mx-auto px-6 py-20 text-center text-white">
    <h2 class="h2 text-4xl md:text-5xl mb-6">Spec the EM20-CMB. Ship 3-day.</h2>
    <p class="opacity-80 max-w-2xl mx-auto mb-8">In stock from US warehouses. /AG cold-pack adder ships made-to-order — confirm lead time at quote.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/support/sample-request?subject=EM20-CMB%2F260DC+Quote" class="btn btn-primary">REQUEST QUOTE</a>
      <a href="/support/sample-request?subject=EM20-CMB%2F260DC+Sample" class="btn btn-outline-light">REQUEST SAMPLE</a>
      <a href="#resources" class="btn btn-outline-light">DOCUMENTATION ↓</a>
    </div>
  </div>
</section>

<script>
  const dots = document.querySelectorAll('.anchor-rail .anchor-dot');
  const sections = Array.from(dots).map(d => document.querySelector(d.getAttribute('href')));
  function spy() {
    let i = 0;
    for (let k = 0; k < sections.length; k++) {
      if (sections[k] && sections[k].getBoundingClientRect().top < window.innerHeight * 0.4) i = k;
    }
    dots.forEach((d, k) => d.classList.toggle('active', k === i));
  }
  window.addEventListener('scroll', spy, { passive: true });
  // Spec TOC active state
  const tocLinks = document.querySelectorAll('.toc-link');
  const specArticles = Array.from(tocLinks).map(l => document.querySelector(l.getAttribute('href')));
  function spySpec() {
    let i = 0;
    for (let k = 0; k < specArticles.length; k++) {
      if (specArticles[k] && specArticles[k].getBoundingClientRect().top < window.innerHeight * 0.5) i = k;
    }
    tocLinks.forEach((l, k) => l.classList.toggle('active', k === i));
  }
  window.addEventListener('scroll', spySpec, { passive: true });
</script>
</BaseLayout>
