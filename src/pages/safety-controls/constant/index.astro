---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const title = "const<span class='aa'>Ⓐ</span>NT — Emergency Drivers";
const description = "UL 924 listed emergency battery-backup drivers for commercial and industrial. Universal voltage. 90-minute egress. 5-year warranty. Four install tiers.";
---
<BaseLayout {title} {description}>
<style>
  :root {
    --accent: #F32740;
    --warm: #F5C24A;
    --paper: #FAF8F4;
    --paper-2: #F1ECE3;
    --char: #111111;
    --ink: #111111;
  }
  .section-bg-paper { background: var(--paper); color: var(--ink); }
  .section-bg-paper-2 { background: var(--paper-2); color: var(--ink); }
  .section-bg-dark { background: var(--char); color: white; }
  .accent-text { color: var(--accent); }
  .mono { font-family: ui-monospace, monospace; }
  .h1 { font-weight: 800; letter-spacing: -0.03em; line-height: 1.05; }
  .h2 { font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; }
  .eyebrow { font-family: ui-monospace, monospace; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; }
  .eyebrow-rule { display: flex; align-items: center; gap: 0.75rem; }
  .eyebrow-rule::before { content: \'\'; display: block; width: 2rem; height: 2px; background: currentColor; flex-shrink: 0; }
  .btn { display: inline-flex; align-items: center; padding: 0.75rem 1.5rem; font-family: ui-monospace, monospace; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; cursor: pointer; text-decoration: none; transition: background 0.15s, color 0.15s; }
  .btn-primary { background: var(--accent); color: white; }
  .btn-primary:hover { background: #C41E32; color: white; }
  .btn-outline-dark { border: 1px solid rgba(0,0,0,0.3); color: var(--ink); }
  .btn-outline-dark:hover { background: rgba(0,0,0,0.05); color: var(--ink); }
  .btn-outline-light { border: 1px solid rgba(255,255,255,0.5); color: white; }
  .btn-outline-light:hover { background: rgba(255,255,255,0.1); color: white; }
  .stat-num { font-weight: 800; font-size: 2.25rem; letter-spacing: -0.03em; line-height: 1; }
  .stat-label { font-family: ui-monospace, monospace; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.7; margin-top: 0.5rem; }
  .icon-block { width: 56px; height: 56px; color: var(--accent); display: inline-flex; }
  .icon-stat { width: 40px; height: 40px; display: inline-flex; }
  /* Vertical tiles */
  .vertical-tile { position: relative; overflow: hidden; display: block; text-decoration: none; }
  .vertical-tile:hover .vertical-tile-art { transform: scale(1.03); }
  .vertical-tile-art { aspect-ratio: 4/3; transition: transform 0.3s; }
  .vertical-tile-art--cold { background: linear-gradient(135deg, #243640 0%, #0E1A22 100%); }
  .vertical-tile-art--datacenter { background: linear-gradient(135deg, #2F2F3A 0%, #15151E 100%); }
  .vertical-tile-art--education { background: linear-gradient(135deg, #4A3520 0%, #261B11 100%); }
  .vertical-tile-art--gov { background: linear-gradient(135deg, #1E2A1E 0%, #0E140E 100%); }
  .vertical-tile-art--health { background: linear-gradient(135deg, #2A3E48 0%, #14202A 100%); }
  .vertical-tile-art--hospitality { background: linear-gradient(135deg, #3F2A1E 0%, #1C120A 100%); }
  .vertical-tile-art--industrial { background: linear-gradient(135deg, #2C2C2C 0%, #0F0F0F 100%); }
  .vertical-tile-art--warehouse { background: linear-gradient(135deg, #2A2620 0%, #14110D 100%); }
  .vertical-tile-body { position: absolute; left: 0; right: 0; bottom: 0; padding: 1.25rem 1.4rem; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%); }
  .vertical-tile-body h3 { font-weight: 800; font-size: 1.25rem; letter-spacing: -0.01em; color: white; margin-bottom: 0.25rem; }
  .vertical-tile-body p { font-family: ui-monospace, monospace; font-size: 0.65rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.7); }
  .vertical-tile-tag { position: absolute; top: 0.85rem; left: 0.95rem; font-family: ui-monospace, monospace; font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.55); }
  /* SKU matrix */
  .matrix-row:hover { background: rgba(243,39,64,0.04); }
  .matrix-row td { padding: 0.75rem 1rem; border-bottom: 1px solid #E5E5E5; font-size: 0.875rem; }
  /* Right-side dot anchor nav */
  .anchor-rail { position: fixed; right: 16px; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 12px; z-index: 30; padding-right: 4px; }
  .anchor-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(0,0,0,0.25); transition: background 0.2s, transform 0.2s; cursor: pointer; position: relative; display: block; }
  .anchor-dot:hover { background: rgba(0,0,0,0.6); transform: scale(1.3); }
  .anchor-dot.active { background: var(--accent); transform: scale(1.4); }
  .anchor-dot::before {
    content: attr(data-label);
    position: absolute;
    right: 18px;
    top: 50%;
    transform: translateY(-50%);
    background: var(--ink);
    color: white;
    padding: 5px 9px;
    font-family: ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s;
  }
  .anchor-dot:hover::before { opacity: 1; }
  @media (prefers-reduced-motion: reduce) { * { animation: none !important; transition: none !important; } }
  .skip-link { position: absolute; left: -9999px; top: 0; padding: 1rem; background: var(--ink); color: white; }
  .skip-link:focus { left: 0; }
</style>

<a href="#main" class="skip-link">Skip to content</a>

<!-- Breadcrumb -->
<div class="border-b border-black/10 bg-white">
  <div class="max-w-screen-2xl mx-auto px-6 py-3 mono text-xs tracking-widest opacity-70">
    <a href="/" class="hover:text-[#F32740]">HOME</a> \u203a <a href="/solutions/safety-controls" class="hover:text-[#F32740]">SAFETY &amp; CONTROLS</a> \u203a CONST<span class="aa">\u24b6</span>NT
  </div>
</div>

<!-- Right-side anchor menu -->
<aside class="anchor-rail" aria-label="On-page sections">
  <a href="#hero" class="anchor-dot active" data-label="Top" aria-label="Top"></a>
  <a href="#tiers" class="anchor-dot" data-label="Install tiers" aria-label="Install tiers"></a>
  <a href="#adders" class="anchor-dot" data-label="Adders" aria-label="Adders"></a>
  <a href="#verticals" class="anchor-dot" data-label="Verticals" aria-label="Verticals"></a>
  <a href="#matrix" class="anchor-dot" data-label="SKU matrix" aria-label="SKU matrix"></a>
  <a href="#compliance" class="anchor-dot" data-label="Compliance" aria-label="Compliance"></a>
  <a href="#cta" class="anchor-dot" data-label="Talk to a rep" aria-label="Talk to a rep"></a>
</aside>

<main id="main">

<!-- HERO -->
<section id="hero" class="section-bg-paper" aria-labelledby="hero-h1">
  <div class="max-w-screen-xl mx-auto px-6 py-24 text-center">
    <p class="eyebrow eyebrow-rule mb-8 opacity-70 justify-center">SAFETY &amp; EMERGENCY \u00b7 CONST<span class="aa">\u24b6</span>NT \u00b7 UL 924 LISTED</p>
    <h1 id="hero-h1" class="h1 text-5xl md:text-6xl lg:text-7xl mb-8">Four solutions.<br>One ecosystem. <span class="accent-text">Constant power.</span></h1>
    <p class="text-xl max-w-2xl mx-auto mb-12 opacity-85 leading-snug">Emergency battery-backup drivers for commercial &amp; industrial. Universal voltage. 90-minute egress. 5-year warranty.</p>
    <div class="flex justify-center flex-wrap gap-x-12 gap-y-8 mb-12">
      <div class="text-center">
        <div class="icon-stat accent-text mx-auto mb-3"><svg viewBox="0 0 64 64" class="w-full h-full" fill="currentColor"><path d="M36 4 L14 36 L28 36 L24 60 L50 26 L34 26 Z"/></svg></div>
        <div class="stat-num">100\u2013347V</div><div class="stat-label">Universal AC</div>
      </div>
      <div class="text-center">
        <div class="icon-stat accent-text mx-auto mb-3"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><circle cx="32" cy="32" r="24"/><line x1="32" y1="14" x2="32" y2="32" stroke-width="3"/><line x1="32" y1="32" x2="44" y2="40" stroke-width="3"/></svg></div>
        <div class="stat-num">90 min</div><div class="stat-label">Egress runtime</div>
      </div>
      <div class="text-center">
        <div class="icon-stat accent-text mx-auto mb-3"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><path d="M32 6 L52 14 L52 32 Q52 50 32 58 Q12 50 12 32 L12 14 Z"/><path d="M22 32 L29 39 L43 25" stroke-width="2.5"/></svg></div>
        <div class="stat-num">UL 924</div><div class="stat-label">Listed</div>
      </div>
      <div class="text-center">
        <div class="icon-stat accent-text mx-auto mb-3"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><rect x="8" y="14" width="44" height="36" rx="3"/><line x1="52" y1="24" x2="58" y2="24"/><line x1="52" y1="40" x2="58" y2="40"/><path d="M16 32 L24 24 L24 30 L32 30 L32 38 L24 38 L24 44 Z" fill="currentColor" stroke="none"/></svg></div>
        <div class="stat-num">5-Year</div><div class="stat-label">Warranty</div>
      </div>
    </div>
    <div class="flex justify-center flex-wrap gap-3">
      <a href="#tiers" class="btn btn-primary">BROWSE BY INSTALL TIER \u2192</a>
      <a href="#verticals" class="btn btn-outline-dark">FIND BY VERTICAL</a>
    </div>
  </div>
</section>

<div class="section-bg-paper-2">
  <div class="max-w-screen-xl mx-auto px-6 py-6 italic text-center text-sm opacity-80">
    One driver SKU spans 120/208/240/277/347V buildings. No variant ordering. No wrong call at the bid stage.
  </div>
</div>

<!-- 4 INSTALL TIERS -->
<section id="tiers" class="section-bg-paper" aria-labelledby="tiers-h2">
  <div class="max-w-screen-2xl mx-auto px-6 py-20">
    <p class="eyebrow eyebrow-rule mb-6 accent-text">FOUR INSTALL TIERS</p>
    <h2 id="tiers-h2" class="h2 text-4xl md:text-5xl mb-4 max-w-3xl">Pick the install path. Filter by power class.</h2>
    <p class="opacity-80 max-w-3xl mb-12">Three power classes (Low 5\u20139W \u00b7 Mid 15\u201325W \u00b7 High 30\u201360W) across all four install tiers. Adders /AG /XD /CL modify the SKU at the suffix level.</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
      <a href="/safety-controls/constant/em20-cmb-260dc" class="bg-white p-6 border border-black/10 hover:border-[#F32740] transition-colors block">
        <div class="icon-block accent-text mb-4"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 56 L6 28 L22 36 L22 28 L38 36 L38 28 L58 36 L58 56 Z"/><rect x="14" y="42" width="6" height="14" fill="currentColor" stroke="none"/><rect x="30" y="42" width="6" height="14" fill="currentColor" stroke="none"/><rect x="46" y="42" width="6" height="14" fill="currentColor" stroke="none"/><line x1="6" y1="28" x2="14" y2="6"/><line x1="14" y1="6" x2="22" y2="28"/></svg></div>
        <p class="mono text-xs tracking-widest accent-text mb-2">TIER 01</p>
        <h3 class="font-bold text-xl mb-3">Factory</h3>
        <p class="text-sm opacity-80 mb-4">Installed at the fixture factory. Cleanest install. All power classes.</p>
        <ul class="text-xs opacity-70 space-y-1 mono"><li>\u00b7 All power classes (5\u201360W)</li><li>\u00b7 LiFePO4 battery</li><li>\u00b7 /AG /XD /CL adders available</li><li>\u00b7 \u221240\u00b0F \u2013 140\u00b0F</li></ul>
      </a>
      <a href="/safety-controls/constant/em20-cmb-260dc" class="bg-white p-6 border border-black/10 hover:border-[#F32740] transition-colors block">
        <div class="icon-block accent-text mb-4"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><rect x="8" y="14" width="44" height="36" rx="3"/><line x1="52" y1="24" x2="58" y2="24"/><line x1="52" y1="40" x2="58" y2="40"/><path d="M16 32 L24 24 L24 30 L32 30 L32 38 L24 38 L24 44 Z" fill="currentColor" stroke="none"/></svg></div>
        <p class="mono text-xs tracking-widest accent-text mb-2">TIER 02</p>
        <h3 class="font-bold text-xl mb-3">Field</h3>
        <p class="text-sm opacity-80 mb-4">Installed in the field by the electrician. Retrofit-friendly. All power classes.</p>
        <ul class="text-xs opacity-70 space-y-1 mono"><li>\u00b7 All power classes (5\u201360W)</li><li>\u00b7 LiFePO4 battery</li><li>\u00b7 /AG /XD /CL adders available</li><li>\u00b7 \u221240\u00b0F \u2013 140\u00b0F</li></ul>
      </a>
      <a href="/safety-controls/constant/em20-cmb-260dc" class="bg-white p-6 border border-black/10 hover:border-[#F32740] transition-colors block">
        <div class="icon-block accent-text mb-4"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="6" width="44" height="44" rx="2"/><circle cx="22" cy="22" r="3" fill="currentColor"/><circle cx="42" cy="22" r="3" fill="currentColor"/><circle cx="22" cy="42" r="3" fill="currentColor"/><circle cx="42" cy="42" r="3" fill="currentColor"/></svg></div>
        <p class="mono text-xs tracking-widest accent-text mb-2">TIER 03</p>
        <h3 class="font-bold text-xl mb-3">Quick-Install</h3>
        <p class="text-sm opacity-80 mb-4">J-Box mount for rapid remote deployment. CRC family.</p>
        <ul class="text-xs opacity-70 space-y-1 mono"><li>\u00b7 Mid-power only (15\u201325W)</li><li>\u00b7 Lithium Ion battery</li><li>\u00b7 No networked option</li><li>\u00b7 41\u00b0F \u2013 122\u00b0F</li></ul>
      </a>
      <a href="/safety-controls/constant/em20-cmb-260dc" class="bg-white p-6 border border-black/10 hover:border-[#F32740] transition-colors block">
        <div class="icon-block accent-text mb-4"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="20" width="44" height="24" rx="2"/><text x="28" y="38" fill="currentColor" stroke="none" text-anchor="middle" font-family="ui-monospace,monospace" font-weight="bold" font-size="12">EXIT</text><path d="M52 32 L62 32 M58 28 L62 32 L58 36"/></svg></div>
        <p class="mono text-xs tracking-widest accent-text mb-2">TIER 04</p>
        <h3 class="font-bold text-xl mb-3">Safety &amp; Emergency</h3>
        <p class="text-sm opacity-80 mb-4">Direct mount to J-Box, ceiling or wall. Standard or high-output heads.</p>
        <ul class="text-xs opacity-70 space-y-1 mono"><li>\u00b7 2-Head / 4-Head / Remote</li><li>\u00b7 Li-Ion or NiCd battery</li><li>\u00b7 Networked option (select)</li><li>\u00b7 32\u00b0F \u2013 104\u00b0F</li></ul>
      </a>
    </div>
  </div>
</section>

<!-- ADDERS -->
<section id="adders" class="section-bg-paper-2" aria-labelledby="adders-h2">
  <div class="max-w-screen-2xl mx-auto px-6 py-20">
    <p class="eyebrow eyebrow-rule mb-6 accent-text">THREE ORDER-CODE ADDERS \u00b7 MADE TO ORDER</p>
    <h2 id="adders-h2" class="h2 text-4xl md:text-5xl mb-12 max-w-3xl">Three suffixes that re-shape the SKU at order time.</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white p-8 border border-black/10">
        <div class="icon-block accent-text mb-4"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><line x1="32" y1="6" x2="32" y2="58"/><line x1="6" y1="32" x2="58" y2="32"/><line x1="13" y1="13" x2="51" y2="51"/><line x1="51" y1="13" x2="13" y2="51"/><circle cx="32" cy="32" r="4" fill="currentColor" stroke="none"/></svg></div>
        <p class="mono text-xs tracking-widest accent-text mb-2">/AG</p>
        <h3 class="font-bold text-xl mb-3"><span class="aa">\u24b6</span>rcticGuard cold-pack</h3>
        <p class="text-sm opacity-85 mb-4">Cold-rated LiFePO4 battery extends operating range to \u22124\u00b0F (140\u00b0F upper bound). Specified for freezer egress, refrigerated warehouses, outdoor enclosures.</p>
        <p class="mono text-xs tracking-widest opacity-60">EXAMPLE \u00b7 EM20-CMB/260DC/AG</p>
      </div>
      <div class="bg-white p-8 border border-black/10">
        <div class="icon-block accent-text mb-4"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><circle cx="32" cy="32" r="24"/><line x1="32" y1="14" x2="32" y2="32" stroke-width="3"/><line x1="32" y1="32" x2="44" y2="40" stroke-width="3"/></svg></div>
        <p class="mono text-xs tracking-widest accent-text mb-2">/XD</p>
        <h3 class="font-bold text-xl mb-3">Extended Discharge</h3>
        <p class="text-sm opacity-85 mb-4">120-min emergency runtime (vs. 90-min standard). Specified where local code or AHJ requires extended egress duration.</p>
        <p class="mono text-xs tracking-widest opacity-60">EXAMPLE \u00b7 EM08-HMB/170DC/XD</p>
      </div>
      <div class="bg-white p-8 border border-black/10">
        <div class="icon-block accent-text mb-4"><svg viewBox="0 0 64 64" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="2"><circle cx="32" cy="14" r="3" fill="currentColor"/><circle cx="14" cy="32" r="3" fill="currentColor"/><circle cx="50" cy="32" r="3" fill="currentColor"/><circle cx="22" cy="50" r="3" fill="currentColor"/><circle cx="42" cy="50" r="3" fill="currentColor"/><line x1="32" y1="14" x2="14" y2="32"/><line x1="32" y1="14" x2="50" y2="32"/><line x1="14" y1="32" x2="22" y2="50"/><line x1="50" y1="32" x2="42" y2="50"/><line x1="22" y1="50" x2="42" y2="50"/><line x1="14" y1="32" x2="50" y2="32"/></svg></div>
        <p class="mono text-xs tracking-widest accent-text mb-2">/CL</p>
        <h3 class="font-bold text-xl mb-3">const<span class="aa">\u24b6</span>NTLink</h3>
        <p class="text-sm opacity-85 mb-4">SILVAIR-networked emergency driver. CA Title 24 NLC compliance and remote test/log automation. Joins the same mesh as contr<span class="aa">\u24b6</span>LS by SILVAIR.</p>
        <p class="mono text-xs tracking-widest opacity-60">EXAMPLE \u00b7 EM15-PMB/120AC/CL</p>
      </div>
    </div>
  </div>
</section>

<!-- 8 VERTICALS -->
<section id="verticals" class="section-bg-paper" aria-labelledby="verticals-h2">
  <div class="max-w-screen-2xl mx-auto px-6 py-20">
    <p class="eyebrow eyebrow-rule mb-6 accent-text">EIGHT VERTICAL ENTRY POINTS</p>
    <h2 id="verticals-h2" class="h2 text-4xl md:text-5xl mb-12 max-w-3xl" set:html="Every vertical has a const<span class="aa">Ⓐ</span>NT story."></h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <a href="/safety-controls/constant/em20-cmb-260dc" class="vertical-tile" data-photo-pending="true">
        <div class="vertical-tile-art vertical-tile-art--cold"></div>
        <span class="vertical-tile-tag">01 / 08</span>
        <div class="vertical-tile-body"><h3>Cold Storage</h3><p>/AG \u00b7 \u22124\u00b0F to 140\u00b0F</p></div>
      </a>
      <a href="/safety-controls/constant/em20-cmb-260dc" class="vertical-tile" data-photo-pending="true">
        <div class="vertical-tile-art vertical-tile-art--datacenter"></div>
        <span class="vertical-tile-tag">02 / 08</span>
        <div class="vertical-tile-body"><h3>Data Center</h3><p>EM15 / EM20 \u00b7 /CL</p></div>
      </a>
      <a href="/safety-controls/constant/em20-cmb-260dc" class="vertical-tile" data-photo-pending="true">
        <div class="vertical-tile-art vertical-tile-art--education"></div>
        <span class="vertical-tile-tag">03 / 08</span>
        <div class="vertical-tile-body"><h3>Education</h3><p>/CL \u00b7 /XD</p></div>
      </a>
      <a href="/safety-controls/constant/em20-cmb-260dc" class="vertical-tile" data-photo-pending="true">
        <div class="vertical-tile-art vertical-tile-art--gov"></div>
        <span class="vertical-tile-tag">04 / 08</span>
        <div class="vertical-tile-body"><h3>Gov\u2019t &amp; Military</h3><p>UL 924 \u00b7 5-year</p></div>
      </a>
      <a href="/safety-controls/constant/em20-cmb-260dc" class="vertical-tile" data-photo-pending="true">
        <div class="vertical-tile-art vertical-tile-art--health"></div>
        <span class="vertical-tile-tag">05 / 08</span>
        <div class="vertical-tile-body"><h3>Healthcare</h3><p>EM08 \u00b7 /XD \u00b7 NFPA 99</p></div>
      </a>
      <a href="/safety-controls/constant/em20-cmb-260dc" class="vertical-tile" data-photo-pending="true">
        <div class="vertical-tile-art vertical-tile-art--hospitality"></div>
        <span class="vertical-tile-tag">06 / 08</span>
        <div class="vertical-tile-body"><h3>Hospitality</h3><p>Field \u00b7 CRC quick</p></div>
      </a>
      <a href="/safety-controls/constant/em20-cmb-260dc" class="vertical-tile" data-photo-pending="true">
        <div class="vertical-tile-art vertical-tile-art--industrial"></div>
        <span class="vertical-tile-tag">07 / 08</span>
        <div class="vertical-tile-body"><h3>Industrial</h3><p>EM30 / EM60 \u00b7 /AG</p></div>
      </a>
      <a href="/safety-controls/constant/em20-cmb-260dc" class="vertical-tile" data-photo-pending="true">
        <div class="vertical-tile-art vertical-tile-art--warehouse"></div>
        <span class="vertical-tile-tag">08 / 08</span>
        <div class="vertical-tile-body"><h3>Warehouse</h3><p>EM25 / EM60 \u00b7 /AG \u00b7 /CL</p></div>
      </a>
    </div>
  </div>
